                d_turn_val := "跌幅收窄 (止血)"
                d_tactics_turn := "悲观修正，尝试性建仓\n布局错杀资产"
            else if s5 == -0.5 // 紧缩
                d_cur_mean := "总量收缩，水位下降"
                d_tactics  := "货币供应收缩，资金枯竭\n空仓或持有现金"
                d_turn_val := "突破 0 轴 (开始放水)"
                d_tactics_turn := "放水开启，全仓买入\n普涨行情起点"
            else if s5 == 0.0 // 存量
                d_cur_mean := "存量博弈，结构行情\n(水位震荡)"
                d_tactics  := "资金无明显增量\n多看少做"
                d_turn_val := "突破 0 轴 (活水注入)"
                d_tactics_turn := "活水注入，加仓核心资产\n享受贝塔收益"
            else // 扩张
                d_cur_mean := "流动性泛滥，万物普涨\n(水位上涨)"
                d_tactics  := "资金充裕，美国放水\n闭眼买核心资产"
                d_turn_val := "跌破 0 轴 (开始抽水)"
                d_tactics_turn := "放水结束，逐步撤退\n转入防御"
                
            if s5 == -1.0 // 枯竭
                d_risk := "止血企稳"
            else if s5 == -0.5 // 紧缩
                d_risk := "开始放水"
            else if s5 == 0.0 // 存量
                d_risk := "活水注入"
            else // 扩张
                d_risk := "开始抽水"
        else
            d_title := "流动性增速差\n[M1增速 - M2增速]", d_def := "公式：M1增速 - M2增速 (信贷脉搏)\n正: 活水注入; 负: 资金空转(定期化)。"
            d_obs := "12月 (同比)", d_logic := "🔴 严重空转: <-5%\n🟠 空转: <0\n🟡 震荡: ≈0\n🟢 活化: >0", d_conf := "连续2个月确认"
            d_w := w5 > 1.0 ? "x2" : "x1"
            d_cur_stat := t5_s
            d_cur_val := str.tostring(cn_gap, "0.00") + "% | " + fmt_ym(cn_time)
            d_turn_val := s5 > 0 ? "跌破 0 轴" : "突破 0 轴"
            d_cur_mean := s5 > 0 ? "存款搬家进股市" : "躺平吃利息"
            d_risk := s5 < 0 ? "活水注入" : "资金空转"
            d_tactics := (s5 < 0 ? (cn_gap < -5.0 ? "活期存款断崖下跌，现金流枯竭\n现金为王，回避一切风险资产" : "资金定期化，躺平存钱\n回避重资产，关注高股息") : (s5 > 0 ? "存款活期化，流向消费/投资\n挑真正受益于资金活化的板块" : "资金结构稳定，多看少做"))
            d_tactics_turn := "剪刀差收窄是第一步，转正即冲锋"

    else if mode == "6. 利润空间"
        if region == "美国"
            d_title := "利润空间\n[CPI-PPI]", d_def := "CPI(售价) - PPI(成本) \n美国是全球最大消费国，重点看CPI(本国需求)"
            d_obs := "12月 (同比)", d_logic := "🔴 过热: CPI>3%\n🔴 通缩: 双负\n🟠 亏损: <0\n🟡 承压: >0 但收窄/平\n🟢 修复: <0 但走阔\n🟢 躺赚: >0 且走阔", d_conf := "状态 2 个月确认\n\n趋势 3 个月确认"
            d_w := w6 > 1.0 ? "x2" : "x1"
