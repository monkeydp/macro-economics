    if mode == "1. 基准利率"
        cur_score_disp := s1
        if s1 == -1.0 // 救火 -> 恐慌消退 (黄)
            turn_score_disp := 0.0
        else if s1 == -0.5 // 加息 -> 停止加息 (黄)
            turn_score_disp := 0.0
        else if s1 == 0.0 // 震荡 -> 开始降息 (绿)
            turn_score_disp := 1.0
        else // 降息 -> 停止降息 (黄)
            turn_score_disp := 0.0
            
    else if mode == "2. 真实利率"
        cur_score_disp := s2
        if s2 == -1.0 
            if rgdp_val < 0 // 滞胀 -> 复苏 (绿)
                turn_score_disp := 1.0
            else // 虹吸 -> 压力缓解/杀估值 (橙)
                turn_score_disp := -0.5
        else if s2 == -0.5 // 杀估值 -> 修复 (绿)
            turn_score_disp := 1.0
        else // 健康/负利率 -> 压力/泡沫退潮 (橙)
            turn_score_disp := -0.5
            
    else if mode == "3. 利差结构"
        cur_score_disp := s3
        if s3 == -1.0 // 牛陡 -> 企稳 (橙)
            turn_score_disp := -0.5
        else if s3 == -0.5 // 倒挂 -> 解除 (黄)
            turn_score_disp := 0.0
        else if s3 == 0.0 // 平坦 -> 复苏 (绿)
            turn_score_disp := 1.0
        else if s3 == 0.5 // 陡峭(常态) -> 倒挂(橙)
            turn_score_disp := -0.5
        else // 熊陡 -> 倒挂 (橙)
            turn_score_disp := -0.5
            
    else if mode == "4. 信用风险"
        cur_score_disp := s4
        if s4 == -1.0 and w4 > 1.0 // 熔断 -> 严重恶化 (红)
            turn_score_disp := -1.0
        else if s4 == -1.0 // 严重恶化 -> 恢复/走阔 (橙)
            turn_score_disp := -0.5
        else if s4 == -0.5 // 走阔 -> 缓解 (黄)
            turn_score_disp := 0.0
        else if s4 == 0.0 // 压力 -> 宽松 (绿)
            turn_score_disp := 1.0
        else // 收敛 -> 收紧 (黄)
            turn_score_disp := 0.0
            
    else if mode == "5. 流动性"
        cur_score_disp := s5
        if s5 == -1.0 // 枯竭 -> 止血 (橙)
            turn_score_disp := -0.5
        else if s5 == -0.5 // 紧缩 -> 放水 (绿)
            turn_score_disp := 1.0
        else if s5 == 0.0 // 存量 -> 注入 (绿)
            turn_score_disp := 1.0
        else // 扩张 -> 抽水 (橙)
            turn_score_disp := -0.5
            
    else if mode == "6. 利润空间"
        cur_score_disp := s6
        if s6 == -1.0 // 过热/通缩 -> 降温/走出 (黄)
            turn_score_disp := 0.0
        else if s6 == -0.5 // 亏损 -> 收窄 (黄)
            turn_score_disp := 0.0
        else if s6 == 0.0 // 震荡 -> 释放 (绿)
            turn_score_disp := 1.0
        else if s6 == 0.5 // 修复 -> 变薄 (黄)
            turn_score_disp := 0.0
        else // 躺赚 -> 变薄 (浅绿)
            turn_score_disp := 0.5
            
    else if mode == "7. 实体热度"
        cur_score_disp := s7
        if s7 == -1.0 // 崩盘 -> 止血 (橙)
            turn_score_disp := -0.5
        else if s7 == -0.5 
            if is_fake_recovery // 伪复苏 -> 真复苏 (绿)
                turn_score_disp := 1.0
            else // 衰退 -> 企稳 (黄)
                turn_score_disp := 0.0
        else if s7 == 0.0 // 震荡 -> 复苏 (绿)
            turn_score_disp := 1.0
        else // 复苏 -> 衰退 (橙)
            turn_score_disp := -0.5
            
    else if mode == "8. 萨姆规则"
        cur_score_disp := s8
        if s8 == -1.0 and w8 > 1.0 // 熔断 -> 预警 (红)
            turn_score_disp := -1.0
        else if s8 == -1.0 // 预警 -> 解除 (绿)
            turn_score_disp := 1.0
        else if s8 == -0.5 // ICSA -> 改善 (绿)
            turn_score_disp := 1.0
        else // 健康 -> 预警 (红)
            turn_score_disp := -1.0

    table.cell(info, 1, 3, d_cur_val, bgcolor = c_bg, text_color = get_score_col(cur_score_disp)), table.merge_cells(info, 1, 3, 2, 3), table.cell_set_text_halign(info, 1, 3, text.align_left)
    // 修改：拐点值颜色根据反转后的状态色显示
    table.cell(info, 3, 3, d_turn_val, bgcolor = c_bg, text_color = get_score_col(turn_score_disp), text_halign = text.align_left)
    // Row 4
    table.cell(info, 0, 4, "含义:", bgcolor = c_bg, text_color = c_beige, text_halign = text.align_left)
    table.cell(info, 1, 4, d_cur_mean, bgcolor = c_bg, text_color = c_white, text_halign = text.align_left), table.merge_cells(info, 1, 4, 2, 4)
    table.cell(info, 3, 4, d_risk, bgcolor = c_bg, text_color = c_white, text_halign = text.align_left)
    // Row 5
    table.cell(info, 0, 5, "战术:", bgcolor = c_bg, text_color = c_beige, text_halign = text.align_left)
    // 修改：移除 "【战术】\n" 前缀，移除 size.small
    string clean_tactics = str.replace(d_tactics, "【战术】\n", "")
    table.cell(info, 1, 5, clean_tactics, bgcolor = c_bg, text_color = c_white, text_halign = text.align_left), table.merge_cells(info, 1, 5, 2, 5)
    // 修改：移除 "" 前缀，移除 size.small
    string clean_tactics_turn = str.replace(d_tactics_turn, "", "")
    table.cell(info, 3, 5, clean_tactics_turn, bgcolor = c_bg, text_color = c_white, text_halign = text.align_left)
