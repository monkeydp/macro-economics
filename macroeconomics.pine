//@version=6
indicator("[薯仔] 宏观经济", overlay = false, precision = 2, max_labels_count = 500)

// ==========================================
// 1. 设置与参数
// ==========================================
show_report = input.bool(true, "显示决策看板", group="显示设置")
show_markers = input.bool(true, "显示事件标记", group="显示设置")
mode = input.string("1. 基准利率", "当前显示曲线",
     options=["1. 基准利率", "2. 真实利率", "3. 利差结构",
     "4. 信用风险", "5. 流动性", "6. 利润空间",
     "7. 实体热度", "8. 萨姆规则"], group="显示设置")
region = input.string("美国", "监控地区", options=["美国", "中国"], group="显示设置", tooltip="仅影响: 5.流动性 / 6.利润空间")

// --- 1. 基准利率 (EFFR) ---
grp_1 = "1. 基准利率 (EFFR)"
sym_effr        = input.symbol("FRED:EFFR", "数据源 (EFFR)", group=grp_1, display=display.none)
effr_ema_len    = input.int(10, "EMA 周期（月）", minval=1, group=grp_1, display=display.none)
th_effr_noise   = input.float(0.05, "震荡阈值", minval=0.0, step=0.01, group=grp_1, display=display.none)
dur_sahm_panic  = input.int(90, "救火降息有效期 (日)", minval=1, group=grp_1, tooltip="自然日。90日 ≈ 1季度", display=display.none)

// --- 2. 真实利率 (TIPS) ---
grp_2 = "2. 真实利率 (TIPS)"
sym_tips        = input.symbol("FRED:DFII10", "数据源 (TIPS)", group=grp_2, display=display.none)
sym_rgdp        = input.symbol("FRED:A191RL1Q225SBEA", "数据源 (RGDP)", group=grp_2, display=display.none)
dur_tips_conf   = input.int(5, "确认时长 (日)", minval=1, group=grp_2, display=display.none)

// --- 3. 利差结构 (Yield Curve) ---
grp_3 = "3. 利差结构 (10Y-2Y)"
sym_us_10y      = input.symbol("FRED:GS10", "数据源 (10Y)", group=grp_3, display=display.none)
sym_us_2y       = input.symbol("FRED:GS2", "数据源 (2Y)", group=grp_3, display=display.none)
dur_yc_bear_conf= input.int(5, "熊陡确认时长 (日)", minval=1, group=grp_3, display=display.none)
th_yc_noise     = input.float(0.15, "震荡阈值", minval=0.0, step=0.01, group=grp_3, display=display.none)
th_yc_bull_steep= input.float(0.15, "牛陡容差", minval=0.0, step=0.01, group=grp_3, display=display.none)
th_yc_bear_steep= input.float(0.15, "熊陡容差", minval=0.0, step=0.01, group=grp_3, display=display.none)
lock_bull_steep = input.int(10, "牛陡熔断锁定 (日)", minval=1, group=grp_3, display=display.none)


// --- 4. 信用风险 (OAS) ---
grp_4 = "4. 信用风险 (OAS)"
sym_oas         = input.symbol("FRED:BAMLH0A0HYM2", "数据源 (OAS)", group=grp_4, display=display.none)
oas_slope_len   = input.int(60, "斜率观测周期", minval=1, group=grp_4, display=display.none)
dur_oas_conf    = input.int(3, "状态确认时长 (日)", minval=1, group=grp_4, display=display.none)
th_oas_noise    = input.float(0.01, "斜率震荡阈值", minval=0.0, step=0.01, group=grp_4, display=display.none)
lock_credit_crash = input.int(10, "熔断锁定 (日)", minval=1, group=grp_4, display=display.none)

// --- 5. 流动性 (Liquidity) ---
grp_5 = "5. 流动性 (M2 / M1-M2)"
sym_us_m2       = input.symbol("FRED:M2REAL", "数据源 (美国M2)", group=grp_5, display=display.none)
sym_cn_m1       = input.symbol("ECONOMICS:CNM1", "数据源 (中国M1)", group=grp_5, display=display.none)
sym_cn_m2       = input.symbol("ECONOMICS:CNM2", "数据源 (中国M2)", group=grp_5, display=display.none)
liq_yoy_len     = input.int(12, "同比周期 (月)", minval=1, group=grp_5, display=display.none)
dur_liq_conf    = input.int(2, "确认时长 (月)", minval=1, group=grp_5, display=display.none)
th_liq_us_noise = input.float(0.50, "美国震荡阈值 (M2)", minval=0.0, step=0.1, group=grp_5, display=display.none)
th_liq_us_crash = input.float(-2.0, "美国枯竭阈值 (M2)", step=0.1, group=grp_5, display=display.none)
th_liq_cn_noise = input.float(0.50, "中国震荡阈值 (M1-M2)", minval=0.0, step=0.1, group=grp_5, display=display.none)
th_liq_cn_crash = input.float(-5.0, "中国空转阈值 (M1-M2)", step=0.1, group=grp_5, display=display.none)
lock_liq_crash  = input.int(3, "熔断锁定 (月)", minval=1, group=grp_5, display=display.none)

// --- 6. 利润空间 (Profit) ---
grp_6 = "6. 利润空间 (CPI-PPI)"
sym_us_cpi      = input.symbol("FRED:CPIAUCSL", "数据源 (美国CPI)", group=grp_6, display=display.none)
sym_us_ppi      = input.symbol("FRED:PPIACO", "数据源 (美国PPI)", group=grp_6, display=display.none)
sym_cn_cpi      = input.symbol("ECONOMICS:CNCPI", "数据源 (中国CPI)", group=grp_6, display=display.none)
sym_cn_ppi      = input.symbol("ECONOMICS:CNPPI", "数据源 (中国PPI)", group=grp_6, display=display.none)
prof_yoy_len    = input.int(12, "同比周期 (月)", minval=1, group=grp_6, display=display.none)
dur_prof_state  = input.int(2, "状态确认时长 (月)", minval=1, group=grp_6, display=display.none)
dur_prof_trend  = input.int(3, "趋势确认时长 (月)", minval=2, group=grp_6, display=display.none)
th_prof_noise   = input.float(0.20, "震荡阈值", minval=0.0, step=0.1, group=grp_6, display=display.none)


// --- 7. 实体热度 (Copper/Gold) ---
grp_7 = "7. 实体热度 (铜金比)"
sym_copper      = input.symbol("COMEX:HG1!", "数据源 (铜)", group=grp_7, display=display.none)
sym_gold        = input.symbol("COMEX:GC1!", "数据源 (金)", group=grp_7, display=display.none)
cg_slope_len    = input.int(60, "斜率观测周期", minval=1, group=grp_7, display=display.none)
dur_cg_conf     = input.int(5, "趋势确认时长 (日)", minval=1, group=grp_7, display=display.none)
th_cg_noise     = input.float(1.0, "涨跌幅容差 (%)", minval=0.0, step=0.1, group=grp_7, display=display.none) 
lock_cg_crash   = input.int(5, "崩盘锁定 (日)", minval=1, group=grp_7, display=display.none)

// --- 8. 萨姆规则 (Sahm) ---
grp_8 = "8. 萨姆规则 (Sahm)"
sym_sahm        = input.symbol("FRED:SAHMREALTIME", "数据源 (Sahm)", group=grp_8, display=display.none)
sym_icsa        = input.symbol("FRED:ICSA", "数据源 (ICSA)", group=grp_8, display=display.none)

// 颜色定义
c_red          = color.red      // 🔴 红色 (得分 -1.0)
c_orange       = color.orange   // 🟠 橙色 (得分 -0.5)
c_yellow       = color.yellow   // 🟡 黄色 (得分 0.0)
c_lime         = color.lime     // 🟢 亮绿 (得分 +1.0 / +0.5)
c_super_red    = #800000        // 🛑 深红 (熔断背景)
c_super_green  = #006400        // 🟢 深绿 (满仓背景)
c_navy_60      = color.new(#000080, 40) // 海军蓝60 (宏观对冲行背景)
c_beige        = #F5F5DC        // 米色 (标签文字)
c_score_col    = #78D6FB        // 浅蓝 (得分/权重)
c_gray_dark    = #333333        // 深灰
c_bg           = color.new(c_gray_dark, 50) // 背景色
c_header       = color.new(color.gray, 50)  // 表头背景
c_white        = color.white
c_black        = color.black

// ==========================================
// 2. 数据获取与计算
// ==========================================

// --- 辅助函数 ---
fmt_ym(t) => str.tostring(year(t)) + "-" + (month(t) < 10 ? "0" : "") + str.tostring(month(t))
fmt_ymd(t) => str.tostring(year(t)) + "-" + (month(t) < 10 ? "0" : "") + str.tostring(month(t)) + "-" + (dayofmonth(t) < 10 ? "0" : "") + str.tostring(dayofmonth(t))

// Helper to append unique
append_unique(list, item) =>
    if str.contains(list, item)
        list
    else
        list == "" ? item : list + "/" + item

calc_slope_linreg(src, len) => 
    slope = ta.linreg(src, len, 0) - ta.linreg(src, len, 1)
    slope

calc_yoy(src, len) => (src / src[len] - 1) * 100

// 计算下一次非农日期 (基于数据时间推算)
calc_next_nfp_status(data_time, current_time) =>
    // data_time 是当前数据的月份 (例如 1月1日)
    // 1月数据 -> 2月发布
    // 下一次发布(2月数据) -> 3月发布
    // 所以目标月份 = data_time + 2个月
    
    int next_m = month(data_time) + 2
    int next_y = year(data_time)
    
    // 处理跨年 (可能跨1年或2年，比如11月+2=13 -> 1月; 12月+2=14 -> 2月)
    if next_m > 12
        next_m := next_m - 12
        next_y := next_y + 1
        
    // 计算该月1号
    int t_first = timestamp(next_y, next_m, 1, 0, 0, 0)
    int dow = dayofweek(t_first)
    int days_add = 0
    // dow: Sun=1 ... Fri=6 ... Sat=7
    if dow <= 6
        days_add := 6 - dow
    else 
        days_add := 6 // 周六 -> 下周五 (+6天)
    
    int t_next_nfp = t_first + days_add * 86400000
    
    // 判定是否延迟
    // 给一点缓冲时间 (16小时)，覆盖发布时间(08:30 EST)和时区差异
    string status = ""
    if current_time > t_next_nfp + 57600000 
        status := " (待同步)"
        
    fmt_ymd(t_next_nfp) + status

float sec_per_bar = timeframe.in_seconds(timeframe.period)
float sec_per_day = 86400

// --- 录入美联储官方公布的议息会议日期 ---
// 注意：美联储会议通常为期两天，利率决议在第二天的美东时间下午 14:00 公布
var int[] f_year  = array.from(2025, 2025, 2025, 2025, 2025, 2025, 2025, 2025, 2026, 2026, 2026, 2026, 2026, 2026, 2026, 2026)
var int[] f_month = array.from(   1,    3,    5,    6,    7,    9,   10,   12,    1,    3,    4,    6,    7,    9,   10,   12)
var int[] f_day   = array.from(  29,   19,    7,   18,   30,   17,   29,   10,   28,   18,   29,   17,   29,   16,   28,    9)

get_fomc_formatted_times() =>
    string last_str = "暂无数据"
    string next_str = "暂无数据"
    
    // 获取当前K线所在时区的年份
    int current_year = year(time, syminfo.timezone)
    
    for i = 0 to array.size(f_year) - 1
        y = array.get(f_year, i)
        m = array.get(f_month, i)
        d = array.get(f_day, i)
        
        // 生成美东时间(纽约)下午14:00的时间戳
        fomc_time = timestamp("America/New_York", y, m, d, 14, 0, 0)
        
        // 获取该会议在你本地时区的年份
        int fomc_year = year(fomc_time, syminfo.timezone)
        bool is_same_year = (fomc_year == current_year)
        
        // --- 分支逻辑 ---
        if fomc_time <= time
            // 【上一次 (已发布)】: 只显示日期，不要时间
            string fmt_past = is_same_year ? "MM-dd" : "yyyy-MM-dd"
            last_str := str.format_time(fomc_time, fmt_past, syminfo.timezone)
        else
            // 【下一次 (即将发布)】: 显示日期 + 时间，精确到分
            string fmt_future = is_same_year ? "MM-dd HH:mm" : "yyyy-MM-dd HH:mm"
            next_str := str.format_time(fomc_time, fmt_future, syminfo.timezone)
            
            // 找到最近的一个未来时间后，立即退出循环
            break
            
    [last_str, next_str]

[last_fomc_time, next_fomc_time] = get_fomc_formatted_times()

// --- 1. 基准利率 (EFFR) ---

// 1. 获取日线实时数据
[effr_live, effr_time, effr_chg] = request.security(sym_effr, "D", [close, time, close[1] - close], gaps = barmerge.gaps_off)
// 2. 获取长期趋势 EMA (月线)
effr_ema = request.security(sym_effr, "M", ta.ema(close, effr_ema_len), gaps = barmerge.gaps_off)

// 3. 救火降息扫描
float effr_drop_scan = 0.0
if timeframe.isdaily
    // 日线图：直接看当天跌幅
    effr_drop_scan := effr_chg
else if timeframe.isweekly or timeframe.ismonthly
    // 周/月线图：全量扫描日线跌幅
    // request.security_lower_tf 返回的是本周期内的日线数据数组
    float[] drops = request.security_lower_tf(sym_effr, "D", close[1] - close)
    if array.size(drops) > 0
        // 只要有一天跌幅超过 0.5，max 就会超过 0.5
        effr_drop_scan := array.max(drops)

// 统一使用扫描结果
effr_drop = effr_drop_scan

// --- 2. 真实利率 (TIPS) ---
// 确认时长: 连续 5 日
[tips_live, tips_time] = request.security(sym_tips, "D", [close, time], gaps = barmerge.gaps_off)
[rgdp_val, rgdp_time]  = request.security(sym_rgdp, "D", [close, time], gaps = barmerge.gaps_off)

// --- 3. 利差结构 (10Y-2Y) ---
// 确认时长: 即时生效 (基于 20 日趋势)
// 强制在 Daily 级别计算 Change
[y10, y10_chg_d] = request.security(sym_us_10y, "D", [close, close - close[1]], gaps = barmerge.gaps_off)
[y2, y2_chg_d]   = request.security(sym_us_2y, "D", [close, close - close[1]], gaps = barmerge.gaps_off)
yc_val = y10 - y2
y10_chg = y10_chg_d
y2_chg  = y2_chg_d

// 牛陡判定 (日线逻辑)
bool is_bull_steep_daily = y10_chg < 0 and y2_chg < -th_yc_bull_steep and y2_chg < y10_chg

// 月线/周线图适配：使用 request.security_lower_tf 捕捉月内/周内牛陡
// 仅在月线/周线图启用，节省性能
bool is_bull_steep_htf = false
bool is_high_tf_yc = timeframe.isweekly or timeframe.ismonthly
if is_high_tf_yc
    [y10_diffs_m, y10_times_m] = request.security_lower_tf(sym_us_10y, "D", [close - close[1], time])
    [y2_diffs_m, y2_times_m]  = request.security_lower_tf(sym_us_2y, "D", [close - close[1], time])
    
    if array.size(y10_diffs_m) > 0 and array.size(y2_diffs_m) > 0
        int len10 = array.size(y10_diffs_m)
        int len2 = array.size(y2_diffs_m)
        
        // 双指针遍历，确保时间戳对齐
        int i10 = 0
        int i2 = 0
        
        while i10 < len10 and i2 < len2
            int t10 = array.get(y10_times_m, i10)
            int t2 = array.get(y2_times_m, i2)
            
            if t10 == t2
                float d10 = array.get(y10_diffs_m, i10)
                float d2 = array.get(y2_diffs_m, i2)
                
                // 只有当两者时间完全一致时才比较
                if d10 < 0 and d2 < -th_yc_bull_steep and d2 < d10
                    is_bull_steep_htf := true
                    break
                
                i10 := i10 + 1
                i2 := i2 + 1
            else if t10 < t2
                // t10 更早，说明 t2 这一天 10Y 缺数据，跳过 t10
                i10 := i10 + 1
            else
                // t2 更早，说明 t10 这一天 2Y 缺数据，跳过 t2
                i2 := i2 + 1

is_bull_steep_trigger = is_high_tf_yc ? is_bull_steep_htf : is_bull_steep_daily

// 锁定 10 日 (默认)
int bars_lock_bull = math.max(1, math.ceil(lock_bull_steep * sec_per_day / sec_per_bar))
var int bull_steep_cnt = 0
if is_bull_steep_trigger
    bull_steep_cnt := bars_lock_bull
else if bull_steep_cnt > 0
    bull_steep_cnt := bull_steep_cnt - 1
is_bull_steep = bull_steep_cnt > 0

// --- 4. 信用风险 (OAS) ---
// 确认时长: 连续 3 日; 熔断即时
// 核心：全周期扫描逻辑
// 日线图：直接读取当日状态
// 周线/月线图：扫描本周期内每一天，只要有一天处于“熔断”状态，即触发
// OAS > 10% 或 (OAS > 6% 且 5日涨幅 > 20%)

// 1. 获取日线实时数据
[oas_val, oas_slope, oas_chg_5d_pct, oas_time] = request.security(sym_oas, "D", [close, calc_slope_linreg(close, oas_slope_len), (close / close[5] - 1) * 100, time], gaps = barmerge.gaps_off)


// 2. 信用崩盘扫描
bool oas_crash_scan = false
if timeframe.isdaily
    // 日线图：直接看当天是否熔断
    oas_crash_scan := oas_val > 10.0 or (oas_val > 6.0 and oas_chg_5d_pct > 20.0)
else if timeframe.isweekly or timeframe.ismonthly
    // 周/月线图：全量扫描日线状态
    // 我们需要在 lower_tf 表达式中直接计算好是否熔断，返回布尔值数组
    // 注意：request.security_lower_tf 不支持复杂的元组返回，建议返回 float (1.0/0.0)
    // 表达式逻辑：如果 (OAS > 10) 或 (OAS > 6 且 5日涨幅 > 20%) 则返回 1.0，否则 0.0
    float[] crash_flags = request.security_lower_tf(sym_oas, "D", (close > 10.0 or (close > 6.0 and (close / close[5] - 1) * 100 > 20.0)) ? 1.0 : 0.0)
    if array.size(crash_flags) > 0
        // 只要有一天是 1.0，max 就是 1.0
        if array.max(crash_flags) > 0.5
            oas_crash_scan := true

// 统一使用扫描结果
is_oas_crash_trigger = oas_crash_scan

// 锁定 10 日 (默认)
int bars_lock_credit = math.max(1, math.ceil(lock_credit_crash * sec_per_day / sec_per_bar))
var int oas_crash_cnt = 0
if is_oas_crash_trigger
    oas_crash_cnt := bars_lock_credit
else if oas_crash_cnt > 0
    oas_crash_cnt := oas_crash_cnt - 1
is_oas_crash = oas_crash_cnt > 0

// --- 5. 流动性 (M2 / M1-M2) ---
// 确认时长: 连续 2 个月
[us_m2_real, us_m2_yoy, us_m2_time] = request.security(sym_us_m2, "M", [close, calc_yoy(close, liq_yoy_len), time], gaps = barmerge.gaps_off)

[cn_m1, cn_m1_yoy, cn_time] = request.security(sym_cn_m1, "M", [close, calc_yoy(close, liq_yoy_len), time], gaps = barmerge.gaps_off)
[cn_m2, cn_m2_yoy] = request.security(sym_cn_m2, "M", [close, calc_yoy(close, liq_yoy_len)], gaps = barmerge.gaps_off)
cn_gap = cn_m1_yoy - cn_m2_yoy

// --- 6. 利润空间 (CPI-PPI) ---
// 确认时长: 连续 2 个月
[us_cpi, us_cpi_yoy, us_prof_time] = request.security(sym_us_cpi, "M", [close, calc_yoy(close, prof_yoy_len), time], gaps = barmerge.gaps_off)
[us_ppi, us_ppi_yoy] = request.security(sym_us_ppi, "M", [close, calc_yoy(close, prof_yoy_len)], gaps = barmerge.gaps_off)
us_profit_gap = us_cpi_yoy - us_ppi_yoy

[cn_cpi_yoy, cn_prof_time] = request.security(sym_cn_cpi, "M", [calc_yoy(close, prof_yoy_len), time], gaps = barmerge.gaps_off)
cn_ppi_yoy = request.security(sym_cn_ppi, "M", calc_yoy(close, prof_yoy_len), gaps = barmerge.gaps_off)
cn_profit_gap = cn_cpi_yoy - cn_ppi_yoy

// --- 7. 实体热度 (铜金比) ---
// 确认时长: 连续 5 日
// 核心：全周期扫描逻辑
// 日线图：直接读取当日跌幅
// 周线/月线图：扫描本周期内每一天的跌幅，只要有一天 < -3.0%，即触发崩盘

// 1. 获取日线实时数据及趋势数据
[cop_d, cop_d_prev, cop_d_trend] = request.security(sym_copper, "D", [close, close[1], close[cg_slope_len]], gaps = barmerge.gaps_off)
[gld_d, gld_d_prev, gld_d_trend] = request.security(sym_gold,   "D", [close, close[1], close[cg_slope_len]], gaps = barmerge.gaps_off)

// 2. 本地计算比值
cg_ratio_d       = cop_d / gld_d * 1000
cg_ratio_prev_d  = cop_d_prev / gld_d_prev * 1000     // 用于单日显示/崩盘计算
cg_ratio_trend_d = cop_d_trend / gld_d_trend * 1000   // 用于60日趋势计算

// 计算单日涨跌幅 (仅用于崩盘扫描)
cg_chg_pct_d = (cg_ratio_d / cg_ratio_prev_d - 1) * 100

// 3. 崩盘扫描
bool cg_crash_scan = false
if timeframe.isdaily
    // 日线图：直接看当天跌幅
    cg_crash_scan := cg_chg_pct_d < -3.0
else if timeframe.isweekly or timeframe.ismonthly
    // 周/月线图：全量扫描日线跌幅
    // 分别获取铜和金的日线比率 (Price Ratio = close / close[1])
    float[] cop_ratios = request.security_lower_tf(sym_copper, "D", close / close[1])
    float[] gld_ratios = request.security_lower_tf(sym_gold, "D", close / close[1])
    
    if array.size(cop_ratios) > 0 and array.size(gld_ratios) > 0
        int len_r = math.min(array.size(cop_ratios), array.size(gld_ratios))
        for i = 0 to len_r - 1
            float c_r = array.get(cop_ratios, i)
            float g_r = array.get(gld_ratios, i)
            // 计算比值的日涨跌幅
            float r_chg = (c_r / g_r - 1) * 100
            if r_chg < -3.0
                cg_crash_scan := true
                break

// 统一使用扫描结果
is_cg_crash_trigger = cg_crash_scan

// 锁定 5 日 (默认)
int bars_lock_cg = math.max(1, math.ceil(lock_cg_crash * sec_per_day / sec_per_bar))
var int cg_crash_cnt = 0
if is_cg_crash_trigger
    cg_crash_cnt := bars_lock_cg
else if cg_crash_cnt > 0
    cg_crash_cnt := cg_crash_cnt - 1
is_cg_crash = cg_crash_cnt > 0

// 趋势判定
float cg_trend_chg_pct = (cg_ratio_d / cg_ratio_trend_d - 1) * 100
float cop_trend_chg_pct = (cop_d / cop_d_trend - 1) * 100

bool is_trend_up   = cg_trend_chg_pct > th_cg_noise
bool is_trend_down = cg_trend_chg_pct < -th_cg_noise
bool is_cop_trend_up   = cop_trend_chg_pct > 0
bool is_cop_trend_down = cop_trend_chg_pct < 0

// 伪复苏: 铜金比趋势涨，但铜价趋势跌
bool is_cg_fake_recovery = is_trend_up and is_cop_trend_down

float cg_ratio = cg_ratio_d
float cg_ratio_prev = cg_ratio_prev_d
float copper_prev = cop_d_prev
float copper = cop_d

// --- 8. 萨姆规则 (就业) ---
// 确认时长: 非农公布日
[sahm_val, sahm_time] = request.security(sym_sahm, "M", [close, time], gaps = barmerge.gaps_off)
// ICSA 预警: 初请失业金同比 > 15%
[icsa, icsa_yoy, icsa_yoy_prev] = request.security(sym_icsa, "W", [close, (close / close[52] - 1) * 100, (close[1] / close[53] - 1) * 100], gaps = barmerge.gaps_off)
// 连续 2 周确认
icsa_warn = icsa_yoy > 15.0 and icsa_yoy_prev > 15.0

// ==========================================
// 3. 评分逻辑
// ==========================================

// --- 权重系统 ---
// 基础权重
float w1=1.0, float w2=1.0, float w3=1.0, float w4=1.0
float w5=1.0, float w6=1.0, float w7=1.0, float w8=1.0

// 时代判定
bool is_inflation_era = us_cpi_yoy > 3.0
bool is_panic_era     = sahm_val >= 0.3 or is_bull_steep

// 动态权重调整
// 1. 通胀时代: 无论正负，权重全部翻倍 (实物资产逻辑主导)
if is_inflation_era
    w6 := 2.0 // 利润
    w7 := 2.0 // 实体

// 2. 恐慌时代: 仅当指标为负时，权重翻倍 (只放大风险，不放大机会)
// 先占位，具体赋值放到评分计算后进行修正

// --- 评分计算 ---
float s1=0.0, float s2=0.0, float s3=0.0, float s4=0.0
float s5=0.0, float s6=0.0, float s7=0.0, float s8=0.0

// 全局文案变量
string t1_s = "", string t1_a = ""
string t2_s = "", string t2_a = ""
string t3_s = "", string t3_a = ""
string t4_s = "", string t4_a = ""
string t5_s = "", string t5_a = ""
string t6_s = "", string t6_a = ""
string t7_s = "", string t7_a = ""
string t8_s = "", string t8_a = ""

// 1. 基准利率
// 状态定义：基于 EMA 的周期判定
bool is_cut_cycle  = effr_live < effr_ema - th_effr_noise
bool is_hike_cycle = effr_live > effr_ema + th_effr_noise

// 救火事件判定 (Panic Event)
bool is_panic_drop = is_cut_cycle and effr_drop >= 0.50

// 计算距离上次救火事件的时间 (Days)
// 使用 bar_index 辅助判断，若从未触发则为 na
int bars_since_panic = ta.barssince(is_panic_drop)
// 将 K 线数粗略转换为天数 (假设日线数据连续，如果有周末跳空则大约是 1.4 倍 bar 数，这里简单用时间差更准)
// Pine Script v6 中，time 是毫秒，一天 = 86400000
// 如果当前时间 - 上次触发时间 < 30天，则维持救火状态
bool in_panic_window = false
if not na(bars_since_panic)
    // 获取上次触发时的时间
    // 注意：ta.valuewhen(condition, source, occurrence)
    int time_of_panic = ta.valuewhen(is_panic_drop, time, 0)
    if time - time_of_panic < dur_sahm_panic * 86400000 // 90天有效期 (一个季度)
        in_panic_window := true

// 评分逻辑
if in_panic_window
    s1 := -1.0 // 救火降息 (衰退) - 有效期 90 天
else if is_hike_cycle
    s1 := -0.5 // 加息周期 (抽水)
else if is_cut_cycle
    s1 := 1.0  // 降息周期 (放水)
else
    s1 := 0.0  // 常态震荡

// 2. 真实利率
int bars_tips_conf = math.max(1, math.ceil(dur_tips_conf * sec_per_day / sec_per_bar))

// 辅助函数：连续满足
is_sustained(cond, len) => math.sum(cond ? 1 : 0, len) == len

if is_sustained(rgdp_val < 0, bars_tips_conf)
    s2 := -1.0 // 滞胀/萧条
else if is_sustained(tips_live >= rgdp_val, bars_tips_conf)
    s2 := -1.0 // 虹吸
else if is_sustained(tips_live >= 0.75 * rgdp_val, bars_tips_conf)
    s2 := -0.5 // 杀估值
else if is_sustained(tips_live >= 0.5 * rgdp_val, bars_tips_conf)
    s2 := 0.0  // 资金成本上升
else if is_sustained(tips_live < 0, bars_tips_conf)
    s2 := 1.0  // 负利率
else
    s2 := 1.0  // 健康支撑

// 3. 利差结构
if is_bull_steep
    w3 := 2.0
    s3 := -1.0 // 基础分设为-1, 配合权重2 => -2
else if yc_val < -th_yc_noise
    s3 := -0.5 // 倒挂
else if math.abs(yc_val) <= th_yc_noise
    s3 := 0.0  // 平坦
else
    // 熊陡: 双涨且长债涨幅 > 短债涨幅 (且长债涨幅显著 > 阈值)

    int bars_yc_conf = math.max(1, math.ceil(dur_yc_bear_conf * sec_per_day / sec_per_bar))
    bool is_bear_steep_raw = y10_chg > th_yc_bear_steep and y2_chg > 0 and y10_chg > y2_chg
    bool is_bear_steep = is_sustained(is_bear_steep_raw, bars_yc_conf)
    s3 := is_bear_steep ? 1.0 : 0.5 // 熊陡+1.0, 普通陡峭+0.5

// 恐慌时代动态权重: 利差 (仅负分翻倍)
if is_panic_era and s3 < 0
    w3 := 2.0

// 4. 信用风险
int bars_oas_conf = math.max(1, math.ceil(dur_oas_conf * sec_per_day / sec_per_bar))

if is_oas_crash
    s4 := -1.0 
    w4 := 2.0
else if oas_val > 6.0
    s4 := -1.0 
else if oas_val >= 3.5
    // 风险走阔: 趋势向上
    if is_sustained(oas_slope > th_oas_noise, bars_oas_conf)
        s4 := -0.5
    else
        s4 := 0.0 // 局部压力
else // < 3.5
    // 底部回升: 趋势向上
    if is_sustained(oas_slope > th_oas_noise, bars_oas_conf)
        s4 := 0.0
    else
        s4 := 1.0 // 风险收敛

// 恐慌时代动态权重: 信用 (仅负分翻倍)
if is_panic_era and s4 < 0
    w4 := 2.0

// 5. 流动性
// 分别计算 US 和 CN 的流动性得分，用于宏观对冲逻辑
float score_us_liq = 0.0
float score_cn_liq = 0.0

// --- 美国流动性计算 ---
float sec_per_month_liq = 86400000 / 1000 * 30 
int bars_liq_conf = math.max(1, math.ceil(dur_liq_conf * sec_per_month_liq / sec_per_bar))

bool is_liq_crash = us_m2_yoy < th_liq_us_crash
bool is_liq_tight = is_sustained(us_m2_yoy < -th_liq_us_noise, bars_liq_conf)
bool is_liq_expand = is_sustained(us_m2_yoy > th_liq_us_noise, bars_liq_conf)

if is_liq_crash
    score_us_liq := -1.0 // 枯竭
else if is_liq_tight
    score_us_liq := -0.5 // 紧缩
else if is_liq_expand
    score_us_liq := 1.0  // 扩张
else
    score_us_liq := 0.0  // 存量博弈

// --- 中国流动性计算 ---
bool is_cn_crash = cn_gap < th_liq_cn_crash
bool is_cn_tight = is_sustained(cn_gap < -th_liq_cn_noise, bars_liq_conf)
bool is_cn_expand = is_sustained(cn_gap > th_liq_cn_noise, bars_liq_conf)

if is_cn_crash
    score_cn_liq := -1.0 // 严重空转
else if is_cn_tight
    score_cn_liq := -0.5 // 资金空转
else if is_cn_expand
    score_cn_liq := 1.0  // 活化
else
    score_cn_liq := 0.0  // 结构震荡

// 根据地区选择赋值
if region == "美国"
    s5 := score_us_liq
else // 中国
    s5 := score_cn_liq

// --- 6. 利润空间 (CPI-PPI) ---
// 状态与趋势变量初始化 (全局) - 重命名以避开冲突
bool is_us_heat_state = false
bool is_us_deflation_state = false
bool is_us_widening_state = false 

bool is_cn_heat_state = false
bool is_cn_deflation_state = false
bool is_cn_widening_state = false

// 美国计算逻辑 (全局提升)
float sec_per_month_prof = 86400000 / 1000 * 30 
int bars_prof_state = math.max(1, math.ceil(dur_prof_state * sec_per_month_prof / sec_per_bar))
int bars_prof_trend = math.max(1, math.ceil(dur_prof_trend * sec_per_month_prof / sec_per_bar))

// 美国状态
is_us_heat_state := is_sustained(us_cpi_yoy > 3.0, bars_prof_state)
is_us_deflation_state := is_sustained(us_cpi_yoy < 0 and us_ppi_yoy < 0, bars_prof_state)

// 美国趋势
bool us_widening_raw = true
for i = 0 to bars_prof_trend - 2
    if us_profit_gap[i] <= us_profit_gap[i+1]
        us_widening_raw := false
        break
is_us_widening_state := us_widening_raw

// 中国状态
is_cn_heat_state := is_sustained(cn_cpi_yoy > 3.0, bars_prof_state)
is_cn_deflation_state := is_sustained(cn_cpi_yoy < 0 and cn_ppi_yoy < 0, bars_prof_state)

// 中国趋势
bool cn_widening_raw = true
for i = 0 to bars_prof_trend - 2
    if cn_profit_gap[i] <= cn_profit_gap[i+1]
        cn_widening_raw := false
        break
is_cn_widening_state := cn_widening_raw

if region == "美国"
    // 逻辑分层
    if is_us_heat_state
        s6 := -1.0, w6 := 2.0 // 过热
        t6_s := "通胀过热 (政策收紧)", t6_a := "【避险】 ⛔成长股 | ✅现金/能源"
    else if is_us_deflation_state
        s6 := -1.0 // 通缩
        t6_s := "深度通缩 (需求崩塌)", t6_a := "【避险】 ⛔周期股 | ✅必选消费"
    else if is_sustained(us_profit_gap < 0, bars_prof_state)
        if is_us_widening_state
            s6 := 0.5 // 困境反转 (亏损收窄)
            t6_s := "困境反转 (亏损收窄)", t6_a := "【进攻】 ⛔防御股 | ✅反转股"
        else
            s6 := -0.5 // 亏损恶化 (成本倒挂)
            t6_s := "亏损恶化 (成本倒挂)", t6_a := "【防御】 ⛔中游制造 | ✅上游资源"
    else if is_sustained(us_profit_gap > 0, bars_prof_state)
        // 分支：走阔(躺赚) vs 其他(承压)
        if is_us_widening_state
            s6 := 1.0 // 利润走阔 (躺赚时刻)
            t6_s := "利润走阔 (躺赚时刻)", t6_a := "【进攻】 ⛔上游资源 | ✅消费/中下游"
        else
            // 收窄 或 走平
            s6 := 0.0 // 🟡 利润承压 (增长停滞)
            t6_s := "利润承压 (增长停滞)", t6_a := "【观察】 ⛔同质化 | ✅提价权龙头"
    else
        // 震荡区 (正负切换期间，或未满2个月确认期)
        s6 := 0.0 
        t6_s := "利润震荡 (方向不明)"
        t6_a := "【观察】 多看少做" 

else // CN
    if is_cn_heat_state
        s6 := -1.0, w6 := 2.0 // 过热
        t6_s := "通胀过热 (政策收紧)", t6_a := "【避险】 ⛔成长股 | ✅现金/能源"
    else if is_cn_deflation_state
        s6 := -1.0 // 通缩
        t6_s := "深度通缩 (需求崩塌)", t6_a := "【避险】 ⛔周期/消费 | ✅红利/国债"
    else if is_sustained(cn_profit_gap < 0, bars_prof_state)
        // 分支：收窄(修复) vs 走阔(恶化)
        if is_cn_widening_state
            s6 := 0.5 // 困境反转
            t6_s := "困境反转 (亏损收窄)", t6_a := "【进攻】 ⛔防御股 | ✅反转股"
        else
            s6 := -0.5 // 亏损恶化
            t6_s := "亏损恶化 (成本倒挂)", t6_a := "【防御】 ⛔中游制造 | ✅上游资源"
    else if is_sustained(cn_profit_gap > 0, bars_prof_state)
        // 分支：走阔(躺赚) vs 其他(承压)
        if is_cn_widening_state
            s6 := 1.0 // 利润走阔
            t6_s := "利润走阔 (躺赚时刻)", t6_a := "【进攻】 ⛔上游资源 | ✅消费/中下游"
        else
            // 收窄 或 走平
            s6 := 0.0 // 🟡 利润承压 (增长停滞)
            t6_s := "利润承压 (增长停滞)", t6_a := "【观察】 ⛔同质化 | ✅提价权龙头"
    else
        // 震荡区 (正负切换期间，或未满2个月确认期)
        s6 := 0.0 
        t6_s := "利润震荡 (方向不明)"
        t6_a := "【观察】 多看少做"

// 7. 实体热度
// 引入连续确认逻辑 (连续 N 日)
int bars_cg_conf = math.max(1, math.ceil(dur_cg_conf * sec_per_day / sec_per_bar))

if is_cg_crash
    s7 := -1.0 // 崩盘 (单日暴跌优先，无需确认)
else if is_sustained(is_cg_fake_recovery, bars_cg_conf)
    s7 := -0.5 // 伪复苏 (趋势背离)
else if is_sustained(is_trend_down, bars_cg_conf)
    s7 := -0.5 // 衰退 (趋势向下)
else if is_sustained(is_trend_up and is_cop_trend_up, bars_cg_conf)
    s7 := 1.0  // 复苏 (趋势向上且铜价上涨)
else
    s7 := 0.0  // 震荡 (趋势不明显)

// 8. 萨姆规则
float sec_per_week = 86400000 / 1000 * 7
int bars_icsa_conf = math.max(1, math.ceil(2 * sec_per_week / sec_per_bar)) // 连续2周

// ICSA 预警: 初请失业金同比 > 15% (连续 N 周)
bool is_icsa_warn = true
for i = 0 to bars_icsa_conf - 1
    // 注意：icsa_yoy 是周线数据，这里需要获取对应的历史值
    // 但 request.security 获取的已经是当前周期的序列
    // 简化逻辑：如果当前是周线以上周期，只需检查当前值；如果是日线，检查过去 N 天
    // 由于 icsa_yoy 已经是 request.security("W") 获取的，它在日线图上会自动填充
    // 所以直接检查当前值持续 N 个 Bar 即可
    if icsa_yoy[i] <= 15.0
        is_icsa_warn := false
        break

if sahm_val >= 0.5
    s8 := -1.0 // 衰退熔断
else if sahm_val >= 0.3
    s8 := -0.5 // 衰退关注 (橙色)
else if is_icsa_warn
    s8 := -0.5 // ICSA 预警
else
    s8 := 1.0  // 就业健康

// 恐慌时代动态权重: 萨姆 (负分翻倍，Sahm本身就是负分源头)
if is_panic_era and s8 < 0
    w8 := 2.0

// --- 总分计算 ---
total_score = s1*w1 + s2*w2 + s3*w3 + s4*w4 + s5*w5 + s6*w6 + s7*w7 + s8*w8
max_score   = w1 + w2 + w3 + w4 + w5 + w6 + w7 + w8

// 熔断一票否决
// 流动性熔断 (s5 == -1.0) 权重不翻倍，但也算熔断
bool is_meltdown = (s3 == -1.0 and w3 > 1.0) or (s4 == -1.0 and w4 > 1.0) or (s8 == -1.0 and w8 > 1.0) or (s5 == -1.0)

// ==========================================
// 4. UI 渲染
// ==========================================

// --- 状态文本生成器 ---
get_act_txt(score, w, meltdown_label, red_label, orange_label, yellow_label, green_label, assets_sell, assets_buy) =>
    // 熔断处理
    if score == -1.0 and w > 1.0
        "【清仓】 卖出" + assets_sell + "，买入" + assets_buy
    else if score == -1.0
        "【避险】 卖出" + assets_sell + "，买入" + assets_buy
    else if score == -0.5
        "【防御】 卖出" + assets_sell + "，买入" + assets_buy
    else if score == 0.0
        "【观察】 多看少做"
    else if score == 0.5
        "【进攻】 卖出" + assets_sell + "，买入" + assets_buy // 修复/弱进攻
    else
        "【进攻】 卖出" + assets_sell + "，买入" + assets_buy

// 资产定义
a_risk     = "风险资产"
a_tech     = "科技/顺周期"
a_safe     = "黄金/长债"
a_cash     = "美元/短债"
a_def      = "长债/成长" // 加息周期卖出
a_hyg      = "垃圾债/股票"
a_core     = "核心/红利"
a_cycle    = "周期/大宗"



// --- 颜色辅助函数 ---
get_score_col(s) =>
    if s == -1.0
        c_red
    else if s == -0.5
        c_orange
    else if s == 0.0
        c_yellow
    else
        c_lime // +0.5 or +1.0

// --- 全局文案生成 ---
// 优化：引入 ⛔ (禁区) 和 ✅ (机会) 符号，直观展示黑白名单

// 1. 基准利率
if s1 == -1.0
    t1_s := "救火降息 (衰退)", t1_a := "【避险】 ⛔顺周期/科技 | ✅黄金/长债"
else if s1 == -0.5
    t1_s := "加息周期 (抽水)", t1_a := "【防御】 ⛔长债/成长 | ✅短债/美元"
else if s1 == 0.0
    t1_s := "常态震荡", t1_a := "【观察】 多看少做"
else
    t1_s := "降息周期 (放水)", t1_a := "【进攻】 ⛔美元/短债 | ✅科技/长债"

// 2. 真实利率
if s2 == -1.0
    if rgdp_val < 0
        t2_s := "滞胀/萧条 (负利率陷阱)", t2_a := "【避险】 ⛔所有风险资产 | ✅美元/黄金"
    else
        t2_s := "虹吸", t2_a := "【避险】 ⛔所有风险资产 | ✅美元/短债"
else if s2 == -0.5
    t2_s := "杀估值", t2_a := "【防御】 ⛔高估值/加密 | ✅核心/红利"
else if s2 == 0.0
    t2_s := "资金成本上升", t2_a := "【观察】 多看少做"
else if s2 == 1.0
    if tips_live < 0
        t2_s := "负利率", t2_a := "【进攻】 ⛔美元 | ✅黄金/加密"
    else
        t2_s := "健康支撑", t2_a := "【进攻】 ⛔美元 | ✅科技/成长"

// 3. 利差结构
if s3 == -1.0
    t3_s := "牛陡 (衰退熔断)", t3_a := "【清仓】 ⛔风险资产/大宗 | ✅美债/黄金"
else if s3 == -0.5
    t3_s := "倒挂 (衰退警报)", t3_a := "【防御】 ⛔成长股 | ✅现金/红利"
else if s3 == 0.0
    t3_s := "平坦 (震荡)", t3_a := "【观察】 多看少做"
else if s3 == 0.5
    t3_s := "陡峭 (常态)", t3_a := "【进攻】 ⛔防御资产 | ✅风险资产"
else
    t3_s := "熊陡 (复苏)", t3_a := "【进攻】 ⛔美债 | ✅周期股/大宗"

// 4. 信用风险
if s4 == -1.0 and w4 > 1.0
    t4_s := "信用危机 (熔断)", t4_a := "【清仓】 ⛔垃圾债/股票 | ✅美元/短债"
else if s4 == -1.0
    t4_s := "信用严重恶化 (枯竭)", t4_a := "【避险】 ⛔垃圾债/小盘 | ✅美元/短债"
else if s4 == -0.5
    t4_s := "信用风险走阔 (收缩)", t4_a := "【防御】 ⛔垃圾债/小盘 | ✅核心/红利"
else if s4 == 0.0
    if oas_val < 3.5
        t4_s := "底部回升 (关注)", t4_a := "【观察】 环境宽松 | 保持关注"
    else
        t4_s := "局部压力 (信用摇摆)", t4_a := "【观察】 多看少做"
else
    t4_s := "风险收敛 (信用扩张)", t4_a := "【进攻】 ⛔美元 | ✅垃圾债/小盘"

// 5. 流动性
if region == "美国"
    if s5 == -1.0 // 严重收缩 (熔断)
        t5_s := "严重收缩 (水位见底)", t5_a := "【清仓】 ⛔所有风险资产 | ✅美元现金"
    else if s5 == -0.5
        t5_s := "紧缩 (水位下降)", t5_a := "【防御】 ⛔风险资产 | ✅现金"
    else if s5 == 0.0
        t5_s := "存量博弈 (水位震荡)", t5_a := "【观察】 多看少做"
    else
        t5_s := "扩张 (水位上涨)", t5_a := "【进攻】 ⛔美元 | ✅科技/成长"
else
    if s5 == -1.0 // 严重空转 (熔断)
        t5_s := "严重空转 (活水断流)", t5_a := "【清仓】 ⛔所有资产 | ✅现金"
    else if s5 == -0.5
        t5_s := "资金空转 (活水变少)", t5_a := "【防御】 ⛔重资产 | ✅高股息/红利"
    else if s5 == 0.0
        t5_s := "存量博弈 (活水震荡)", t5_a := "【观察】 多看少做"
    else
        t5_s := "资金活化 (活水变多)", t5_a := "【进攻】 ⛔红利/防御 | ✅科技/成长"

// 6. 利润空间
// 逻辑移至计算模块，因为涉及复杂的趋势判定
// t6_s, t6_a 已在上方赋值，这里需要重新根据新格式覆盖


// 7. 实体热度
if s7 == -1.0
    t7_s := "实体崩盘 (信心崩溃)", t7_a := "【避险】 ⛔所有资产 | ✅美元/美债"
else if s7 == -0.5
    if is_cg_fake_recovery
        t7_s := "伪复苏 (金价暴跌)", t7_a := "【防御】 ⛔工业品/铜 | ✅黄金/美债"
    else
        t7_s := "实体衰退 (弃修鱼池)", t7_a := "【防御】 ⛔强周期 | ✅黄金/美债"
else if s7 == 0.0
    t7_s := "实体震荡", t7_a := "【观察】 方向未定 | ⚠️多看少做"
else
    t7_s := "实体复苏 (扩建鱼池)", t7_a := "【进攻】 ⛔避险资产 | ✅周期股/工业品"

// 8. 萨姆规则
if s8 == -1.0
    t8_s := "衰退确认 (熔断)", t8_a := "【清仓】 ⛔风险资产 | ✅美债/黄金"
else if s8 == -0.5
    if sahm_val >= 0.3
        t8_s := "衰退风险关注", t8_a := "【防御】 ⛔加仓 | ✅美债对冲"
    else
        t8_s := "ICSA 提前预警", t8_a := "【防御】 ⛔风险资产 | ✅现金/红利"
else
    t8_s := "就业健康", t8_a := "【进攻】 ⛔避险资产 | ✅科技/消费"

// 绘制主图曲线
float plot_val = 0.0
// 默认颜色根据当前模式的得分
color dyn_c = c_white

if mode == "1. 基准利率"
    plot_val := effr_live
    // 修复：基准利率的颜色应该反映“救火”状态
    // 如果是月线/周线图，且发生了救火降息，则强制红色
    bool is_fire_cut_htf = (timeframe.isweekly or timeframe.ismonthly) and effr_drop >= 0.5
    dyn_c := is_fire_cut_htf ? c_red : get_score_col(s1)
else if mode == "2. 真实利率"
    plot_val := tips_live
    dyn_c := get_score_col(s2)
else if mode == "3. 利差结构"
    plot_val := yc_val
    dyn_c := get_score_col(s3)
else if mode == "4. 信用风险"
    plot_val := oas_val
    dyn_c := get_score_col(s4)
else if mode == "5. 流动性"
    plot_val := region == "美国" ? us_m2_yoy : cn_gap
    dyn_c := get_score_col(s5)
else if mode == "6. 利润空间"
    plot_val := region == "美国" ? us_profit_gap : cn_profit_gap
    dyn_c := get_score_col(s6)
else if mode == "7. 实体热度"
    plot_val := cg_ratio
    // 如果是月线/周线图，且发生了崩盘，则强制红色
    bool is_cg_crash_htf = (timeframe.isweekly or timeframe.ismonthly) and cg_crash_scan
    dyn_c := is_cg_crash_htf ? c_red : get_score_col(s7)
else if mode == "8. 萨姆规则"
    plot_val := sahm_val
    dyn_c := s8 == -1.0 ? c_super_red : get_score_col(s8)
    
// 实体热度崩盘背景高亮
bool is_cg_crash_bg = mode == "7. 实体热度" and (s7 == -1.0 or ((timeframe.isweekly or timeframe.ismonthly) and cg_crash_scan))
bgcolor(is_cg_crash_bg ? color.new(c_red, 80) : na, title="Copper Crash BG")

// 萨姆规则熔断背景高亮
bgcolor(mode == "8. 萨姆规则" and s8 == -1.0 ? color.new(c_super_red, 80) : na, title="Sahm Meltdown BG")

// 基准利率救火背景高亮 (全局作用域)
// 逻辑: 模式为1 且 (s1为-1.0 或 高周期扫描出暴跌)
bool is_effr_panic_bg = mode == "1. 基准利率" and (s1 == -1.0 or ((timeframe.isweekly or timeframe.ismonthly) and effr_drop >= 0.5))
bgcolor(is_effr_panic_bg ? color.new(c_red, 80) : na, title="EFFR Panic BG")

// 真实利率背景高亮
// 滞胀: 深红 (痛苦指数高)
bool is_stag_bg = mode == "2. 真实利率" and s2 == -1.0 and rgdp_val < 0
bgcolor(is_stag_bg ? color.new(c_super_red, 80) : na, title="Stagflation BG")

// 虹吸: 红色 (资金抽离)
bool is_siphon_bg = mode == "2. 真实利率" and s2 == -1.0 and tips_live >= rgdp_val
bgcolor(is_siphon_bg ? color.new(c_red, 80) : na, title="Siphon BG")

// --- 综合绘图 ---
// 1. 基准利率: 阶梯图 + EMA
plot(mode == "1. 基准利率" ? plot_val : na, "EFFR", color = dyn_c, linewidth = 2, style = plot.style_stepline)
plot(mode == "1. 基准利率" ? effr_ema : na, "EFFR EMA", color = color.blue, linewidth = 1)

// 1. 救火标记
bool is_fire_cut = mode == "1. 基准利率" and s1 == -1.0
if is_fire_cut and not is_fire_cut[1] and show_markers
    label.new(bar_index, plot_val + 0.5, "🚒\n救火", xloc = xloc.bar_index, yloc = yloc.price, color = color(na), style = label.style_none, textcolor = c_black, size = size.small, textalign = text.align_center)

// 2. 真实利率: TIPS + RGDP + 阈值
// 优化：RGDP 极端值截断 (仅用于绘图)
// 将绘图用的 RGDP 限制在 -10% 到 +10% 之间
float rgdp_plot = math.max(math.min(rgdp_val, 10.0), -10.0)

plot(mode == "2. 真实利率" ? plot_val : na, "TIPS", color = dyn_c, linewidth = 2)
plot(mode == "2. 真实利率" ? rgdp_plot : na, "RGDP", color = color.gray, linewidth = 1, style = plot.style_stepline)
plot(mode == "2. 真实利率" ? 0.5 * rgdp_plot : na, "0.5 RGDP", color = color.new(c_orange, 50), style = plot.style_circles)

// 真实利率风险标记 (状态切换时绘制一次性标签)
// 逻辑: 仅在状态首次触发时，在曲线下方绘制图标+文字
// 避免连续绘制导致图表压扁或重叠

// 滞胀: RGDP < 0 (显示在曲线上方，避免与虹吸重叠)
bool is_stag = mode == "2. 真实利率" and s2 == -1.0 and rgdp_val < 0
if is_stag and not is_stag[1] and show_markers
    label.new(bar_index, plot_val + 0.5, "🔥滞胀", xloc = xloc.bar_index, yloc = yloc.price, color = color(na), style = label.style_none, textcolor = c_black, size = size.small, textalign = text.align_center)

// 虹吸: TIPS >= RGDP (显示在曲线下方)
bool is_siphon = mode == "2. 真实利率" and s2 == -1.0 and tips_live >= rgdp_val
if is_siphon and not is_siphon[1] and show_markers
    label.new(bar_index, plot_val - 0.5, "🌪️虹吸", xloc = xloc.bar_index, yloc = yloc.price, color = color(na), style = label.style_none, textcolor = c_black, size = size.small, textalign = text.align_center)

// 添加 RGDP 极端值标签 (显示真实值)
// 优化：仅在"季度结束"时绘制上一个季度的标签
// 检测季度变化: 当前季度 != 上一根K线的季度
int cur_q = math.ceil(month(time) / 3.0)
int prev_q_idx = math.ceil(month(time[1]) / 3.0)
bool is_new_quarter = (cur_q != prev_q_idx) or (year(time) != year(time[1]))

// 变量记录上一次绘制的标签数值，用于去重
var float last_lbl_val = 0.0
// 始终根据当前 K 线的数据时间更新日期字符串
// 增加 5 天偏移量，防止时区导致季度首日(10.1)漂移回上月(9.30)而被误判为Q3
int t_rgdp = rgdp_time + 5 * 86400000
int y_rgdp = year(t_rgdp)
int m_rgdp = month(t_rgdp)
int q_rgdp = math.ceil(m_rgdp / 3.0)
string rgdp_date_str = " (" + str.tostring(y_rgdp) + " Q" + str.tostring(q_rgdp) + ")"

// 优化：改用"数据突变点 + 时间偏移"的物理定位法
// 仅在 RGDP 数值发生突变 (新季度数据发布) 时绘制
if mode == "2. 真实利率" and ta.change(rgdp_val) != 0
    // 获取当前新的 RGDP 值
    float cur_val = rgdp_val
    
    // 只有当当前值是极端值，且与上一次标注的值不同时才画
    if (cur_val > 10.0 or cur_val < -10.0) and cur_val != last_lbl_val
        // 计算居中时间：当前时间 + 45天 (季度的一半)
        // 使用 xloc.bar_time 确保在任意周期图表上都在季度中间
        int time_mid = time + 45 * 86400000
        
        // 重新计算当前的截断值 (用于定位标签Y轴)
        float plot_y = math.max(math.min(cur_val, 10.0), -10.0)
        
        if cur_val > 10.0
            // 上方截断: 标签在上，箭头向下指
            label.new(time_mid, plot_y, "▲ " + str.tostring(cur_val, "0.0") + "%", xloc = xloc.bar_time, color = c_lime, style = label.style_label_down, textcolor = c_white, size = size.tiny)
        else
            // 下方截断: 标签在下，箭头向上指
            label.new(time_mid, plot_y, "▼ " + str.tostring(cur_val, "0.0") + "%", xloc = xloc.bar_time, color = c_red, style = label.style_label_up, textcolor = c_white, size = size.tiny)
        
        // 更新记录
        last_lbl_val := cur_val

// 处理当前最新的季度 (如果当前是极端值，且还没结束，暂时画在最后)
if barstate.islast and mode == "2. 真实利率" and (rgdp_val > 10.0 or rgdp_val < -10.0)
    // 防止重复：如果最后一根K线刚好也是季度第一天，上面的逻辑已经画过了，这里就不画
    if not is_new_quarter
        float plot_y_cur = math.max(math.min(rgdp_val, 10.0), -10.0)
        if rgdp_val > 10.0
            label.new(bar_index, plot_y_cur, "▲ " + str.tostring(rgdp_val, "0.0") + "%", color = c_lime, style = label.style_label_down, textcolor = c_white, size = size.tiny)
        else
            label.new(bar_index, plot_y_cur, "▼ " + str.tostring(rgdp_val, "0.0") + "%", color = c_red, style = label.style_label_up, textcolor = c_white, size = size.tiny)

// 添加 RGDP 标签
if barstate.islast and mode == "2. 真实利率"
    // RGDP 标签
    label.new(bar_index, rgdp_plot, "真实美国GDP | RGDP" + rgdp_date_str, 
              color = color.gray, 
              style = label.style_label_lower_left, 
              textcolor = c_white, 
              size = size.small, 
              textalign = text.align_left)
    
    // 0.5 RGDP 标签
    label.new(bar_index, 0.5 * rgdp_plot, "0.5 RGDP", 
              color = c_orange, 
              style = label.style_label_upper_left, 
              textcolor = c_white, 
              size = size.small, 
              textalign = text.align_left)

// 3. 利差结构: 10Y-2Y
bool is_bull_steep_melt = mode == "3. 利差结构" and s3 == -1.0 and w3 > 1.0

// 1. 曲线变色 (保持深红)
color yc_col = is_bull_steep_melt ? c_super_red : dyn_c
plot(mode == "3. 利差结构" ? plot_val : na, "10Y-2Y", color = yc_col, linewidth = 2)

// 2. 背景高亮 (深红半透明)
bgcolor(is_bull_steep_melt ? color.new(c_super_red, 70) : na, title="Bull Steep Melt BG")

// 3. 文本标记 (仅在熔断开始时显示，避免拥挤)
bool show_bull_mark = mode == "3. 利差结构" and is_bull_steep_melt
if show_bull_mark and not show_bull_mark[1] and show_markers
    label.new(bar_index, plot_val + 0.2, "🐂\n牛陡", color = color(na), style = label.style_none, textcolor = c_black, size = size.small, textalign = text.align_center)


// 4. 信用风险: OAS + 阈值
color oas_col = dyn_c
if mode == "4. 信用风险" and s4 == -1.0 and w4 > 1.0
    oas_col := c_super_red

// 4. 信用崩盘标记
bool is_credit_crash = mode == "4. 信用风险" and s4 == -1.0 and w4 > 1.0
if is_credit_crash and not is_credit_crash[1] and show_markers
    label.new(bar_index, plot_val + 0.5, "💔\n危机", color = color(na), style = label.style_none, textcolor = c_black, size = size.small, textalign = text.align_center)

// 4. 严重恶化标记 (非熔断，但恶化)
bool is_credit_bad = mode == "4. 信用风险" and s4 == -1.0 and w4 <= 1.0
if is_credit_bad and not is_credit_bad[1] and show_markers
    label.new(bar_index, plot_val + 0.5, "🩸\n恶化", color = color(na), style = label.style_none, textcolor = c_black, size = size.small, textalign = text.align_center)

plot(mode == "4. 信用风险" ? plot_val : na, "OAS", color = oas_col, linewidth = 2)
plot(mode == "4. 信用风险" ? 10.0 : na, "OAS 10", color = c_super_red)
plot(mode == "4. 信用风险" ? 6.0 : na, "OAS 6", color = c_red)
plot(mode == "4. 信用风险" ? 3.5 : na, "OAS 3.5", color = c_lime)

bool is_oas_meltdown_bg = mode == "4. 信用风险" and s4 == -1.0 and w4 > 1.0
bgcolor(is_oas_meltdown_bg ? color.new(c_super_red, 70) : na, title="OAS Melt BG")

if barstate.islast and mode == "4. 信用风险"
    label.new(bar_index, 10.0, "熔断 (10%)", color = c_super_red, style = label.style_label_left, textcolor = c_white, size = size.small)
    label.new(bar_index, 6.0, "严重恶化 (6%)", color = c_red, style = label.style_label_left, textcolor = c_white, size = size.small)
    label.new(bar_index, 3.5, "▼ 风险收敛 (3.5%)", color = c_lime, style = label.style_label_left, textcolor = c_white, size = size.small)


// 5. 流动性: M2 YoY + 阈值
color liq_col = dyn_c
bool is_liq_meltdown = false
if region == "美国"
    is_liq_meltdown := is_liq_crash
else
    is_liq_meltdown := is_cn_crash

// 5. 枯竭标记
bool show_liq_mark = mode == "5. 流动性" and is_liq_meltdown
if show_liq_mark and not show_liq_mark[1] and show_markers
    label.new(bar_index, plot_val - 4, "🏜️\n枯竭", color = color(na), style = label.style_none, textcolor = c_black, size = size.small, textalign = text.align_center)

if is_liq_meltdown
    liq_col := c_super_red

plot(mode == "5. 流动性" ? plot_val : na, "Liquidity", color = liq_col, linewidth = 2)
plot(mode == "5. 流动性" and region == "美国" ? th_liq_us_crash : na, "M2 -2", color = c_super_red)
plot(mode == "5. 流动性" and region == "中国" ? th_liq_cn_crash : na, "M1-M2 -5", color = c_super_red)

bgcolor(mode == "5. 流动性" and is_liq_meltdown ? color.new(c_super_red, 70) : na, title="Liq Melt BG")

// 增加标签
if barstate.islast and mode == "5. 流动性"
    if region == "美国"
        label.new(bar_index, th_liq_us_crash, "熔断 (-2.0)", color = c_super_red, style = label.style_label_left, textcolor = c_white, size = size.small)
    else
        label.new(bar_index, th_liq_cn_crash, "熔断 (-5.0)", color = c_super_red, style = label.style_label_left, textcolor = c_white, size = size.small)

// 6. 利润空间: Gap
// 定义 CPI & PPI 变量 (提前到这里，供绘图和标签使用)
float cpi_val = region == "美国" ? us_cpi_yoy : cn_cpi_yoy
float ppi_val = region == "美国" ? us_ppi_yoy : cn_ppi_yoy

plot(mode == "6. 利润空间" ? plot_val : na, "Profit Gap", color = dyn_c, linewidth = 2)

// 6. 通胀过热标记
bool is_overheat = mode == "6. 利润空间" and cpi_val > 3.0
if is_overheat and not is_overheat[1] and show_markers
    label.new(bar_index, plot_val + 4, "🥵\n过热", color = color(na), style = label.style_none, textcolor = c_black, size = size.small, textalign = text.align_center)

// 6. 深度通缩标记
bool is_deflation = mode == "6. 利润空间" and cpi_val < 0 and ppi_val < 0
if is_deflation and not is_deflation[1] and show_markers
    label.new(bar_index, plot_val - 4, "🥶\n通缩", color = color(na), style = label.style_none, textcolor = c_black, size = size.small, textalign = text.align_center)

// 新增: CPI & PPI 辅助线
// 确保只在"6. 利润空间"模式下显示
plot(mode == "6. 利润空间" ? cpi_val : na, "CPI", color = color.purple, linewidth = 1)
plot(mode == "6. 利润空间" ? ppi_val : na, "PPI", color = color.blue, linewidth = 1)
plot(mode == "6. 利润空间" ? 3.0 : na, "CPI 3.0", color = color.new(color.red, 50), style = plot.style_circles)

// 过热背景高亮 (CPI > 3.0)
bgcolor(mode == "6. 利润空间" and cpi_val > 3.0 ? color.new(c_red, 85) : na, title="CPI Overheat BG")

// 通缩背景高亮 (CPI < 0 且 PPI < 0)
bgcolor(mode == "6. 利润空间" and cpi_val < 0 and ppi_val < 0 ? color.new(color.blue, 85) : na, title="Deflation BG")

// 增加静态图例 (Legend Table)
// 仅在 "6. 利润空间" 模式且为最后一根 K 线时显示
// 位置：右下角
var table legend_prof = table.new(position.bottom_right, 2, 4, bgcolor = c_bg, border_width = 1, border_color = color.gray, frame_width = 1)
if barstate.islast and mode == "6. 利润空间"
    // 标题行
    table.cell(legend_prof, 0, 0, "📊 利润空间", text_color = c_white, text_size = size.small, bgcolor = c_header)
    table.cell(legend_prof, 1, 0, "", bgcolor = c_header) // 占位
    table.merge_cells(legend_prof, 0, 0, 1, 0)
    
    // 行 1: CPI (紫)
    table.cell(legend_prof, 0, 1, "CPI", text_color = color.purple, text_halign = text.align_left, text_size = size.small)
    table.cell(legend_prof, 1, 1, str.tostring(cpi_val, "0.00") + "%", text_color = c_white, text_halign = text.align_right, text_size = size.small)
    
    // 行 2: PPI (蓝)
    table.cell(legend_prof, 0, 2, "PPI", text_color = color.blue, text_halign = text.align_left, text_size = size.small)
    table.cell(legend_prof, 1, 2, str.tostring(ppi_val, "0.00") + "%", text_color = c_white, text_halign = text.align_right, text_size = size.small)

    // 保留过热线标签 (因为它在顶部，不遮挡曲线)
    label.new(bar_index, 3.0, "过热线 (3.0%)", color = color.new(color.red, 50), style = label.style_label_left, textcolor = c_white, size = size.small)

// 7. 实体热度: 铜金比
plot(mode == "7. 实体热度" ? plot_val : na, "Copper/Gold", color = dyn_c, linewidth = 2)

// 7. 崩盘标记
bool is_cg_crash_mark = mode == "7. 实体热度" and s7 == -1.0
if is_cg_crash_mark and not is_cg_crash_mark[1] and show_markers
    label.new(bar_index, plot_val + 0.1, "📉\n崩盘", color = color(na), style = label.style_none, textcolor = c_black, size = size.small, textalign = text.align_center)

// 动态计算 EMA 周期
// 日线: 60 (季度线)
// 周线: 12 (季度线)
// 月线: 12 (年线，更有意义)
int ema_len_dynamic = timeframe.isdaily ? 60 : 12
plot(mode == "7. 实体热度" ? ta.ema(plot_val, ema_len_dynamic) : na, "CG EMA", color = color.blue, linewidth = 1)

// 8. 萨姆规则: Sahm + 阈值
plot(mode == "8. 萨姆规则" ? plot_val : na, "Sahm", color = dyn_c, linewidth = 2)

// 8. 衰退熔断标记
bool is_sahm_melt = mode == "8. 萨姆规则" and s8 == -1.0
if is_sahm_melt and not is_sahm_melt[1] and show_markers
    label.new(bar_index, plot_val + 0.1, "💀\n衰退", color = color(na), style = label.style_none, textcolor = c_black, size = size.small, textalign = text.align_center)

// 萨姆规则阈值线
plot(mode == "8. 萨姆规则" ? 0.50 : na, "衰退熔断线", color = c_super_red, linewidth = 2, style = plot.style_line)
plot(mode == "8. 萨姆规则" ? 0.30 : na, "衰退关注线", color = c_orange, linewidth = 1, style = plot.style_circles)

// 萨姆规则标签
if mode == "8. 萨姆规则" and barstate.islast
    label.new(bar_index + 3, 0.50, "衰退熔断 (0.5%)", color = color(na), style = label.style_none, textcolor = c_super_red, size = size.normal, textalign = text.align_left)
    label.new(bar_index + 3, 0.30, "衰退关注 (0.3%)", color = color(na), style = label.style_none, textcolor = c_orange, size = size.small, textalign = text.align_left)

// 通用 0 轴 (虚线)
hline(0, "零线", color = color.gray, linestyle = hline.style_dashed)

// --- 看板绘制 ---
var table rpt = table.new(position.middle_left, 7, 11, bgcolor = c_bg, border_width = 1, border_color = color.gray)
var table info = table.new(position.middle_right, 4, 6, bgcolor = c_bg, border_width = 1, border_color = color.gray)

// Helper to fill row
fill_row(r, name, val_str, s, w, meta, status, action, is_melt) =>
    c_s = get_score_col(s)
    w_str = w > 1.0 ? "x2" : ""
    float final_s = s * w
    string s_str = final_s > 0 ? "+" + str.tostring(final_s, "#.#") : (final_s == 0 ? "0" : str.tostring(final_s, "#.#"))
    
    // 熔断检测: 仅针对 "数值" 和 "现状含义" 修改背景色 (深红 + 黄字)
    bool is_meltdown_row = is_melt
    color bg_hlt = is_meltdown_row ? c_super_red : c_bg
    color txt_hlt_val = is_meltdown_row ? c_yellow : c_s
    color txt_hlt_stat = is_meltdown_row ? c_yellow : c_white

    table.cell(rpt, 0, r, name, text_color = c_white, bgcolor = c_bg)
    table.cell(rpt, 1, r, val_str, text_color = txt_hlt_val, bgcolor = bg_hlt)
    table.cell(rpt, 2, r, s_str, text_color = c_score_col, bgcolor = c_bg)
    table.cell(rpt, 3, r, w_str, text_color = c_white, bgcolor = c_bg) 
    table.cell(rpt, 4, r, meta, text_color = c_white, bgcolor = c_bg)
    table.cell(rpt, 5, r, status, text_color = txt_hlt_stat, bgcolor = bg_hlt)
    table.cell(rpt, 6, r, action, text_color = c_s, bgcolor = c_bg, text_halign = text.align_left)

if barstate.islast and show_report
    // --- 左表: 报告 ---
    // Header
    table.cell(rpt, 0, 0, "维度", text_color = c_white, bgcolor = c_header)
    table.cell(rpt, 1, 0, "数值", text_color = c_white, bgcolor = c_header)
    table.cell(rpt, 2, 0, "得分", text_color = c_white, bgcolor = c_header)
    table.cell(rpt, 3, 0, "权重", text_color = c_white, bgcolor = c_header)
    table.cell(rpt, 4, 0, "比喻", text_color = c_white, bgcolor = c_header)
    table.cell(rpt, 5, 0, "现状含义", text_color = c_white, bgcolor = c_header)
    table.cell(rpt, 6, 0, "建议操作逻辑", text_color = c_white, bgcolor = c_header)

    fill_row(1, "1.基准利率", str.tostring(effr_live, "0.00")+"%", s1, w1, "总水坝闸门", t1_s, t1_a, false)
    fill_row(2, "2.真实利率", str.tostring(tips_live, "0.00")+"%", s2, w2, "水厂回购价", t2_s, t2_a, false)
    fill_row(3, "3.利差结构", str.tostring(yc_val, "0.00"), s3, w3, "天气预报", t3_s, t3_a, s3 == -1.0 and w3 > 1.0)
    fill_row(4, "4.信用风险", str.tostring(oas_val, "0.00")+"%", s4, w4, "风险保证金", t4_s, t4_a, s4 == -1.0 and w4 > 1.0)
    
    string l5_v = region == "美国" ? str.tostring(us_m2_yoy, "0.00")+"%" : str.tostring(cn_gap, "0.00")+"%"
    fill_row(5, "5.流动性", l5_v, s5, w5, "鱼池活水率", t5_s, t5_a, s5 == -1.0)
    
    string l6_v = region == "美国" ? str.tostring(us_profit_gap, "0.00")+"%" : str.tostring(cn_profit_gap, "0.00")+"%"
    fill_row(6, "6.利润空间", l6_v, s6, w6, "养鱼账本", t6_s, t6_a, false)
    
    fill_row(7, "7.实体热度", str.tostring(cg_ratio, "0.00"), s7, w7, "鱼池扩建率", t7_s, t7_a, false)
    fill_row(8, "8.萨姆规则", str.tostring(sahm_val, "0.00")+"%", s8, w8, "失业信号", t8_s, t8_a, s8 == -1.0 and w8 > 1.0)

    // Row 9: 宏观对冲策略
    // 逻辑: US (Liquidity + Rate), CN (Liquidity)
    bool us_loose = s1 == 1.0 or score_us_liq == 1.0 // US: 降息 OR M2扩张
    bool us_tight = s1 < 0 or score_us_liq < 0       // US: 加息/救火 OR M2紧缩/枯竭
    bool us_panic = is_panic_era or is_meltdown      // US: 恐慌

    // CN: Loose (Activate), Tight (Idle), Flat
    bool cn_loose = score_cn_liq == 1.0
    bool cn_tight = score_cn_liq == -1.0

    string strat_t = "", string strat_d = "", string strat_us = "", string strat_cn = ""
    color strat_c = c_white
    
    if us_loose and cn_loose
        strat_t := "🟢 共振复苏", strat_d := "【全仓猛干】 买铜、原油、澳元、新兴市场(港股/A股)", strat_c := c_lime
        strat_us := "🟢 美松 (印钱)", strat_cn := "🟢 中松 (放水)"
    else if us_tight and cn_tight
        strat_t := "🔴 双重紧缩", strat_d := "【现金为王】 只持有美元现金，或者做空 A 股", strat_c := c_orange
        strat_us := "🟠 美紧 (抽水)", strat_cn := "🟠 中紧 (空转)"
    else if us_panic and cn_tight
        strat_t := "🔴 衰退共振", strat_d := "【避险】 买美债、黄金、日元避险", strat_c := c_orange
        strat_us := "🔴 美恐 (救火)", strat_cn := "🟠 中紧 (空转)"
    else if us_panic and cn_loose
        strat_t := "🟠 东升西降", strat_d := "【结构性做多】 买 A股龙头，做空美股", strat_c := c_yellow
        strat_us := "🔴 美恐 (救火)", strat_cn := "🟢 中松 (放水)"
    else if us_tight and cn_loose
        strat_t := "🟠 分化博弈", strat_d := "【两头吃】 存美元吃利息，同时买 A股结构性机会", strat_c := c_yellow
        strat_us := "🟠 美紧 (加息)", strat_cn := "🟢 中松 (放水)"
    else if us_loose and cn_tight
        strat_t := "🟠 单极驱动", strat_d := "【只买美国】 买美股科技/黄金，千万别碰工业品", strat_c := c_yellow
        strat_us := "🟢 美松 (降息)", strat_cn := "🟠 中紧 (躺平)"
    else
        strat_t := "🟡 垃圾时间", strat_d := "【多看少动】 别瞎折腾，等新趋势出来", strat_c := c_yellow
        strat_us := "🟡 美平", strat_cn := "🟡 中平"

    table.cell(rpt, 0, 9, "中美宏观对冲", bgcolor = c_navy_60, text_color = c_white), table.merge_cells(rpt, 0, 9, 1, 9)
    table.cell(rpt, 2, 9, strat_t, bgcolor = c_navy_60, text_color = strat_c), table.merge_cells(rpt, 2, 9, 3, 9)
    table.cell(rpt, 4, 9, strat_us + "\n" + strat_cn, bgcolor = c_navy_60, text_color = c_white, text_size = size.small)
    table.cell(rpt, 5, 9, strat_d, bgcolor = c_navy_60, text_color = c_white), table.merge_cells(rpt, 5, 9, 6, 9)

    // Row 10: 最终诊断
    // 升级为双轨制建议：进攻仓位 + 避险仓位 + 警惕项
    
    // 1. 收集各维度的资产建议 (去重逻辑)
    // 定义资产桶
    string risk_assets = ""  // ⚔️ 进攻资产 (股票/商品/垃圾债)
    string safe_assets = ""  // 🛡️ 避险资产 (美债/黄金/现金)
    string warn_risks = ""   // ⚠️ 警惕 (风险点)
    string veto_assets = ""  // ⛔ 否决 (仅用于警惕项展示)

    // 遍历指标填充桶
    // 1. 基准利率
    if s1 == -1.0
        safe_assets := append_unique(safe_assets, "黄金/长债")
        veto_assets := append_unique(veto_assets, "顺周期")
    else if s1 == -0.5
        safe_assets := append_unique(safe_assets, "短债/美元")
        veto_assets := append_unique(veto_assets, "长债")
    else if s1 == 1.0
        risk_assets := append_unique(risk_assets, "科技/长债")
        veto_assets := append_unique(veto_assets, "美元")

    // 2. 真实利率
    if s2 == -1.0
        safe_assets := append_unique(safe_assets, "美元")
        veto_assets := append_unique(veto_assets, "风险资产")
    else if s2 == -0.5
        risk_assets := append_unique(risk_assets, "红利")
        veto_assets := append_unique(veto_assets, "高估值")
    else if s2 == 1.0
        risk_assets := append_unique(risk_assets, "成长")
        safe_assets := append_unique(safe_assets, "黄金")

    // 3. 利差结构
    if s3 == -1.0
        safe_assets := append_unique(safe_assets, "美债")
        veto_assets := append_unique(veto_assets, "风险资产")
    else if s3 == -0.5
        safe_assets := append_unique(safe_assets, "现金")
        risk_assets := append_unique(risk_assets, "红利")
    else if s3 == 0.5
        risk_assets := append_unique(risk_assets, "风险资产")
    else if s3 > 0.5
        risk_assets := append_unique(risk_assets, "周期")

    // 4. 信用风险
    if s4 == -1.0
        safe_assets := append_unique(safe_assets, "美元")
        veto_assets := append_unique(veto_assets, "垃圾债")
    else if s4 == -0.5
        risk_assets := append_unique(risk_assets, "红利")
        veto_assets := append_unique(veto_assets, "小盘")
    else if s4 > 0
        risk_assets := append_unique(risk_assets, "小盘")

    // 5. 流动性
    if s5 == -1.0
        safe_assets := append_unique(safe_assets, "现金")
        veto_assets := append_unique(veto_assets, "所有资产")
    else if s5 == -0.5
        safe_assets := append_unique(safe_assets, "现金")
        veto_assets := append_unique(veto_assets, "重资产")
    else if s5 > 0
        risk_assets := append_unique(risk_assets, "科技")

    // 6. 利润空间
    if s6 == -1.0
        risk_assets := append_unique(risk_assets, "必选消费")
        veto_assets := append_unique(veto_assets, "周期")
    else if s6 == -0.5
        risk_assets := append_unique(risk_assets, "上游")
        veto_assets := append_unique(veto_assets, "制造")
    else if s6 > 0
        risk_assets := append_unique(risk_assets, "消费")

    // 7. 实体热度
    if s7 == -1.0
        safe_assets := append_unique(safe_assets, "美债")
        veto_assets := append_unique(veto_assets, "所有资产")
    else if s7 == -0.5
        safe_assets := append_unique(safe_assets, "黄金")
        veto_assets := append_unique(veto_assets, "强周期")
    else if s7 > 0
        risk_assets := append_unique(risk_assets, "工业品")

    // 8. 萨姆规则
    if s8 == -1.0
        safe_assets := append_unique(safe_assets, "美债")
        veto_assets := append_unique(veto_assets, "风险资产")
    else if s8 == -0.5
        safe_assets := append_unique(safe_assets, "现金")
        warn_risks := append_unique(warn_risks, "衰退关注")
    else if s8 > 0
        risk_assets := append_unique(risk_assets, "消费")

    // 2. 构建最终建议文案 (双轨制)
    string final_res = "", string line_risk = "", string line_safe = "", string line_warn = ""
    color final_bg = c_gray_dark
    color final_txt = c_white
    
    // 熔断逻辑 (死刑)
    if is_meltdown
        final_res := "【熔断】"
        line_risk := "⚔️ 进攻 (0%): ⛔ 空仓"
        line_safe := "🛡️ 避险 (100%): 黄金/美债"
        line_warn := "⚠️ 警惕: 系统性崩盘"
        final_bg := c_super_red
        final_txt := c_yellow
    
    // 严重衰退逻辑 (局部否决)
    else if total_score < -5.0
        final_res := "危机模式"
        line_risk := "⚔️ 进攻 (0-10%): " + (risk_assets == "" ? "仅底仓" : risk_assets)
        line_safe := "🛡️ 避险 (90-100%): " + (safe_assets == "" ? "现金" : safe_assets)
        line_warn := "⚠️ 警惕: " + (veto_assets == "" ? "深度衰退" : "否决" + veto_assets)
        final_bg := c_red
        final_txt := c_white
        
    // 衰退预警
    else if total_score < -1.5
        final_res := "衰退预警"
        line_risk := "⚔️ 进攻 (10-30%): " + (risk_assets == "" ? "核心底仓" : risk_assets)
        line_safe := "🛡️ 避险 (70-90%): " + (safe_assets == "" ? "美债/现金" : safe_assets)
        line_warn := "⚠️ 警惕: " + (veto_assets == "" ? "宏观转差" : "否决" + veto_assets)
        final_bg := c_orange
        final_txt := c_black
        
    // 震荡期
    else if total_score < 1.5
        final_res := "混沌震荡"
        line_risk := "⚔️ 进攻 (30-50%): " + (risk_assets == "" ? "红利/底仓" : risk_assets)
        line_safe := "🛡️ 避险 (50-70%): " + (safe_assets == "" ? "现金/黄金" : safe_assets)
        line_warn := "⚠️ 警惕: 方向未定"
        final_bg := c_yellow
        final_txt := c_black
        
    // 复苏期
    else if total_score <= 5.0
        final_res := "温和增长"
        line_risk := "⚔️ 进攻 (50-80%): " + (risk_assets == "" ? "优质股" : risk_assets)
        line_safe := "🛡️ 避险 (20-50%): " + (safe_assets == "" ? "现金" : safe_assets)
        line_warn := "⚠️ 警惕: " + (veto_assets == "" ? "追高" : "否决" + veto_assets)
        final_bg := c_lime
        final_txt := c_black
        
    // 全面复苏
    else // > 5.0
        final_res := "全面复苏"
        line_risk := "⚔️ 进攻 (80-100%): " + (risk_assets == "" ? "核心股/商品" : risk_assets)
        line_safe := "🛡️ 避险 (0-20%): " + (safe_assets == "" ? "现金" : safe_assets)
        line_warn := "🚀 驱动: 全面共振"
        final_bg := c_super_green
        final_txt := c_white

    table.cell(rpt, 0, 10, "最终诊断", bgcolor = c_bg, text_color = c_white), table.merge_cells(rpt, 0, 10, 1, 10)
    
    string total_s_str = total_score == 0 ? "0" : str.tostring(total_score, "#.#")
    table.cell(rpt, 2, 10, total_s_str, bgcolor = c_bg, text_color = final_bg)
    
    table.cell(rpt, 3, 10, str.tostring(max_score, "#.#"), bgcolor = c_bg, text_color = c_white)
    table.cell(rpt, 4, 10, "结论", bgcolor = c_bg, text_color = c_white)
    
    color final_bg_trans = color.new(final_bg, 25)
    table.cell(rpt, 5, 10, final_res, bgcolor = final_bg_trans, text_color = final_txt)
    
    string final_full_sugg = line_risk + "\n" + line_safe + "\n" + line_warn
    table.cell(rpt, 6, 10, final_full_sugg, bgcolor = final_bg_trans, text_color = final_txt, text_halign = text.align_left)

    // --- 右表: 详情 ---
    string d_title="", string d_def="", string d_obs="", string d_logic="", string d_conf="", string d_w="", string d_cur_stat="", string d_cur_val="", string d_turn_val="", string d_cur_mean="", string d_risk="", string d_tactics="", string d_tactics_turn=""
    
    if mode == "1. 基准利率"
        d_title := "基准利率\n[EFFR]", d_def := "美联储联邦基金有效利率\n全球资金成本的总阀门。"
        d_obs := "10月 (EMA)", d_logic := "🔴 救火: ≥50bp\n🟠 加息: >EMA\n🟡 震荡: ≈EMA\n🟢 降息: <EMA", d_conf := "FOMC公布日确认\n" + next_fomc_time
        d_w := w1 > 1.0 ? "x2" : "x1"
        d_cur_stat := t1_s
        d_cur_val := str.tostring(effr_live, "0.00") + "% | " + last_fomc_time
        
        // 1. 基准利率含义与战术 (全状态覆盖)
        if s1 == -1.0 // 救火
            d_cur_mean := "衰退确信，初期伴随暴跌"
            d_tactics  := "此时降息预期极强\n买长债对冲股票下跌"
            d_turn_val := "降幅收窄 (恐慌消退)"
            d_tactics_turn := "恐慌消退，尝试左侧建仓\n买入超跌资产"
        else if s1 == -0.5 // 加息
            d_cur_mean := "资金变贵，现金为王"
            d_tactics  := "买短债吃高息，等跌\n规避久期敏感资产"
            d_turn_val := "跌破 EMA (停止加息)"
            d_tactics_turn := "停止加息，资金面转宽\n满仓买入利率敏感资产"
        else if s1 == 0.0 // 震荡
            d_cur_mean := "政策观望，方向未定"
            d_tactics  := "政策方向不明朗，观察期\n多看少动"
            d_turn_val := "跌破 EMA (开始降息)"
            d_tactics_turn := "确认降息周期开启\n加大杠杆做多"
        else // 降息
            d_cur_mean := "资金便宜，利好成长"
            d_tactics  := "布局科技、加密和生物医药\n利好利率敏感资产"
            d_turn_val := "上穿 EMA (停止降息)"
            d_tactics_turn := "降息结束，利好出尽\n落袋为安，防范通胀反弹"
            
        if s1 == -1.0
            d_risk := "恐慌消退"
        else if s1 == -0.5
            d_risk := "流动性转宽"
        else if s1 == 1.0
            d_risk := "流动性收紧"
        else
            d_risk := "方向明确"

    else if mode == "2. 真实利率"
        d_title := "真实利率\n[TIPS]", d_def := "10年期通胀保值债券收益率\nTIPS 上行 = 资金流出风险资产(买美债)\nTIPS 下行 = 资金流入风险资产(买股票)\nTIPS ≥ RGDP，会对风险资产产生‘虹吸效应’"
        d_obs := "日线 (实时)", d_logic := "🔴 滞胀: RGDP < 0\n🔴 虹吸: ≥ RGDP\n🟠 杀估值: ≥ 0.75RGDP\n🟡 震荡: ≥ 0.5RGDP\n🟢 健康: < 0.5RGDP\n🟢 负利率: < 0", d_conf := "连续5日确认"
        d_w := w2 > 1.0 ? "x2" : "x1"
        d_cur_stat := t2_s
        d_cur_val := str.tostring(tips_live, "0.00") + "% | " + fmt_ymd(tips_time)
        
        // 2. 真实利率含义与战术
        if s2 == -1.0
            if rgdp_val < 0 // 滞胀
                d_cur_mean := "经济停滞，物价飞涨\n(负利率陷阱)"
                d_tactics  := "现金为王，卖出所有资产\n买入美元/黄金"
                d_turn_val := "RGDP 转正 (经济复苏)"
                d_tactics_turn := "经济复苏，重仓股票\n关注周期反转"
            else // 虹吸
                d_cur_mean := "无风险收益极高，虹吸一切"
                d_tactics  := "只有美元现金最安全\n卖出风险资产"
                d_turn_val := "跌破 RGDP"
                d_tactics_turn := "虹吸效应结束，配置核心资产\n资金重回股市"
        else if s2 == -0.5 // 杀估值
            d_cur_mean := "实际资金成本过高，压制估值"
            d_tactics  := "买低估值红利股\n规避高估值成长股"
            d_turn_val := "跌破 0.75 RGDP"
            d_tactics_turn := "估值压制解除，进入震荡\n多看少做"
        else if s2 == 0.0 // 资金成本上升
            d_cur_mean := "资金成本上升，尚未杀估值"
            d_tactics  := "环境开始变差\n多看少做"
            d_turn_val := "跌破 0.5 RGDP (健康)"
            d_tactics_turn := "资金成本适宜，买入成长股\n科技股迎来春天"
        else if s2 == 1.0
            if tips_live < 0 // 负利率
                d_cur_mean := "实际利率为负，资产泡沫化"
                d_tactics  := "实物资产/数字黄金抗贬值\n满仓风险资产"
                d_turn_val := "利率转正"
                d_tactics_turn := "泡沫退潮，卖出黄金/加密\n转入防御性资产"
            else // 健康
                d_cur_mean := "资金成本适宜，利好股市"
                d_tactics  := "安心持有成长股\n享受估值溢价"
                d_turn_val := tips_live >= 0.5 * rgdp_val ? "突破 0.5 RGDP（确认中）" : "突破 0.5 RGDP"
                d_tactics_turn := "实际利率上行，转入震荡\n多看少做"
            
        if s2 == -1.0
            if rgdp_val < 0 // 滞胀
                d_risk := "复苏开启"
            else // 虹吸
                d_risk := "压力缓解"
        else if s2 == -0.5 // 杀估值
            d_risk := "估值修复"
        else if s2 == 0.0 // 震荡
            d_risk := "压力缓解"
        else if s2 == 1.0
            if tips_live < 0 // 负利率
                d_risk := "泡沫破裂"
            else // 健康
                d_risk := "进入震荡"
        else
            d_risk := "方向未定"

    else if mode == "3. 利差结构"
        d_title := "利差结构\n[10Y-2Y]", d_def := "10年期与2年期美债利差\n10Y看长期(经济前景); 2Y看短期(美联储政策)"
        d_obs := "20日 (趋势)", d_logic := "🛑 牛陡: 2Y 跌幅高于 10Y\n🟠 倒挂: 10Y < 2Y\n🟡 平坦: 10Y ≈ 2Y\n🟢 常态: 10Y > 2Y\n🟢 熊陡: 10Y 涨幅高于 2Y", d_conf := "即时生效(20日趋势)确认"
        d_w := w3 > 1.0 ? "x2" : "x1"
        d_cur_stat := t3_s
        d_cur_val := str.tostring(yc_val, "0.00")
        
        // 3. 利差含义与战术
        if s3 == -1.0 // 牛陡
            d_cur_mean := "衰退迫在眉睫，恐慌蔓延"
            d_tactics  := "立刻清空股票\n避险资金涌入，买美债/黄金"
            d_turn_val := "短债企稳 (恐慌消退)"
            d_tactics_turn := "恐慌消退，尝试左侧建仓\n买入超跌资产"
        else if s3 == -0.5 // 倒挂
            d_cur_mean := "长期前景堪忧，资金避险"
            d_tactics  := "衰退倒计时，收缩战线\n买防御性资产，避激进投资"
            d_turn_val := "重新转正 (解除警报)"
            d_tactics_turn := "警报解除，右侧确认买入\n加仓风险资产"
        else if s3 == 0.0 // 平坦
            d_cur_mean := "经济方向未定，多空博弈"
            d_tactics  := "倒挂/走阔转换期\n方向未定，多看少做"
            d_turn_val := "重新转正 (复苏确认)"
            d_tactics_turn := "复苏确认，加仓周期股\n做多商品"
        else if s3 == 0.5 // 陡峭 (常态)
            d_cur_mean := "经济正向运转，借短贷长获利"
            d_tactics  := "宏观环境无虞，持有风险资产\n只要不是倒挂，安心赚钱"
            d_turn_val := "重新倒挂"
            d_tactics_turn := "再次倒挂，清仓离场\n转入防御"
        else // 熊陡
            d_cur_mean := "经济复苏强劲，预期乐观"
            d_tactics  := "经济复苏，通胀回升\n卖美债，买周期股和大宗商品"
            d_turn_val := "重新倒挂"
            d_tactics_turn := "再次倒挂，清仓离场\n转入防御"
            
        if s3 == -1.0 // 牛陡
            d_risk := "恐慌消退"
        else if s3 == -0.5 // 倒挂
            d_risk := yc_val >= 0 ? "警报解除 (确认中)" : "警报解除"
        else if s3 == 0.0 // 平坦
            d_risk := "复苏确认"
        else if s3 == 0.5 // 陡峭 (常态)
            d_risk := yc_val < 0 ? "衰退风险 (确认中)" : "衰退风险"
        else // 熊陡
            d_risk := "衰退风险"

    else if mode == "4. 信用风险"
        d_title := "信用风险\n[OAS]", d_def := "高收益企业债期权调整利差\n银行借钱给烂公司的额外利息(风险保证金)\n趋势向上 = 银行惜贷，信用收缩\n趋势向下 = 市场风险偏好下降，融资成本上升"
        d_obs := "20日 (趋势)", d_logic := "🛑 危机: >10%或暴涨\n🔴 恶化: >6%\n🟠 走阔: 趋势上\n🟡 压力: 震荡\n🟡 底部回升：< 3.5% 但趋势向上\n🟢 收敛: <3.5%", d_conf := "连续3日确认\n\n熔断/严重恶化即时"
        d_w := w4 > 1.0 ? "x2" : "x1"
        d_cur_stat := t4_s
        d_cur_val := str.tostring(oas_val, "0.00") + "% | " + fmt_ymd(oas_time)
        
        // 4. 信用含义与战术
        if s4 == -1.0 and w4 > 1.0 // 熔断
            d_cur_mean := "融资断裂，破产潮来袭"
            d_tactics  := "信用市场冻结\n仅美元现金/短债安全"
            d_turn_val := "回落至 10% 下 (危机解除)"
            d_tactics_turn := "危机解除，报复性反弹\n买入超跌垃圾债"
            d_risk := "危机解除"
        else if s4 == -1.0 // 恶化
            d_cur_mean := "融资成本极高，企业失血\n(信用枯竭)"
            d_tactics  := "绝对风险过高，下降也不碰\n抛售垃圾债和小盘股"
            d_turn_val := "回落至 6% 下 (流动性恢复)"
            d_tactics_turn := "流动性恢复，买入小盘股\n关注困境反转"
            d_risk := "流动性恢复"
        else if s4 == -0.5 // 走阔
            d_cur_mean := "避险升温，资金嫌贫爱富\n(信用收缩)"
            d_tactics  := "减少风险资产配置\n退守大盘股或美债"
            d_turn_val := "趋势向下 (压力缓解)"
            d_tactics_turn := "压力缓解，关注信用债\n配置可转债"
            d_risk := "压力缓解"
        else if s4 == 0.0 // 压力/底部回升
            if oas_val < 3.5 // 底部回升
                d_cur_mean := "虽在变差，但环境仍宽松\n(关注)"
                d_tactics  := "环境宽松，无需过度紧张\n保持关注"
                d_turn_val := "趋势向下 (虚惊一场)"
                d_tactics_turn := "虚惊一场，继续奏乐\n维持进攻"
                d_risk := "虚惊一场"
            else // 局部压力
                d_cur_mean := "虽有压力但未失控\n(信用摇摆)"
                d_tactics  := "金融环境尚可\n(多看少做)"
                d_turn_val := "回落至 3.5% 下 (环境宽松)"
                d_tactics_turn := "环境宽松，大胆加杠杆\n全仓进攻"
                d_risk := "环境宽松"
        else // 收敛
            d_cur_mean := "资金泛滥，融资容易\n(信用扩张)"
            d_tactics  := "风险偏好提升，资金泛滥\n买入垃圾债"
            d_turn_val := "突破 3.5% (环境收紧)"
            d_tactics_turn := "环境收紧，降低杠杆\n卖出垃圾债"
            d_risk := "环境收紧"

    else if mode == "5. 流动性"
        if region == "美国"
            d_title := "流动性增速\n[M2REAL YoY]", d_def := "广义货币供应量同比(剔除通胀)\nM2REAL 同比 >0 = 美国印钱 = 全球水位上涨"
            d_obs := "12月 (同比)", d_logic := "🔴 枯竭: <-2%\n🟠 紧缩: <0\n🟡 存量: ≈0\n🟢 扩张: >0", d_conf := "连续2个月确认"
            d_w := w5 > 1.0 ? "x2" : "x1"
            d_cur_stat := t5_s
            d_cur_val := str.tostring(us_m2_yoy, "0.00") + "% | " + fmt_ym(us_m2_time)
            
            // 5. 流动性含义与战术
            if s5 == -1.0 // 枯竭
                d_cur_mean := "极度紧缩，资产崩盘\n(水位见底)"
