//@version=6
indicator("[薯仔] 宏观经济 (Expert Edition)", overlay = false, precision = 2, max_labels_count = 500)

// --- 1. 设置与配色 ---
show_report = input.bool(true, "显示决策看板", group="显示设置")
mode = input.string("1. 基准利率 (EFFR)", "当前显示曲线",
     options=["1. 基准利率 (EFFR)", "2. 真实利率 (10Y TIPS)", "3. 利差结构 (10Y-2Y)",
     "4. 信用风险 (OAS)", "5. 流动性 (M1-M2)", "6. 利润空间 (CPI-PPI)",
     "7. 实体热度 (铜金比)", "8. 衰退熔断 (就业)"], group="显示设置")
region = input.string("美国 (US)", "监控地区", options=["美国 (US)", "中国 (CN)"], group="显示设置", tooltip="仅影响: 5.流动性 / 6.利润空间")

effr_ema_len = input.int(10, "基准利率 EMA 周期", minval=1, group="周期参数设置", tooltip="仅影响: 1.基准利率")
yoy_len = input.int(12, "增速同比周期 (月)", minval=1, group="周期参数设置", tooltip="仅影响: 5.流动性 / 6.利润空间")
slope_len = input.int(20, "斜率观测周期 (日)", minval=1, group="周期参数设置", tooltip="仅影响: 3.利差结构 / 4.信用风险 / 7.实体热度")

// 配色
c_beige = #F5F5DC, c_white = color.white, c_lime = color.lime, c_red = color.red, c_yell = color.yellow, c_maroon = #800000, c_orange = color.orange
c_black = color.black, c_gray = color.gray
c_bg = color.new(color.black, 15), c_header = color.new(color.gray, 10)
c_score_col = #78D6FB

// --- 2. 核心数据与辅助计算 ---

// Helper Functions
fmt_ym(t) => str.tostring(year(t)) + "-" + (month(t) < 10 ? "0" : "") + str.tostring(month(t))
fmt_ymd(t) => str.tostring(year(t)) + "-" + (month(t) < 10 ? "0" : "") + str.tostring(month(t)) + "-" + (dayofmonth(t) < 10 ? "0" : "") + str.tostring(dayofmonth(t))

// Helper Function for Split Score
fmt_s_act(s, w) => 
    float v = s * w
    // Fix: Show "0" for zero, and show up to 2 decimals for non-zero (e.g. 2.25)
    // Avoid rounding 2.25 to 2.3 by using "#.##" format
    v == 0 ? "0" : ((v > 0 ? "+" : "") + str.tostring(v, "#.##"))

fmt_s_max(w) => "x" + str.tostring(w, "#")

calc_effr_m() => [close, ta.ema(close, 10), close[1], (close[1] - close) * 100]
calc_slope(len) => [close, close - close[len]]
calc_yoy_3(len) => 
    v = (close / close[len] - 1) * 100
    [v, v[1], v[2], v[3]]
calc_sahm_m() =>
    u = close
    s = ta.sma(u, 3)
    l = ta.lowest(s, 12)
    val = s - l
    [val, val[1]]
calc_val_and_lag(len) => [close, close[len]]
calc_slope_3d(len) => 
    s = close - close[len]
    [s, s[1], s[2]]
calc_chg_5d() => (close / close[5] - 1) * 100
calc_seq_5d_above(val, th) => val > th and val[1] > th and val[2] > th and val[3] > th and val[4] > th
calc_seq_5d_below(val, th) => val < th and val[1] < th and val[2] < th and val[3] < th and val[4] < th

// 2.2 数据抓取 (全面升级)

// 1. EFFR
effr_live = request.security("FRED:EFFR", "D", close, gaps = barmerge.gaps_off)
[effr_m, effr_ema, effr_m_1, effr_drop] = request.security("FRED:EFFR", "M", calc_effr_m(), gaps = barmerge.gaps_off)
effr_live_time = request.security("FRED:EFFR", "D", time, gaps = barmerge.gaps_off)

// 2. TIPS
tips_live = request.security("FRED:DFII10", "D", close, gaps = barmerge.gaps_off)
[gdp_val, gdp_time] = request.security("FRED:A191RL1Q225SBEA", "D", [close, time_close], gaps = barmerge.gaps_off)
gdp_half = gdp_val * 0.5
tips_above_gdp_5d = request.security("FRED:DFII10", "D", calc_seq_5d_above(close, gdp_val), gaps = barmerge.gaps_off)
tips_below_half_5d = request.security("FRED:DFII10", "D", calc_seq_5d_below(close, gdp_half), gaps = barmerge.gaps_off)
tips_above_half_5d = request.security("FRED:DFII10", "D", calc_seq_5d_above(close, gdp_half), gaps = barmerge.gaps_off)

// 3. Yield Curve
[y10_d, y10_d_old] = request.security("FRED:GS10", "D", calc_val_and_lag(slope_len), gaps = barmerge.gaps_off)
[y2_d, y2_d_old] = request.security("FRED:GS2", "D", calc_val_and_lag(slope_len), gaps = barmerge.gaps_off)
yc_val_d = y10_d - y2_d
y10_slope = y10_d - y10_d_old
y2_slope = y2_d - y2_d_old

// 4. OAS & NFCI (Scheme B: Validation)
[oas_val, oas_old] = request.security("FRED:BAMLH0A0HYM2", "D", calc_val_and_lag(slope_len), gaps = barmerge.gaps_off)
[oas_s0, oas_s1, oas_s2] = request.security("FRED:BAMLH0A0HYM2", "D", calc_slope_3d(slope_len), gaps = barmerge.gaps_off)
oas_chg_5d = request.security("FRED:BAMLH0A0HYM2", "D", calc_chg_5d(), gaps = barmerge.gaps_off)
nfci_val = request.security("FRED:NFCI", "W", close, gaps = barmerge.gaps_off) // Weekly

// 5. Liquidity (Scheme C: Global Fetch)
// Fixed: Using "M" timeframe to correctly calculate YoY (12 months)
[m2real_yoy, m2real_yoy_1, m2real_yoy_2, m2real_yoy_3] = request.security("FRED:M2REAL", "M", calc_yoy_3(yoy_len), gaps = barmerge.gaps_off)
m2real_time = request.security("FRED:M2REAL", "M", time_close, gaps = barmerge.gaps_off)

[cn_m1_yoy, cn_m1_yoy_1, cn_m1_yoy_2, cn_m1_yoy_3] = request.security("ECONOMICS:CNM1", "M", calc_yoy_3(yoy_len), gaps = barmerge.gaps_off)
[cn_m2_yoy, cn_m2_yoy_1, cn_m2_yoy_2, cn_m2_yoy_3] = request.security("ECONOMICS:CNM2", "M", calc_yoy_3(yoy_len), gaps = barmerge.gaps_off)
cn_time = request.security("ECONOMICS:CNM1", "M", time_close, gaps = barmerge.gaps_off)

// Selected Region Liquidity
float liq_val = na, float liq_val_1 = na, int liq_time = na
if region == "美国 (US)"
    liq_val := m2real_yoy, liq_val_1 := m2real_yoy_1, liq_time := m2real_time
else
    liq_val := cn_m1_yoy - cn_m2_yoy, liq_val_1 := cn_m1_yoy_1 - cn_m2_yoy_1, liq_time := cn_time

// 6. Profit (CPI-PPI)
// Fixed: Using "M" timeframe for correct YoY
[cpi_yoy, cpi_yoy_1, cpi_yoy_2, cpi_yoy_3] = request.security(region == "美国 (US)" ? "FRED:CPIAUCSL" : "ECONOMICS:CNCPI", "M", calc_yoy_3(yoy_len), gaps = barmerge.gaps_off)
[ppi_yoy, ppi_yoy_1, ppi_yoy_2, ppi_yoy_3] = request.security(region == "美国 (US)" ? "FRED:PPIACO" : "ECONOMICS:CNPPI", "M", calc_yoy_3(yoy_len), gaps = barmerge.gaps_off)
prof_time = request.security(region == "美国 (US)" ? "FRED:CPIAUCSL" : "ECONOMICS:CNCPI", "M", time_close, gaps = barmerge.gaps_off)
prof_val = cpi_yoy - ppi_yoy
prof_val_1 = cpi_yoy_1 - ppi_yoy_1

// 7. Real Economy
[hg_d, hg_d_old] = request.security("COMEX:HG1!", "D", calc_val_and_lag(slope_len), gaps = barmerge.gaps_off)
[gc_d, gc_d_old] = request.security("COMEX:GC1!", "D", calc_val_and_lag(slope_len), gaps = barmerge.gaps_off)
cg_ratio = (hg_d / gc_d) * 1000
cg_ratio_old = (hg_d_old / gc_d_old) * 1000
cg_slope = cg_ratio - cg_ratio_old
hg_slope = hg_d - hg_d_old
cg_ratio_5d_val = request.security("(COMEX:HG1!/COMEX:GC1!)*1000", "D", close[5], gaps = barmerge.gaps_off)
cg_drop_5d = (cg_ratio / cg_ratio_5d_val - 1) * 100
cg_up_5d = request.security("(COMEX:HG1!/COMEX:GC1!)*1000", "D", calc_seq_5d_above(close - close[20], 0), gaps = barmerge.gaps_off)

// 8. Sahm & ICSA (Scheme B: Leading Indicator)
[sahm_val, sahm_val_1] = request.security("FRED:UNRATE", "M", calc_sahm_m(), gaps = barmerge.gaps_off)
sahm_time = request.security("FRED:UNRATE", "M", time, gaps = barmerge.gaps_off)

// ICSA: 4-week YoY Check
// FRED:ICSA is Weekly
calc_icsa_yoy() => (close - close[52]) / close[52] * 100
icsa_yoy = request.security("FRED:ICSA", "W", calc_icsa_yoy(), gaps = barmerge.gaps_off)
icsa_warn = request.security("FRED:ICSA", "W", ta.lowest(icsa_yoy, 4) > 15.0, gaps = barmerge.gaps_off) // 4 weeks > 15%

// --- 3. 评分系统 (Scheme A: Dynamic Weights & Logic) ---

// 3.0 Regime Definition
// Fixed: Using "M" timeframe
[us_cpi_yoy_raw, _1, _2, _3] = request.security("FRED:CPIAUCSL", "M", calc_yoy_3(12), gaps = barmerge.gaps_off)
is_inflation_era = us_cpi_yoy_raw > 3.0

yc_slope_diff = math.abs(y10_slope - y2_slope)
is_bull_steep = yc_val_d > 0 and yc_slope_diff > 0.02 and y2_slope < 0 and y2_slope < y10_slope
is_panic_era = sahm_val >= 0.3 or is_bull_steep

// Base Weights
float w1 = 1.0, float w2 = 1.0, float w3 = 1.0, float w4 = 1.0
float w5 = 1.0, float w6 = 1.0, float w7 = 1.0, float w8 = 1.0

// Dynamic Weight Adjustment
if is_inflation_era
    w6 := w6 * 2.0 // Profit (CPI-PPI)
    w7 := w7 * 2.0 // Real Econ (Copper)

if is_panic_era
    w3 := w3 * 2.0 // Yield Curve
    w4 := w4 * 2.0 // OAS
    w8 := w8 * 2.0 // Sahm

// Raw Scores
var float s1 = 0.0, var float s2 = 0.0, var float s3 = 0.0, var float s4 = 0.0
var float s5 = 0.0, var float s6 = 0.0, var float s7 = 0.0, var float s8 = 0.0

// S1: EFFR
if effr_m < 1.25
    s1 := 1.0
else if effr_m < (effr_ema - 0.05)
    s1 := 1.0
else if effr_m > (effr_ema + 0.05)
    s1 := -1.0
is_rescue = effr_drop >= 0.50

// S2: TIPS
if tips_below_half_5d
    s2 := 1.0
else if tips_above_gdp_5d
    s2 := -1.0
else if tips_above_half_5d
    s2 := -1.0
else
    if tips_live < gdp_half
        s2 := 1.0
    else if tips_live >= gdp_val
        s2 := -1.0
    else
        s2 := -1.0
tips_confirmed = (s2 == 1.0 and tips_below_half_5d) or (s2 == -1.0 and tips_above_gdp_5d) or (s2 == -1.0 and tips_above_half_5d)

// S3: Yield Curve
if yc_val_d > 0
    if yc_slope_diff > 0.02
        if y10_slope > 0 and y10_slope > y2_slope
            s3 := 1.0 // Bear Steep
        else if is_bull_steep
            s3 := -1.0 // Bull Steep
        else
            s3 := -1.0 // Flat
    else
        s3 := -1.0 // Flat
else
    s3 := -1.0 // Inverted

// S4: OAS (with NFCI Validation)
oas_up_3d = oas_s0 > 0.01 and oas_s1 > 0.01 and oas_s2 > 0.01
oas_dn_3d = oas_s0 < -0.01 and oas_s1 < -0.01 and oas_s2 < -0.01
oas_meltdown = oas_val > 10.0 or oas_chg_5d >= 20.0

if oas_meltdown
    s4 := -1.0
else if oas_val > 6.0
    s4 := -1.0
else if oas_val > 3.5 // Elevated
    // NFCI Check: If OAS high but NFCI loose (<0), it's local stress, not systemic
    if nfci_val < 0
        s4 := -0.5 // Reduced penalty
    else
        s4 := oas_dn_3d ? 0.5 : -1.0
else // Normal
    if oas_dn_3d
        s4 := 1.0
    else if oas_up_3d
        s4 := -1.0
    else
        s4 := 0.5

// S5: Liquidity
if liq_val > 0.2 and liq_val_1 > 0.2
    s5 := 1.0
else if liq_val < -0.2 and liq_val_1 < -0.2
    s5 := -1.0
else
    s5 := 0.0

// S6: Profit (with Anti-Illusion)
prof_contract = prof_val <= prof_val_1
prof_expand = prof_val > prof_val_1
// Anti-Illusion Rule
if cpi_yoy < 0 and ppi_yoy < 0
    s6 := -1.0 // Deflationary Illusion -> Negative
else if prof_val < -0.1
    s6 := -1.0
else if prof_val > 0.1
    s6 := prof_expand ? 1.0 : (prof_contract ? 0.5 : 0.0)
else
    s6 := 0.0

// S7: Real Economy
if cg_drop_5d < -3.0
    s7 := -1.0
else if cg_slope > 0
    if hg_slope >= 0
        s7 := cg_up_5d ? 1.0 : 0.0
    else
        s7 := -1.0 // Fake
else
    s7 := hg_slope >= 0 ? 0.0 : -1.0

// S8: Sahm (with ICSA Leading Indicator)
if sahm_val < 0.3
    // Leading Indicator Check
    if icsa_warn
        s8 := -0.5 // Warning triggered despite low Sahm
    else
        s8 := 1.0
else if sahm_val >= 0.5
    s8 := -1.0
else
    // 0.3 <= sahm_val < 0.5: Warning Zone
    // Assign -0.5 so that dynamic weight (x2) results in -1.0 score impact
    s8 := -0.5

// Total Score Calculation
total_score = s1*w1 + s2*w2 + s3*w3 + s4*w4 + s5*w5 + s6*w6 + s7*w7 + s8*w8
max_possible = w1 + w2 + w3 + w4 + w5 + w6 + w7 + w8

// --- 4. 绘图与可视化 ---

// Helper for action text
get_action_color(score, is_rescue, is_obs) =>
    if score <= -1.5 or score == -2.0
        c_red
    else if is_rescue
        c_yell
    else if score > 0 and not is_obs
        c_lime
    else if score < 0 and not is_obs
        c_orange
    else
        c_yell

get_action_text(score, is_rescue, is_obs, assets_atk, assets_def, assets_obs, assets_crash) =>
    if score <= -1.5 or score == -2.0
        "【清仓】" + assets_crash
    else if is_rescue
        "【观察】" + assets_obs
    else if score > 0 and not is_obs
        "【进攻】" + assets_atk
    else if score < 0 and not is_obs
        "【防御】" + assets_def
    else
        "【观察】" + assets_obs

float plot_val = switch mode
    "1. 基准利率 (EFFR)"    => effr_live
    "2. 真实利率 (10Y TIPS)" => tips_live
    "3. 利差结构 (10Y-2Y)"   => yc_val_d
    "4. 信用风险 (OAS)"      => oas_val
    "5. 流动性 (M1-M2)"      => liq_val
    "6. 利润空间 (CPI-PPI)"  => prof_val
    "7. 实体热度 (铜金比)"    => cg_ratio
    "8. 衰退熔断 (就业)"     => sahm_val
    => 0.0

color dyn_c = c_white
if mode == "1. 基准利率 (EFFR)"
    dyn_c := is_rescue ? c_yell : (s1 > 0 ? c_lime : c_orange)
else if mode == "2. 真实利率 (10Y TIPS)"
    dyn_c := not tips_confirmed ? c_yell : (s2 > 0 ? c_lime : c_red)
else if mode == "3. 利差结构 (10Y-2Y)"
    dyn_c := is_bull_steep ? c_red : (s3 > 0 ? c_lime : c_orange)
else if mode == "4. 信用风险 (OAS)"
    dyn_c := s4 > 0 ? c_lime : c_orange
else if mode == "5. 流动性 (M1-M2)"
    dyn_c := s5 > 0 ? c_lime : (s5 == 0.0 ? c_yell : c_orange)
else if mode == "6. 利润空间 (CPI-PPI)"
    dyn_c := s6 == 1.0 ? c_lime : (s6 == -1.0 ? c_red : c_yell)
else if mode == "7. 实体热度 (铜金比)"
    dyn_c := s7 > 0 ? c_lime : (s7 == 0.0 ? c_yell : c_orange)
else if mode == "8. 衰退熔断 (就业)"
    dyn_c := sahm_val >= 0.5 ? c_red : (sahm_val >= 0.3 ? c_yell : c_lime)

plot(plot_val, "审计主线", color = dyn_c, linewidth = 2, style = (mode == "1. 基准利率 (EFFR)" or mode == "5. 流动性 (M1-M2)" or mode == "6. 利润空间 (CPI-PPI)" or mode == "8. 衰退熔断 (就业)") ? plot.style_stepline : plot.style_line)
plot(mode == "1. 基准利率 (EFFR)" ? effr_ema : na, "EMA10参考线", color = color.blue, linewidth = 1)

g_p = math.max(math.min(gdp_val, 10.0), -5.0), h_p = math.max(math.min(gdp_half, 5.0), -2.5)
show_gdp = (mode == "2. 真实利率 (10Y TIPS)")
plot(show_gdp ? g_p : na, "真实美国GDP", color = color.new(color.gray, 70), style = plot.style_stepline, linewidth = 2)
plot(show_gdp ? h_p : na, "重力线", color = color.new(color.orange, 60), style = plot.style_stepline, linewidth = 2)

if barstate.islast and show_gdp
    y = year(gdp_time)
    m = month(gdp_time)
    d_day = dayofmonth(gdp_time)
    q_offset = (m % 3 == 0 and d_day > 20) ? 1 : 0
    q_raw = math.ceil(m / 3) + q_offset
    if q_raw > 4
        q_raw := 1
        y := y + 1
    label.new(bar_index, g_p, "真实美国GDP (" + str.tostring(y) + " Q" + str.tostring(q_raw) + ")", textcolor = color.gray, style = label.style_none, size = size.normal)

hline(0, "零轴", color = color.gray, linestyle = hline.style_dashed)

if barstate.islast and mode == "8. 衰退熔断 (就业)"
    line.new(bar_index - 1, 0.5, bar_index, 0.5, xloc=xloc.bar_index, extend=extend.both, color=c_red, style=line.style_dashed, width=2)
    s_col = sahm_val >= 0.5 ? c_red : (sahm_val >= 0.3 ? c_yell : c_lime)
    msg = "萨姆: " + str.tostring(sahm_val, "0.3") + (icsa_warn ? "\n【预警】初请失业金激增" : "")
    label.new(bar_index, sahm_val, msg, color = s_col, textcolor = color.black, style = label.style_label_left)

bgcolor(color.new(dyn_c, 92))

// --- 5. 看板渲染 ---
var table info = table.new(position.middle_right, 4, 6, bgcolor = c_bg, border_width = 1, border_color = color.gray)
var table rpt = table.new(position.middle_left, 7, 11, bgcolor = c_bg, border_width = 1, border_color = color.gray)

if barstate.islast and show_report
    // US/CN Logic
    bool us_tight = effr_m > effr_ema or m2real_yoy < 0
    bool us_loose = effr_m < effr_ema and m2real_yoy > 0
    float cn_pulse = cn_m1_yoy - cn_m2_yoy
    bool cn_tight = cn_pulse < -5.0
    bool cn_loose = cn_pulse > 0

    // Strategy Matrix
    string strat_title = "中美策略", string strat_desc = "", color strat_col = c_white
    
    // State Descriptions
    string us_state_txt = us_tight ? "美紧: 货币紧缩" : (us_loose ? "美松: 货币宽松" : "美平: 政策观察")
    string cn_state_txt = cn_tight ? "中紧: 资金空转" : (cn_loose ? "中松: 信贷激活" : "中平: 信用磨底")
    
    if us_loose and cn_loose
        strat_title := "共振复苏", strat_desc := "全仓进攻 (铜+原油+澳元)", strat_col := c_lime
    else if us_tight and cn_tight
        strat_title := "双重紧缩", strat_desc := "美元独强 (做多USD+空A股)", strat_col := c_red
    else if is_panic_era and cn_tight
        strat_title := "衰退共振", strat_desc := "现金为王 (美债+黄金+日元)", strat_col := c_maroon
    else if is_panic_era and cn_loose
        strat_title := "东升西降", strat_desc := "结构性做多 (多A股+空美股)", strat_col := c_yell
    // New Granular Scenarios
    else if us_tight and cn_loose
        strat_title := "分化博弈", strat_desc := "多美元(吃利息) + 多A股(独立行情)", strat_col := c_white
    else if us_loose and cn_tight
        strat_title := "单极驱动", strat_desc := "做多美股/黄金，规避工业大宗", strat_col := c_white
    else
        strat_title := "垃圾时间", strat_desc := "多看少动，等待新一轮趋势", strat_col := c_white

    // 5.1 Variables
    string title = "", string intro = "", string cur_s = "", string cur_v = "", string cur_d = "", string cur_t = "", string pre_v = "", string pre_d = "", string pre_t = ""
    string obs_v = "", string obs_desc = "", string confirm_v = ""
    color f_c1 = c_score_col, color pr_col = c_lime
    t_g = str.tostring(gdp_val, "#.##"), t_h = str.tostring(gdp_half, "#.##")

    // Assets Templates
    string a_tech = "流动性受益资产" 
    string a_cash = "红利/现金/短债"
    string a_gold = "转持现金/黄金"
    string a_comm = "工业金属/大宗/顺周期"
    string a_core = "各赛道核心龙头"
    string a_def_bond = "持有高股息/国债"
    string a_def_gen = "持有防御性资产"

    // 5.2 Right Table Logic
    if mode == "1. 基准利率 (EFFR)"
        title := "基准利率\n[EFFR]", intro := "美联储联邦基金有效利率\n利率下降(降息) = 资金成本降低，流动性释放\n救火式降息: <50bp; 开启降息周期: ≥50bp", cur_s := "权重: " + (w1 > 1.0 ? "x2" : "x1")
        cur_v := str.tostring(effr_live, "0.00") + "% | " + fmt_ymd(effr_live_time) + "\n" + "(EMA" + str.tostring(effr_ema_len) + "：" + str.tostring(effr_ema, "0.00") + "% )"
        cur_d := is_rescue ? "央行被迫大幅降息" : (s1 > 0 ? "央行开始降息" : "央行加息或利率维持高位")
        cur_t := get_action_text(s1, is_rescue, false, a_tech, a_def_bond, "观察确认", a_gold)
        pr_col := get_action_color(s1, is_rescue, false)
        obs_v := str.tostring(effr_ema_len) + "月(EMA)", obs_desc := "站上EMA: 加息周期\n跌破EMA: 降息周期", confirm_v := "公布日确认"
        pre_v := s1 > 0 ? "上穿 EMA" + str.tostring(effr_ema_len) : "观察利率底部\n(连续3个月±12.5 bp)"
        pre_d := s1 > 0 ? "加息周期，流动性收紧" : "降息周期，流动性充裕"
        pre_t := s1 > 0 ? "【回避】" + a_def_bond : "【进攻】" + a_tech
        pr_col := s1 > 0 ? c_red : c_lime 

    else if mode == "2. 真实利率 (10Y TIPS)"
        title := "真实利率\n[10Y TIPS]", intro := "10年期通胀保值债券收益率\n实际利率上行 = 资金流出风险资产(买美债)\n实际利率下行 = 资金流入风险资产(股市)\n实际利率>GDP增速会对风险资产产生‘虹吸效应’", cur_s := "权重: " + (w2 > 1.0 ? "x2" : "x1")
        cur_v := str.tostring(tips_live, "0.00") + "%\n(真实美国GDP: " + t_g + "%)"
        cur_d := s2 == -1.5 ? "【崩坏】无风险收益高于真实GDP" : (s2 == -1.0 ? "【压制】实际利率过高，压制估值" : "【利好】实际利率适宜，支撑估值")
        cur_t := get_action_text(s2, false, not tips_confirmed, "高弹性资产", "减配高估值", "趋势确认中", a_gold)
        pr_col := get_action_color(s2, false, not tips_confirmed)
        obs_v := "每日实时", obs_desc := "上穿真实GDP: 估值极度承压\n站上重力线: 估值承压\n跌破重力线: 估值支撑", confirm_v := "持续5日确认"
        pre_v := s2 > 0 ? "站上 " + t_h + "%" : (s2 == -1.5 ? "跌破 " + t_g + "%" : "跌破 " + t_h + "%")
        pre_d := s2 > 0 ? "实际利率上行，估值承压" : (s2 == -1.5 ? "估值崩坏，回归压制" : "实际利率下行，估值修复")
        pre_t := s2 > 0 ? "【回避】减配高估值" : (s2 == -1.5 ? "【观察】等待确认" : "【进攻】" + a_tech)
        pr_col := s2 > 0 ? c_red : (s2 == -1.5 ? c_yell : c_lime)

    else if mode == "3. 利差结构 (10Y-2Y)"
        title := "利差结构\n[10Y-2Y]", intro := "10年期与2年期美债利差\n10Y看长期(经济前景); 2Y看短期(货币政策)", cur_s := "权重: " + (w3 > 1.0 ? "x2" : "x1")
        cur_v := str.tostring(yc_val_d, "0.00")
        cur_d := s3 * w3 <= -1.5 ? (is_bull_steep ? "【牛陡】衰退恐慌，市场预期降息" : "长短债倒挂，预警经济衰退") : (s3 > 0 ? "长债利率上行，确认复苏" : "利差收窄，方向未明")
        cur_t := get_action_text(s3 * w3, is_bull_steep, false, "顺周期/价值", "持有短债/现金", "保留现金", a_gold)
        pr_col := get_action_color(s3 * w3, is_bull_steep, false)
        obs_v := str.tostring(slope_len) + "日(斜率)", obs_desc := "倒挂: 衰退预警\n牛陡: 衰退恐慌\n熊陡: 复苏确认\n熊平: 紧缩加压\n牛平: 增长见顶", confirm_v := "即刻确认"
        if s3 == -2.0 and is_bull_steep 
            pre_v := "经济预期回暖", pre_d := "转为熊陡(复苏)", pre_t := "【进攻】" + a_comm, pr_col := c_lime
        else if s3 * w3 <= -1.5 
            pre_v := "曲线回正", pre_d := "解除倒挂", pre_t := "【观察】等待牛陡确认", pr_col := c_yell
        else 
            pre_v := "重新倒挂", pre_d := "衰退风险回归", pre_t := "【防御】" + a_def_bond, pr_col := c_red

    else if mode == "4. 信用风险 (OAS)"
        title := "信用风险\n[OAS]", intro := "高收益企业债期权调整利差\n利差走阔 = 市场风险偏好下降，融资成本上升\n斜率向上 = 银行惜贷，信用收缩", cur_s := "权重: " + (w4 > 1.0 ? "x2" : "x1"), cur_v := str.tostring(oas_val, "0.2") + "%"
        cur_d := s4 > 0 ? "信用利差收窄，融资环境宽松" : (s4 <= -1.5 ? "【熔断】信用利差飙升，流动性枯竭" : "信用利差走阔，融资环境收紧")
        cur_t := get_action_text(s4, false, s4==0.5, "超跌修复", "规避高杠杆", "分批布局", a_gold)
        pr_col := get_action_color(s4, false, s4==0.5)
        obs_v := str.tostring(slope_len) + "日(斜率)", obs_desc := "向上: 信用收缩\n向下: 信用扩张", confirm_v := "持续3日确认"
        pre_v := s4 > 0 ? "斜率转正(3日)" : "斜率转负(3日)"
        pre_d := s4 > 0 ? "信用环境变差" : "信用环境改善"
        pre_t := s4 > 0 ? "【防御】规避高杠杆" : "【进攻】博弈超跌龙头"
        pr_col := s4 > 0 ? c_red : c_lime 

    else if mode == "5. 流动性 (M1-M2)"
        title := region == "美国 (US)" ? "流动性增速\n[M2REAL YoY]" : "流动性增速差\n[M1增速 - M2增速]", intro := region == "美国 (US)" ? "广义货币供应量(剔除通胀)\nM2REAL 同比>0 = 货币供应扩张\n全球美元充裕" : "M1增速 - M2增速 (信贷脉搏)\n增速差为负 = 资金在金融体系空转\n实体流动性紧缩", cur_s := "权重: " + (w5 > 1.0 ? "x2" : "x1")
        cur_v := str.tostring(liq_val, "0.00") + " | " + fmt_ym(liq_time)
        cur_d := region == "美国 (US)" ? (s5 > 0 ? "全球美元流动性充裕" : "全球美元流动性收紧") : (s5 > 0 ? "M1增速回升，企业资金活化" : "M1增速低迷，企业资金空转")
        cur_t := get_action_text(s5, false, s5==0.0, a_tech, "减持科技成长", "分批布局", a_gold)
        pr_col := get_action_color(s5, false, s5==0.0)
        obs_v := str.tostring(yoy_len) + "月(同比)", obs_desc := "数值>0: 流动性扩张\n数值<0: 流动性收缩", confirm_v := "公布日确认"
        pre_v := s5 > 0 ? "跌破 0 轴" : "向上突破 0 轴"
        pre_d := s5 > 0 ? "流动性收缩" : "流动性扩张"
        pre_t := s5 > 0 ? "【回避】降低科技敞口" : "【进攻】加仓" + a_tech
        pr_col := s5 > 0 ? c_red : c_lime

    else if mode == "6. 利润空间 (CPI-PPI)"
        title := "利润空间\n[CPI-PPI]", intro := region == "美国 (US)" ? "CPI(售价) - PPI(成本) | 利润剪刀差(美)\n卖价(CPI) - 成本(PPI) = 利润\n差值走阔 = 企业盈利改善" : "CPI(需求) - PPI(产能) | 利润剪刀差(中)\n警惕‘通缩型利差虚增’", cur_s := "权重: " + (w6 > 1.0 ? "x2" : "x1")
        cur_v := str.tostring(prof_val, "0.00") + " | " + fmt_ym(prof_time)
        cur_d := s6 == 1.0 ? "剪刀差走阔，企业盈利改善" : (s6 == -1.0 ? "剪刀差倒挂，企业盈利承压" : (s6 == 0.5 ? "剪刀差收窄，盈利空间压缩" : "剪刀差震荡，盈利方向未明"))
        cur_t := get_action_text(s6, false, s6!=1.0 and s6!=-1.0, "高毛利/定价权龙头", "减仓观望", "分批布局", a_gold)
        pr_col := get_action_color(s6, false, s6!=1.0 and s6!=-1.0)
        obs_v := "12月同比差值 (趋势)", obs_desc := "走阔: 利润空间扩大\n收窄: 利润空间压缩", confirm_v := "公布日确认"
        if s6 == 1.0 
            pre_v := "差值转跌", pre_d := "盈利见顶", pre_t := "【观察】等待确认", pr_col := c_yell
        else if s6 == -1.0 
            pre_v := "重回 0 轴上方", pre_d := "盈利修复", pre_t := "【进攻】关注修复", pr_col := c_lime
        else 
            pre_v := "差值转涨", pre_d := "空间重新走阔", pre_t := "【进攻】" + "高毛利龙头", pr_col := c_lime

    else if mode == "7. 实体热度 (铜金比)"
        title := "实体热度\n[铜金比]", intro := "铜价 / 金价 | 经济周期风向标\n铜代表工业需求(经济复苏)\n金代表避险情绪(经济衰退)", cur_s := "权重: " + (w7 > 1.0 ? "x2" : "x1"), cur_v := str.tostring(cg_ratio, "0.00")
        string s7_zero_txt = ""
        if s7 == 0.0
            if cg_slope > 0 
                s7_zero_txt := "实体复苏信号确认中"
            else 
                s7_zero_txt := "铜金背离 (金强于铜)"
        cur_d := s7 > 0 ? "铜强金弱，实体需求复苏" : (s7 < 0 ? "金强铜弱，避险情绪主导" : s7_zero_txt)
        cur_t := get_action_text(s7, false, s7==0.0, a_comm, "持有黄金/美债", "等待方向确认", a_gold)
        pr_col := get_action_color(s7, false, s7==0.0)
        obs_v := str.tostring(slope_len) + "日(斜率)", obs_desc := "向上: 复苏确认\n向下: 避险主导", confirm_v := "持续5日确认"
        pre_v := s7 > 0 ? "斜率转向下" : "斜率转向上"
        pre_d := s7 > 0 ? "复苏受阻" : "确认经济复苏"
        pre_t := s7 > 0 ? "【防御】持有黄金/美债" : "【进攻】" + a_comm
        pr_col := s7 > 0 ? c_red : c_lime

    else if mode == "8. 衰退熔断 (就业)"
        title := "衰退预警\n[萨姆规则]", cur_s := "权重: " + (w8 > 1.0 ? "x2" : "x1")
        intro := "实时萨姆衰退指标 | 衰退确认信号\n失业率飙升 = 消费萎缩 = 经济衰退\n历史100%准确的衰退指标", cur_v := str.tostring(sahm_val, "0.3") + " | " + fmt_ym(sahm_time)
        cur_d := s8 == -2.0 ? "衰退确认\n立刻清仓" : "就业韧性\n无需恐慌"
        cur_t := get_action_text(s8, false, sahm_val >= 0.3 and sahm_val < 0.5, "", "", "美联储政策", a_gold)
        obs_v := "12月(低点)", obs_desc := "突破0.5: 确认衰退\n低于0.5: 就业尚具韧性", confirm_v := "公布日确认"
        if sahm_val >= 0.5
            pre_v := "跌回 0.5 下方", pre_d := "衰退解除", pre_t := "【进攻】风险解除后逐步加仓", pr_col := c_lime
        else if sahm_val >= 0.3
            pre_v := "跌回 0.3 下方", pre_d := "风险缓解", pre_t := "【进攻】分批加仓核心资产", pr_col := c_lime
        else
            pre_v := "上穿 0.3", pre_d := "警惕就业恶化", pre_t := "【回避】防守(红利/现金)", pr_col := c_red

    // Render Right Table
    table.cell(info, 0, 0, title, text_color = c_white, bgcolor = c_header)
    table.cell(info, 1, 0, intro, text_color = c_white, text_halign = text.align_left), table.merge_cells(info, 1, 0, 3, 0)
    table.cell(info, 0, 1, "观测周期:", text_color = c_beige, text_halign = text.align_left)
    table.cell(info, 1, 1, obs_v, text_color = c_white, text_halign = text.align_left)
    table.cell(info, 2, 1, obs_desc, text_color = c_beige, text_halign = text.align_left)
    table.cell(info, 3, 1, confirm_v, text_color = f_c1, text_halign = text.align_left)
    table.cell(info, 0, 2, cur_s, text_color = f_c1, text_halign = text.align_left)
    table.cell(info, 1, 2, "【当前】", text_color = c_white, bgcolor = c_header), table.merge_cells(info, 1, 2, 2, 2)
    table.cell(info, 3, 2, "【拐点】", text_color = c_white, bgcolor = c_header)
    table.cell(info, 0, 3, "状态:", text_color = c_beige, text_halign = text.align_left)
    table.cell(info, 1, 3, cur_v, text_color = dyn_c, text_halign = text.align_left), table.merge_cells(info, 1, 3, 2, 3)
    table.cell(info, 3, 3, pre_v, text_color = pr_col, text_halign = text.align_left)
    table.cell(info, 0, 4, "含义:", text_color = c_beige, text_halign = text.align_left)
    table.cell(info, 1, 4, cur_d, text_color = c_white, text_halign = text.align_left), table.merge_cells(info, 1, 4, 2, 4)
    table.cell(info, 3, 4, pre_d, text_color = c_white, text_halign = text.align_left)
    table.cell(info, 0, 5, "战术:", text_color = c_beige, text_halign = text.align_left)
    table.cell(info, 1, 5, cur_t, text_color = c_white, text_halign = text.align_left), table.merge_cells(info, 1, 5, 2, 5)
    table.cell(info, 3, 5, pre_t, text_color = c_white, text_halign = text.align_left)

    // 5.3 Left Table Variables

    // Format: Actual Score (Weighted) / Max Possible Score (Weighted)
    s1_txt = fmt_s_act(s1, w1), s1_max = fmt_s_max(w1)
    s2_txt = fmt_s_act(s2, w2), s2_max = fmt_s_max(w2)
    s3_txt = fmt_s_act(s3, w3), s3_max = fmt_s_max(w3)
    s4_txt = fmt_s_act(s4, w4), s4_max = fmt_s_max(w4)
    s5_txt = fmt_s_act(s5, w5), s5_max = fmt_s_max(w5)
    s6_txt = fmt_s_act(s6, w6), s6_max = fmt_s_max(w6)
    s7_txt = fmt_s_act(s7, w7), s7_max = fmt_s_max(w7)
    s8_txt = fmt_s_act(s8, w8), s8_max = fmt_s_max(w8)

    // Render Left Table
    table.cell(rpt, 0, 0, "分析维度", text_color = c_white, bgcolor = c_header)
    table.cell(rpt, 1, 0, "数值", text_color = c_white, bgcolor = c_header)
    table.cell(rpt, 2, 0, "得分", text_color = c_white, bgcolor = c_header)
    table.cell(rpt, 3, 0, "权重", text_color = c_white, bgcolor = c_header)
    table.cell(rpt, 4, 0, "比喻", text_color = c_white, bgcolor = c_header)
    table.cell(rpt, 5, 0, "现状含义", text_color = c_white, bgcolor = c_header)
    table.cell(rpt, 6, 0, "建议操作逻辑", text_color = c_white, bgcolor = c_header)

    // Row 1: EFFR
    table.cell(rpt, 0, 1, "1. 基准利率", text_color = c_white)
    table.cell(rpt, 1, 1, str.tostring(effr_live, "0.00") + "%", text_color = get_action_color(s1*w1, is_rescue, false))
    table.cell(rpt, 2, 1, s1_txt, text_color = c_score_col, tooltip = "基础分: " + str.tostring(s1) + "\n权重: x" + str.tostring(w1))
    table.cell(rpt, 3, 1, s1_max, text_color = c_white)
    table.cell(rpt, 4, 1, "总水坝闸门", text_color = c_white)
    table.cell(rpt, 5, 1, is_rescue ? "央行救火式降息" : (s1 > 0 ? "央行开启降息周期" : "央行加息/高位维持"), text_color = c_white)
    table.cell(rpt, 6, 1, get_action_text(s1*w1, is_rescue, false, a_tech, a_def_bond, "观察确认", a_gold), text_color = get_action_color(s1*w1, is_rescue, false))

    // Row 2: TIPS
    table.cell(rpt, 0, 2, "2. 真实利率", text_color = c_white)
    table.cell(rpt, 1, 2, str.tostring(tips_live, "0.00") + "%", text_color = get_action_color(s2*w2, false, not tips_confirmed))
    table.cell(rpt, 2, 2, s2_txt, text_color = c_score_col, tooltip = "基础分: " + str.tostring(s2) + "\n权重: x" + str.tostring(w2))
    table.cell(rpt, 3, 2, s2_max, text_color = c_white)
    table.cell(rpt, 4, 2, "水厂回购价", text_color = c_white)
    table.cell(rpt, 5, 2, s2 == -1.5 ? "【崩坏】躺赚收益超过干活收益" : (s2 == -1.0 ? "【压制】资金成本过高" : "【利好】资金成本低，利好资产"), text_color = c_white)
    table.cell(rpt, 6, 2, get_action_text(s2*w2, false, not tips_confirmed, "高弹性资产", "减配高估值", "趋势确认中", a_gold), text_color = get_action_color(s2*w2, false, not tips_confirmed))

    // Row 3: Yield Curve
    table.cell(rpt, 0, 3, "3. 利差结构", text_color = c_white)
    table.cell(rpt, 1, 3, str.tostring(yc_val_d, "0.00"), text_color = get_action_color(s3*w3, is_bull_steep, false))
    table.cell(rpt, 2, 3, s3_txt, text_color = c_score_col, tooltip = "基础分: " + str.tostring(s3) + "\n权重: x" + str.tostring(w3))
    table.cell(rpt, 3, 3, s3_max, text_color = c_white)
    table.cell(rpt, 4, 3, "天气预报", text_color = c_white)
    table.cell(rpt, 5, 3, s3 * w3 <= -1.5 ? (is_bull_steep ? "【牛陡】衰退恐慌" : "长短债倒挂衰退") : (s3 > 0 ? "熊陡复苏确认" : "利差收窄/平坦"), text_color = c_white)
    table.cell(rpt, 6, 3, get_action_text(s3*w3, is_bull_steep, false, "顺周期/价值", "防守(短债/现金)", "保留现金", a_gold), text_color = get_action_color(s3*w3, is_bull_steep, false))

    // Row 4: OAS
    table.cell(rpt, 0, 4, "4. 信用风险", text_color = c_white)
    table.cell(rpt, 1, 4, str.tostring(oas_val, "0.2"), text_color = get_action_color(s4*w4, false, s4==0.5))
    table.cell(rpt, 2, 4, s4_txt, text_color = c_score_col, tooltip = "基础分: " + str.tostring(s4) + "\n权重: x" + str.tostring(w4))
    table.cell(rpt, 3, 4, s4_max, text_color = c_white)
    table.cell(rpt, 4, 4, "风险保证金", text_color = c_white)
    table.cell(rpt, 5, 4, s4 > 0 ? "企业融资容易，信用环境好" : (s4 <= -1.5 ? "【熔断】企业借不到钱，信用崩塌" : "银行不敢借钱，企业融资难"), text_color = c_white)
    table.cell(rpt, 6, 4, get_action_text(s4*w4, false, s4==0.5, "超跌修复", "规避高杠杆", "分批布局", a_gold), text_color = get_action_color(s4*w4, false, s4==0.5))

    // Row 5: Liquidity
    table.cell(rpt, 0, 5, "5. 流动性", text_color = c_white)
    table.cell(rpt, 1, 5, str.tostring(liq_val, "0.00"), text_color = get_action_color(s5*w5, false, s5==0.0))
    table.cell(rpt, 2, 5, s5_txt, text_color = c_score_col, tooltip = "基础分: " + str.tostring(s5) + "\n权重: x" + str.tostring(w5))
    table.cell(rpt, 3, 5, s5_max, text_color = c_white)
    table.cell(rpt, 4, 5, "鱼池活水率", text_color = c_white)
    table.cell(rpt, 5, 5, s5 > 0 ? (region == "美国 (US)" ? "全球美元流动性充裕" : "中国企业愿意借钱投资了") : (region == "美国 (US)" ? "全球美元流动性收紧" : "中国企业只存钱不投资"), text_color = c_white)
    table.cell(rpt, 6, 5, get_action_text(s5*w5, false, s5==0.0, a_tech, "减持科技成长", "分批布局", a_gold), text_color = get_action_color(s5*w5, false, s5==0.0))

    // Row 6: Profit
    table.cell(rpt, 0, 6, "6. 利润空间", text_color = c_white)
    table.cell(rpt, 1, 6, str.tostring(prof_val, "0.00"), text_color = get_action_color(s6*w6, false, s6!=1.0 and s6!=-1.0))
    table.cell(rpt, 2, 6, s6_txt, text_color = c_score_col, tooltip = "基础分: " + str.tostring(s6) + "\n权重: x" + str.tostring(w6))
    table.cell(rpt, 3, 6, s6_max, text_color = c_white)
    table.cell(rpt, 4, 6, "养鱼账本", text_color = c_white)
    table.cell(rpt, 5, 6, s6 == 1.0 ? "企业利润变厚，赚钱容易" : (s6 == -1.0 ? "成本太高，企业亏本经营" : (s6 == 0.5 ? "企业利润变薄，赚钱难" : "企业利润波动，方向不明")), text_color = c_white)
    table.cell(rpt, 6, 6, get_action_text(s6*w6, false, s6!=1.0 and s6!=-1.0, "高毛利/定价权龙头", "减仓观望", "分批布局", a_gold), text_color = get_action_color(s6*w6, false, s6!=1.0 and s6!=-1.0))

    // Row 7: Real Economy
    table.cell(rpt, 0, 7, "7. 实体热度", text_color = c_white)
    table.cell(rpt, 1, 7, str.tostring(cg_ratio, "0.00"), text_color = get_action_color(s7*w7, false, s7==0.0))
    table.cell(rpt, 2, 7, s7_txt, text_color = c_score_col, tooltip = "基础分: " + str.tostring(s7) + "\n权重: x" + str.tostring(w7))
    table.cell(rpt, 3, 7, s7_max, text_color = c_white)
    table.cell(rpt, 4, 7, "扩建/避险", text_color = c_white)
    
    string s7_left_txt = ""
    if s7 == 0.0
        if cg_slope > 0 
            s7_left_txt := "复苏信号确认中"
        else 
            s7_left_txt := "铜金背离 (金强于铜)"
    
    string d7_txt = s7 > 0 ? "需求复苏，增长跑赢恐惧" : (s7 < 0 ? "避险跑赢需求，实体寒冬" : s7_left_txt)
    
    table.cell(rpt, 5, 7, d7_txt, text_color = c_white)
    table.cell(rpt, 6, 7, get_action_text(s7*w7, false, s7==0.0, a_comm, "持有黄金/美债", "等待方向确认", a_gold), text_color = get_action_color(s7*w7, false, s7==0.0))

    // Row 8: Sahm
    table.cell(rpt, 0, 8, "8. 衰退熔断", text_color = c_white)
    table.cell(rpt, 1, 8, str.tostring(sahm_val, "0.3"), text_color = sahm_val >= 0.5 ? c_red : (sahm_val >= 0.3 ? c_yell : c_lime))
    table.cell(rpt, 2, 8, s8_txt, text_color = c_score_col, tooltip = "基础分: " + str.tostring(s8) + "\n权重: x" + str.tostring(w8))
    table.cell(rpt, 3, 8, s8_max, text_color = c_white)
    table.cell(rpt, 4, 8, "没人买鱼了", text_color = c_white)
    table.cell(rpt, 5, 8, s8 == -2.0 ? "触发萨姆规则" : "就业尚具韧性", text_color = c_white)
    table.cell(rpt, 6, 8, get_action_text(s8*w8, false, sahm_val >= 0.3 and sahm_val < 0.5, "", "", "美联储政策", a_gold), text_color = sahm_val >= 0.5 ? c_red : (sahm_val >= 0.3 ? c_yell : c_lime))

    // Final Diagnosis Logic
    string final_cmd = ""
    
    // 重新设计：结论单元格的背景色与文字色 (Traffic Light Style)
    color concl_bg = c_gray
    color concl_txt = c_white

    // 熔断条件：必须使用加权后分数判断 (s * w)，因为基础分最大仅为 -1.0
    bool is_bull_steep_final = (yc_val_d > 0) and (math.abs(y10_slope - y2_slope) > 0.02) and (y2_slope < 0) and (y2_slope < y10_slope)
    bool meltdown_trigger = (s8 * w8 <= -1.5) or is_bull_steep_final or (s4 * w4 <= -1.5)

    if meltdown_trigger or total_score < -5.0
        final_cmd := "最高级警报！100% 撤回现金或黄金\n拒绝任何博弈动作"
        concl_bg := c_red
        concl_txt := c_white
    else if total_score > 4.0
        final_cmd := "100% 仓位进攻各赛道核心龙头"
        concl_bg := c_lime
        concl_txt := c_black
    else if total_score >= 1.0
        final_cmd := "70% 进攻各行业核心巨头\n30% 留作红利资产防守"
        concl_bg := c_lime
        concl_txt := c_black
    else if total_score >= -3.0
        final_cmd := "50% 仓位守住高息红利股\n50% 强制保留现金"
        concl_bg := c_yell
        concl_txt := c_black
    else // -5.0 to -3.0
        final_cmd := "仅留 30% 具备回购注销能力的巨头\n70% 持有实物黄金或现金避险"
        concl_bg := c_orange
        concl_txt := c_black

    string diag_txt = "收缩博弈"
    string meltdown_src = ""
    if s8 * w8 <= -1.5
        meltdown_src := "8.萨姆规则"
    else if is_bull_steep_final
        meltdown_src := "3.牛陡"
    else if s4 * w4 <= -1.5
        meltdown_src := "4.信用崩塌"

    if meltdown_trigger
        diag_txt := "【熔断】" + meltdown_src + "确认"
        concl_bg := c_maroon
        concl_txt := c_yell

    // Global Macro Strategy Row (Row 9) - 使用深蓝色背景区分
    color row9_bg = color.new(color.navy, 60)
    
    table.cell(rpt, 0, 9, "中美宏观对冲", bgcolor = row9_bg, text_color = c_beige, tooltip = "判定依据:\n1. 美国: 真实M2同比 + 利率趋势\n2. 中国: M1增速 - M2增速 (信贷脉搏)"), table.merge_cells(rpt, 0, 9, 1, 9)
    table.cell(rpt, 2, 9, strat_title, bgcolor = row9_bg, text_color = strat_col), table.merge_cells(rpt, 2, 9, 3, 9)
    
    // US Cell (Col 3) -> Status
    table.cell(rpt, 4, 9, us_state_txt + "\n" + cn_state_txt, bgcolor = row9_bg, text_color = c_white)

    // CN Cell + Strategy (Col 4-5) -> Action
    table.cell(rpt, 5, 9, strat_desc, bgcolor = row9_bg, text_color = c_white), table.merge_cells(rpt, 5, 9, 6, 9)

    // Final Diagnosis Row (Row 10)
    string total_score_str = total_score == 0 ? "0" : ((total_score > 0 ? "+" : "") + str.tostring(total_score, "#.##"))
    string max_score_str = str.tostring(max_possible, "#.##")
    
    // 最终得分颜色 (Score Color) - 仅文字变色，背景保持深色以确保可读性
    color final_score_c = c_white
    if total_score < -6.0
        final_score_c := c_red
    else if total_score > 6.0
        final_score_c := c_lime
    else if total_score >= -2.0 and total_score <= 2.0
        final_score_c := c_yell
    else if total_score > 2.0
        final_score_c := c_lime
    else // -6.0 to -2.0
        final_score_c := c_orange

    table.cell(rpt, 0, 10, "最终诊断", bgcolor = c_bg, text_color = c_beige, tooltip = "总分 = Σ(基础分 × 动态权重)"), table.merge_cells(rpt, 0, 10, 1, 10)
    table.cell(rpt, 2, 10, total_score_str, bgcolor = c_bg, text_color = final_score_c)
    table.cell(rpt, 3, 10, max_score_str, bgcolor = c_bg, text_color = c_white)
    table.cell(rpt, 4, 10, "结论", bgcolor = c_bg, text_color = c_beige)
    // 结论单元格：恢复为两列布局
    // Col 5: 诊断结论 (Traffic Light Style)
    table.cell(rpt, 5, 10, diag_txt, bgcolor = concl_bg, text_color = concl_txt)
    
    // Col 6: 操作建议 (与结论单元格保持一致配色，提高可读性)
    table.cell(rpt, 6, 10, final_cmd, bgcolor = concl_bg, text_color = concl_txt)
