                d_turn_val := "CPI 回落 (通胀降温)"
                d_tactics_turn := "通胀降温，加仓成长股\n利好科技"
            else if s6 == -1.0 // 通缩
                d_cur_mean := "需求冰封，全线通缩\n(需求崩塌)"
                d_tactics  := "成本降因经济崩\n现金为王"
                d_turn_val := "CPI/PPI 转正 (走出通缩)"
                d_tactics_turn := "走出通缩，买入消费股\n经济复苏"
            else if s6 == -0.5 // 亏损
                d_cur_mean := "成本倒挂，卖多亏多\n(成本倒挂)"
                d_tactics  := "成本高于售价，亏损扩大\n规避中下游制造业"
                d_turn_val := "趋势走阔 (亏损收窄)"
                d_tactics_turn := "困境反转，关注行业龙头\n抢反弹"
            else if s6 == 0.0 // 承压
                d_cur_mean := "利润微薄，存量竞争\n(增长停滞)"
                d_tactics  := "利润空间有限\n多看少做"
                d_turn_val := "趋势走阔 (利润释放)"
                d_tactics_turn := "利润释放，加仓成长股\n业绩驱动"
            else if s6 == 0.5 // 修复
                d_cur_mean := "利润修复，困境反转\n(亏损收窄)"
                d_tactics  := "虽利润变薄，但还在赚钱\n不激进追高"
                d_turn_val := "趋势收窄 (持续变薄)"
                d_tactics_turn := "利润变薄，去弱留强\n切换防御"
            else // 躺赚
                d_cur_mean := "躺着赚钱，利润暴增\n(躺赚时刻)"
                d_tactics  := "售价涨幅大于成本\n积极买入成长股"
                d_turn_val := "趋势收窄 (利润变薄)"
                d_tactics_turn := "暴利终结，切换防御资产\n落袋为安"
                
            d_risk := "趋势变化"
                
        else
            d_title := "利润空间\n[CPI-PPI]", d_def := "公式：CPI(售价) - PPI(成本) \n中国是全球最大制造国，重点看PPI(对应全球需求)"
            d_obs := "12月 (同比)", d_logic := "🔴 过热: CPI>3%\n🔴 通缩: 双负\n🟠 亏损: <0\n🟡 承压: >0 但收窄/平\n🟢 修复: <0 但走阔\n🟢 躺赚: >0 且走阔", d_conf := "状态 2 个月确认\n\n趋势 3 个月确认"
            d_w := w6 > 1.0 ? "x2" : "x1"
            d_cur_stat := t6_s
            d_cur_val := str.tostring(cn_profit_gap, "0.00") + "% | " + fmt_ym(cn_prof_time)
            
            // 6. 利润含义与战术 (CN)
            // 简单填充，具体逻辑参考 README
            d_cur_mean := "制造国利润变动"
            d_tactics := "关注出海与龙头"
            d_risk := "趋势变化"
            d_cur_val := str.tostring(cn_profit_gap, "0.00") + "% | " + fmt_ym(cn_prof_time)
            
            // 6. 利润含义与战术 (中国)
            if s6 == -1.0 // 通缩
                d_cur_mean := "需求冰封，全线通缩\n(需求崩塌)"
                d_tactics  := "全产业链通缩，需求疲软\n远离周期股，关注必选消费"
                d_turn_val := "CPI/PPI 转正 (走出通缩)"
                d_tactics_turn := "走出通缩，买入消费股\n经济复苏"
                d_risk := "走出通缩"
            else if s6 == -0.5 // 亏损
                d_cur_mean := "成本倒挂，卖多亏多\n(成本倒挂)"
                d_tactics  := "出厂价低于成本价\n回避中游制造，关注上游资源"
                d_turn_val := "差值走阔 (亏损收窄)"
                d_tactics_turn := "困境反转，关注行业龙头\n抢反弹"
                d_risk := "亏损收窄"
            else if s6 == 0.0 // 震荡/内卷
                d_cur_mean := "上游涨价，下游卖不动\n(增长停滞)"
                d_tactics  := "利润压缩，内卷严重\n回避同质化竞争，只看龙头"
                d_turn_val := "差值走阔 (利润释放)"
                d_tactics_turn := "利润释放，加仓成长股\n业绩驱动"
                d_risk := "利润释放"
            else if s6 == 0.5 // 修复
                d_cur_mean := "亏损减少，困境反转\n(亏损收窄)"
                d_tactics  := "最惨时刻已过\n博弈困境反转，左侧建仓"
                d_turn_val := "差值收窄 (持续变薄)"
                d_tactics_turn := "利润变薄，去弱留强\n切换防御"
                d_risk := "利润变薄"
            else // 躺赚
                d_cur_mean := "躺着赚钱，利润暴增\n(躺赚时刻)"
                d_tactics  := "上游降价，下游需求旺\n卖上游资源，买消费/中下游制造"
                d_turn_val := "差值收窄 (利润变薄)"
                d_tactics_turn := "暴利终结，切换防御资产\n落袋为安"
                d_risk := "利润变薄"

    else if mode == "7. 实体热度"
        d_title := "实体热度\n[铜金比]", d_def := "铜(工业) / 金(避险)\n比值涨=复苏; 比值跌=衰退。"
        d_obs := "60日 (趋势)", d_logic := "🔴 崩盘: 单日跌>3%\n🟠 衰退: 跌\n🟠 伪复苏: 涨，但铜跌\n🟡 震荡: 平\n🟢 复苏: 双涨", d_conf := "连续5日确认"
        d_w := w7 > 1.0 ? "x2" : "x1"
        d_cur_stat := t7_s
        d_cur_val := str.tostring(cg_ratio, "0.00")
        
        // 7. 实体热度拐点
        if s7 == -1.0 // 崩盘
            d_turn_val := "跌幅收窄 (止血)"
        else if s7 == -0.5 
            if is_cg_fake_recovery // 伪复苏
                d_turn_val := "铜价转涨 (真复苏)"
            else // 衰退
                d_turn_val := "转涨 (企稳)"
        else if s7 == 0.0 // 震荡
            d_turn_val := "转涨 (复苏开始)"
        else // 复苏
            d_turn_val := "转跌 (衰退开始)"
            
        // 7. 实体含义与拐点战术
        if s7 == -1.0 // 崩盘
            d_cur_mean := "信心崩塌，抛售一切"
            d_tactics_turn := "恐慌盘杀出，短线反弹\n轻仓抢反弹"
        else if s7 == -0.5 
            if is_cg_fake_recovery // 伪复苏
                d_cur_mean := "铜价下跌，虚假繁荣"
                d_tactics_turn := "真复苏确认，重仓顺周期\n买入铜/油"
            else // 衰退
                d_cur_mean := "需求萎缩，生意难做"
                d_tactics_turn := "企稳迹象，轻仓试探\n关注大宗商品"
        else if s7 == 0.0 // 震荡
            d_cur_mean := "多空胶着，方向未定"
            d_tactics_turn := "复苏开始，买入工业品\n加仓周期股"
        else // 复苏
            d_cur_mean := "供销两旺，实体繁荣"
            d_tactics_turn := "繁荣顶点，清仓离场\n转入避险"
            
        if s7 == -1.0 // 崩盘
            d_risk := "止血企稳"
        else if s7 == -0.5 
            if is_cg_fake_recovery // 伪复苏
                d_risk := "真复苏"
            else // 衰退
                d_risk := "企稳反弹"
        else if s7 == 0.0 // 震荡
            d_risk := "复苏开启"
        else // 复苏
            d_risk := "衰退开始"
            
        d_tactics := (s7 < 0 ? (is_cg_crash ? "极度恐慌，抛售一切资产\n只有美元和美债最安全" : (is_cg_fake_recovery ? "铜比金强但都在跌，衰退假象\n不要被比值上涨迷惑" : "实体疲软，避险主导\n买黄金/美债，规避强周期")) : (s7 > 0 ? "实体需求旺盛，风险偏好上升\n买周期股、工业大宗商品" : "方向不明，多看少做"))

    else if mode == "8. 萨姆规则"
        string next_nfp_date = calc_next_nfp_status(sahm_time, timenow)
        d_title := "衰退预警\n[萨姆规则]", d_def := "实时萨姆衰退指标 | 衰退确认信号\n公式：失业率3月均值 - 过去12个月低点\n失业率飙升 = 消费萎缩 = 经济衰退\n历史100%准确的衰退指标"
        d_obs := "12月 (低点)", d_logic := "🛑 衰退: ≥0.5%\n🟠 关注: ≥0.3%\n🟠 预警: ICSA>15%\n🟢 健康: <0.3%", d_conf := "非农发布日确认\n\n下次: " + next_nfp_date
        d_w := w8 > 1.0 ? "x2" : "x1"
        d_cur_stat := t8_s
        d_cur_val := str.tostring(sahm_val, "0.00") + "% | " + fmt_ym(sahm_time)
        
        // 8. 萨姆规则含义与战术 (复用左表逻辑)
        if s8 == -1.0 // 熔断
            d_cur_mean := "经济确信衰退，失业失控"
            d_tactics  := "历史准确率100%的衰退信号\n必须离场，买入美债避险"
            d_turn_val := "回落至 0.5% 下 (警报解除)"
            d_tactics_turn := "警报解除，但需确认趋势\n轻仓试探风险资产"
            d_risk := "警报解除"
        else if s8 == -0.5
            if sahm_val >= 0.3 // 衰退关注
                d_cur_mean := "衰退概率激增，不再恋战"
                d_tactics  := "停止进攻，配置美债对冲\n不再加仓风险资产"
                d_turn_val := "回落至 0.3% 下 (风险解除)"
                d_tactics_turn := "虚惊一场，买回筹码\n加仓风险资产"
                d_risk := "风险解除"
            else // ICSA 预警
                d_cur_mean := "就业市场出现裂痕"
                d_tactics  := "初请失业金人数飙升\n减仓观望，等待萨姆确认"
                d_turn_val := "ICSA 回落 (就业改善)"
                d_tactics_turn := "就业数据改善\n恢复正常仓位"
                d_risk := "就业改善"
        else
            d_cur_mean := "就业强劲，工资上涨"
            d_tactics  := "消费有底气，利好美股\n大胆持有成长股"
            d_turn_val := "突破 0.3% (衰退关注)"
            d_tactics_turn := "就业恶化，准备防守\n降低风险敞口"
            d_risk := "衰退关注"

    // Render Right Table
    // Row 0
    table.cell(info, 0, 0, d_title, bgcolor = c_header, text_color = c_white)
    table.cell(info, 1, 0, d_def, bgcolor = c_bg, text_color = c_white, text_halign = text.align_left), table.merge_cells(info, 1, 0, 3, 0)
    // Row 1
    table.cell(info, 0, 1, "观测周期:", bgcolor = c_bg, text_color = c_beige, text_halign = text.align_left)
    table.cell(info, 1, 1, d_obs, bgcolor = c_bg, text_color = c_white, text_halign = text.align_left)
    table.cell(info, 2, 1, d_logic, bgcolor = c_bg, text_color = c_beige, text_halign = text.align_left, text_size = size.small)
    table.cell(info, 3, 1, d_conf, bgcolor = c_bg, text_color = c_score_col, text_halign = text.align_left)
    // Row 2
    table.cell(info, 0, 2, "权重: " + d_w, bgcolor = c_bg, text_color = c_score_col, text_halign = text.align_left)
    table.cell(info, 1, 2, "【当前】", bgcolor = c_header, text_color = c_white), table.merge_cells(info, 1, 2, 2, 2)
    table.cell(info, 3, 2, "【拐点】", bgcolor = c_header, text_color = c_white)
    // Row 3
    table.cell(info, 0, 3, "状态:", bgcolor = c_bg, text_color = c_beige, text_halign = text.align_left)
    
    float cur_score_disp = 0.0
    float turn_score_disp = 0.0 // 新增：拐点得分，用于判断颜色

    if mode == "1. 基准利率"
        cur_score_disp := s1
        if s1 == -1.0 // 救火 -> 恐慌消退 (黄)
            turn_score_disp := 0.0
        else if s1 == -0.5 // 加息 -> 停止加息 (黄)
            turn_score_disp := 0.0
        else if s1 == 0.0 // 震荡 -> 开始降息 (绿)
            turn_score_disp := 1.0
        else // 降息 -> 停止降息 (黄)
            turn_score_disp := 0.0
            
    else if mode == "2. 真实利率"
        cur_score_disp := s2
        if s2 == -1.0 
            if rgdp_val < 0 // 滞胀 -> 复苏 (绿)
                turn_score_disp := 1.0
            else // 虹吸 -> 压力缓解/杀估值 (橙)
                turn_score_disp := -0.5
        else if s2 == -0.5 // 杀估值 -> 震荡 (黄)
            turn_score_disp := 0.0
        else if s2 == 0.0 // 震荡 -> 健康 (绿)
            turn_score_disp := 1.0
        else // 健康/负利率 -> 压力/泡沫退潮 (黄)
            turn_score_disp := 0.0
            
    else if mode == "3. 利差结构"
        cur_score_disp := s3
        if s3 == -1.0 // 牛陡 -> 企稳 (橙)
            turn_score_disp := -0.5
        else if s3 == -0.5 // 倒挂 -> 解除 (黄)
            turn_score_disp := 0.0
        else if s3 == 0.0 // 平坦 -> 复苏 (绿)
            turn_score_disp := 1.0
        else if s3 == 0.5 // 陡峭(常态) -> 倒挂(橙)
            turn_score_disp := -0.5
        else // 熊陡 -> 倒挂 (橙)
            turn_score_disp := -0.5
            
    else if mode == "4. 信用风险"
        cur_score_disp := s4
        if s4 == -1.0 and w4 > 1.0 // 熔断 -> 严重恶化 (红)
            turn_score_disp := -1.0
        else if s4 == -1.0 // 严重恶化 -> 恢复/走阔 (橙)
            turn_score_disp := -0.5
        else if s4 == -0.5 // 走阔 -> 缓解 (黄)
            turn_score_disp := 0.0
        else if s4 == 0.0 // 压力 -> 宽松 (绿)
            turn_score_disp := 1.0
        else // 收敛 -> 收紧 (黄)
            turn_score_disp := 0.0
            
    else if mode == "5. 流动性"
        cur_score_disp := s5
        if s5 == -1.0 // 枯竭 -> 止血 (橙)
            turn_score_disp := -0.5
        else if s5 == -0.5 // 紧缩 -> 放水 (绿)
            turn_score_disp := 1.0
        else if s5 == 0.0 // 存量 -> 注入 (绿)
            turn_score_disp := 1.0
        else // 扩张 -> 抽水 (橙)
            turn_score_disp := -0.5
            
    else if mode == "6. 利润空间"
        cur_score_disp := s6
        if region == "美国"
            if s6 == -1.0 and w6 > 1.0 // 过热 -> 降温 (绿)
                turn_score_disp := 0.5
            else if s6 == -1.0 // 通缩 -> 复苏 (绿)
                turn_score_disp := 0.5
            else if s6 == -0.5 // 亏损 -> 收窄 (黄)
                turn_score_disp := 0.0
            else if s6 == 0.0 // 承压 -> 释放 (绿)
                turn_score_disp := 1.0
            else if s6 == 0.5 // 修复 -> 变薄 (黄)
                turn_score_disp := 0.0
            else // 躺赚 -> 变薄 (浅绿)
                turn_score_disp := 0.5
        else
            if s6 == -1.0 // 通缩 -> 复苏 (绿)
                turn_score_disp := 0.5
            else if s6 == -0.5 // 亏损 -> 收窄 (黄)
                turn_score_disp := 0.0
            else if s6 == 0.0 // 承压 -> 释放 (绿)
                turn_score_disp := 1.0
            else if s6 == 0.5 // 修复 -> 变薄 (黄)
                turn_score_disp := 0.0
            else // 躺赚 -> 变薄 (浅绿)
                turn_score_disp := 0.5
            
    else if mode == "7. 实体热度"
        cur_score_disp := s7
        if s7 == -1.0 // 崩盘 -> 止血 (橙)
            turn_score_disp := -0.5
        else if s7 == -0.5 
            if is_cg_fake_recovery // 伪复苏
                turn_score_disp := 1.0
            else // 衰退
                turn_score_disp := 0.0
        else if s7 == 0.0 // 震荡
            turn_score_disp := 1.0
        else // 复苏
            turn_score_disp := -0.5
            
    else if mode == "8. 萨姆规则"
        cur_score_disp := s8
        if s8 == -1.0 and w8 > 1.0 // 熔断
            turn_score_disp := -1.0
        else if s8 == -0.5 // 关注
            turn_score_disp := 1.0
        else if s8 == 1.0 // 健康
            turn_score_disp := -0.5
        else // ICSA
            turn_score_disp := 1.0

    // 渲染右表
    // Row 3: 状态行 (含拐点)
    table.cell(info, 1, 3, d_cur_val, bgcolor = c_bg, text_color = get_score_col(cur_score_disp)), table.merge_cells(info, 1, 3, 2, 3), table.cell_set_text_halign(info, 1, 3, text.align_left)
    table.cell(info, 3, 3, d_turn_val, bgcolor = c_bg, text_color = get_score_col(turn_score_disp), text_halign = text.align_left)
    
    // Row 4: 含义行
    table.cell(info, 0, 4, "含义:", bgcolor = c_bg, text_color = c_beige, text_halign = text.align_left)
    table.cell(info, 1, 4, d_cur_mean, bgcolor = c_bg, text_color = c_white, text_halign = text.align_left), table.merge_cells(info, 1, 4, 2, 4)
    table.cell(info, 3, 4, d_risk, bgcolor = c_bg, text_color = c_white, text_halign = text.align_left)
    
    // Row 5: 战术行
    table.cell(info, 0, 5, "战术:", bgcolor = c_bg, text_color = c_beige, text_halign = text.align_left)
    string clean_tactics = str.replace(d_tactics, "【战术】\n", "")
    table.cell(info, 1, 5, clean_tactics, bgcolor = c_bg, text_color = c_white, text_halign = text.align_left), table.merge_cells(info, 1, 5, 2, 5)
    string clean_tactics_turn = str.replace(d_tactics_turn, "", "")
    table.cell(info, 3, 5, clean_tactics_turn, bgcolor = c_bg, text_color = c_white, text_halign = text.align_left)
