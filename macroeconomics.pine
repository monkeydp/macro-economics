//@version=6
indicator("[薯仔] 宏观经济", overlay = false, precision = 2, max_labels_count = 500)

// ==========================================
// 1. 设置与参数
// ==========================================
show_report = input.bool(true, "显示决策看板", group="显示设置")
show_markers = input.bool(true, "显示事件标记", group="显示设置")
mode = input.string("1. 基准利率", "当前显示曲线",
     options=["1. 基准利率", "2. 真实利率", "3. 利差结构",
     "4. 信用风险", "5. 流动性", "6. 利润空间",
     "7. 实体热度", "8. 萨姆规则"], group="显示设置")
region = input.string("美国", "监控地区", options=["美国", "中国"], group="显示设置", tooltip="仅影响: 5.流动性 / 6.利润空间")

// --- 全局地区变量 (Global) ---
bool is_us = region == "美国"
bool is_cn = region == "中国"

// --- 1. 基准利率 (EFFR) ---
grp_1 = "1. 基准利率 (EFFR)"
sym_effr        = input.symbol("FRED:EFFR", "数据源 (EFFR)", group=grp_1, display=display.none)
effr_ema_len    = input.int(10, "EMA 周期（月）", minval=1, group=grp_1, display=display.none)
th_effr_noise   = input.float(0.05, "震荡阈值", minval=0.0, step=0.01, group=grp_1, display=display.none)
dur_sahm_panic  = input.int(90, "救火降息有效期 (日)", minval=1, group=grp_1, tooltip="自然日。90日 ≈ 1季度", display=display.none)

// --- 2. 真实利率 (TIPS) ---
grp_2 = "2. 真实利率 (TIPS)"
sym_tips        = input.symbol("FRED:DFII10", "数据源 (TIPS)", group=grp_2, display=display.none)
sym_rgdp        = input.symbol("FRED:A191RL1Q225SBEA", "数据源 (RGDP)", group=grp_2, display=display.none)
dur_tips_conf   = input.int(5, "确认时长 (日)", minval=1, group=grp_2, display=display.none)

// --- 3. 利差结构 (Yield Curve) ---
grp_3 = "3. 利差结构 (10Y-2Y)"
sym_us_10y      = input.symbol("FRED:GS10", "数据源 (10Y)", group=grp_3, display=display.none)
sym_us_2y       = input.symbol("FRED:GS2", "数据源 (2Y)", group=grp_3, display=display.none)
dur_yc_bear_conf= input.int(5, "熊陡确认时长 (日)", minval=1, group=grp_3, display=display.none)
th_yc_noise     = input.float(0.15, "震荡阈值", minval=0.0, step=0.01, group=grp_3, display=display.none)
th_yc_bull_steep= input.float(0.15, "牛陡容差", minval=0.0, step=0.01, group=grp_3, display=display.none)
th_yc_bear_steep= input.float(0.15, "熊陡容差", minval=0.0, step=0.01, group=grp_3, display=display.none)
lock_bull_steep = input.int(10, "牛陡熔断锁定 (日)", minval=1, group=grp_3, display=display.none)


// --- 4. 信用风险 (OAS) ---
grp_4 = "4. 信用风险 (OAS)"
sym_oas         = input.symbol("FRED:BAMLH0A0HYM2", "数据源 (OAS)", group=grp_4, display=display.none)
oas_slope_len   = input.int(60, "斜率观测周期", minval=1, group=grp_4, display=display.none)
dur_oas_conf    = input.int(3, "状态确认时长 (日)", minval=1, group=grp_4, display=display.none)
th_oas_noise    = input.float(0.01, "斜率震荡阈值", minval=0.0, step=0.01, group=grp_4, display=display.none)
lock_credit_crash = input.int(10, "熔断锁定 (日)", minval=1, group=grp_4, display=display.none)

// --- 5. 流动性 (Liquidity) ---
grp_5 = "5. 流动性 (M2 / M1-M2)"
sym_us_m2       = input.symbol("FRED:M2REAL", "数据源 (美国M2)", group=grp_5, display=display.none)
sym_cn_m1       = input.symbol("ECONOMICS:CNM1", "数据源 (中国M1)", group=grp_5, display=display.none)
sym_cn_m2       = input.symbol("ECONOMICS:CNM2", "数据源 (中国M2)", group=grp_5, display=display.none)
liq_yoy_len     = input.int(12, "同比周期 (月)", minval=1, group=grp_5, display=display.none)
dur_liq_conf    = input.int(2, "确认时长 (月)", minval=1, group=grp_5, display=display.none)
th_liq_us_noise = input.float(0.50, "美国震荡阈值 (M2)", minval=0.0, step=0.1, group=grp_5, display=display.none)
th_liq_us_crash = input.float(-2.0, "美国枯竭阈值 (M2)", step=0.1, group=grp_5, display=display.none)
th_liq_cn_noise = input.float(0.50, "中国震荡阈值 (M1-M2)", minval=0.0, step=0.1, group=grp_5, display=display.none)
th_liq_cn_crash = input.float(-5.0, "中国空转阈值 (M1-M2)", step=0.1, group=grp_5, display=display.none)
lock_liq_crash  = input.int(3, "熔断锁定 (月)", minval=1, group=grp_5, display=display.none)

// --- 6. 利润空间 (Profit) ---
grp_6 = "6. 利润空间 (CPI-PPI)"
sym_us_cpi      = input.symbol("FRED:CPIAUCSL", "数据源 (美国CPI)", group=grp_6, display=display.none)
sym_us_ppi      = input.symbol("FRED:PPIACO", "数据源 (美国PPI)", group=grp_6, display=display.none)
sym_cn_cpi      = input.symbol("ECONOMICS:CNCPI", "数据源 (中国CPI)", group=grp_6, display=display.none)
sym_cn_ppi      = input.symbol("ECONOMICS:CNPPI", "数据源 (中国PPI)", group=grp_6, display=display.none)
prof_yoy_len    = input.int(12, "同比周期 (月)", minval=1, group=grp_6, display=display.none)
dur_prof_state  = input.int(2, "状态确认时长 (月)", minval=1, group=grp_6, display=display.none)
dur_prof_trend  = input.int(3, "趋势确认时长 (月)", minval=2, group=grp_6, display=display.none)
th_prof_noise   = input.float(0.20, "震荡阈值", minval=0.0, step=0.1, group=grp_6, display=display.none)


// --- 7. 实体热度 (Copper/Gold) ---
grp_7 = "7. 实体热度 (铜金比)"
sym_copper      = input.symbol("COMEX:HG1!", "数据源 (铜)", group=grp_7, display=display.none)
sym_gold        = input.symbol("COMEX:GC1!", "数据源 (金)", group=grp_7, display=display.none)
cg_slope_len    = input.int(60, "斜率观测周期", minval=1, group=grp_7, display=display.none)
dur_cg_conf     = input.int(5, "趋势确认时长 (日)", minval=1, group=grp_7, display=display.none)
th_cg_noise     = input.float(1.0, "涨跌幅容差 (%)", minval=0.0, step=0.1, group=grp_7, display=display.none) 
lock_cg_crash   = input.int(5, "崩盘锁定 (日)", minval=1, group=grp_7, display=display.none)

// --- 8. 萨姆规则 (Sahm) ---
grp_8 = "8. 萨姆规则 (Sahm)"
sym_sahm        = input.symbol("FRED:SAHMREALTIME", "数据源 (Sahm)", group=grp_8, display=display.none)
sym_icsa        = input.symbol("FRED:ICSA", "数据源 (ICSA)", group=grp_8, display=display.none)

// 颜色定义
c_red          = color.red      // 🔴 红色 (得分 -1.0)
c_orange       = color.orange   // 🟠 橙色 (得分 -0.5)
c_yellow       = color.yellow   // 🟡 黄色 (得分 0.0)
c_lime         = color.lime     // 🟢 亮绿 (得分 +1.0 / +0.5)
c_super_red    = #800000        // 🛑 深红 (熔断背景)
c_super_green  = #006400        // 🟢 深绿 (满仓背景)
c_navy_60      = color.new(#000080, 40) // 海军蓝60 (宏观对冲行背景)
c_beige        = #F5F5DC        // 米色 (标签文字)
c_score_col    = #78D6FB        // 浅蓝 (得分/权重)
c_gray_dark    = #333333        // 深灰
c_bg           = color.new(c_gray_dark, 50) // 背景色
c_header       = color.new(color.gray, 50)  // 表头背景
c_white        = color.white
c_black        = color.black

// ==========================================
// 2. 数据结构与全局状态注册
// ==========================================

// --- 1. 定义配置结构体 ---
type StateConfig
    float score        // 分数 (-1.0 ~ 1.0)
    float weight_mult  // 权重倍数 (1.0 or 2.0)
    string label       // 显示文案 "通胀过热"
    string advice      // 操作建议 "⛔科技 🛡️现金"
    string reason      // 详细理由 "..."
    color col          // 颜色

// --- 2. 初始化全局配置 Map ---
var state_map = map.new<string, StateConfig>()

// 注册状态方法
register_state(string id, float s, float w, string l, string a, string r, color c) =>
    state_map.put(id, StateConfig.new(s, w, l, a, r, c))

// --- 资产常量定义 (Global) ---
string A_RISK       = "风险资产"
string A_SAFE       = "避险资产"
string A_CASH       = "现金"
string A_USD        = "美元"
string A_BOND_S     = "短债"
string A_BOND_L     = "长债"
string A_GOLD       = "黄金"

// --- 权益类资产 ---
string A_TECH       = "科技"
string A_CORE       = "核心"
string A_DIV        = "红利"
string A_STAPLES    = "必选"
string A_SMALL      = "小盘"
string A_JUNK       = "垃圾债"

// --- 周期/大宗类资产 ---
string A_CYCLE      = "周期"
string A_CYCLE_UP   = "上游"
string A_CYCLE_MID  = "中游"

// 初始化所有状态 (只运行一次)
if barstate.isfirst
    // --- 1. 基准利率 (EFFR) ---
    register_state("S1_PANIC", -1.0, 1.0, "救火降息", "【避险】 ⛔" + A_CYCLE + "/" + A_TECH + "/" + A_SMALL + " 🛡️" + A_GOLD + "/" + A_BOND_L, "⛔[" + A_CYCLE + "]: 经济硬着陆确认，需求冰封杀业绩\n⛔[" + A_TECH + "]: 衰退初期风险溢价飙升，杀估值\n🛡️[" + A_GOLD + "/" + A_BOND_L + "]: 避险资金涌入，降息预期利好美债", c_red)
    register_state("S1_HIKE",  -0.5, 1.0, "加息周期", "【防御】 ⛔" + A_BOND_L + "/" + A_TECH + " ⚠️" + A_DIV + " 🛡️" + A_BOND_S + "/" + A_CASH, "⛔[" + A_BOND_L + "]: 利率上行直接杀久期\n⛔[" + A_TECH + "]: 贴现率上升压制DCF估值分母端\n⚠️[" + A_DIV + "]: 高负债行业(如房产/公用)承压\n🛡️[" + A_BOND_S + "/" + A_CASH + "]: 现金为王，无风险收益率极具吸引力", c_orange)
    register_state("S1_NOISE",  0.0, 1.0, "央行态度暧昧", "【观察】 ⚠️" + A_TECH + "/" + A_BOND_L, "⚠️[" + A_TECH + "/" + A_BOND_L + "]: 降息预期反复博弈，资产波动加大", c_yellow)
    register_state("S1_CUT",    1.0, 1.0, "降息周期", "【进攻】 ⚔️" + A_TECH + "/" + A_BOND_L, "⚔️[" + A_TECH + "/" + A_BOND_L + "]: 资金成本下降，分母端逻辑改善，利好久期资产", c_lime)

    // --- 2. 真实利率 (TIPS) ---
    register_state("S2_STAG",   -1.0, 1.0, "滞胀萧条", "【避险】 ⛔" + A_CYCLE + "/" + A_TECH + " 🛡️" + A_GOLD, "⛔[" + A_CYCLE + "]: 经济停滞导致需求端杀业绩\n⛔[" + A_TECH + "]: 高通胀推高名义利率，杀估值\n🛡️[" + A_GOLD + "]: 股债双杀，实物黄金抗通胀且无违约风险", c_red)
    register_state("S2_SIPHON", -1.0, 1.0, "虹吸效应", "【避险】 ⛔" + A_TECH + "/" + A_SMALL + " 🛡️" + A_CASH + "/" + A_BOND_S, "⛔[" + A_TECH + "/" + A_SMALL + "]: 无风险收益过高(TIPS>RGDP)，资金回流债市\n⛔[" + A_TECH + "]: 风险溢价不足以补偿持有成本\n🛡️[" + A_CASH + "/" + A_BOND_S + "]: 回流美元现金，坐享高息", c_red)
    register_state("S2_KILL",   -0.5, 1.0, "杀估值", "【防御】 ⛔" + A_TECH + "/" + A_SMALL + " 🛡️" + A_DIV, "⛔[" + A_TECH + "/" + A_SMALL + "]: 实际资金成本过高，压制高PE板块\n⛔[" + A_TECH + "]: 成长股对资金成本最敏感\n🛡️[" + A_DIV + "]: 低估值、高股息资产具备防御属性", c_orange)
    register_state("S2_RISE",    0.0, 1.0, "资金成本变贵", "【观察】 ⚠️" + A_TECH, "⚠️[" + A_TECH + "]: 资金成本上升未见顶，风险收益比下降", c_yellow)
    register_state("S2_NEG",     1.0, 1.0, "负利率", "【进攻】 ⚔️" + A_GOLD + "/" + A_TECH, "⚔️[" + A_GOLD + "/" + A_TECH + "]: 货币购买力贬值，资产泡沫化，抗贬值资产受益", c_lime)
    register_state("S2_HEALTH",  1.0, 1.0, "健康支撑", "【进攻】 ⚔️" + A_TECH, "⚔️[" + A_TECH + "]: 实际利率低位(TIPS<0.5RGDP)，利好股市估值扩张", c_lime)

    // --- 3. 利差结构 ---
    register_state("S3_CRASH",  -1.0, 2.0, "牛陡", "【清仓】 ⛔" + A_RISK + " 🛡️" + A_BOND_L + "/" + A_GOLD, "⛔[" + A_RISK + "]: 衰退确认，市场恐慌抛售一切风险资产\n🛡️[" + A_BOND_L + "/" + A_GOLD + "]: 资金涌入避险，且降息预期推升债价", c_super_red)
    register_state("S3_INVERT", -0.5, 1.0, "倒挂", "【防御】 ⛔" + A_CYCLE + "/" + A_TECH + "/" + A_SMALL + " 🛡️" + A_CASH + "/" + A_DIV, "⛔[" + A_CYCLE + "]: 长期经济前景堪忧，提前计价衰退\n⛔[" + A_TECH + "/" + A_SMALL + "]: 衰退初期杀估值逻辑主导，风险溢价飙升\n🛡️[" + A_CASH + "/" + A_DIV + "]: 收缩战线，配置防御性资产过冬", c_orange)
    register_state("S3_FLAT",    0.0, 1.0, "长短债博弈激烈", "【观察】 ⚠️" + A_BOND_L, "⚠️[" + A_BOND_L + "]: 通胀反弹风险未除，长端利率波动大", c_yellow)
    register_state("S3_STEEP",   0.5, 1.0, "陡峭", "【进攻】 ⚔️" + A_TECH + "/" + A_CORE, "⚔️[" + A_TECH + "/" + A_CORE + "]: 宏观环境回归常态，利好核心资产稳健增长", c_lime)
    register_state("S3_BEAR",    1.0, 1.0, "熊陡", "【进攻】 ⚔️" + A_CYCLE, "⚔️[" + A_CYCLE + "]: 通胀温和回升，经济强劲，利好上游资源", c_lime)

    // --- 4. 信用风险 ---
    register_state("S4_CRASH",  -1.0, 2.0, "信用崩盘", "【清仓】 ⛔" + A_RISK + " 🛡️" + A_CASH, "⛔[" + A_RISK + "]: 企业融资链条断裂，违约风险剧增 (无差别抛售)\n🛡️[" + A_CASH + "]: 现金最安全，等待危机解除", c_super_red)
    register_state("S4_BAD",    -1.0, 1.0, "严重恶化", "【避险】 ⛔" + A_JUNK + "/" + A_SMALL + " 🛡️" + A_BOND_S, "⛔[" + A_JUNK + "/" + A_SMALL + "]: 市场风险偏好极度下降，抛售高风险债\n⛔[" + A_SMALL + "]: 流动性差的资产难变现，折价出售\n🛡️[" + A_BOND_S + "]: 短债流动性好且无本金风险", c_red)
    register_state("S4_WIDEN",  -0.5, 1.0, "风险走阔", "【防御】 ⛔" + A_JUNK + " ⚠️" + A_SMALL + " 🛡️" + A_DIV, "⛔[" + A_JUNK + "]: 资金避险情绪升温，抛售高风险债\n⚠️[" + A_SMALL + "]: 融资成本上升，小盘股经营压力大\n🛡️[" + A_DIV + "]: 现金流充沛的企业更受青睐", c_orange)
    register_state("S4_BOTTOM",  0.0, 1.0, "底部回升", "【观察】 ⚠️" + A_JUNK, "⚠️[" + A_JUNK + "]: 信用风险触底反弹，利差有走阔压力", c_yellow)
    register_state("S4_LOCAL",   0.0, 1.0, "局部压力", "【观察】 ⚠️" + A_SMALL, "⚠️[" + A_SMALL + "]: 部分企业融资困难，面临出清风险", c_yellow)
    register_state("S4_GOOD",    1.0, 1.0, "风险收敛", "【进攻】 ⚔️" + A_JUNK + "/" + A_SMALL, "⚔️[" + A_JUNK + "/" + A_SMALL + "]: 资金泛滥追逐高收益，高弹性资产受益", c_lime)

    // --- 5. 流动性 ---
    // US
    register_state("S5_US_CRASH", -1.0, 1.0, "流动性枯竭", "【清仓】 ⛔" + A_RISK + " 🛡️" + A_CASH, "⛔[" + A_RISK + "]: 市场流动性枯竭，无差别杀跌\n🛡️[" + A_CASH + "]: 现金为王，保住本金", c_super_red)
    register_state("S5_US_TIGHT", -0.5, 1.0, "收缩", "【防御】 ⛔" + A_CYCLE + "/" + A_SMALL + " 🛡️" + A_DIV, "⛔[" + A_CYCLE + "/" + A_SMALL + "]: 货币供应量收缩，总需求下降杀业绩\n⚠️[" + A_SMALL + "]: 缺乏流动性支持，估值回归\n🛡️[" + A_DIV + "]: 股息提供安全垫，抗跌属性强", c_orange)
    register_state("S5_US_NOISE",  0.0, 1.0, "市场增量不足", "【观察】 ⚠️" + A_SMALL, "⚠️[" + A_SMALL + "]: 股市缺乏活水注入，边缘资产无人问津", c_yellow)
    register_state("S5_US_GOOD",   1.0, 1.0, "扩张", "【进攻】 ⚔️" + A_TECH + "/" + A_CORE, "⚔️[" + A_TECH + "/" + A_CORE + "]: 资金充裕推升资产价格，核心资产率先受益", c_lime)
    // CN
    register_state("S5_CN_CRASH", -1.0, 1.0, "严重空转", "【清仓】 ⛔" + A_RISK + " 🛡️" + A_CASH, "⛔[" + A_RISK + "]: 市场流动性枯竭，无差别杀跌\n🛡️[" + A_CASH + "]: 现金为王，保住本金", c_super_red)
    register_state("S5_CN_TIGHT", -0.5, 1.0, "资金空转", "【防御】 ⛔" + A_CYCLE + "/" + A_SMALL + " 🛡️" + A_DIV, "⛔[" + A_CYCLE + "/" + A_SMALL + "]: 货币供应量收缩，总需求下降杀业绩\n⚠️[" + A_SMALL + "]: 缺乏流动性支持，估值回归\n🛡️[" + A_DIV + "]: 股息提供安全垫，抗跌属性强", c_orange)
    register_state("S5_CN_NOISE",  0.0, 1.0, "存款搬家停滞", "【观察】 ⚠️" + A_SMALL, "⚠️[" + A_SMALL + "]: 股市缺乏活水", c_yellow)
    register_state("S5_CN_GOOD",   1.0, 1.0, "资金活化", "【进攻】 ⚔️" + A_TECH + "/" + A_CORE, "⚔️[" + A_TECH + "/" + A_CORE + "]: 资金充裕推升资产价格，核心资产率先受益", c_lime)

    // --- 6. 利润空间 ---
    register_state("S6_HEAT",     -1.0, 2.0, "通胀过热", "【避险】 ⛔" + A_TECH + "/" + A_BOND_L + " 🛡️" + A_CASH + "/" + A_CYCLE_UP, "⛔[" + A_TECH + "/" + A_BOND_L + "]: 联储加息预期升温，杀高估值\n🛡️[" + A_CASH + "/" + A_CYCLE_UP + "]: 现金抗波动，拥抱抗通胀资产", c_red)
    register_state("S6_DEFL",     -1.0, 1.0, "深度通缩", "【避险】 ⛔" + A_CYCLE + " 🛡️" + A_STAPLES, "⛔[" + A_CYCLE + "]: 需求崩塌，企业利润全线暴跌杀业绩\n🛡️[" + A_STAPLES + "]: 必选消费需求刚性，受经济周期影响小", c_red)
    register_state("S6_BAD",      -0.5, 1.0, "亏损恶化", "【防御】 ⛔" + A_CYCLE_MID + " ⚔️" + A_CYCLE_UP, "⛔[" + A_CYCLE_MID + "]: 成本高企、售价难涨，两头受挤压\n⚔️[" + A_CYCLE_UP + "]: 涨价受益方，利润向.上游集中", c_orange)
    register_state("S6_NOISE_US",  0.0, 1.0, "企业增长停滞", "【观察】 ⚠️" + A_SMALL, "⚠️[" + A_SMALL + "]: 价格战侵蚀企业利润，无护城河企业出清", c_yellow)
    register_state("S6_NOISE_CN",  0.0, 1.0, "行业内卷加剧", "【观察】 ⚠️" + A_SMALL, "⚠️[" + A_SMALL + "]: 价格战侵蚀利润", c_yellow)
    register_state("S6_TURN",      0.5, 1.0, "困境反转", "【进攻】 ⚔️" + A_CYCLE_MID, "⚔️[" + A_CYCLE_MID + "]: 成本下降或需求回暖，盈利触底回升弹性大", c_lime)
    register_state("S6_GOOD",      1.0, 1.0, "利润走阔", "【进攻】 ⚔️" + A_TECH + "/" + A_CORE, "⚔️[" + A_TECH + "/" + A_CORE + "]: 业绩驱动股价上涨，享受戴维斯双击", c_lime)

    // --- 7. 实体热度 ---
    register_state("S7_CRASH",    -1.0, 1.0, "实体崩盘", "【避险】 ⛔" + A_CYCLE + "/" + A_TECH + "/" + A_SMALL + " 🛡️" + A_BOND_L + "/" + A_GOLD, "⛔[" + A_CYCLE + "/" + A_TECH + "/" + A_SMALL + "]: 实体需求信心崩塌，杀业绩主跌浪\n⛔[" + A_CYCLE + "]: 市场一致性交易衰退预期\n🛡️[" + A_BOND_L + "/" + A_GOLD + "]: 避险买盘涌入，对冲经济下行风险", c_red)
    register_state("S7_RECESS",   -0.5, 1.0, "衰退交易", "【防御】 ⛔" + A_CYCLE + " 🛡️" + A_GOLD, "⛔[" + A_CYCLE + "]: 制造业景气度下行，需求不足\n🛡️[" + A_GOLD + "]: 经济下行压力下，黄金具备对冲属性", c_orange)
    register_state("S7_FAKE",     -0.5, 1.0, "伪复苏", "【观察】 ⚠️" + A_CYCLE, "⚠️[" + A_CYCLE + "]: 仅金价上涨掩盖铜价疲软，非真实需求改善", c_orange)
    register_state("S7_NOISE",     0.0, 1.0, "下游需求不明", "【观察】 ⚠️" + A_CYCLE, "⚠️[" + A_CYCLE + "]: 工厂补库意愿疲弱，缺乏上涨动力", c_yellow)
    register_state("S7_GOOD",      1.0, 1.0, "复苏", "【进攻】 ⚔️" + A_CYCLE, "⚔️[" + A_CYCLE + "]: 工业生产供销两旺，量价齐升利好周期股", c_lime)

    // --- 8. 萨姆规则 ---
    register_state("S8_CRASH",    -1.0, 2.0, "衰退确认", "【清仓】 ⛔" + A_RISK + " 🛡️" + A_BOND_L, "⛔[" + A_RISK + "]: 失业率飙升确认衰退，无差别杀跌\n🛡️[" + A_BOND_L + "]: 衰退期唯一确定的避险资产", c_super_red)
    register_state("S8_RISK",     -0.5, 1.0, "风险关注", "【防御】 ⛔" + A_CYCLE + "/" + A_TECH + "/" + A_SMALL + "/" + A_CORE + " 🛡️" + A_BOND_L, "⛔[" + A_CYCLE + "]: 萨姆法则触发临界点，强周期板块最先反应\n⛔[" + A_TECH + "/" + A_SMALL + "/" + A_CORE + "]: 衰退预期升温，风险偏好逆转\n🛡️[" + A_BOND_L + "]: 避险买盘提前布局降息预期", c_orange)
    register_state("S8_WARN",     -0.5, 1.0, "ICSA预警", "【防御】 ⛔" + A_CORE + " 🛡️" + A_CASH, "⛔[" + A_CORE + "]: 失业人数超预期恶化，打击居民收入与消费意愿 (只杀可选消费)\n🛡️[" + A_CASH + "]: 局势不明朗，现金观望", c_orange)
    register_state("S8_GOOD",      1.0, 1.0, "就业健康", "【进攻】 ⚔️" + A_TECH + "/" + A_CORE, "⚔️[" + A_TECH + "/" + A_CORE + "]: 居民收入增长支撑消费，经济强劲利好科技基本面", c_lime)

// ==========================================
// 3. 数据获取与计算
// ==========================================

// --- 辅助函数 ---
fmt_ym(t) => str.tostring(year(t)) + "-" + (month(t) < 10 ? "0" : "") + str.tostring(month(t))
fmt_ymd(t) => str.tostring(year(t)) + "-" + (month(t) < 10 ? "0" : "") + str.tostring(month(t)) + "-" + (dayofmonth(t) < 10 ? "0" : "") + str.tostring(dayofmonth(t))

// Helper to append unique
append_unique(list, item) =>
    if str.contains(list, item)
        list
    else
        list == "" ? item : list + "/" + item

calc_slope_linreg(src, len) => 
    slope = ta.linreg(src, len, 0) - ta.linreg(src, len, 1)
    slope

calc_yoy(src, len) => (src / src[len] - 1) * 100

// 计算下一次非农日期 (基于数据时间推算)
calc_next_nfp_status(data_time, current_time) =>
    // data_time 是当前数据的月份 (例如 1月1日)
    // 1月数据 -> 2月发布
    // 下一次发布(2月数据) -> 3月发布
    // 所以目标月份 = data_time + 2个月
    
    int next_m = month(data_time) + 2
    int next_y = year(data_time)
    
    // 处理跨年 (可能跨1年或2年，比如11月+2=13 -> 1月; 12月+2=14 -> 2月)
    if next_m > 12
        next_m := next_m - 12
        next_y := next_y + 1
        
    // 计算该月1号
    int t_first = timestamp(next_y, next_m, 1, 0, 0, 0)
    int dow = dayofweek(t_first)
    int days_add = 0
    // dow: Sun=1 ... Fri=6 ... Sat=7
    if dow <= 6
        days_add := 6 - dow
    else 
        days_add := 6 // 周六 -> 下周五 (+6天)
    
    int t_next_nfp = t_first + days_add * 86400000
    
    // 判定是否延迟
    // 给一点缓冲时间 (16小时)，覆盖发布时间(08:30 EST)和时区差异
    string status = ""
    if current_time > t_next_nfp + 57600000 
        status := " (待同步)"
        
    fmt_ymd(t_next_nfp) + status

float sec_per_bar = timeframe.in_seconds(timeframe.period)
float sec_per_day = 86400

// --- 录入美联储官方公布的议息会议日期 ---
// 注意：美联储会议通常为期两天，利率决议在第二天的美东时间下午 14:00 公布
var int[] f_year  = array.from(2025, 2025, 2025, 2025, 2025, 2025, 2025, 2025, 2026, 2026, 2026, 2026, 2026, 2026, 2026, 2026)
var int[] f_month = array.from(   1,    3,    5,    6,    7,    9,   10,   12,    1,    3,    4,    6,    7,    9,   10,   12)
var int[] f_day   = array.from(  29,   19,    7,   18,   30,   17,   29,   10,   28,   18,   29,   17,   29,   16,   28,    9)

get_fomc_formatted_times() =>
    string last_str = "暂无数据"
    string next_str = "暂无数据"
    
    // 获取当前K线所在时区的年份
    int current_year = year(time, syminfo.timezone)
    
    for i = 0 to array.size(f_year) - 1
        y = array.get(f_year, i)
        m = array.get(f_month, i)
        d = array.get(f_day, i)
        
        // 生成美东时间(纽约)下午14:00的时间戳
        fomc_time = timestamp("America/New_York", y, m, d, 14, 0, 0)
        
        // 获取该会议在你本地时区的年份
        int fomc_year = year(fomc_time, syminfo.timezone)
        bool is_same_year = (fomc_year == current_year)
        
        // --- 分支逻辑 ---
        if fomc_time <= time
            string fmt_past = is_same_year ? "MM-dd" : "yyyy-MM-dd"
            last_str := str.format_time(fomc_time, fmt_past, syminfo.timezone)
        else
            string fmt_future = is_same_year ? "MM-dd HH:mm" : "yyyy-MM-dd HH:mm"
            next_str := str.format_time(fomc_time, fmt_future, syminfo.timezone)

            break
            
    [last_str, next_str]

[last_fomc_time, next_fomc_time] = get_fomc_formatted_times()

// --- 1. 基准利率 (EFFR) ---

[effr_live, effr_time, effr_chg] = request.security(sym_effr, "D", [close, time, close[1] - close], gaps = barmerge.gaps_off)
effr_ema = request.security(sym_effr, "M", ta.ema(close, effr_ema_len), gaps = barmerge.gaps_off)

float effr_drop_scan = 0.0
if timeframe.isdaily
    effr_drop_scan := effr_chg
else if timeframe.isweekly or timeframe.ismonthly
    float[] drops = request.security_lower_tf(sym_effr, "D", close[1] - close)
    if array.size(drops) > 0
        effr_drop_scan := array.max(drops)

effr_drop = effr_drop_scan

// --- 2. 真实利率 (TIPS) ---
[tips_live, tips_time] = request.security(sym_tips, "D", [close, time], gaps = barmerge.gaps_off)
[rgdp_val, rgdp_time]  = request.security(sym_rgdp, "D", [close, time], gaps = barmerge.gaps_off)

// --- 3. 利差结构 (10Y-2Y) ---
[y10, y10_chg_d] = request.security(sym_us_10y, "D", [close, close - close[1]], gaps = barmerge.gaps_off)
[y2, y2_chg_d]   = request.security(sym_us_2y, "D", [close, close - close[1]], gaps = barmerge.gaps_off)
yc_val = y10 - y2
y10_chg = y10_chg_d
y2_chg  = y2_chg_d

// 牛陡判定 (日线逻辑)
bool is_bull_steep_daily = y10_chg < 0 and y2_chg < -th_yc_bull_steep and y2_chg < y10_chg

// 月线/周线图适配：使用 request.security_lower_tf 捕捉月内/周内牛陡
// 仅在月线/周线图启用，节省性能
bool is_bull_steep_htf = false
bool is_high_tf_yc = timeframe.isweekly or timeframe.ismonthly
if is_high_tf_yc
    [y10_diffs_m, y10_times_m] = request.security_lower_tf(sym_us_10y, "D", [close - close[1], time])
    [y2_diffs_m, y2_times_m]  = request.security_lower_tf(sym_us_2y, "D", [close - close[1], time])
    
    if array.size(y10_diffs_m) > 0 and array.size(y2_diffs_m) > 0
        int len10 = array.size(y10_diffs_m)
        int len2 = array.size(y2_diffs_m)
        
        // 双指针遍历，确保时间戳对齐
        int i10 = 0
        int i2 = 0
        
        while i10 < len10 and i2 < len2
            int t10 = array.get(y10_times_m, i10)
            int t2 = array.get(y2_times_m, i2)
            
            if t10 == t2
                float d10 = array.get(y10_diffs_m, i10)
                float d2 = array.get(y2_diffs_m, i2)
                
                // 只有当两者时间完全一致时才比较
                if d10 < 0 and d2 < -th_yc_bull_steep and d2 < d10
                    is_bull_steep_htf := true
                    break
                
                i10 := i10 + 1
                i2 := i2 + 1
            else if t10 < t2
                // t10 更早，说明 t2 这一天 10Y 缺数据，跳过 t10
                i10 := i10 + 1
            else
                // t2 更早，说明 t10 这一天 2Y 缺数据，跳过 t2
                i2 := i2 + 1

is_bull_steep_trigger = is_high_tf_yc ? is_bull_steep_htf : is_bull_steep_daily

int bars_lock_bull = math.max(1, math.ceil(lock_bull_steep * sec_per_day / sec_per_bar))
var int bull_steep_cnt = 0
if is_bull_steep_trigger
    bull_steep_cnt := bars_lock_bull
else if bull_steep_cnt > 0
    bull_steep_cnt := bull_steep_cnt - 1
is_bull_steep = bull_steep_cnt > 0

// --- 4. 信用风险 (OAS) ---

// 1. 获取日线实时数据
[oas_val, oas_slope, oas_chg_5d_pct, oas_time] = request.security(sym_oas, "D", [close, calc_slope_linreg(close, oas_slope_len), (close / close[5] - 1) * 100, time], gaps = barmerge.gaps_off)


// 2. 信用崩盘扫描
bool oas_crash_scan = false
if timeframe.isdaily
    // 日线图：直接看当天是否熔断
    oas_crash_scan := oas_val > 10.0 or (oas_val > 6.0 and oas_chg_5d_pct > 20.0)
else if timeframe.isweekly or timeframe.ismonthly
    float[] crash_flags = request.security_lower_tf(sym_oas, "D", (close > 10.0 or (close > 6.0 and (close / close[5] - 1) * 100 > 20.0)) ? 1.0 : 0.0)
    if array.size(crash_flags) > 0
        // 只要有一天是 1.0，max 就是 1.0
        if array.max(crash_flags) > 0.5
            oas_crash_scan := true

// 统一使用扫描结果
is_oas_crash_trigger = oas_crash_scan

int bars_lock_credit = math.max(1, math.ceil(lock_credit_crash * sec_per_day / sec_per_bar))
var int oas_crash_cnt = 0
if is_oas_crash_trigger
    oas_crash_cnt := bars_lock_credit
else if oas_crash_cnt > 0
    oas_crash_cnt := oas_crash_cnt - 1
is_oas_crash = oas_crash_cnt > 0

// --- 5. 流动性 (M2 / M1-M2) ---
[us_m2_real, us_m2_yoy, us_m2_time] = request.security(sym_us_m2, "M", [close, calc_yoy(close, liq_yoy_len), time], gaps = barmerge.gaps_off)

[cn_m1, cn_m1_yoy, cn_time] = request.security(sym_cn_m1, "M", [close, calc_yoy(close, liq_yoy_len), time], gaps = barmerge.gaps_off)
[cn_m2, cn_m2_yoy] = request.security(sym_cn_m2, "M", [close, calc_yoy(close, liq_yoy_len)], gaps = barmerge.gaps_off)
cn_gap = cn_m1_yoy - cn_m2_yoy

// --- 6. 利润空间 (CPI-PPI) ---
[us_cpi, us_cpi_yoy, us_prof_time] = request.security(sym_us_cpi, "M", [close, calc_yoy(close, prof_yoy_len), time], gaps = barmerge.gaps_off)
[us_ppi, us_ppi_yoy] = request.security(sym_us_ppi, "M", [close, calc_yoy(close, prof_yoy_len)], gaps = barmerge.gaps_off)
us_profit_gap = us_cpi_yoy - us_ppi_yoy

[cn_cpi_yoy, cn_prof_time] = request.security(sym_cn_cpi, "M", [calc_yoy(close, prof_yoy_len), time], gaps = barmerge.gaps_off)
cn_ppi_yoy = request.security(sym_cn_ppi, "M", calc_yoy(close, prof_yoy_len), gaps = barmerge.gaps_off)
cn_profit_gap = cn_cpi_yoy - cn_ppi_yoy

// --- 7. 实体热度 (铜金比) ---

// 1. 获取日线实时数据及趋势数据
[cop_d, cop_d_prev, cop_d_trend] = request.security(sym_copper, "D", [close, close[1], close[cg_slope_len]], gaps = barmerge.gaps_off)
[gld_d, gld_d_prev, gld_d_trend] = request.security(sym_gold,   "D", [close, close[1], close[cg_slope_len]], gaps = barmerge.gaps_off)

// 2. 本地计算比值
cg_ratio_d       = cop_d / gld_d * 1000
cg_ratio_prev_d  = cop_d_prev / gld_d_prev * 1000
cg_ratio_trend_d = cop_d_trend / gld_d_trend * 1000

// 计算单日涨跌幅 (仅用于崩盘扫描)
cg_chg_pct_d = (cg_ratio_d / cg_ratio_prev_d - 1) * 100

// 3. 崩盘扫描
bool cg_crash_scan = false
if timeframe.isdaily
    // 日线图：直接看当天跌幅
    cg_crash_scan := cg_chg_pct_d < -3.0
else if timeframe.isweekly or timeframe.ismonthly
    // 周/月线图：全量扫描日线跌幅
    float[] cop_ratios = request.security_lower_tf(sym_copper, "D", close / close[1])
    float[] gld_ratios = request.security_lower_tf(sym_gold, "D", close / close[1])
    
    if array.size(cop_ratios) > 0 and array.size(gld_ratios) > 0
        int len_r = math.min(array.size(cop_ratios), array.size(gld_ratios))
        for i = 0 to len_r - 1
            float c_r = array.get(cop_ratios, i)
            float g_r = array.get(gld_ratios, i)
            // 计算比值的日涨跌幅
            float r_chg = (c_r / g_r - 1) * 100
            if r_chg < -3.0
                cg_crash_scan := true
                break

// 统一使用扫描结果
is_cg_crash_trigger = cg_crash_scan

int bars_lock_cg = math.max(1, math.ceil(lock_cg_crash * sec_per_day / sec_per_bar))
var int cg_crash_cnt = 0
if is_cg_crash_trigger
    cg_crash_cnt := bars_lock_cg
else if cg_crash_cnt > 0
    cg_crash_cnt := cg_crash_cnt - 1
is_cg_crash = cg_crash_cnt > 0

// 趋势判定
float cg_trend_chg_pct = (cg_ratio_d / cg_ratio_trend_d - 1) * 100
float cop_trend_chg_pct = (cop_d / cop_d_trend - 1) * 100

bool is_trend_up   = cg_trend_chg_pct > th_cg_noise
bool is_trend_down = cg_trend_chg_pct < -th_cg_noise
bool is_cop_trend_up   = cop_trend_chg_pct > 0
bool is_cop_trend_down = cop_trend_chg_pct < 0

// 伪复苏: 铜金比趋势涨，但铜价趋势跌
bool is_cg_fake_recovery = is_trend_up and is_cop_trend_down

float cg_ratio = cg_ratio_d
float cg_ratio_prev = cg_ratio_prev_d
float copper_prev = cop_d_prev
float copper = cop_d

// --- 8. 萨姆规则 (就业) ---
// 确认时长: 非农公布日
[sahm_val, sahm_time] = request.security(sym_sahm, "M", [close, time], gaps = barmerge.gaps_off)
// ICSA 预警: 初请失业金同比 > 15%
[icsa, icsa_yoy, icsa_yoy_prev] = request.security(sym_icsa, "W", [close, (close / close[52] - 1) * 100, (close[1] / close[53] - 1) * 100], gaps = barmerge.gaps_off)
// 连续 2 周确认
icsa_warn = icsa_yoy > 15.0 and icsa_yoy_prev > 15.0

// ==========================================
// 3. 评分逻辑
// ==========================================

// --- 权重系统 ---
// 基础权重
float w1=1.0, float w2=1.0, float w3=1.0, float w4=1.0
float w5=1.0, float w6=1.0, float w7=1.0, float w8=1.0

// 时代判定
bool is_inflation_era = us_cpi_yoy > 3.0
bool is_panic_era     = sahm_val >= 0.3 or is_bull_steep

// 动态权重调整
// 1. 通胀时代: 无论正负，权重全部翻倍 (实物资产逻辑主导)
if is_inflation_era
    w6 := 2.0 // 利润
    w7 := 2.0 // 实体

// 2. 恐慌时代: 仅当指标为负时，权重翻倍 (只放大风险，不放大机会)

// --- 逻辑层变量定义 ---

// 辅助函数
is_sustained(cond, len) => math.sum(cond ? 1 : 0, len) == len

bars_tips_conf = math.max(1, math.ceil(dur_tips_conf * sec_per_day / sec_per_bar))
bars_yc_conf   = math.max(1, math.ceil(dur_yc_bear_conf * sec_per_day / sec_per_bar))
bars_oas_conf  = math.max(1, math.ceil(dur_oas_conf * sec_per_day / sec_per_bar))
bars_prof_state= math.max(1, math.ceil(dur_prof_state * 30 * sec_per_day / sec_per_bar)) // Month -> Days approx
bars_cg_conf   = math.max(1, math.ceil(dur_cg_conf * sec_per_day / sec_per_bar))

// 1. 基准利率
int dur_panic_bars = math.max(1, math.ceil(dur_sahm_panic * sec_per_day / sec_per_bar))
bool in_panic_window = ta.barssince(effr_drop >= 0.5) < dur_panic_bars
bool is_hike_cycle   = effr_live > effr_ema + th_effr_noise
bool is_cut_cycle    = effr_live < effr_ema - th_effr_noise

// 5. 流动性
bool is_liq_crash    = us_m2_yoy < th_liq_us_crash
bool is_liq_tight    = us_m2_yoy < 0
bool is_liq_expand   = us_m2_yoy > 0
bool is_cn_crash     = cn_gap < th_liq_cn_crash
bool is_cn_tight     = cn_gap < 0
bool is_cn_expand    = cn_gap > 0

// 6. 利润空间
bool is_us_heat_state      = us_cpi_yoy > 3.0
bool is_us_deflation_state = us_cpi_yoy < 0 and us_ppi_yoy < 0
bool is_us_widening_state  = us_profit_gap > us_profit_gap[1]
bool is_cn_heat_state      = cn_cpi_yoy > 3.0
bool is_cn_deflation_state = cn_cpi_yoy < 0 and cn_ppi_yoy < 0
bool is_cn_widening_state  = cn_profit_gap > cn_profit_gap[1]

// 8. 萨姆规则
bool is_icsa_warn    = icsa_warn

// --- 评分计算 ---
float s1=0.0, float s2=0.0, float s3=0.0, float s4=0.0
float s5=0.0, float s6=0.0, float s7=0.0, float s8=0.0

// 全局文案变量
string t1_s = ""
string t1_a = ""
string t2_s = ""
string t2_a = ""
string t3_s = ""
string t3_a = ""
string t4_s = ""
string t4_a = ""
string t5_s = ""
string t5_a = ""
string t6_s = ""
string t6_a = ""
string t7_s = ""
string t7_a = ""
string t8_s = ""
string t8_a = ""

string t1_reason = ""
string t2_reason = ""
string t3_reason = ""
string t4_reason = ""
string t5_reason = ""
string t6_reason = ""
string t7_reason = ""
string t8_reason = ""

// --- 业务逻辑层 (只返回 ID) ---
// 定义状态ID变量
string id1 = na
string id2 = na
string id3 = na
string id4 = na
string id5 = na
string id6 = na
string id7 = na
string id8 = na

// 1. 基准利率
if in_panic_window
    id1 := "S1_PANIC"
else if is_hike_cycle
    id1 := "S1_HIKE"
else if is_cut_cycle
    id1 := "S1_CUT"
else
    id1 := "S1_NOISE"

// 2. 真实利率
bool is_sustained_stag   = is_sustained(rgdp_val < 0, bars_tips_conf)
bool is_sustained_siphon = is_sustained(tips_live >= rgdp_val, bars_tips_conf)
bool is_sustained_kill   = is_sustained(tips_live >= 0.75 * rgdp_val, bars_tips_conf)
bool is_sustained_rise   = is_sustained(tips_live >= 0.5 * rgdp_val, bars_tips_conf)
bool is_sustained_neg    = is_sustained(tips_live < 0, bars_tips_conf)

if is_sustained_stag
    id2 := "S2_STAG"
else if is_sustained_siphon
    id2 := "S2_SIPHON"
else if is_sustained_kill
    id2 := "S2_KILL"
else if is_sustained_rise
    id2 := "S2_RISE"
else if is_sustained_neg
    id2 := "S2_NEG"
else
    id2 := "S2_HEALTH"

// 3. 利差结构
// 熊陡判定复用原逻辑
bool is_bear_steep_raw = y10_chg > th_yc_bear_steep and y2_chg > 0 and y10_chg > y2_chg
bool is_bear_steep = is_sustained(is_bear_steep_raw, bars_yc_conf)

if is_bull_steep
    id3 := "S3_CRASH"
else if yc_val < -th_yc_noise
    id3 := "S3_INVERT"
else if math.abs(yc_val) <= th_yc_noise
    id3 := "S3_FLAT"
else
    id3 := is_bear_steep ? "S3_BEAR" : "S3_STEEP"

// 4. 信用风险
bool is_sustained_oas_widen = is_sustained(oas_slope > th_oas_noise, bars_oas_conf)

if is_oas_crash
    id4 := "S4_CRASH"
else if oas_val > 6.0
    id4 := "S4_BAD"
else if oas_val >= 3.5
    // 风险走阔: 趋势向上
    if is_sustained_oas_widen
        id4 := "S4_WIDEN"
    else
        id4 := "S4_LOCAL"
else // < 3.5
    // 底部回升: 趋势向上
    if is_sustained_oas_widen
        id4 := "S4_BOTTOM"
    else
        id4 := "S4_GOOD"

// 5. 流动性
if is_us
    if is_liq_crash
        id5 := "S5_US_CRASH"
    else if is_liq_tight
        id5 := "S5_US_TIGHT"
    else if is_liq_expand
        id5 := "S5_US_GOOD"
    else
        id5 := "S5_US_NOISE"
else // CN
    if is_cn_crash
        id5 := "S5_CN_CRASH"
    else if is_cn_tight
        id5 := "S5_CN_TIGHT"
    else if is_cn_expand
        id5 := "S5_CN_GOOD"
    else
        id5 := "S5_CN_NOISE"

// 6. 利润空间 (CPI-PPI)
bool is_sustained_prof_neg = is_sustained(is_us ? us_profit_gap < 0 : cn_profit_gap < 0, bars_prof_state)
bool is_sustained_prof_pos = is_sustained(is_us ? us_profit_gap > 0 : cn_profit_gap > 0, bars_prof_state)

if is_us
    if is_us_heat_state
        id6 := "S6_HEAT"
    else if is_us_deflation_state
        id6 := "S6_DEFL"
    else if is_sustained_prof_neg
        if is_us_widening_state
            id6 := "S6_TURN"
        else
            id6 := "S6_BAD"
    else if is_sustained_prof_pos
        if is_us_widening_state
            id6 := "S6_GOOD"
        else
            id6 := "S6_NOISE_US"
    else
        id6 := "S6_NOISE_US" // 震荡归为承压
else // CN
    if is_cn_heat_state
        id6 := "S6_HEAT" // 理论上CN很少过热，但保留
    else if is_cn_deflation_state
        id6 := "S6_DEFL"
    else if is_sustained_prof_neg
        if is_cn_widening_state
            id6 := "S6_TURN"
        else
            id6 := "S6_BAD"
    else if is_sustained_prof_pos
        if is_cn_widening_state
            id6 := "S6_GOOD"
        else
            id6 := "S6_NOISE_CN"
    else
        id6 := "S6_NOISE_CN"

// 7. 实体热度
bool is_sustained_fake = is_sustained(is_cg_fake_recovery, bars_cg_conf)
bool is_sustained_down = is_sustained(is_trend_down, bars_cg_conf)
bool is_sustained_up   = is_sustained(is_trend_up and is_cop_trend_up, bars_cg_conf)

if is_cg_crash
    id7 := "S7_CRASH"
else if is_sustained_fake
    id7 := "S7_FAKE"
else if is_sustained_down
    id7 := "S7_RECESS"
else if is_sustained_up
    id7 := "S7_GOOD"
else
    id7 := "S7_NOISE"

    // 8. 萨姆规则
if sahm_val >= 0.5
    id8 := "S8_CRASH"
else if sahm_val >= 0.3
    id8 := "S8_RISK"
else if is_icsa_warn
    id8 := "S8_WARN"
else
    id8 := "S8_GOOD"

// --- 从 Map 获取配置 (含空值保护) ---
StateConfig cfg1 = state_map.get(id1)
StateConfig cfg2 = state_map.get(id2)
StateConfig cfg3 = state_map.get(id3)
StateConfig cfg4 = state_map.get(id4)
StateConfig cfg5 = state_map.get(id5)
StateConfig cfg6 = state_map.get(id6)
StateConfig cfg7 = state_map.get(id7)
StateConfig cfg8 = state_map.get(id8)

// 赋值给计算变量 (兼容旧逻辑)
if not na(cfg1)
    s1 := cfg1.score
    w1 := cfg1.weight_mult
    t1_s := cfg1.label
    t1_a := cfg1.advice
    t1_reason := cfg1.reason

if not na(cfg2)
    s2 := cfg2.score
    w2 := cfg2.weight_mult
    t2_s := cfg2.label
    t2_a := cfg2.advice
    t2_reason := cfg2.reason

if not na(cfg3)
    s3 := cfg3.score
    w3 := cfg3.weight_mult
    t3_s := cfg3.label
    t3_a := cfg3.advice
    t3_reason := cfg3.reason

if not na(cfg4)
    s4 := cfg4.score
    w4 := cfg4.weight_mult
    t4_s := cfg4.label
    t4_a := cfg4.advice
    t4_reason := cfg4.reason

if not na(cfg5)
    s5 := cfg5.score
    w5 := cfg5.weight_mult
    t5_s := cfg5.label
    t5_a := cfg5.advice
    t5_reason := cfg5.reason

if not na(cfg6)
    s6 := cfg6.score
    w6 := cfg6.weight_mult
    t6_s := cfg6.label
    t6_a := cfg6.advice
    t6_reason := cfg6.reason

if not na(cfg7)
    s7 := cfg7.score
    w7 := cfg7.weight_mult
    t7_s := cfg7.label
    t7_a := cfg7.advice
    t7_reason := cfg7.reason

if not na(cfg8)
    s8 := cfg8.score
    w8 := cfg8.weight_mult
    t8_s := cfg8.label
    t8_a := cfg8.advice
    t8_reason := cfg8.reason

// 计算中美流动性得分 (供策略使用)
float score_us_liq = is_liq_crash ? -1.0 : (is_liq_tight ? -0.5 : (is_liq_expand ? 1.0 : 0.0))
float score_cn_liq = is_cn_crash ? -1.0 : (is_cn_tight ? -0.5 : (is_cn_expand ? 1.0 : 0.0))

// 恐慌时代动态权重
if is_panic_era
    if s3 < 0 and w3 < 2.0 
        w3 := 2.0
    if s4 < 0 and w4 < 2.0
        w4 := 2.0
    if s8 < 0 and w8 < 2.0
        w8 := 2.0

// --- 总分计算 ---
total_score = s1*w1 + s2*w2 + s3*w3 + s4*w4 + s5*w5 + s6*w6 + s7*w7 + s8*w8
max_score   = w1 + w2 + w3 + w4 + w5 + w6 + w7 + w8

// 熔断一票否决
bool is_meltdown = (s3 == -1.0 and w3 > 1.0) or (s4 == -1.0 and w4 > 1.0) or (s8 == -1.0 and w8 > 1.0) or (s5 == -1.0)

// ==========================================
// 4. UI 渲染
// ==========================================

// --- 动态曲线选择 ---
float plot_val = na
color dyn_c = c_gray_dark

// 根据不同模式选择数据源
if mode == "1. 基准利率"
    plot_val := effr_live
    dyn_c := s1 == 1.0 ? c_lime : (s1 == -0.5 ? c_orange : (s1 == -1.0 ? c_red : c_yellow))
else if mode == "2. 真实利率"
    plot_val := tips_live
    dyn_c := s2 == 1.0 ? c_lime : (s2 == -0.5 ? c_orange : (s2 == -1.0 ? c_red : c_yellow))
else if mode == "3. 利差结构"
    plot_val := yc_val
    dyn_c := s3 >= 0.5 ? c_lime : (s3 == -0.5 ? c_orange : (s3 == -1.0 ? c_super_red : c_yellow))
else if mode == "4. 信用风险"
    plot_val := oas_val
    dyn_c := s4 == 1.0 ? c_lime : (s4 == -0.5 ? c_orange : (s4 == -1.0 ? c_red : c_yellow))
else if mode == "5. 流动性"
    plot_val := is_us ? us_m2_yoy : cn_gap
    dyn_c := s5 == 1.0 ? c_lime : (s5 == -0.5 ? c_orange : (s5 == -1.0 ? c_super_red : c_yellow))
else if mode == "6. 利润空间"
    plot_val := is_us ? us_profit_gap : cn_profit_gap
    dyn_c := s6 >= 0.5 ? c_lime : (s6 == -0.5 ? c_orange : (s6 <= -1.0 ? c_red : c_yellow))
else if mode == "7. 实体热度"
    plot_val := cg_ratio
    dyn_c := s7 == 1.0 ? c_lime : (s7 == -0.5 ? c_orange : (s7 == -1.0 ? c_red : c_yellow))
else if mode == "8. 萨姆规则"
    plot_val := sahm_val
    dyn_c := s8 == 1.0 ? c_lime : (s8 == -0.5 ? c_orange : (s8 == -1.0 ? c_super_red : c_yellow))

// --- 状态文本生成器 ---

// 实体热度崩盘背景高亮
bool is_cg_crash_bg = mode == "7. 实体热度" and (s7 == -1.0 or ((timeframe.isweekly or timeframe.ismonthly) and cg_crash_scan))
bgcolor(is_cg_crash_bg ? color.new(c_red, 80) : na, title="Copper Crash BG")

// 萨姆规则熔断背景高亮
bgcolor(mode == "8. 萨姆规则" and s8 == -1.0 ? color.new(c_super_red, 80) : na, title="Sahm Meltdown BG")

// 基准利率救火背景高亮 (全局作用域)
bool is_effr_panic_bg = mode == "1. 基准利率" and (s1 == -1.0 or ((timeframe.isweekly or timeframe.ismonthly) and effr_drop >= 0.5))
bgcolor(is_effr_panic_bg ? color.new(c_red, 80) : na, title="EFFR Panic BG")

// 真实利率背景高亮
// 滞胀: 深红 (痛苦指数高)
bool is_stag_bg = mode == "2. 真实利率" and s2 == -1.0 and rgdp_val < 0
bgcolor(is_stag_bg ? color.new(c_super_red, 80) : na, title="Stagflation BG")

// 虹吸: 红色 (资金抽离)
bool is_siphon_bg = mode == "2. 真实利率" and s2 == -1.0 and tips_live >= rgdp_val
bgcolor(is_siphon_bg ? color.new(c_red, 80) : na, title="Siphon BG")

// --- 综合绘图 ---
// 1. 基准利率: 阶梯图 + EMA
plot(mode == "1. 基准利率" ? plot_val : na, "EFFR", color = dyn_c, linewidth = 2, style = plot.style_stepline)
plot(mode == "1. 基准利率" ? effr_ema : na, "EFFR EMA", color = color.blue, linewidth = 1)

// 救火标记
bool is_fire_cut = mode == "1. 基准利率" and s1 == -1.0
if is_fire_cut and not is_fire_cut[1] and show_markers
    label.new(bar_index, plot_val + 0.5, "🚒\n救火", xloc = xloc.bar_index, yloc = yloc.price, color = color(na), style = label.style_none, textcolor = c_black, size = size.small, textalign = text.align_center)

// 2. 真实利率: TIPS + RGDP + 阈值
float rgdp_plot = math.max(math.min(rgdp_val, 10.0), -10.0)

plot(mode == "2. 真实利率" ? plot_val : na, "TIPS", color = dyn_c, linewidth = 2)
plot(mode == "2. 真实利率" ? rgdp_plot : na, "RGDP", color = color.gray, linewidth = 1, style = plot.style_stepline)
plot(mode == "2. 真实利率" ? 0.5 * rgdp_plot : na, "0.5 RGDP", color = color.new(c_orange, 50), style = plot.style_circles)

// 真实利率风险标记 (状态切换时绘制一次性标签)

// 滞胀: RGDP < 0 (显示在曲线上方，避免与虹吸重叠)
bool is_stag = mode == "2. 真实利率" and s2 == -1.0 and rgdp_val < 0
if is_stag and not is_stag[1] and show_markers
    label.new(bar_index, plot_val + 0.5, "🔥滞胀", xloc = xloc.bar_index, yloc = yloc.price, color = color(na), style = label.style_none, textcolor = c_black, size = size.small, textalign = text.align_center)

// 虹吸: TIPS >= RGDP (显示在曲线下方)
bool is_siphon = mode == "2. 真实利率" and s2 == -1.0 and tips_live >= rgdp_val
if is_siphon and not is_siphon[1] and show_markers
    label.new(bar_index, plot_val - 0.5, "🌪️虹吸", xloc = xloc.bar_index, yloc = yloc.price, color = color(na), style = label.style_none, textcolor = c_black, size = size.small, textalign = text.align_center)

// 添加 RGDP 极端值标签 (显示真实值)
int cur_q = math.ceil(month(time) / 3.0)
int prev_q_idx = math.ceil(month(time[1]) / 3.0)
bool is_new_quarter = (cur_q != prev_q_idx) or (year(time) != year(time[1]))

// 变量记录上一次绘制的标签数值，用于去重
var float last_lbl_val = 0.0
int t_rgdp = rgdp_time + 5 * 86400000
int y_rgdp = year(t_rgdp)
int m_rgdp = month(t_rgdp)
int q_rgdp = math.ceil(m_rgdp / 3.0)
string rgdp_date_str = " (" + str.tostring(y_rgdp) + " Q" + str.tostring(q_rgdp) + ")"

// 优化：改用"数据突变点 + 时间偏移"的物理定位法
// 仅在 RGDP 数值发生突变 (新季度数据发布) 时绘制
if mode == "2. 真实利率" and ta.change(rgdp_val) != 0
    // 获取当前新的 RGDP 值
    float cur_val = rgdp_val
    
    // 只有当当前值是极端值，且与上一次标注的值不同时才画
    if (cur_val > 10.0 or cur_val < -10.0) and cur_val != last_lbl_val
        // 计算居中时间：当前时间 + 45天 (季度的一半)
        // 使用 xloc.bar_time 确保在任意周期图表上都在季度中间
        int time_mid = time + 45 * 86400000
        
        // 重新计算当前的截断值 (用于定位标签Y轴)
        float plot_y = math.max(math.min(cur_val, 10.0), -10.0)
        
        if cur_val > 10.0
            label.new(time_mid, plot_y, "▲ " + str.tostring(cur_val, "0.0") + "%", xloc = xloc.bar_time, color = c_lime, style = label.style_label_down, textcolor = c_white, size = size.tiny)
        else
            label.new(time_mid, plot_y, "▼ " + str.tostring(cur_val, "0.0") + "%", xloc = xloc.bar_time, color = c_red, style = label.style_label_up, textcolor = c_white, size = size.tiny)
        
        last_lbl_val := cur_val

// 处理当前最新的季度 (如果当前是极端值，且还没结束，暂时画在最后)
if barstate.islast and mode == "2. 真实利率" and (rgdp_val > 10.0 or rgdp_val < -10.0)
    // 防止重复：如果最后一根K线刚好也是季度第一天，上面的逻辑已经画过了，这里就不画
    if not is_new_quarter
        float plot_y_cur = math.max(math.min(rgdp_val, 10.0), -10.0)
        if rgdp_val > 10.0
            label.new(bar_index, plot_y_cur, "▲ " + str.tostring(rgdp_val, "0.0") + "%", color = c_lime, style = label.style_label_down, textcolor = c_white, size = size.tiny)
        else
            label.new(bar_index, plot_y_cur, "▼ " + str.tostring(rgdp_val, "0.0") + "%", color = c_red, style = label.style_label_up, textcolor = c_white, size = size.tiny)

// 添加 RGDP 标签
if barstate.islast and mode == "2. 真实利率"
    // RGDP 标签
    label.new(bar_index, rgdp_plot, "真实美国GDP | RGDP" + rgdp_date_str, 
              color = color.gray, 
              style = label.style_label_lower_left, 
              textcolor = c_white, 
              size = size.small, 
              textalign = text.align_left)
    
    // 0.5 RGDP 标签
    label.new(bar_index, 0.5 * rgdp_plot, "0.5 RGDP", 
              color = c_orange, 
              style = label.style_label_upper_left, 
              textcolor = c_white, 
              size = size.small, 
              textalign = text.align_left)

// 3. 利差结构: 10Y-2Y
bool is_bull_steep_melt = mode == "3. 利差结构" and s3 == -1.0 and w3 > 1.0

// 曲线变色 (保持深红)
color yc_col = is_bull_steep_melt ? c_super_red : dyn_c
plot(mode == "3. 利差结构" ? plot_val : na, "10Y-2Y", color = yc_col, linewidth = 2)

// 背景高亮 (深红半透明)
bgcolor(is_bull_steep_melt ? color.new(c_super_red, 70) : na, title="Bull Steep Melt BG")

// 文本标记 (仅在熔断开始时显示，避免拥挤)
bool show_bull_mark = mode == "3. 利差结构" and is_bull_steep_melt
if show_bull_mark and not show_bull_mark[1] and show_markers
    label.new(bar_index, plot_val + 0.2, "🐂\n牛陡", color = color(na), style = label.style_none, textcolor = c_black, size = size.small, textalign = text.align_center)


// 4. 信用风险: OAS + 阈值
color oas_col = dyn_c
if mode == "4. 信用风险" and s4 == -1.0 and w4 > 1.0
    oas_col := c_super_red

// 信用崩盘标记
bool is_credit_crash = mode == "4. 信用风险" and s4 == -1.0 and w4 > 1.0
if is_credit_crash and not is_credit_crash[1] and show_markers
    label.new(bar_index, plot_val + 0.5, "💔\n危机", color = color(na), style = label.style_none, textcolor = c_black, size = size.small, textalign = text.align_center)

// 严重恶化标记 (非熔断，但恶化)
bool is_credit_bad = mode == "4. 信用风险" and s4 == -1.0 and w4 <= 1.0
if is_credit_bad and not is_credit_bad[1] and show_markers
    label.new(bar_index, plot_val + 0.5, "🩸\n恶化", color = color(na), style = label.style_none, textcolor = c_black, size = size.small, textalign = text.align_center)

plot(mode == "4. 信用风险" ? plot_val : na, "OAS", color = oas_col, linewidth = 2)
plot(mode == "4. 信用风险" ? 10.0 : na, "OAS 10", color = c_super_red)
plot(mode == "4. 信用风险" ? 6.0 : na, "OAS 6", color = c_red)
plot(mode == "4. 信用风险" ? 3.5 : na, "OAS 3.5", color = c_lime)

bool is_oas_meltdown_bg = mode == "4. 信用风险" and s4 == -1.0 and w4 > 1.0
bgcolor(is_oas_meltdown_bg ? color.new(c_super_red, 70) : na, title="OAS Melt BG")

if barstate.islast and mode == "4. 信用风险"
    label.new(bar_index, 10.0, "熔断 (10%)", color = c_super_red, style = label.style_label_left, textcolor = c_white, size = size.small)
    label.new(bar_index, 6.0, "严重恶化 (6%)", color = c_red, style = label.style_label_left, textcolor = c_white, size = size.small)
    label.new(bar_index, 3.5, "▼ 风险收敛 (3.5%)", color = c_lime, style = label.style_label_left, textcolor = c_white, size = size.small)


// 5. 流动性: M2 YoY + 阈值
color liq_col = dyn_c
bool is_liq_meltdown = false
if is_us
    is_liq_meltdown := is_liq_crash
else
    is_liq_meltdown := is_cn_crash

// 枯竭标记
bool show_liq_mark = mode == "5. 流动性" and is_liq_meltdown
if show_liq_mark and not show_liq_mark[1] and show_markers
    label.new(bar_index, plot_val - 4, "🏜️\n枯竭", color = color(na), style = label.style_none, textcolor = c_black, size = size.small, textalign = text.align_center)

if is_liq_meltdown
    liq_col := c_super_red

plot(mode == "5. 流动性" ? plot_val : na, "Liquidity", color = liq_col, linewidth = 2)
plot(mode == "5. 流动性" and is_us ? th_liq_us_crash : na, "M2 -2", color = c_super_red)
plot(mode == "5. 流动性" and is_cn ? th_liq_cn_crash : na, "M1-M2 -5", color = c_super_red)

bgcolor(mode == "5. 流动性" and is_liq_meltdown ? color.new(c_super_red, 70) : na, title="Liq Melt BG")

if barstate.islast and mode == "5. 流动性"
    if is_us
        label.new(bar_index, th_liq_us_crash, "熔断 (-2.0)", color = c_super_red, style = label.style_label_left, textcolor = c_white, size = size.small)
    else
        label.new(bar_index, th_liq_cn_crash, "熔断 (-5.0)", color = c_super_red, style = label.style_label_left, textcolor = c_white, size = size.small)

// 6. 利润空间: Gap
float cpi_val = is_us ? us_cpi_yoy : cn_cpi_yoy
float ppi_val = is_us ? us_ppi_yoy : cn_ppi_yoy

plot(mode == "6. 利润空间" ? plot_val : na, "Profit Gap", color = dyn_c, linewidth = 2)

// 通胀过热标记
bool is_overheat = mode == "6. 利润空间" and cpi_val > 3.0
if is_overheat and not is_overheat[1] and show_markers
    label.new(bar_index, plot_val + 4, "🥵\n过热", color = color(na), style = label.style_none, textcolor = c_black, size = size.small, textalign = text.align_center)

// 深度通缩标记
bool is_deflation = mode == "6. 利润空间" and cpi_val < 0 and ppi_val < 0
if is_deflation and not is_deflation[1] and show_markers
    label.new(bar_index, plot_val - 4, "🥶\n通缩", color = color(na), style = label.style_none, textcolor = c_black, size = size.small, textalign = text.align_center)

// 确保只在"6. 利润空间"模式下显示
plot(mode == "6. 利润空间" ? cpi_val : na, "CPI", color = color.purple, linewidth = 1)
plot(mode == "6. 利润空间" ? ppi_val : na, "PPI", color = color.blue, linewidth = 1)
plot(mode == "6. 利润空间" ? 3.0 : na, "CPI 3.0", color = color.new(color.red, 50), style = plot.style_circles)

// 过热背景高亮 (CPI > 3.0)
bgcolor(mode == "6. 利润空间" and cpi_val > 3.0 ? color.new(c_red, 85) : na, title="CPI Overheat BG")

// 通缩背景高亮 (CPI < 0 且 PPI < 0)
bgcolor(mode == "6. 利润空间" and cpi_val < 0 and ppi_val < 0 ? color.new(color.blue, 85) : na, title="Deflation BG")

// 仅在 "6. 利润空间" 模式且为最后一根 K 线时显示
var table legend_prof = table.new(position.bottom_right, 2, 4, bgcolor = c_bg, border_width = 1, border_color = color.gray, frame_width = 1)
if barstate.islast and mode == "6. 利润空间"
    table.cell(legend_prof, 0, 0, "📊 利润空间", text_color = c_white, text_size = size.small, bgcolor = c_header)
    table.cell(legend_prof, 1, 0, "", bgcolor = c_header) // 占位
    table.merge_cells(legend_prof, 0, 0, 1, 0)
    
    table.cell(legend_prof, 0, 1, "CPI", text_color = color.purple, text_halign = text.align_left, text_size = size.small)
    table.cell(legend_prof, 1, 1, str.tostring(cpi_val, "0.00") + "%", text_color = c_white, text_halign = text.align_right, text_size = size.small)
    
    table.cell(legend_prof, 0, 2, "PPI", text_color = color.blue, text_halign = text.align_left, text_size = size.small)
    table.cell(legend_prof, 1, 2, str.tostring(ppi_val, "0.00") + "%", text_color = c_white, text_halign = text.align_right, text_size = size.small)

    label.new(bar_index, 3.0, "过热线 (3.0%)", color = color.new(color.red, 50), style = label.style_label_left, textcolor = c_white, size = size.small)

// 7. 实体热度: 铜金比
plot(mode == "7. 实体热度" ? plot_val : na, "Copper/Gold", color = dyn_c, linewidth = 2)

// 崩盘标记
bool is_cg_crash_mark = mode == "7. 实体热度" and s7 == -1.0
if is_cg_crash_mark and not is_cg_crash_mark[1] and show_markers
    label.new(bar_index, plot_val + 0.1, "📉\n崩盘", color = color(na), style = label.style_none, textcolor = c_black, size = size.small, textalign = text.align_center)

// 动态计算 EMA 周期
// 日线: 60 (季度线)
// 周线: 12 (季度线)
// 月线: 12 (年线，更有意义)
int ema_len_dynamic = timeframe.isdaily ? 60 : 12
plot(mode == "7. 实体热度" ? ta.ema(plot_val, ema_len_dynamic) : na, "CG EMA", color = color.blue, linewidth = 1)

// 8. 萨姆规则: Sahm + 阈值
plot(mode == "8. 萨姆规则" ? plot_val : na, "Sahm", color = dyn_c, linewidth = 2)

// 衰退熔断标记
bool is_sahm_melt = mode == "8. 萨姆规则" and s8 == -1.0
if is_sahm_melt and not is_sahm_melt[1] and show_markers
    label.new(bar_index, plot_val + 0.1, "💀\n衰退", color = color(na), style = label.style_none, textcolor = c_black, size = size.small, textalign = text.align_center)

// 萨姆规则阈值线
plot(mode == "8. 萨姆规则" ? 0.50 : na, "衰退熔断线", color = c_super_red, linewidth = 2, style = plot.style_line)
plot(mode == "8. 萨姆规则" ? 0.30 : na, "衰退关注线", color = c_orange, linewidth = 1, style = plot.style_circles)

// 萨姆规则标签
if mode == "8. 萨姆规则" and barstate.islast
    label.new(bar_index + 3, 0.50, "衰退熔断 (0.5%)", color = color(na), style = label.style_none, textcolor = c_super_red, size = size.normal, textalign = text.align_left)
    label.new(bar_index + 3, 0.30, "衰退关注 (0.3%)", color = color(na), style = label.style_none, textcolor = c_orange, size = size.small, textalign = text.align_left)

// 通用 0 轴 (虚线)
hline(0, "零线", color = color.gray, linestyle = hline.style_dashed)

// --- 看板绘制 ---
var table rpt = table.new(position.middle_left, 8, 11, bgcolor = c_bg, border_width = 1, border_color = color.gray)
var table info = table.new(position.middle_right, 4, 6, bgcolor = c_bg, border_width = 1, border_color = color.gray)

get_score_col(s) =>
    if s >= 0.5
        c_lime
    else if s == 0.0
        c_yellow
    else if s == -0.5
        c_orange
    else
        c_red

fill_row(r, name, val_str, s, w, meta, status, action, reason, is_melt) =>
    c_s = get_score_col(s)
    w_str = w > 1.0 ? "x2" : ""
    float final_s = s * w
    string s_str = final_s > 0 ? "+" + str.tostring(final_s, "#.#") : (final_s == 0 ? "0" : str.tostring(final_s, "#.#"))
    
    // 熔断检测: 仅针对 "数值" 和 "现状含义" 修改背景色 (深红 + 黄字)
    bool is_meltdown_row = is_melt
    color bg_hlt = is_meltdown_row ? c_super_red : c_bg
    color txt_hlt_val = is_meltdown_row ? c_yellow : c_s
    color txt_hlt_stat = is_meltdown_row ? c_yellow : c_white

    table.cell(rpt, 0, r, name, text_color = c_white, bgcolor = c_bg)
    table.cell(rpt, 1, r, val_str, text_color = txt_hlt_val, bgcolor = bg_hlt)
    table.cell(rpt, 2, r, s_str, text_color = c_score_col, bgcolor = c_bg)
    table.cell(rpt, 3, r, w_str, text_color = c_white, bgcolor = c_bg) 
    table.cell(rpt, 4, r, meta, text_color = c_white, bgcolor = c_bg)
    table.cell(rpt, 5, r, status, text_color = txt_hlt_stat, bgcolor = bg_hlt)
    
    // 拆分操作建议 (Space split)
    int sp_idx = str.pos(action, " ")
    string act_head = sp_idx != -1 ? str.substring(action, 0, sp_idx) : action
    string act_body = sp_idx != -1 ? str.substring(action, sp_idx + 1) : ""
    
    table.cell(rpt, 6, r, act_head, text_color = c_s, bgcolor = c_bg, tooltip = reason)
    table.cell(rpt, 7, r, act_body, text_color = c_white, bgcolor = c_bg, text_halign = text.align_left, tooltip = reason)

if barstate.islast and show_report
    table.cell(rpt, 0, 0, "维度", text_color = c_white, bgcolor = c_header)
    table.cell(rpt, 1, 0, "数值", text_color = c_white, bgcolor = c_header)
    table.cell(rpt, 2, 0, "得分", text_color = c_white, bgcolor = c_header)
    table.cell(rpt, 3, 0, "权重", text_color = c_white, bgcolor = c_header)
    table.cell(rpt, 4, 0, "比喻", text_color = c_white, bgcolor = c_header)
    table.cell(rpt, 5, 0, "现状含义", text_color = c_white, bgcolor = c_header)
    table.cell(rpt, 6, 0, "操作", text_color = c_white, bgcolor = c_header)
    table.cell(rpt, 7, 0, "建议", text_color = c_white, bgcolor = c_header)

    fill_row(1, "1.基准利率", str.tostring(effr_live, "0.00")+"%", s1, w1, "总水坝闸门", t1_s, t1_a, t1_reason, false)
    fill_row(2, "2.真实利率", str.tostring(tips_live, "0.00")+"%", s2, w2, "水厂回购价", t2_s, t2_a, t2_reason, false)
    fill_row(3, "3.利差结构", str.tostring(yc_val, "0.00"), s3, w3, "天气预报", t3_s, t3_a, t3_reason, s3 == -1.0 and w3 > 1.0)
    fill_row(4, "4.信用风险", str.tostring(oas_val, "0.00")+"%", s4, w4, "风险保证金", t4_s, t4_a, t4_reason, s4 == -1.0 and w4 > 1.0)
    
    string l5_v = is_us ? str.tostring(us_m2_yoy, "0.00")+"%" : str.tostring(cn_gap, "0.00")+"%"
    fill_row(5, "5.流动性", l5_v, s5, w5, "鱼池活水率", t5_s, t5_a, t5_reason, s5 == -1.0)
    
    string l6_v = is_us ? str.tostring(us_profit_gap, "0.00")+"%" : str.tostring(cn_profit_gap, "0.00")+"%"
    fill_row(6, "6.利润空间", l6_v, s6, w6, "养鱼账本", t6_s, t6_a, t6_reason, false)
    
    fill_row(7, "7.实体热度", str.tostring(cg_ratio, "0.00"), s7, w7, "鱼池扩建率", t7_s, t7_a, t7_reason, false)
    fill_row(8, "8.萨姆规则", str.tostring(sahm_val, "0.00")+"%", s8, w8, "失业信号", t8_s, t8_a, t8_reason, s8 == -1.0 and w8 > 1.0)

    // Row 9: 宏观对冲策略
    bool us_loose = s1 == 1.0 or score_us_liq == 1.0 // US: 降息 OR M2扩张
    bool us_tight = s1 < 0 or score_us_liq < 0       // US: 加息/救火 OR M2紧缩/枯竭
    bool us_panic = is_panic_era or is_meltdown      // US: 恐慌

    bool cn_loose = score_cn_liq == 1.0
    bool cn_tight = score_cn_liq == -1.0

    string strat_t = "", string strat_d = "", string strat_us = "", string strat_cn = ""
    color strat_c = c_white
    
    if us_loose and cn_loose
        strat_t := "🟢 共振复苏"
        strat_d := "【全仓猛干】 买铜、原油、澳元、新兴市场(港股/A股)"
        strat_c := c_lime
        strat_us := "🟢 美松 (印钱)"
        strat_cn := "🟢 中松 (放水)"
    else if us_tight and cn_tight
        strat_t := "🔴 双重紧缩"
        strat_d := "【现金为王】 只持有美元现金，或者做空 A 股"
        strat_c := c_orange
        strat_us := "🟠 美紧 (抽水)"
        strat_cn := "🟠 中紧 (空转)"
    else if us_panic and cn_tight
        strat_t := "🔴 衰退共振"
        strat_d := "【避险】 买美债、黄金、日元避险"
        strat_c := c_orange
        strat_us := "🔴 美恐 (救火)"
        strat_cn := "🟠 中紧 (空转)"
    else if us_panic and cn_loose
        strat_t := "🟠 东升西降"
        strat_d := "【结构性做多】 买 A股龙头，做空美股"
        strat_c := c_yellow
        strat_us := "🔴 美恐 (救火)"
        strat_cn := "🟢 中松 (放水)"
    else if us_tight and cn_loose
        strat_t := "🟠 分化博弈"
        strat_d := "【两头吃】 存美元吃利息，同时买 A股结构性机会"
        strat_c := c_yellow
        strat_us := "🟠 美紧 (加息)"
        strat_cn := "🟢 中松 (放水)"
    else if us_loose and cn_tight
        strat_t := "🟠 单极驱动"
        strat_d := "【只买美国】 买美股科技/黄金，千万别碰工业品"
        strat_c := c_yellow
        strat_us := "🟢 美松 (降息)"
        strat_cn := "🟠 中紧 (躺平)"
    else
        strat_t := "🟡 垃圾时间"
        strat_d := "【多看少动】 别瞎折腾，等新趋势出来"
        strat_c := c_yellow
        strat_us := "🟡 美平"
        strat_cn := "🟡 中平"

    table.cell(rpt, 0, 9, "中美宏观对冲", bgcolor = c_navy_60, text_color = c_white), table.merge_cells(rpt, 0, 9, 1, 9)
    table.cell(rpt, 2, 9, strat_t, bgcolor = c_navy_60, text_color = strat_c), table.merge_cells(rpt, 2, 9, 3, 9)
    table.cell(rpt, 4, 9, strat_us + "\n" + strat_cn, bgcolor = c_navy_60, text_color = c_white, text_size = size.small)
    table.cell(rpt, 5, 9, strat_d, bgcolor = c_navy_60, text_color = c_white), table.merge_cells(rpt, 5, 9, 7, 9)

    // Row 10: 最终诊断
    // 升级为双轨制建议：进攻仓位 + 避险仓位 + 警惕项
    
    // --- Row 10: 最终诊断 (双轨制逻辑重构) ---
    // 1. 定义资产推荐开关
    bool rec_tech   = false // 科技
    bool rec_cycle  = false // 周期
    bool rec_core   = false // 核心
    bool rec_div    = false // 红利
    bool rec_staples= false // 必选
    bool rec_small  = false // 小盘
    bool rec_junk   = false // 垃圾债
    bool rec_gold_atk = false // 黄金 (进攻)
    bool rec_cycle_up = false // 上游
    bool rec_cycle_mid= false // 中游

    // 2. 定义避险资产推荐
    bool rec_cash   = false // 现金
    bool rec_bond_s = false // 短债
    bool rec_bond_l = false // 长债
    bool rec_gold_def = false // 黄金 (避险)

    // 3. 定义否决/警惕开关
    bool veto_tech  = false
    bool veto_cycle = false
    bool veto_small = false
    bool veto_core  = false
    bool veto_bond_l = false
    bool veto_junk  = false
    bool veto_cycle_mid = false
    bool veto_risk_all = false // 一票否决所有风险资产

    bool warn_tech  = false
    bool warn_cycle = false
    bool warn_small = false
    bool warn_junk  = false
    bool warn_core  = false
    bool warn_bond_l = false
    bool warn_div   = false

    // --- 遍历维度填充开关 ---

    // 1. 基准利率 (EFFR)
    if s1 == -1.0 // 救火
        rec_gold_def := true
        rec_bond_l := true
        veto_cycle := true
        veto_tech := true
        veto_small := true
    else if s1 == -0.5 // 加息
        rec_bond_s := true
        rec_cash := true
        veto_bond_l := true
        veto_tech := true
        warn_div := true // 警惕红利(高负债)
    else if s1 == 0.0 // 震荡
        warn_tech := true
        warn_bond_l := true
    else if s1 == 1.0 // 降息
        rec_tech := true
        rec_bond_l := true

    // 2. 真实利率 (TIPS)
    if s2 == -1.0 
        if rgdp_val < 0 // 滞胀
            rec_gold_def := true
            veto_cycle := true
            veto_tech := true
        else // 虹吸
            rec_cash := true
            rec_bond_s := true
            veto_tech := true
            veto_small := true
    else if s2 == -0.5 // 杀估值
        rec_div := true
        veto_tech := true
        veto_small := true
    else if s2 == 0.0 // 成本升
        warn_tech := true
    else if s2 == 1.0 
        rec_tech := true
        if tips_live < 0 // 负利率
            rec_gold_atk := true
        else // 健康
            na 

    // 3. 利差结构 (10Y-2Y)
    if s3 == -1.0 // 牛陡
        rec_bond_l := true
        rec_gold_def := true
        veto_risk_all := true
    else if s3 == -0.5 // 倒挂
        rec_cash := true
        rec_div := true
        veto_cycle := true
        veto_tech := true
        veto_small := true
    else if s3 == 0.0 // 平坦
        warn_bond_l := true
    else if s3 == 0.5 // 陡峭
        rec_tech := true
        rec_core := true
    else if s3 == 1.0 // 熊陡
        rec_cycle := true

    // 4. 信用风险 (OAS)
    if s4 == -1.0 // 熔断/恶化
        if w4 > 1.0 // 熔断
            rec_cash := true
            veto_risk_all := true
        else // 恶化
            rec_bond_s := true
            veto_junk := true
            veto_small := true
    else if s4 == -0.5 // 走阔
        rec_div := true
        veto_junk := true
        warn_small := true
    else if s4 == 0.0 // 压力/底部
        warn_junk := true
    else if s4 == 1.0 // 收敛
        rec_junk := true
        rec_small := true

    // 5. 流动性 (M2)
    if s5 == -1.0 // 枯竭
        rec_cash := true
        veto_risk_all := true
    else if s5 == -0.5 // 紧缩
        rec_div := true
        veto_cycle := true
        veto_small := true
    else if s5 == 0.0 // 存量
        warn_small := true
    else if s5 == 1.0 // 扩张
        rec_tech := true
        rec_core := true

    // 6. 利润空间 (CPI-PPI)
    if s6 == -1.0
        if is_us and is_us_heat_state // 过热
            rec_cash := true
            rec_cycle_up := true
            veto_tech := true
            veto_bond_l := true
        else // 通缩
            rec_staples := true
            veto_cycle := true
    else if s6 == -0.5 // 亏损
        rec_cycle_up := true
        veto_cycle_mid := true
    else if s6 == 0.0 // 承压
        warn_small := true
    else if s6 == 0.5 // 修复
        rec_cycle_mid := true
    else if s6 == 1.0 // 躺赚
        rec_tech := true
        rec_core := true

    // 7. 实体热度 (铜金比)
    if s7 == -1.0 // 崩盘
        rec_bond_l := true
        rec_gold_def := true
        veto_cycle := true
        veto_tech := true
        veto_small := true
    else if s7 == -0.5 // 衰退
        rec_gold_def := true
        veto_cycle := true
    else if s7 == 0.0 // 震荡
        warn_cycle := true
    else if s7 == 1.0 // 复苏
        rec_cycle := true

    // 8. 萨姆规则 (失业信号)
    if s8 == -1.0 // 熔断
        rec_bond_l := true
        veto_risk_all := true
    else if s8 == -0.5 and id8 == "S8_WARN" // 关注 (预警)
        rec_cash := true
        veto_core := true
    else if s8 == -0.5 // 关注 (风险)
        rec_bond_l := true
        veto_cycle := true
        veto_tech := true
        veto_small := true
        veto_core := true
    else if s8 == 1.0 // 健康
        rec_tech := true
        rec_core := true

    // --- 逻辑整合 ---

    // 1. 全局熔断覆盖
    if is_meltdown
        veto_risk_all := true

    // 2. 否决传导
    if veto_risk_all
        veto_tech := true
        veto_cycle := true
        veto_small := true
        veto_core := true
        veto_junk := true
        veto_cycle_mid := true

    // 3. 构建 警惕 字符串
    string warn_assets_str = ""
    if warn_tech and not veto_tech
        warn_assets_str := append_unique(warn_assets_str, A_TECH)
    if warn_cycle and not veto_cycle
        warn_assets_str := append_unique(warn_assets_str, A_CYCLE)
    if warn_small and not veto_small
        warn_assets_str := append_unique(warn_assets_str, A_SMALL)
    if warn_junk and not veto_junk
        warn_assets_str := append_unique(warn_assets_str, A_JUNK)
    if warn_bond_l and not veto_bond_l
        warn_assets_str := append_unique(warn_assets_str, A_BOND_L)
    if warn_core and not veto_core
        warn_assets_str := append_unique(warn_assets_str, A_CORE)
    if warn_div
        warn_assets_str := append_unique(warn_assets_str, A_DIV)

    // 4. 构建 否决 字符串
    string veto_assets_str = ""
    if veto_risk_all
        veto_assets_str := A_RISK
    else
        if veto_tech
            veto_assets_str := append_unique(veto_assets_str, A_TECH)
        if veto_cycle
            veto_assets_str := append_unique(veto_assets_str, A_CYCLE)
        if veto_small
            veto_assets_str := append_unique(veto_assets_str, A_SMALL)
        if veto_core
            veto_assets_str := append_unique(veto_assets_str, A_CORE)
        if veto_bond_l
            veto_assets_str := append_unique(veto_assets_str, A_BOND_L)
        if veto_junk
            veto_assets_str := append_unique(veto_assets_str, A_JUNK)
        if veto_cycle_mid
            veto_assets_str := append_unique(veto_assets_str, A_CYCLE_MID)

    // 5. 构建 进攻 字符串
    string risk_assets_str = ""
    
    // 黄金双重属性处理: 进攻优先
    if rec_gold_atk
        risk_assets_str := append_unique(risk_assets_str, A_GOLD)
        
    if rec_tech and not veto_tech and not warn_tech
        risk_assets_str := append_unique(risk_assets_str, A_TECH)
        
    if rec_cycle and not veto_cycle and not warn_cycle
        risk_assets_str := append_unique(risk_assets_str, A_CYCLE)
        
    if rec_cycle_up and not veto_cycle // 上游受周期否决
        risk_assets_str := append_unique(risk_assets_str, A_CYCLE_UP)
        
    if rec_cycle_mid and not veto_cycle_mid // 中游
        risk_assets_str := append_unique(risk_assets_str, A_CYCLE_MID)
        
    if rec_core and not veto_core
        risk_assets_str := append_unique(risk_assets_str, A_CORE)
        
    if rec_div and not veto_core 
        risk_assets_str := append_unique(risk_assets_str, A_DIV)
        
    if rec_staples and not veto_core
        risk_assets_str := append_unique(risk_assets_str, A_STAPLES)
        
    if rec_small and not veto_small and not warn_small
        risk_assets_str := append_unique(risk_assets_str, A_SMALL)
        
    if rec_junk and not veto_junk and not warn_junk
        risk_assets_str := append_unique(risk_assets_str, A_JUNK)

    // 6. 构建 避险 字符串
    string safe_assets_str = ""
    
    if rec_cash
        safe_assets_str := append_unique(safe_assets_str, A_CASH)
    if rec_bond_l and not veto_bond_l and not warn_bond_l
        safe_assets_str := append_unique(safe_assets_str, A_BOND_L)
    if rec_bond_s
        safe_assets_str := append_unique(safe_assets_str, A_BOND_S)
    
    // 黄金: 如果没有被进攻收录，且推荐避险
    if rec_gold_def and not rec_gold_atk
        safe_assets_str := append_unique(safe_assets_str, A_GOLD)


    // 兜底：如果进攻组被剔除空了，显示暂无
    if risk_assets_str == "" and total_score >= 1.5
        risk_assets_str := "暂无 (建议观望)"

    // 赋值给原始变量以兼容后续代码
    string risk_assets = risk_assets_str
    string safe_assets = safe_assets_str
    string veto_assets = veto_assets_str
    string warn_risks  = warn_assets_str
    
    // 2. 构建最终建议文案 (双轨制 - 纯净版)
    string final_res = ""
    string line_veto = ""
    string line_warn = ""
    string line_risk = ""
    string line_safe = ""
    
    color final_bg = c_gray_dark
    color final_txt = c_white
    
    // 仓位变量
    string pos_risk = ""
    string pos_safe = ""
    
    // --- 逻辑分支 ---
    
    // A. 熔断 (最高优先级 - 唯一能强制空仓的)
    if is_meltdown
        final_res := "【熔断】"
        final_bg := c_super_red
        final_txt := c_yellow
        
        pos_risk := "0% (空仓)"
        pos_safe := "100%"
        
        // 强制清空进攻列表 (双重保险)
        risk_assets := "❌️禁止开仓"

    // B. 正常评分逻辑 (含红色指标)
    // 仓位完全由总分决定
    else
        if total_score <= -5.0
            final_res := "危机模式"
            final_bg := c_red
            final_txt := c_white
            pos_risk := "0-10%"
            pos_safe := "90-100%"
            if risk_assets == "" 
                risk_assets := "仅底仓"
                
        else if total_score < -1.5
            final_res := "衰退预警"
            final_bg := c_orange
            final_txt := c_black
            pos_risk := "10-30%"
            pos_safe := "70-90%"
            if risk_assets == "" 
                risk_assets := "核心底仓"
                
        else if total_score <= 1.5
            final_res := "混沌震荡"
            final_bg := c_yellow
            final_txt := c_black
            pos_risk := "30-50%"
            pos_safe := "50-70%"
            if risk_assets == "" 
                risk_assets := "红利/底仓"
                
        else if total_score < 5.0
            final_res := "温和增长"
            final_bg := c_lime
            final_txt := c_black
            pos_risk := "50-80%"
            pos_safe := "20-50%"
            if risk_assets == "" 
                risk_assets := "暂无 (建议观望)"
                
        else // > 5.0
            final_res := "全面复苏"
            final_bg := c_super_green
            final_txt := c_white
            pos_risk := "80-100%"
            pos_safe := "0-20%"
            if risk_assets == "" 
                risk_assets := "核心股/商品"

    // --- 构建四行文案 (强制显示) ---
    // 1. 否决行
    if veto_assets != ""
        line_veto := "⛔ 否决: " + veto_assets + "\n"
        
    // 2. 警惕行
    if warn_risks != ""
        line_warn := "⚠️ 警惕: " + warn_risks + "\n"

    // 3. 进攻行 (始终显示，带仓位)
    line_risk := "⚔️ 进攻 (" + pos_risk + "): " + risk_assets + "\n"
    
    // 4. 避险行 (始终显示，带仓位)
    line_safe := "🛡️ 避险 (" + pos_safe + "): " + (safe_assets == "" ? "现金" : safe_assets)

    // 熔断特殊处理：隐藏冗余信息，强调空仓
    if is_meltdown
        line_veto := "" // 既然都熔断了，否决列表已经没有意义，全是红的
        line_warn := "" 
        line_risk := "⚔️ 进攻 (0%): ❌ 禁止开仓 (系统性风险)\n"
        line_safe := "🛡️ 避险 (100%): 美元/现金/美债/短债"

    string final_full_sugg = line_veto + line_warn + line_risk + line_safe

    // --- Row 10: 最终诊断渲染 ---
    float total_max_score = 8.0
    float total_possible = max_score

    // (0,1) 最终诊断
    table.cell(rpt, 0, 10, "最终诊断", bgcolor = c_bg, text_color = c_white), table.merge_cells(rpt, 0, 10, 1, 10)
    
    // (2) 总分
    // 颜色逻辑需与最终诊断(final_res)的区间保持一致
    color score_c = total_score >= 5.0 ? c_super_green : (total_score > 1.5 ? c_lime : (total_score >= -1.5 ? c_yellow : (total_score > -5.0 ? c_orange : c_red)))
    table.cell(rpt, 2, 10, str.tostring(total_score, "0.0"), bgcolor = c_bg, text_color = score_c)
    
    // (3) 理论上限
    table.cell(rpt, 3, 10, str.tostring(total_max_score, "0") + " (" + str.tostring(total_possible, "0") + ")", bgcolor = c_bg, text_color = c_white)
    
    // (4) 结论 (标签)
    table.cell(rpt, 4, 10, "结论", bgcolor = c_bg, text_color = c_white)
    
    final_bgcolor = color.new(final_bg, 40)

    // (5) 现状 (如: 全面复苏)
    table.cell(rpt, 5, 10, final_res, bgcolor = final_bgcolor, text_color = final_txt)
    
    // (6) 详细建议
    table.cell(rpt, 6, 10, final_full_sugg, bgcolor = final_bgcolor, text_color = final_txt, text_halign = text.align_left), table.merge_cells(rpt, 6, 10, 7, 10)

    // --- 右表: 详情 ---
    string d_title="", string d_def="", string d_obs="", string d_logic="", string d_conf="", string d_w="", string d_cur_stat="", string d_cur_val="", string d_turn_val="", string d_cur_mean="", string d_risk="", string d_tactics="", string d_tactics_turn=""
    
    if mode == "1. 基准利率"
        d_title := "基准利率\n[EFFR]"
        d_def := "美联储联邦基金有效利率\n全球资金成本的总阀门。"
        d_obs := "10月 (EMA)"
        d_logic := "🔴 救火: ≥50bp\n🟠 加息: >EMA\n🟡 震荡: ≈EMA\n🟢 降息: <EMA"
        d_conf := "FOMC公布日确认\n\n" + next_fomc_time
        d_w := w1 > 1.0 ? "x2" : "x1"
        d_cur_stat := t1_s
        d_cur_val := str.tostring(effr_live, "0.00") + "% | " + last_fomc_time
        
        // 1. 基准利率含义与战术 (全状态覆盖)
        if s1 == -1.0 // 救火
            d_cur_mean := "衰退确信，初期伴随暴跌"
            d_tactics  := "此时降息预期极强\n🛡️买长债对冲股票下跌"
            d_turn_val := "降幅收窄 (恐慌消退)"
            d_tactics_turn := "恐慌消退，尝试左侧建仓\n⚔️买入超跌资产"
        else if s1 == -0.5 // 加息
            d_cur_mean := "资金变贵，现金为王"
            d_tactics  := "🛡️买短债吃高息，等跌\n规避久期敏感资产"
            d_turn_val := "跌破 EMA (停止加息)"
            d_tactics_turn := "停止加息，资金面转宽\n⚔️满仓买入利率敏感资产"
        else if s1 == 0.0 // 震荡
            d_cur_mean := "政策观望，方向未定"
            d_tactics  := "政策方向不明朗，观察期\n多看少做"
            d_turn_val := "跌破 EMA (开始降息)"
            d_tactics_turn := "确认降息周期开启\n⚔️加大杠杆做多"
        else // 降息
            d_cur_mean := "资金便宜，利好成长"
            d_tactics  := "⚔️布局科技、加密和生物医药\n利好利率敏感资产"
            d_turn_val := "上穿 EMA (停止降息)"
            d_tactics_turn := "降息结束，利好出尽\n落袋为安，防范通胀反弹"
            
        if s1 == -1.0
            d_risk := "恐慌消退"
        else if s1 == -0.5
            d_risk := "流动性转宽"
        else if s1 == 1.0
            d_risk := "流动性收紧"
        else
            d_risk := "方向明确"

    else if mode == "2. 真实利率"
        d_title := "真实利率\n[TIPS]"
        d_def := "10年期通胀保值债券收益率\nTIPS 上行 = 资金流出风险资产(买美债)\nTIPS 下行 = 资金流入风险资产(买股票)\nTIPS ≥ RGDP，会对风险资产产生‘虹吸效应’"
        d_obs := "日线 (实时)"
        d_logic := "🔴 滞胀: RGDP < 0\n🔴 虹吸: ≥ RGDP\n🟠 杀估值: ≥ 0.75RGDP\n🟡 震荡: ≥ 0.5RGDP\n🟢 健康: < 0.5RGDP\n🟢 负利率: < 0"
        d_conf := "连续5日确认"
        d_w := w2 > 1.0 ? "x2" : "x1"
        d_cur_stat := t2_s
        d_cur_val := str.tostring(tips_live, "0.00") + "% | " + fmt_ymd(tips_time)
        
        // 2. 真实利率含义与战术
        if s2 == -1.0
            if rgdp_val < 0 // 滞胀
                d_cur_mean := "经济停滞，物价飞涨\n(负利率陷阱)"
                d_tactics  := "🛡️现金为王，卖出风险资产\n买入美元/黄金"
                d_turn_val := "RGDP 转正 (经济复苏)"
                d_tactics_turn := "经济复苏，重仓股票\n⚔️关注周期反转"
            else // 虹吸
                d_cur_mean := "无风险收益极高，虹吸一切"
                d_tactics  := "🛡️只有美元现金最安全\n卖出风险资产"
                d_turn_val := "跌破 RGDP"
                d_tactics_turn := "虹吸效应结束，配置核心资产\n⚔️资金重回股市"
        else if s2 == -0.5 // 杀估值
            d_cur_mean := "实际资金成本过高，压制估值"
            d_tactics  := "🛡️买低估值红利股\n规避高估值成长股"
            d_turn_val := "跌破 0.75 RGDP"
            d_tactics_turn := "估值压制解除，进入震荡\n多看少做"
        else if s2 == 0.0 // 资金成本上升
            d_cur_mean := "资金成本上升，尚未杀估值"
            d_tactics  := "环境开始变差\n多看少做"
            d_turn_val := "跌破 0.5 RGDP (健康)"
            d_tactics_turn := "资金成本适宜，买入成长股\n⚔️科技股迎来春天"
        else if s2 == 1.0
            if tips_live < 0 // 负利率
                d_cur_mean := "实际利率为负，资产泡沫化"
                d_tactics  := "⚔️实物资产/数字黄金抗贬值\n满仓风险资产"
                d_turn_val := "利率转正"
                d_tactics_turn := "泡沫退潮，卖出黄金/加密\n转入防御性资产"
            else // 健康
                d_cur_mean := "资金成本适宜，利好股市"
                d_tactics  := "⚔️安心持有成长股\n享受估值溢价"
                d_turn_val := tips_live >= 0.5 * rgdp_val ? "突破 0.5 RGDP（确认中）" : "突破 0.5 RGDP"
                d_tactics_turn := "实际利率上行，转入震荡\n多看少做"
            
        if s2 == -1.0
            if rgdp_val < 0 // 滞胀
                d_risk := "复苏开启"
            else // 虹吸
                d_risk := "压力缓解"
        else if s2 == -0.5 // 杀估值
            d_risk := "估值修复"
        else if s2 == 0.0 // 震荡
            d_risk := "压力缓解"
        else if s2 == 1.0
            if tips_live < 0 // 负利率
                d_risk := "泡沫破裂"
            else // 健康
                d_risk := "进入震荡"
        else
            d_risk := "方向未定"

    else if mode == "3. 利差结构"
        d_title := "利差结构\n[10Y-2Y]"
        d_def := "10年期与2年期美债利差\n10Y看长期(经济前景); 2Y看短期(美联储政策)"
        d_obs := "20日 (趋势)"
        d_logic := "🛑 牛陡: 2Y 跌幅高于 10Y\n🟠 倒挂: 10Y < 2Y\n🟡 平坦: 10Y ≈ 2Y\n🟢 常态: 10Y > 2Y\n🟢 熊陡: 10Y 涨幅高于 2Y"
        d_conf := "即时生效(20日趋势)确认"
        d_w := w3 > 1.0 ? "x2" : "x1"
        d_cur_stat := t3_s
        d_cur_val := str.tostring(yc_val, "0.00")
        
        // 3. 利差含义与战术
        if s3 == -1.0 // 牛陡
            d_cur_mean := "衰退迫在眉睫，恐慌蔓延"
            d_tactics  := "立刻清空股票\n🛡️避险资金涌入，买美债/黄金"
            d_turn_val := "短债企稳 (恐慌消退)"
            d_tactics_turn := "恐慌消退，尝试左侧建仓\n⚔️买入超跌资产"
        else if s3 == -0.5 // 倒挂
            d_cur_mean := "长期前景堪忧，资金避险"
            d_tactics  := "衰退倒计时，收缩战线\n🛡️买防御性资产，避激进投资"
            d_turn_val := "重新转正 (解除警报)"
            d_tactics_turn := "警报解除，右侧确认买入\n⚔️加仓风险资产"
        else if s3 == 0.0 // 平坦
            d_cur_mean := "经济方向未定，多空博弈"
            d_tactics  := "倒挂/走阔转换期\n方向未定，多看少做"
            d_turn_val := "重新转正 (复苏确认)"
            d_tactics_turn := "复苏确认，加仓周期股\n⚔️做多商品"
        else if s3 == 0.5 // 陡峭 (常态)
            d_cur_mean := "经济正向运转，借短贷长获利"
            d_tactics  := "⚔️宏观环境无虞，持有风险资产\n只要不是倒挂，安心赚钱"
