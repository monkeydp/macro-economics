//@version=6
indicator("[薯仔] 宏观经济审计看板", overlay = false, precision = 2, max_labels_count = 500)

// ==========================================
// 1. 设置与配色 (Settings & Colors)
// ==========================================
show_report = input.bool(true, "显示决策看板", group="显示设置")
mode = input.string("1. 基准利率", "当前显示曲线",
     options=["1. 基准利率", "2. 真实利率", "3. 利差结构",
     "4. 信用风险", "5. 流动性", "6. 利润空间",
     "7. 实体热度", "8. 萨姆规则"], group="显示设置")
region = input.string("美国", "监控地区", options=["美国", "中国"], group="显示设置", tooltip="仅影响: 5.流动性 / 6.利润空间")

// 参数设置
effr_ema_len = input.int(10, "基准利率 EMA 周期", minval=1, group="周期参数设置", tooltip="仅影响: 1.基准利率")
yoy_len = input.int(12, "增速同比周期", minval=1, group="周期参数设置", tooltip="仅影响: 5.流动性 / 6.利润空间")
slope_len = input.int(60, "斜率观测周期", minval=1, group="周期参数设置", tooltip="仅影响: 3.利差结构 / 4.信用风险 / 7.实体热度")

// 震荡过滤阈值
grp_noise = "震荡过滤阈值"
th_effr_noise   = input.float(0.05, "基准利率震荡", minval=0.0, group=grp_noise)
th_yc_noise     = input.float(0.15, "利差结构震荡",   minval=0.0, group=grp_noise)
th_yc_bull_steep= input.float(0.15, "利差牛陡容差",   minval=0.0, group=grp_noise)
th_yc_bear_steep= input.float(0.15, "利差熊陡容差",   minval=0.0, group=grp_noise)
th_oas_noise    = input.float(0.01, "信用风险斜率",  minval=0.0, group=grp_noise)
th_liq_us_noise = input.float(0.50, "美国流动性",     minval=0.0, group=grp_noise)
th_liq_cn_noise = input.float(0.50, "中国流动性",  minval=0.0, group=grp_noise)
th_prof_noise   = input.float(0.20, "利润空间",   minval=0.0, group=grp_noise)
th_cg_noise     = input.float(0.05, "铜金比斜率",     minval=0.0, group=grp_noise)

// 信号锁定周期 (Lock-in)
grp_lock = "信号锁定与确认周期 (Timeframe)"
lock_bull_steep   = input.int(10, "牛陡熔断锁定 (日)", minval=1, group=grp_lock, tooltip="交易日。10日 ≈ 2周")
dur_yc_bear_conf  = input.int(5,  "熊陡确认 (日)",     minval=1, group=grp_lock, tooltip="交易日。5日 ≈ 1周")
lock_credit_crash = input.int(10, "信用熔断锁定 (日)", minval=1, group=grp_lock, tooltip="交易日。10日 ≈ 2周")
lock_cg_crash     = input.int(5,  "铜金崩盘锁定 (日)", minval=1, group=grp_lock, tooltip="交易日。5日 ≈ 1周")
dur_tips_conf     = input.int(5,  "真实利率确认 (日)", minval=1, group=grp_lock)
dur_liq_conf      = input.int(2,  "流动性确认 (月)",   minval=1, group=grp_lock)
dur_prof_conf     = input.int(2,  "利润空间确认 (月)", minval=1, group=grp_lock)
dur_sahm_panic    = input.int(90, "救火降息有效期 (日)", minval=1, group=grp_lock, tooltip="自然日。90日 ≈ 1季度")

// 颜色定义
c_red          = color.red      // 🔴 红色 (得分 -1.0)
c_orange       = color.orange   // 🟠 橙色 (得分 -0.5)
c_yellow       = color.yellow   // 🟡 黄色 (得分 0.0)
c_lime         = color.lime     // 🟢 亮绿 (得分 +1.0 / +0.5)
c_super_red    = #800000        // 🛑 深红 (熔断背景)
c_super_green  = #006400        // 🟢 深绿 (满仓背景)
c_navy_60      = color.new(#000080, 40) // 海军蓝60 (宏观对冲行背景)
c_beige        = #F5F5DC        // 米色 (标签文字)
c_score_col    = #78D6FB        // 浅蓝 (得分/权重)
c_gray_dark    = #333333        // 深灰 (默认背景)
c_bg           = color.new(c_gray_dark, 10) // 背景色
c_header       = color.new(color.gray, 10)  // 表头背景
c_white        = color.white
c_black        = color.black

// ==========================================
// 2. 数据获取与计算 (Data Fetching)
// ==========================================

// --- Helper Functions ---
fmt_ym(t) => str.tostring(year(t)) + "-" + (month(t) < 10 ? "0" : "") + str.tostring(month(t))
fmt_ymd(t) => str.tostring(year(t)) + "-" + (month(t) < 10 ? "0" : "") + str.tostring(month(t)) + "-" + (dayofmonth(t) < 10 ? "0" : "") + str.tostring(dayofmonth(t))

calc_slope_linreg(src, len) => 
    slope = ta.linreg(src, len, 0) - ta.linreg(src, len, 1)
    slope

calc_yoy(src, len) => (src / src[len] - 1) * 100

float sec_per_bar = timeframe.in_seconds(timeframe.period)
float sec_per_day = 86400

// --- 1. 基准利率 (EFFR) ---
// 确认时长: FOMC 公布日
// 修改：只获取当前值，在本地计算跌幅，以适应不同周期 (周线/月线也能捕捉到降息)
// 修复：增加 effr_drop_max_22d 检测月内是否有救火降息
[effr_live, effr_time, effr_chg, effr_drop_max_22d] = request.security("FRED:EFFR", "D", [close, time, close[1] - close, ta.highest(close[1] - close, 22)], gaps = barmerge.gaps_off)
// 修改：使用月线 EMA 以匹配长期趋势 (10月EMA)
effr_ema  = request.security("FRED:EFFR", "M", ta.ema(close, effr_ema_len), gaps = barmerge.gaps_off)

// 核心修正：如果当前是月线图，使用过去22天内的最大降幅
bool is_monthly_tf_effr = sec_per_bar >= 2000000
effr_drop = is_monthly_tf_effr ? effr_drop_max_22d : effr_chg

// --- 2. 真实利率 (TIPS) ---
// 确认时长: 连续 5 日
[tips_live, tips_time] = request.security("FRED:DFII10", "D", [close, time], gaps = barmerge.gaps_off)
// 修改: 同时获取 RGDP 的时间戳，用于精准显示数据周期
[rgdp_val, rgdp_time]  = request.security("FRED:A191RL1Q225SBEA", "D", [close, time], gaps = barmerge.gaps_off)

// --- 3. 利差结构 (10Y-2Y) ---
// 确认时长: 即时生效 (基于 20 日趋势)
// 修复：强制在 Daily 级别计算 Change，防止月线图上出现月度 Change 误判
[y10, y10_chg_d] = request.security("FRED:GS10", "D", [close, close - close[1]], gaps = barmerge.gaps_off)
[y2, y2_chg_d]   = request.security("FRED:GS2", "D", [close, close - close[1]], gaps = barmerge.gaps_off)
yc_val = y10 - y2
// 熔断检测: 双跌且短债跌幅 > 长债跌幅
y10_chg = y10_chg_d
y2_chg  = y2_chg_d
// 牛陡判定: 长跌且短跌，且短跌 > 长跌 (且短跌跌幅显著 > 阈值)
is_bull_steep_trigger = y10_chg < 0 and y2_chg < -th_yc_bull_steep and y2_chg < y10_chg
// 锁定 10 日 (默认)
// 修正：将天数转换为 Bar 数，防止在月线图上锁定 10 个月
int bars_lock_bull = math.max(1, math.ceil(lock_bull_steep * sec_per_day / sec_per_bar))
var int bull_steep_cnt = 0
if is_bull_steep_trigger
    bull_steep_cnt := bars_lock_bull
else if bull_steep_cnt > 0
    bull_steep_cnt := bull_steep_cnt - 1
is_bull_steep = bull_steep_cnt > 0

// --- 4. 信用风险 (OAS) ---
// 确认时长: 连续 3 日; 熔断即时
// 修复：强制在 Daily 级别计算 5日涨幅，防止月线图误判
[oas_val, oas_slope, oas_chg_5d_pct] = request.security("FRED:BAMLH0A0HYM2", "D", [close, calc_slope_linreg(close, slope_len), (close / close[5] - 1) * 100], gaps = barmerge.gaps_off)
// 熔断检测: >10% 或 (>6% 且 5日涨幅 > 20%)
is_oas_crash_trigger = oas_val > 10.0 or (oas_val > 6.0 and oas_chg_5d_pct > 20.0)
// 锁定 10 日 (默认)
// 修正：将天数转换为 Bar 数
int bars_lock_credit = math.max(1, math.ceil(lock_credit_crash * sec_per_day / sec_per_bar))
var int oas_crash_cnt = 0
if is_oas_crash_trigger
    oas_crash_cnt := bars_lock_credit
else if oas_crash_cnt > 0
    oas_crash_cnt := oas_crash_cnt - 1
is_oas_crash = oas_crash_cnt > 0

// --- 5. 流动性 (M2 / M1-M2) ---
// 确认时长: 连续 2 个月
[us_m2_real, us_m2_yoy, us_m2_time] = request.security("FRED:M2REAL", "M", [close, calc_yoy(close, yoy_len), time], gaps = barmerge.gaps_off)

[cn_m1, cn_m1_yoy, cn_time] = request.security("ECONOMICS:CNM1", "M", [close, calc_yoy(close, yoy_len), time], gaps = barmerge.gaps_off)
[cn_m2, cn_m2_yoy] = request.security("ECONOMICS:CNM2", "M", [close, calc_yoy(close, yoy_len)], gaps = barmerge.gaps_off)
cn_gap = cn_m1_yoy - cn_m2_yoy

// --- 6. 利润空间 (CPI-PPI) ---
// 确认时长: 连续 2 个月
[us_cpi, us_cpi_yoy, us_prof_time] = request.security("FRED:CPIAUCSL", "M", [close, calc_yoy(close, yoy_len), time], gaps = barmerge.gaps_off)
[us_ppi, us_ppi_yoy] = request.security("FRED:PPIACO", "M", [close, calc_yoy(close, yoy_len)], gaps = barmerge.gaps_off)
us_profit_gap = us_cpi_yoy - us_ppi_yoy

cn_cpi_yoy = request.security("ECONOMICS:CNCPI", "M", calc_yoy(close, yoy_len), gaps = barmerge.gaps_off)
cn_ppi_yoy = request.security("ECONOMICS:CNPPI", "M", calc_yoy(close, yoy_len), gaps = barmerge.gaps_off)
cn_profit_gap = cn_cpi_yoy - cn_ppi_yoy

// --- 7. 实体热度 (铜金比) ---
// 确认时长: 连续 5 日
[copper, copper_chg_pct_d] = request.security("COMEX:HG1!", "D", [close, (close / close[1] - 1) * 100], gaps = barmerge.gaps_off)
[gold, gold_prev]     = request.security("COMEX:GC1!", "D", [close, close[1]], gaps = barmerge.gaps_off)

// 崩盘检测需要铜金比本身的日度变化
// 我们可以直接在 Daily 级别计算铜金比及其变化
// 修复：增加 was_crash_in_month 检测月内是否有崩盘
[cg_ratio_d, cg_chg_pct_d, was_crash_in_month] = request.security("COMEX:HG1! / COMEX:GC1! * 1000", "D", [close, (close / close[1] - 1) * 100, ta.highest((close / close[1] - 1) * 100 < -3.0 ? 1.0 : 0.0, 22)], gaps = barmerge.gaps_off)

// 崩盘检测: 单日跌幅 > 3% (强制使用日度数据)
// 修复：如果当前是月线图 (sec_per_bar >= 2000000)，使用 was_crash_in_month 回溯检测
// 如果是日线图，直接用 cg_chg_pct_d
bool is_monthly_tf = sec_per_bar >= 2000000 // 粗略判断月线 (2592000)
is_cg_crash_trigger = is_monthly_tf ? (was_crash_in_month > 0) : (cg_chg_pct_d < -3.0)

// 锁定 5 日 (默认)
// 修正：将天数转换为 Bar 数
int bars_lock_cg = math.max(1, math.ceil(lock_cg_crash * sec_per_day / sec_per_bar))
var int cg_crash_cnt = 0
if is_cg_crash_trigger
    cg_crash_cnt := bars_lock_cg
else if cg_crash_cnt > 0
    cg_crash_cnt := cg_crash_cnt - 1
is_cg_crash = cg_crash_cnt > 0
// 伪复苏: 铜金比 5日线涨 但 铜价 5日线跌 (右侧确认)
// 这里的 SMA 5 需要在日线上计算，如果在月线上计算就是 5个月
// 上面的 request 语法有误，不能在一个 request 里请求不同品种
// 分拆请求
[cg_sma_5d, cg_sma_5d_prev] = request.security("COMEX:HG1! / COMEX:GC1! * 1000", "D", [ta.sma(close, 5), ta.sma(close[1], 5)], gaps = barmerge.gaps_off)
[cop_sma_5d, cop_sma_5d_prev] = request.security("COMEX:HG1!", "D", [ta.sma(close, 5), ta.sma(close[1], 5)], gaps = barmerge.gaps_off)

is_fake_recovery = cg_sma_5d > cg_sma_5d_prev and cop_sma_5d < cop_sma_5d_prev
// 为了后续逻辑兼容，cg_ratio 依然需要赋值
float cg_ratio = cg_ratio_d
// 计算 cg_ratio_prev 仅用于后续简单对比，这里可以用 cg_ratio_d / (1 + chg) 反推
float cg_ratio_prev = cg_ratio_d / (1 + cg_chg_pct_d / 100)
// copper 变量也需要赋值用于后续显示
// 只需要补充 copper_prev
float copper_prev_val = request.security("COMEX:HG1!", "D", close[1], gaps = barmerge.gaps_off)
float copper_prev = copper_prev_val

// --- 8. 萨姆规则 (就业) ---
// 确认时长: 非农公布日
[sahm_val, sahm_time] = request.security("FRED:SAHMREALTIME", "M", [close, time], gaps = barmerge.gaps_off)
// ICSA 预警: 初请失业金同比 > 15%
[icsa, icsa_yoy, icsa_yoy_prev] = request.security("FRED:ICSA", "W", [close, (close / close[52] - 1) * 100, (close[1] / close[53] - 1) * 100], gaps = barmerge.gaps_off)
// 连续 2 周确认
icsa_warn = icsa_yoy > 15.0 and icsa_yoy_prev > 15.0

// ==========================================
// 3. 评分逻辑 (Scoring Logic)
// ==========================================

// --- 权重系统 ---
// 基础权重
float w1=1.0, float w2=1.0, float w3=1.0, float w4=1.0
float w5=1.0, float w6=1.0, float w7=1.0, float w8=1.0

// 时代判定 (Regime)
bool is_inflation_era = us_cpi_yoy > 3.0
bool is_panic_era     = sahm_val >= 0.5 or is_bull_steep

// 动态权重调整
if is_inflation_era
    w6 := 2.0 // 利润
    w7 := 2.0 // 实体
if is_panic_era
    w3 := 2.0 // 利差
    w4 := 2.0 // 信用
    w8 := 2.0 // 萨姆

// --- 评分计算 ---
float s1=0.0, float s2=0.0, float s3=0.0, float s4=0.0
float s5=0.0, float s6=0.0, float s7=0.0, float s8=0.0

// 1. EFFR
// 状态定义：基于 EMA 的周期判定
bool is_cut_cycle  = effr_live < effr_ema - th_effr_noise
bool is_hike_cycle = effr_live > effr_ema + th_effr_noise

// 救火事件判定 (Panic Event)
bool is_panic_drop = is_cut_cycle and effr_drop >= 0.50

// 计算距离上次救火事件的时间 (Days)
// 使用 bar_index 辅助判断，若从未触发则为 na
int bars_since_panic = ta.barssince(is_panic_drop)
// 将 K 线数粗略转换为天数 (假设日线数据连续，如果有周末跳空则大约是 1.4 倍 bar 数，这里简单用时间差更准)
// Pine Script v6 中，time 是毫秒，一天 = 86400000
// 如果当前时间 - 上次触发时间 < 30天，则维持救火状态
bool in_panic_window = false
if not na(bars_since_panic)
    // 获取上次触发时的时间
    // 注意：ta.valuewhen(condition, source, occurrence)
    int time_of_panic = ta.valuewhen(is_panic_drop, time, 0)
    if time - time_of_panic < dur_sahm_panic * 86400000 // 90天有效期 (一个季度)
        in_panic_window := true

// 评分逻辑
if in_panic_window
    s1 := -1.0 // 救火降息 (衰退) - 有效期 90 天
else if is_hike_cycle
    s1 := -0.5 // 加息周期 (抽水)
else if is_cut_cycle
    s1 := 1.0  // 降息周期 (放水)
else
    s1 := 0.0  // 常态震荡

// 2. TIPS
int bars_tips_conf = math.max(1, math.ceil(dur_tips_conf * sec_per_day / sec_per_bar))

// 辅助函数：连续满足
is_sustained(cond, len) => math.sum(cond ? 1 : 0, len) == len

if is_sustained(rgdp_val < 0, bars_tips_conf)
    s2 := -1.0 // 滞胀/萧条
else if is_sustained(tips_live >= rgdp_val, bars_tips_conf)
    s2 := -1.0 // 虹吸
else if is_sustained(tips_live >= 0.5 * rgdp_val, bars_tips_conf)
    s2 := -0.5 // 杀估值
else if is_sustained(tips_live < 0, bars_tips_conf)
    s2 := 1.0  // 负利率
else
    s2 := 1.0  // 健康支撑

// 3. Yield Curve
if is_bull_steep
    w3 := 2.0
    s3 := -1.0 // 基础分设为-1, 配合权重2 => -2
else if yc_val < -th_yc_noise
    s3 := -0.5 // 倒挂
else if math.abs(yc_val) <= th_yc_noise
    s3 := 0.0  // 平坦
else
    // 熊陡: 双涨且长债涨幅 > 短债涨幅 (且长债涨幅显著 > 阈值)
    // 增加确认期: 连续 N 日满足条件
    // 修正：将 N 日转换为 N 个 Bar
    int bars_yc_conf = math.max(1, math.ceil(dur_yc_bear_conf * sec_per_day / sec_per_bar))
    bool is_bear_steep_raw = y10_chg > th_yc_bear_steep and y2_chg > 0 and y10_chg > y2_chg
    bool is_bear_steep = is_sustained(is_bear_steep_raw, bars_yc_conf)
    s3 := is_bear_steep ? 1.0 : 0.5 // 熊陡+1.0, 普通陡峭+0.5

// 4. OAS
if is_oas_crash
    s4 := -1.0 // 信用崩盘 (配合权重x2)
    w4 := 2.0
else if oas_val > 6.0
    s4 := -1.0 // 严重恶化
else if oas_val >= 3.5
    // 风险走阔: 趋势向上
    if oas_slope > th_oas_noise
        s4 := -0.5
    else
        s4 := 0.0 // 局部压力
else // < 3.5
    // 底部回升: 趋势向上
    if oas_slope > th_oas_noise
        s4 := 0.0
    else
        s4 := 1.0 // 风险收敛

// 5. Liquidity
// 分别计算 US 和 CN 的流动性得分，用于宏观对冲逻辑
float score_us_liq = 0.0
float score_cn_liq = 0.0

// --- US Liquidity Calculation ---
// 枯竭: <-2.0% (连续 N 月)
float sec_per_month_liq = 86400000 / 1000 * 30 // 近似
int bars_liq_conf = math.max(1, math.ceil(dur_liq_conf * sec_per_month_liq / sec_per_bar))

bool is_liq_crash = true
for i = 0 to bars_liq_conf - 1
    if us_m2_yoy[i] >= -2.0
        is_liq_crash := false
        break
        
bool is_liq_expand = true
for i = 0 to bars_liq_conf - 1
    if us_m2_yoy[i] <= th_liq_us_noise
        is_liq_expand := false
        break

if is_liq_crash
    score_us_liq := -1.0 // 枯竭
// 紧缩: <阈值 (即时)
else if us_m2_yoy < -th_liq_us_noise
    score_us_liq := -0.5 // 紧缩
// 扩张: >阈值 (连续 N 月)
else if is_liq_expand
    score_us_liq := 1.0  // 扩张
else
    score_us_liq := 0.0  // 存量博弈

// --- CN Liquidity Calculation ---
if cn_gap < -5.0
    score_cn_liq := -1.0 // 严重空转
else if cn_m1_yoy < cn_m2_yoy - th_liq_cn_noise
    score_cn_liq := -0.5 // 资金空转
else if cn_m1_yoy > cn_m2_yoy + th_liq_cn_noise
    score_cn_liq := 1.0  // 活化
else
    score_cn_liq := 0.0  // 结构震荡

// Assign s5 based on region selection
if region == "美国"
    s5 := score_us_liq
else // CN
    s5 := score_cn_liq

// 6. Profit
if region == "美国"
    // 修正：将月数转换为 Bar 数
    float sec_per_month_prof = 86400000 / 1000 * 30 // 近似
    int bars_prof_conf = math.max(1, math.ceil(dur_prof_conf * sec_per_month_prof / sec_per_bar))

    bool is_prof_heat = true
    for i = 0 to bars_prof_conf - 1
        if us_cpi_yoy[i] <= 3.0
            is_prof_heat := false
            break
            
    bool is_prof_deflation = true
    for i = 0 to bars_prof_conf - 1
        if us_cpi_yoy[i] >= 0 or us_ppi_yoy[i] >= 0
            is_prof_deflation := false
            break

    // 过热: >3% (连续 N 月)
    if is_prof_heat
        s6 := -1.0 // 通胀过热 (配合权重x2)
        w6 := 2.0
    // 通缩幻觉: 双负 (连续 N 月)
    else if is_prof_deflation
        s6 := -1.0 // 通缩幻觉
    else if us_profit_gap < -th_prof_noise
        s6 := -0.5 // 亏损
    else if us_profit_gap > th_prof_noise
        // 走阔
        if us_profit_gap > us_profit_gap[1]
            s6 := 1.0 // 躺赚
        else
            s6 := 0.5 // 修复
    else
        s6 := 0.0 // 震荡
else // CN
    if cn_cpi_yoy > 3.0
        s6 := -1.0 // 通胀过热
        w6 := 2.0
    else if cn_cpi_yoy < 0 and cn_ppi_yoy < 0
        s6 := -1.0 // 深度通缩
    else if cn_profit_gap < -th_prof_noise
        // 亏损
        if cn_profit_gap > cn_profit_gap[1] // 收窄
            s6 := 0.5 
        else
            s6 := -0.5
    else if cn_profit_gap > th_prof_noise
        // 盈利
        if cn_profit_gap > cn_profit_gap[1]
            s6 := 1.0
        else
            s6 := 0.0
    else
        s6 := 0.0

// 7. Real Economy
if is_cg_crash
    s7 := -1.0 // 崩盘
else if cg_ratio < cg_ratio_prev * (1.0 - th_cg_noise/100.0) // 使用斜率阈值作为下跌缓冲? 这里简单处理，如果跌幅超过阈值
    s7 := -0.5 // 衰退
else if is_fake_recovery
    s7 := -0.5 // 伪复苏
else if cg_ratio > cg_ratio_prev * (1.0 + th_cg_noise/100.0) and copper > copper_prev
    s7 := 1.0  // 复苏
else
    s7 := 0.0  // 震荡

// 8. Sahm
// 修正：将周数转换为 Bar 数 (ICSA 是周更数据)
float sec_per_week = 86400000 / 1000 * 7
int bars_icsa_conf = math.max(1, math.ceil(2 * sec_per_week / sec_per_bar)) // 连续2周

// ICSA 预警: 初请失业金同比 > 15% (连续 N 周)
// 修正：使用 bars_icsa_conf 检查
bool is_icsa_warn = true
for i = 0 to bars_icsa_conf - 1
    // 注意：icsa_yoy 是周线数据，这里需要获取对应的历史值
    // 但 request.security 获取的已经是当前周期的序列
    // 简化逻辑：如果当前是周线以上周期，只需检查当前值；如果是日线，检查过去 N 天
    // 由于 icsa_yoy 已经是 request.security("W") 获取的，它在日线图上会自动填充
    // 所以直接检查当前值持续 N 个 Bar 即可
    if icsa_yoy[i] <= 15.0
        is_icsa_warn := false
        break

if sahm_val >= 0.5
    s8 := -1.0 // 衰退熔断 (配合权重x2)
    w8 := 2.0
else if sahm_val >= 0.3
    s8 := -1.0 // 衰退预警
else if is_icsa_warn
    s8 := -0.5 // ICSA 预警
else
    s8 := 1.0  // 就业健康

// --- 总分计算 ---
total_score = s1*w1 + s2*w2 + s3*w3 + s4*w4 + s5*w5 + s6*w6 + s7*w7 + s8*w8
max_score   = w1 + w2 + w3 + w4 + w5 + w6 + w7 + w8

// 熔断一票否决
bool is_meltdown = (s3 == -1.0 and w3 > 1.0) or (s4 == -1.0 and w4 > 1.0) or (s8 == -1.0 and w8 > 1.0)

// ==========================================
// 4. UI 渲染 (UI Rendering)
// ==========================================

// --- 状态文本生成器 ---
get_act_txt(score, w, meltdown_label, red_label, orange_label, yellow_label, green_label, assets_sell, assets_buy) =>
    // 熔断处理
    if score == -1.0 and w > 1.0
        "【清仓】 卖出" + assets_sell + "，买入" + assets_buy
    else if score == -1.0
        "【避险】 卖出" + assets_sell + "，买入" + assets_buy
    else if score == -0.5
        "【防御】 卖出" + assets_sell + "，买入" + assets_buy
    else if score == 0.0
        "【观察】 多看少做"
    else if score == 0.5
        "【进攻】 卖出" + assets_sell + "，买入" + assets_buy // 修复/弱进攻
    else
        "【进攻】 卖出" + assets_sell + "，买入" + assets_buy

// 资产定义
a_risk     = "风险资产"
a_tech     = "科技/顺周期"
a_safe     = "黄金/长债"
a_cash     = "美元/短债"
a_def      = "长债/成长" // 加息周期卖出
a_hyg      = "垃圾债/股票"
a_core     = "核心/红利"
a_cycle    = "周期/大宗"



// --- 颜色辅助函数 ---
get_score_col(s) =>
    if s == -1.0
        c_red
    else if s == -0.5
        c_orange
    else if s == 0.0
        c_yellow
    else
        c_lime // +0.5 or +1.0

// --- 全局文案生成 (Global Text Generation) ---
// 将文案逻辑从绘图逻辑中剥离，确保左表(Report)始终正确显示
string t1_s = "", string t1_a = ""
string t2_s = "", string t2_a = ""
string t3_s = "", string t3_a = ""
string t4_s = "", string t4_a = ""
string t5_s = "", string t5_a = ""
string t6_s = "", string t6_a = ""
string t7_s = "", string t7_a = ""
string t8_s = "", string t8_a = ""

// 1. 基准利率
if s1 == -1.0
    t1_s := "救火降息 (衰退)", t1_a := "【避险】 卖出科技/顺周期，买入黄金/长债"
else if s1 == -0.5
    t1_s := "加息周期 (抽水)", t1_a := "【防御】 卖出长债/成长，买入短债/美元"
else if s1 == 0.0
    t1_s := "常态震荡", t1_a := "【观察】 多看少做"
else
    t1_s := "降息周期 (放水)", t1_a := "【进攻】 卖出美元/短债，买入科技/长债"

// 2. 真实利率
if s2 == -1.0
    if rgdp_val < 0
        t2_s := "滞胀/萧条 (负利率陷阱)", t2_a := "【避险】 卖出所有资产，买入美元/黄金"
    else
        t2_s := "虹吸", t2_a := "【避险】 卖出所有资产，买入美元/短债"
else if s2 == -0.5
    t2_s := "杀估值", t2_a := "【防御】 卖出高估值/加密，买入核心/红利"
else if s2 == 1.0
    if tips_live < 0
        t2_s := "负利率", t2_a := "【进攻】 卖出美元，买入黄金/加密"
    else
        t2_s := "健康支撑", t2_a := "【进攻】 卖出美元，买入科技/成长"

// 3. 利差结构
if s3 == -1.0
    t3_s := "牛陡 (熔断)", t3_a := "【清仓】 卖出风险资产/大宗，买入美债/黄金"
else if s3 == -0.5
    t3_s := "倒挂 (警报)", t3_a := "【防御】 卖出成长股，买入现金/红利"
else if s3 == 0.0
    t3_s := "平坦 (震荡)", t3_a := "【观察】 多看少做"
else if s3 == 0.5
    t3_s := "陡峭 (常态)", t3_a := "【进攻】 卖出防御资产，买入风险资产"
else
    t3_s := "熊陡 (复苏)", t3_a := "【进攻】 卖出美债，买入周期股/大宗"

// 4. 信用风险
if s4 == -1.0 and w4 > 1.0
    t4_s := "危机 (熔断)", t4_a := "【清仓】 卖出垃圾债/股票，买入美元/短债"
else if s4 == -1.0
    t4_s := "严重恶化 (信用枯竭)", t4_a := "【避险】 卖出垃圾债/小盘，买入美元/短债"
else if s4 == -0.5
    t4_s := "风险走阔 (信用收缩)", t4_a := "【防御】 卖出垃圾债/小盘，买入美债"
else if s4 == 0.0
    if oas_val < 3.5
        t4_s := "底部回升 (关注)", t4_a := "【观察】 环境依然宽松，保持关注"
    else
        t4_s := "局部压力 (信用摇摆)", t4_a := "【观察】 多看少做"
else
    t4_s := "风险收敛 (信用扩张)", t4_a := "【进攻】 卖出美元，买入垃圾债/小盘"

// 5. 流动性
if region == "美国"
    if s5 == -1.0
        t5_s := "枯竭 (休克)", t5_a := "【避险】 卖出所有资产，买入美元"
    else if s5 == -0.5
        t5_s := "紧缩 (水位下降)", t5_a := "【防御】 卖出风险资产，买入现金"
    else if s5 == 0.0
        t5_s := "存量博弈 (水位不定)", t5_a := "【观察】 结构性行情，精选个股"
    else
        t5_s := "扩张 (水位上涨)", t5_a := "【进攻】 卖出美元，买入科技/成长"
else
    if s5 < 0
        if cn_gap < -5.0
            t5_s := "严重空转 (流动性陷阱)", t5_a := "【避险】 卖出所有资产，买入现金"
        else
            t5_s := "空转 (定期化)", t5_a := "【防御】 卖出重资产，买入高股息"
    else
        t5_s := "活化 (活水注入)", t5_a := "【进攻】 卖出防御资产，买入科技/成长"

// 6. 利润空间
if region == "美国"
    if s6 == -1.0 and w6 > 1.0
        t6_s := "通胀过热", t6_a := "【避险】 卖出成长股，买入能源/黄金"
    else if s6 == -1.0
        t6_s := "通缩幻觉 (双负)", t6_a := "【避险】 卖出所有资产，买入美元现金"
    else if s6 == -0.5
        t6_s := "亏损 (成本倒挂)", t6_a := "【防御】 卖出中下游制造，买入防御/红利"
    else if s6 == 0.0
        t6_s := "震荡", t6_a := "【观察】 多看少做"
    else if s6 == 0.5
        t6_s := "修复 (利润变薄)", t6_a := "【进攻】 卖出高估值，买入绩优股/核心"
    else
        t6_s := "躺赚 (利润变厚)", t6_a := "【进攻】 卖出低效资产，买入科技/成长"
else
    if s6 == -1.0
        t6_s := "通缩 (双负)", t6_a := "【避险】 卖出周期股，买入必选消费"
    else if s6 == -0.5
        t6_s := "亏损 (倒挂)", t6_a := "【防御】 卖出中游制造，买入上游资源"
    else if s6 == 0.0
        t6_s := "内卷 (利润压缩)", t6_a := "【观察】 回避同质化竞争，只看龙头"
    else
        t6_s := "修复 (改善)", t6_a := "【进攻】 卖出防御股，买入反转股"

// 7. 实体热度
if s7 == -1.0
    t7_s := "崩盘 (信心崩溃)", t7_a := "【避险】 卖出所有资产，买入美元/美债"
else if s7 == -0.5
    if is_fake_recovery
        t7_s := "伪复苏", t7_a := "【防御】 卖出工业品/铜，买入黄金/美债"
    else
        t7_s := "衰退 (弃修鱼池)", t7_a := "【防御】 卖出强周期板块，买入黄金/美债"
else if s7 == 0.0
    t7_s := "震荡", t7_a := "【观察】 多看少做"
else
    t7_s := "复苏 (扩建鱼池)", t7_a := "【进攻】 卖出避险资产，买入周期股/工业品"

// 8. 萨姆规则
if s8 == -1.0 and w8 > 1.0
    t8_s := "衰退熔断", t8_a := "【清仓】 卖出风险资产，买入美债/黄金"
else if s8 == -1.0
    t8_s := "衰退预警", t8_a := "【避险】 卖出风险资产，买入美债"
else if s8 == -0.5
    t8_s := "ICSA 提前预警", t8_a := "【防御】 卖出风险资产，买入现金/红利"
else
    t8_s := "就业健康", t8_a := "【进攻】 卖出避险资产，买入科技/消费"

// 绘制主图曲线
float plot_val = 0.0
// 默认颜色根据当前模式的得分
color dyn_c = c_white

if mode == "1. 基准利率"
    plot_val := effr_live
    // 修复：基准利率的颜色应该反映“救火”状态
    // 如果是月线图，且发生了救火降息 (effr_drop_max_22d >= 0.5)，则强制红色
    bool is_fire_cut_month = timeframe.ismonthly and effr_drop_max_22d >= 0.5
    dyn_c := is_fire_cut_month ? c_red : get_score_col(s1)
else if mode == "2. 真实利率"
    plot_val := tips_live
    dyn_c := get_score_col(s2)
else if mode == "3. 利差结构"
    plot_val := yc_val
    dyn_c := get_score_col(s3)
else if mode == "4. 信用风险"
    plot_val := oas_val
    dyn_c := get_score_col(s4)
else if mode == "5. 流动性"
    plot_val := region == "美国" ? us_m2_yoy : cn_gap
    dyn_c := get_score_col(s5)
else if mode == "6. 利润空间"
    plot_val := region == "美国" ? us_profit_gap : cn_profit_gap
    dyn_c := get_score_col(s6)
else if mode == "7. 实体热度"
    plot_val := cg_ratio
    // 修复：铜金比颜色应该反映“月内崩盘”状态
    // 如果是月线图，且发生了崩盘 (was_crash_in_month)，则强制红色
    bool is_cg_crash_month = timeframe.ismonthly and was_crash_in_month > 0
    dyn_c := is_cg_crash_month ? c_red : get_score_col(s7)
else if mode == "8. 萨姆规则"
    plot_val := sahm_val
    dyn_c := get_score_col(s8)

// --- 综合绘图 (Plotting) ---
// 1. 基准利率: 阶梯图 + EMA
plot(mode == "1. 基准利率" ? plot_val : na, "EFFR", color = dyn_c, linewidth = 2, style = plot.style_stepline)
plot(mode == "1. 基准利率" ? effr_ema : na, "EFFR EMA", color = color.blue, linewidth = 1)

// 2. 真实利率: TIPS + RGDP + 阈值
// 优化：RGDP 极端值截断 (仅用于绘图，不影响逻辑)
// 2020年Q2 GDP 暴跌至 -30%，Q3 暴涨至 +33%，会导致 Y 轴压缩
// 将绘图用的 RGDP 限制在 -10% 到 +10% 之间，恢复常规波动的可见性
float rgdp_plot = math.max(math.min(rgdp_val, 10.0), -10.0)

plot(mode == "2. 真实利率" ? plot_val : na, "TIPS", color = dyn_c, linewidth = 2)
plot(mode == "2. 真实利率" ? rgdp_plot : na, "RGDP", color = color.gray, linewidth = 1, style = plot.style_stepline)
plot(mode == "2. 真实利率" ? 0.5 * rgdp_plot : na, "0.5 RGDP", color = color.new(color.orange, 50), style = plot.style_circles)

// 添加 RGDP 极端值标签 (显示真实值)
// 优化：仅在"季度结束"时绘制上一个季度的标签，确保每个季度只有一个标签，彻底解决重叠问题
// 检测季度变化: 当前季度 != 上一根K线的季度
int cur_q = math.ceil(month(time) / 3.0)
int prev_q_idx = math.ceil(month(time[1]) / 3.0)
bool is_new_quarter = (cur_q != prev_q_idx) or (year(time) != year(time[1]))

// 变量记录上一次绘制的标签数值，用于去重
var float last_lbl_val = 0.0
// 始终根据当前 K 线的数据时间更新日期字符串
// 修正：增加 5 天偏移量，防止时区导致季度首日(10.1)漂移回上月(9.30)而被误判为Q3
int t_rgdp = rgdp_time + 5 * 86400000
int y_rgdp = year(t_rgdp)
int m_rgdp = month(t_rgdp)
int q_rgdp = math.ceil(m_rgdp / 3.0)
string rgdp_date_str = " (" + str.tostring(y_rgdp) + " Q" + str.tostring(q_rgdp) + ")"

// 优化：放弃复杂的历史回溯居中算法，改用"数据突变点 + 时间偏移"的物理定位法
// 仅在 RGDP 数值发生突变 (新季度数据发布) 时绘制
if mode == "2. 真实利率" and ta.change(rgdp_val) != 0
    // 获取当前新的 RGDP 值
    float cur_val = rgdp_val
    
    // 只有当当前值是极端值，且与上一次标注的值不同时才画
    if (cur_val > 10.0 or cur_val < -10.0) and cur_val != last_lbl_val
        // 计算居中时间：当前时间 + 45天 (季度的一半)
        // 使用 xloc.bar_time 确保在任意周期图表上都在季度中间
        int time_mid = time + 45 * 86400000
        
        // 重新计算当前的截断值 (用于定位标签Y轴)
        float plot_y = math.max(math.min(cur_val, 10.0), -10.0)
        
        if cur_val > 10.0
            // 上方截断: 标签在上，箭头向下指
            label.new(time_mid, plot_y, "▲ " + str.tostring(cur_val, "0.0") + "%", xloc = xloc.bar_time, color = c_lime, style = label.style_label_down, textcolor = c_white, size = size.tiny)
        else
            // 下方截断: 标签在下，箭头向上指
            label.new(time_mid, plot_y, "▼ " + str.tostring(cur_val, "0.0") + "%", xloc = xloc.bar_time, color = c_red, style = label.style_label_up, textcolor = c_white, size = size.tiny)
        
        // 更新记录
        last_lbl_val := cur_val

// 处理当前最新的季度 (如果当前是极端值，且还没结束，暂时画在最后)
if barstate.islast and mode == "2. 真实利率" and (rgdp_val > 10.0 or rgdp_val < -10.0)
    // 防止重复：如果最后一根K线刚好也是季度第一天，上面的逻辑已经画过了，这里就不画
    if not is_new_quarter
        float plot_y_cur = math.max(math.min(rgdp_val, 10.0), -10.0)
        if rgdp_val > 10.0
            label.new(bar_index, plot_y_cur, "▲ " + str.tostring(rgdp_val, "0.0") + "%", color = c_lime, style = label.style_label_down, textcolor = c_white, size = size.tiny)
        else
            label.new(bar_index, plot_y_cur, "▼ " + str.tostring(rgdp_val, "0.0") + "%", color = c_red, style = label.style_label_up, textcolor = c_white, size = size.tiny)

// 添加 RGDP 标签
if barstate.islast and mode == "2. 真实利率"
    // RGDP 标签
    label.new(bar_index, rgdp_plot, "真实美国GDP | RGDP" + rgdp_date_str, 
              color = color.gray, 
              style = label.style_label_lower_left, 
              textcolor = c_white, 
              size = size.small, 
              textalign = text.align_left)
    
    // 0.5 RGDP 标签
    label.new(bar_index, 0.5 * rgdp_plot, "0.5 RGDP", 
              color = color.orange, 
              style = label.style_label_upper_left, 
              textcolor = c_white, 
              size = size.small, 
              textalign = text.align_left)

// 3. 利差结构: 10Y-2Y
// 牛陡熔断: 使用深红背景 + 文本标记
bool is_bull_steep_melt = mode == "3. 利差结构" and s3 == -1.0 and w3 > 1.0

// 1. 曲线变色 (保持深红)
color yc_col = is_bull_steep_melt ? c_super_red : dyn_c
// Fix: linewidth expects input int (constant), cannot be series. Use constant 2.
plot(mode == "3. 利差结构" ? plot_val : na, "10Y-2Y", color = yc_col, linewidth = 2)

// 2. 背景高亮 (深红半透明)
// Fix: bgcolor color argument must be color, not bool.
// Fix: title is optional.
bgcolor(is_bull_steep_melt ? color.new(c_super_red, 70) : na, title="Bull Steep Melt BG")

// 3. 文本标记 (仅在熔断开始时显示，避免拥挤)
if is_bull_steep_melt and not is_bull_steep_melt[1]
    label.new(bar_index, plot_val, "牛陡\n熔断", color = c_super_red, style = label.style_label_down, textcolor = c_white, size = size.small)


// 4. 信用风险: OAS + 阈值
plot(mode == "4. 信用风险" ? plot_val : na, "OAS", color = dyn_c, linewidth = 2)
plot(mode == "4. 信用风险" ? 10.0 : na, "OAS 10", color = c_super_red, style = plot.style_circles)
plot(mode == "4. 信用风险" ? 6.0 : na, "OAS 6", color = c_red)
plot(mode == "4. 信用风险" ? 3.5 : na, "OAS 3.5", color = c_lime)

// 5. 流动性: M2 YoY + 阈值
plot(mode == "5. 流动性" ? plot_val : na, "Liquidity", color = dyn_c, linewidth = 2)
plot(mode == "5. 流动性" and region == "美国" ? -2.0 : na, "M2 -2", color = c_red)

// 6. 利润空间: Gap
plot(mode == "6. 利润空间" ? plot_val : na, "Profit Gap", color = dyn_c, linewidth = 2)

// 7. 实体热度: 铜金比
plot(mode == "7. 实体热度" ? plot_val : na, "Copper/Gold", color = dyn_c, linewidth = 2)

// 8. 萨姆规则: Sahm + 阈值
plot(mode == "8. 萨姆规则" ? plot_val : na, "Sahm", color = dyn_c, linewidth = 2)
plot(mode == "8. 萨姆规则" ? 0.5 : na, "Sahm 0.5", color = c_red, style = plot.style_circles)
plot(mode == "8. 萨姆规则" ? 0.3 : na, "Sahm 0.3", color = c_orange)

// 通用 0 轴 (虚线)
hline(0, "Zero Line", color = color.gray, linestyle = hline.style_dashed)

// --- 看板绘制 ---
var table rpt = table.new(position.middle_left, 7, 11, bgcolor = c_bg, border_width = 1, border_color = color.gray)
var table info = table.new(position.middle_right, 4, 6, bgcolor = c_bg, border_width = 1, border_color = color.gray)

// Helper to fill row
fill_row(r, name, val_str, s, w, meta, status, action, is_melt) =>
    c_s = get_score_col(s)
    w_str = w > 1.0 ? "x2" : ""
    // 修正分数显示格式：移除多余符号，确保正数带+，负数带-，0不带
    float final_s = s * w
    string s_str = final_s > 0 ? "+" + str.tostring(final_s, "#.#") : (final_s == 0 ? "0" : str.tostring(final_s, "#.#"))
    
    // 熔断检测: 仅针对 "数值" 和 "现状含义" 修改背景色 (深红 + 黄字)
    bool is_meltdown_row = is_melt
    color bg_hlt = is_meltdown_row ? c_super_red : c_bg
    color txt_hlt_val = is_meltdown_row ? c_yellow : c_s
    color txt_hlt_stat = is_meltdown_row ? c_yellow : c_white

    table.cell(rpt, 0, r, name, text_color = c_white, bgcolor = c_bg)
    table.cell(rpt, 1, r, val_str, text_color = txt_hlt_val, bgcolor = bg_hlt)
    table.cell(rpt, 2, r, s_str, text_color = c_score_col, bgcolor = c_bg)
    table.cell(rpt, 3, r, w_str, text_color = c_white, bgcolor = c_bg) 
    table.cell(rpt, 4, r, meta, text_color = c_white, bgcolor = c_bg)
    table.cell(rpt, 5, r, status, text_color = txt_hlt_stat, bgcolor = bg_hlt)
    table.cell(rpt, 6, r, action, text_color = c_s, bgcolor = c_bg, text_halign = text.align_left)

if barstate.islast and show_report
    // --- 左表: 报告 ---
    // Header
    table.cell(rpt, 0, 0, "维度", text_color = c_white, bgcolor = c_header)
    table.cell(rpt, 1, 0, "数值", text_color = c_white, bgcolor = c_header)
    table.cell(rpt, 2, 0, "得分", text_color = c_white, bgcolor = c_header)
    table.cell(rpt, 3, 0, "权重", text_color = c_white, bgcolor = c_header)
    table.cell(rpt, 4, 0, "比喻", text_color = c_white, bgcolor = c_header)
    table.cell(rpt, 5, 0, "现状含义", text_color = c_white, bgcolor = c_header)
    table.cell(rpt, 6, 0, "建议操作逻辑", text_color = c_white, bgcolor = c_header)

    fill_row(1, "1.基准利率", str.tostring(effr_live, "0.00")+"%", s1, w1, "总水坝闸门", t1_s, t1_a, false)
    fill_row(2, "2.真实利率", str.tostring(tips_live, "0.00")+"%", s2, w2, "水厂回购价", t2_s, t2_a, false)
    fill_row(3, "3.利差结构", str.tostring(yc_val, "0.00"), s3, w3, "天气预报", t3_s, t3_a, s3 == -1.0 and w3 > 1.0)
    fill_row(4, "4.信用风险", str.tostring(oas_val, "0.00")+"%", s4, w4, "风险保证金", t4_s, t4_a, s4 == -1.0 and w4 > 1.0)
    
    string l5_v = region == "美国" ? str.tostring(us_m2_yoy, "0.00")+"%" : str.tostring(cn_gap, "0.00")+"%"
    fill_row(5, "5.流动性", l5_v, s5, w5, "鱼池活水率", t5_s, t5_a, false)
    
    string l6_v = region == "美国" ? str.tostring(us_profit_gap, "0.00")+"%" : str.tostring(cn_profit_gap, "0.00")+"%"
    fill_row(6, "6.利润空间", l6_v, s6, w6, "养鱼账本", t6_s, t6_a, false)
    
    fill_row(7, "7.实体热度", str.tostring(cg_ratio, "0.00"), s7, w7, "铜金比", t7_s, t7_a, false)
    fill_row(8, "8.萨姆规则", str.tostring(sahm_val, "0.00")+"%", s8, w8, "死神信号", t8_s, t8_a, s8 == -1.0 and w8 > 1.0)

    // Row 9: Macro Hedge Strategy
    // Logic: US (Liquidity + Rate), CN (Liquidity)
    // 修复：强制使用分离后的 US 和 CN 流动性数据，不再依赖 s5
    bool us_loose = s1 == 1.0 or score_us_liq == 1.0 // US: 降息 OR M2扩张
    bool us_tight = s1 < 0 or score_us_liq < 0       // US: 加息/救火 OR M2紧缩/枯竭
    bool us_panic = is_panic_era or is_meltdown      // US: 恐慌

    // CN: Loose (Activate), Tight (Idle), Flat
    bool cn_loose = score_cn_liq == 1.0
    bool cn_tight = score_cn_liq < 0

    string strat_t = "", string strat_d = "", string strat_us = "", string strat_cn = ""
    color strat_c = c_white
    
    if us_loose and cn_loose
        strat_t := "🟢 共振复苏", strat_d := "【全仓猛干】 买铜、原油、澳元、新兴市场(港股/A股)", strat_c := c_lime
        strat_us := "🟢 美松 (印钱)", strat_cn := "🟢 中松 (放水)"
    else if us_tight and cn_tight
        strat_t := "🔴 双重紧缩", strat_d := "【现金为王】 只持有美元现金，或者做空 A 股", strat_c := c_orange
        strat_us := "🟠 美紧 (抽水)", strat_cn := "🟠 中紧 (空转)"
    else if us_panic and cn_tight
        strat_t := "🔴 衰退共振", strat_d := "【避险】 买美债、黄金、日元避险", strat_c := c_orange
        strat_us := "🔴 美恐 (救火)", strat_cn := "🟠 中紧 (空转)"
    else if us_panic and cn_loose
        strat_t := "🟠 东升西降", strat_d := "【结构性做多】 买 A股龙头，做空美股", strat_c := c_yellow
        strat_us := "🔴 美恐 (救火)", strat_cn := "🟢 中松 (放水)"
    else if us_tight and cn_loose
        strat_t := "🟠 分化博弈", strat_d := "【两头吃】 存美元吃利息，同时买 A股结构性机会", strat_c := c_yellow
        strat_us := "🟠 美紧 (加息)", strat_cn := "🟢 中松 (放水)"
    else if us_loose and cn_tight
        strat_t := "🟠 单极驱动", strat_d := "【只买美国】 买美股科技/黄金，千万别碰工业品", strat_c := c_yellow
        strat_us := "🟢 美松 (降息)", strat_cn := "🟠 中紧 (躺平)"
    else
        strat_t := "🟡 垃圾时间", strat_d := "【多看少动】 别瞎折腾，等新趋势出来", strat_c := c_yellow
        strat_us := "🟡 美平", strat_cn := "🟡 中平"

    table.cell(rpt, 0, 9, "中美宏观对冲", bgcolor = c_navy_60, text_color = c_white), table.merge_cells(rpt, 0, 9, 1, 9)
    table.cell(rpt, 2, 9, strat_t, bgcolor = c_navy_60, text_color = strat_c), table.merge_cells(rpt, 2, 9, 3, 9)
    table.cell(rpt, 4, 9, strat_us + "\n" + strat_cn, bgcolor = c_navy_60, text_color = c_white, text_size = size.small)
    table.cell(rpt, 5, 9, strat_d, bgcolor = c_navy_60, text_color = c_white), table.merge_cells(rpt, 5, 9, 6, 9)

    // Row 10: Final Diagnosis
    string final_res = "", string final_sugg = ""
    color final_bg = c_gray_dark
    color final_txt = c_white
    
    if is_meltdown
        final_res := "【熔断】 " + (s3==-1.0 and w3>1.0 ? "3.牛陡 " : "") + (s4==-1.0 and w4>1.0 ? "4.信用 " : "") + (s8==-1.0 and w8>1.0 ? "8.萨姆" : "")
        final_sugg := "清仓，仅留黄金/美债底仓"
        final_bg := c_super_red
        final_txt := c_yellow
    else if total_score < -5.0
        final_res := "危机模式", final_sugg := "风险仓位 < 10%"
        final_bg := c_red
        final_txt := c_white
    else if total_score < -1.5
        final_res := "衰退预警", final_sugg := "风险仓位 10-30%"
        final_bg := c_orange
        final_txt := c_black
    else if total_score < 1.5
        final_res := "混沌震荡", final_sugg := "风险仓位 30-50%"
        final_bg := c_yellow
        final_txt := c_black
    else if total_score <= 5.0
        final_res := "温和增长", final_sugg := "风险仓位 50-80%"
        final_bg := c_lime
        final_txt := c_black
    else // > 5.0
        final_res := "全面复苏", final_sugg := "风险仓位 80-100%"
        final_bg := c_super_green

    table.cell(rpt, 0, 10, "最终诊断", bgcolor = c_bg, text_color = c_white), table.merge_cells(rpt, 0, 10, 1, 10)
    
    string total_s_str = total_score > 0 ? "+" + str.tostring(total_score, "#.#") : (total_score == 0 ? "0" : str.tostring(total_score, "#.#"))
    table.cell(rpt, 2, 10, total_s_str, bgcolor = final_bg, text_color = final_txt)
    
    table.cell(rpt, 3, 10, str.tostring(max_score, "#.#"), bgcolor = c_bg, text_color = c_white)
    table.cell(rpt, 4, 10, "结论", bgcolor = c_bg, text_color = c_white)
    table.cell(rpt, 5, 10, final_res, bgcolor = final_bg, text_color = final_txt)
    table.cell(rpt, 6, 10, final_sugg, bgcolor = final_bg, text_color = final_txt)

    // --- 右表: 详情 ---
    string d_title="", string d_def="", string d_obs="", string d_logic="", string d_conf="", string d_w="", string d_cur_stat="", string d_cur_val="", string d_turn_val="", string d_cur_mean="", string d_risk="", string d_tactics="", string d_tactics_turn=""
    
    if mode == "1. 基准利率"
        d_title := "基准利率\n[EFFR]", d_def := "美联储联邦基金有效利率\n全球资金成本的总阀门。"
        d_obs := "10月 (EMA)", d_logic := "🔴 救火: ≥50bp\n🟠 加息: >EMA\n🟡 震荡: ≈EMA\n🟢 降息: <EMA", d_conf := "FOMC公布日确认"
        d_w := w1 > 1.0 ? "x2" : "x1"
        d_cur_stat := t1_s
        d_cur_val := str.tostring(effr_live, "0.00") + "% | " + fmt_ymd(effr_time)
        
        // 1. 基准利率含义与战术 (全状态覆盖)
        if s1 == -1.0 // 救火
            d_cur_mean := "衰退确信，初期伴随暴跌"
            d_tactics  := "此时降息预期极强\n买长债对冲股票下跌"
            d_turn_val := "降幅收窄 (恐慌消退)"
            d_tactics_turn := "恐慌消退，尝试左侧建仓\n买入超跌资产"
        else if s1 == -0.5 // 加息
            d_cur_mean := "资金变贵，现金为王"
            d_tactics  := "买短债吃高息，等跌\n规避久期敏感资产"
            d_turn_val := "跌破 EMA (停止加息)"
            d_tactics_turn := "停止加息，资金面转宽\n满仓买入利率敏感资产"
        else if s1 == 0.0 // 震荡
            d_cur_mean := "政策观望，方向未定"
            d_tactics  := "政策方向不明朗，观察期\n多看少动"
            d_turn_val := "跌破 EMA (开始降息)"
            d_tactics_turn := "确认降息周期开启\n加大杠杆做多"
        else // 降息
            d_cur_mean := "资金便宜，利好成长"
            d_tactics  := "布局科技、加密和生物医药\n利好利率敏感资产"
            d_turn_val := "上穿 EMA (停止降息)"
            d_tactics_turn := "降息结束，利好出尽\n落袋为安，防范通胀反弹"
            
        if s1 == -1.0
            d_risk := "恐慌消退"
        else if s1 == -0.5
            d_risk := "流动性转宽"
        else if s1 == 1.0
            d_risk := "流动性收紧"
        else
            d_risk := "方向明确"

    else if mode == "2. 真实利率"
        d_title := "真实利率\n[TIPS]", d_def := "10年期通胀保值债券收益率\nTIPS 上行 = 资金流出风险资产(买美债)\nTIPS 下行 = 资金流入风险资产(买股票)\nTIPS ≥ RGDP，会对风险资产产生‘虹吸效应’"
        d_obs := "日线 (实时)", d_logic := "🔴 滞胀: RGDP < 0\n🔴 虹吸: ≥ RGDP\n🟠 杀估值: ≥ 0.5RGDP\n🟢 健康: < 0.5RGDP\n🟢 负利率: < 0", d_conf := "连续5日确认"
        d_w := w2 > 1.0 ? "x2" : "x1"
        d_cur_stat := t2_s
        d_cur_val := str.tostring(tips_live, "0.00") + "% | " + fmt_ymd(tips_time)
        
        // 2. 真实利率含义与战术
        if s2 == -1.0
            if rgdp_val < 0 // 滞胀
                d_cur_mean := "经济停滞，物价飞涨"
                d_tactics  := "现金为王，卖出所有资产\n买入美元/黄金"
                d_turn_val := "RGDP 转正 (经济复苏)"
                d_tactics_turn := "经济复苏，重仓股票\n关注周期反转"
            else // 虹吸
                d_cur_mean := "无风险收益极高，虹吸一切"
                d_tactics  := "只有美元现金最安全\n卖出风险资产"
                d_turn_val := "跌破 RGDP"
                d_tactics_turn := "虹吸效应结束，配置核心资产\n资金重回股市"
        else if s2 == -0.5 // 杀估值
            d_cur_mean := "实际资金成本过高，压制估值"
            d_tactics  := "买低估值红利股\n规避高估值成长股"
            d_turn_val := "跌破 0.5 RGDP"
            d_tactics_turn := "估值压制解除，买入成长股\n科技股迎来春天"
        else if s2 == 1.0
            if tips_live < 0 // 负利率
                d_cur_mean := "实际利率为负，资产泡沫化"
                d_tactics  := "实物资产/数字黄金抗贬值\n满仓风险资产"
                d_turn_val := "利率转正"
                d_tactics_turn := "泡沫退潮，卖出黄金/加密\n转入防御性资产"
            else // 健康
                d_cur_mean := "资金成本适宜，利好股市"
                d_tactics  := "安心持有成长股\n享受估值溢价"
                d_turn_val := tips_live >= 0.5 * rgdp_val ? "突破 0.5 RGDP（确认中）" : "突破 0.5 RGDP"
                d_tactics_turn := "实际利率上行，减仓高估值\n切换至价值股"
            
        if s2 == -1.0
            if rgdp_val < 0 // 滞胀
                d_risk := "复苏开启"
            else // 虹吸
                d_risk := "压力缓解"
        else if s2 == -0.5 // 杀估值
            d_risk := "估值修复"
        else if s2 == 1.0
            if tips_live < 0 // 负利率
                d_risk := "泡沫破裂"
            else // 健康
                d_risk := "压力增大"
        else
            d_risk := "方向未定"

    else if mode == "3. 利差结构"
        d_title := "利差结构\n[10Y-2Y]", d_def := "10年期与2年期美债利差\n10Y看长期(经济前景); 2Y看短期(美联储政策)"
        d_obs := "20日 (趋势)", d_logic := "🛑 牛陡: 2Y 跌幅高于 10Y\n🟠 倒挂: 10Y < 2Y\n🟡 平坦: 10Y ≈ 2Y\n🟢 常态: 10Y > 2Y\n🟢 熊陡: 10Y 涨幅高于 2Y", d_conf := "即时生效(20日趋势)确认"
        d_w := w3 > 1.0 ? "x2" : "x1"
        d_cur_stat := t3_s
        d_cur_val := str.tostring(yc_val, "0.00")
        
        // 3. 利差含义与战术
        if s3 == -1.0 // 牛陡
            d_cur_mean := "衰退迫在眉睫，恐慌蔓延"
            d_tactics  := "立刻清空股票\n避险资金涌入，买美债/黄金"
            d_turn_val := "短债企稳 (恐慌消退)"
            d_tactics_turn := "恐慌消退，尝试左侧建仓\n买入超跌资产"
        else if s3 == -0.5 // 倒挂
            d_cur_mean := "长期前景堪忧，资金避险"
            d_tactics  := "衰退倒计时，收缩战线\n买防御性资产，避激进投资"
            d_turn_val := "重新转正 (解除警报)"
            d_tactics_turn := "警报解除，右侧确认买入\n加仓风险资产"
        else if s3 == 0.0 // 平坦
            d_cur_mean := "经济方向未定，多空博弈"
            d_tactics  := "倒挂/走阔转换期\n方向未定，多看少做"
            d_turn_val := "重新转正 (复苏确认)"
            d_tactics_turn := "复苏确认，加仓周期股\n做多商品"
        else if s3 == 0.5 // 陡峭 (常态)
            d_cur_mean := "经济正向运转，借短贷长获利"
            d_tactics  := "宏观环境无虞，持有风险资产\n只要不是倒挂，安心赚钱"
            d_turn_val := "重新倒挂"
