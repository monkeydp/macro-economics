//@version=6
indicator("[薯仔] 宏观经济审计看板", overlay = false, precision = 2, max_labels_count = 500)

// ==========================================
// 1. 设置与配色 (Settings & Colors)
// ==========================================
show_report = input.bool(true, "显示决策看板", group="显示设置")
mode = input.string("1. 基准利率", "当前显示曲线",
     options=["1. 基准利率", "2. 真实利率", "3. 利差结构",
     "4. 信用风险", "5. 流动性", "6. 利润空间",
     "7. 实体热度", "8. 萨姆规则"], group="显示设置")
region = input.string("美国", "监控地区", options=["美国", "中国"], group="显示设置", tooltip="仅影响: 5.流动性 / 6.利润空间")

// 参数设置
effr_ema_len = input.int(10, "基准利率 EMA 周期", minval=1, group="周期参数设置", tooltip="仅影响: 1.基准利率")
yoy_len = input.int(12, "增速同比周期", minval=1, group="周期参数设置", tooltip="仅影响: 5.流动性 / 6.利润空间")
slope_len = input.int(20, "斜率观测周期", minval=1, group="周期参数设置", tooltip="仅影响: 3.利差结构 / 4.信用风险 / 7.实体热度")

// 新增：震荡过滤阈值 (Noise Filters)
grp_noise = "震荡过滤阈值 (Noise)"
th_effr_noise   = input.float(0.05, "基准利率震荡", minval=0.0, group=grp_noise)
th_yc_noise     = input.float(0.05, "利差结构震荡",   minval=0.0, group=grp_noise)
th_oas_noise    = input.float(0.01, "信用风险斜率",  minval=0.0, group=grp_noise)
th_liq_us_noise = input.float(0.20, "美国流动性",     minval=0.0, group=grp_noise)
th_liq_cn_noise = input.float(0.50, "中国流动性",  minval=0.0, group=grp_noise)
th_prof_noise   = input.float(0.10, "利润空间",   minval=0.0, group=grp_noise)
th_cg_noise     = input.float(0.05, "铜金比斜率",     minval=0.0, group=grp_noise)

// 颜色定义
c_red          = color.red      // 🔴 红色 (得分 -1.0)
c_orange       = color.orange   // 🟠 橙色 (得分 -0.5)
c_yellow       = color.yellow   // 🟡 黄色 (得分 0.0)
c_lime         = color.lime     // 🟢 亮绿 (得分 +1.0 / +0.5)
c_super_red    = #800000        // 🛑 深红 (熔断背景)
c_super_green  = #006400        // 🟢 深绿 (满仓背景)
c_navy_60      = color.new(#000080, 40) // 海军蓝60 (宏观对冲行背景)
c_beige        = #F5F5DC        // 米色 (标签文字)
c_score_col    = #78D6FB        // 浅蓝 (得分/权重)
c_gray_dark    = #333333        // 深灰 (默认背景)
c_bg           = color.new(c_gray_dark, 10) // 背景色
c_header       = color.new(color.gray, 10)  // 表头背景
c_white        = color.white
c_black        = color.black

// ==========================================
// 2. 数据获取与计算 (Data Fetching)
// ==========================================

// --- Helper Functions ---
fmt_ym(t) => str.tostring(year(t)) + "-" + (month(t) < 10 ? "0" : "") + str.tostring(month(t))
fmt_ymd(t) => str.tostring(year(t)) + "-" + (month(t) < 10 ? "0" : "") + str.tostring(month(t)) + "-" + (dayofmonth(t) < 10 ? "0" : "") + str.tostring(dayofmonth(t))

calc_slope_linreg(src, len) => 
    slope = ta.linreg(src, len, 0) - ta.linreg(src, len, 1)
    slope

calc_yoy(src, len) => (src / src[len] - 1) * 100

// --- 1. 基准利率 (EFFR) ---
// 确认时长: FOMC 公布日
// 修改：只获取当前值，在本地计算跌幅，以适应不同周期 (周线/月线也能捕捉到降息)
[effr_live, effr_time] = request.security("FRED:EFFR", "D", [close, time], gaps = barmerge.gaps_off)
// 修改：使用月线 EMA 以匹配长期趋势 (10月EMA)
effr_ema  = request.security("FRED:EFFR", "M", ta.ema(close, effr_ema_len), gaps = barmerge.gaps_off)
// 核心修正：对比上一根 K 线的值 (适应周线/月线)，并放宽阈值至 45bp 以防数据波动
effr_drop = effr_live[1] - effr_live

// --- 2. 真实利率 (TIPS) ---
// 确认时长: 连续 5 日
[tips_live, tips_time] = request.security("FRED:DFII10", "D", [close, time], gaps = barmerge.gaps_off)
rgdp_val  = request.security("FRED:A191RL1Q225SBEA", "D", close, gaps = barmerge.gaps_off)

// --- 3. 利差结构 (10Y-2Y) ---
// 确认时长: 即时生效 (基于 20 日趋势)
[y10, y10_prev] = request.security("FRED:GS10", "D", [close, close[1]], gaps = barmerge.gaps_off)
[y2, y2_prev]   = request.security("FRED:GS2", "D", [close, close[1]], gaps = barmerge.gaps_off)
yc_val = y10 - y2
// 熔断检测: 双跌且短债跌幅 > 长债跌幅
y10_chg = y10 - y10_prev
y2_chg  = y2 - y2_prev
is_bull_steep_trigger = y10_chg < 0 and y2_chg < 0 and y2_chg < y10_chg
// 锁定 5 日
var int bull_steep_cnt = 0
if is_bull_steep_trigger
    bull_steep_cnt := 5
else if bull_steep_cnt > 0
    bull_steep_cnt := bull_steep_cnt - 1
is_bull_steep = bull_steep_cnt > 0

// --- 4. 信用风险 (OAS) ---
// 确认时长: 连续 3 日; 熔断即时
[oas_val, oas_slope, oas_chg_5d_pct] = request.security("FRED:BAMLH0A0HYM2", "D", [close, calc_slope_linreg(close, slope_len), (close / close[5] - 1) * 100], gaps = barmerge.gaps_off)
// 熔断检测: >10% 或 (>6% 且 5日涨幅 > 20%)
is_oas_crash_trigger = oas_val > 10.0 or (oas_val > 6.0 and oas_chg_5d_pct > 20.0)
// 锁定 5 日
var int oas_crash_cnt = 0
if is_oas_crash_trigger
    oas_crash_cnt := 5
else if oas_crash_cnt > 0
    oas_crash_cnt := oas_crash_cnt - 1
is_oas_crash = oas_crash_cnt > 0

// --- 5. 流动性 (M2 / M1-M2) ---
// 确认时长: 连续 2 个月
[us_m2_real, us_m2_yoy, us_m2_time] = request.security("FRED:M2REAL", "M", [close, calc_yoy(close, yoy_len), time], gaps = barmerge.gaps_off)

[cn_m1, cn_m1_yoy, cn_time] = request.security("ECONOMICS:CNM1", "M", [close, calc_yoy(close, yoy_len), time], gaps = barmerge.gaps_off)
[cn_m2, cn_m2_yoy] = request.security("ECONOMICS:CNM2", "M", [close, calc_yoy(close, yoy_len)], gaps = barmerge.gaps_off)
cn_gap = cn_m1_yoy - cn_m2_yoy

// --- 6. 利润空间 (CPI-PPI) ---
// 确认时长: 连续 2 个月
[us_cpi, us_cpi_yoy, us_prof_time] = request.security("FRED:CPIAUCSL", "M", [close, calc_yoy(close, yoy_len), time], gaps = barmerge.gaps_off)
[us_ppi, us_ppi_yoy] = request.security("FRED:PPIACO", "M", [close, calc_yoy(close, yoy_len)], gaps = barmerge.gaps_off)
us_profit_gap = us_cpi_yoy - us_ppi_yoy

cn_cpi_yoy = request.security("ECONOMICS:CNCPI", "M", calc_yoy(close, yoy_len), gaps = barmerge.gaps_off)
cn_ppi_yoy = request.security("ECONOMICS:CNPPI", "M", calc_yoy(close, yoy_len), gaps = barmerge.gaps_off)
cn_profit_gap = cn_cpi_yoy - cn_ppi_yoy

// --- 7. 实体热度 (铜金比) ---
// 确认时长: 连续 5 日
[copper, copper_prev] = request.security("COMEX:HG1!", "D", [close, close[1]], gaps = barmerge.gaps_off)
[gold, gold_prev]     = request.security("COMEX:GC1!", "D", [close, close[1]], gaps = barmerge.gaps_off)
cg_ratio = (copper / gold) * 1000
cg_ratio_prev = (copper_prev / gold_prev) * 1000
// 崩盘检测: 单日跌幅 > 3%
is_cg_crash_trigger = (cg_ratio / cg_ratio_prev - 1) * 100 < -3.0
// 锁定 3 日
var int cg_crash_cnt = 0
if is_cg_crash_trigger
    cg_crash_cnt := 3
else if cg_crash_cnt > 0
    cg_crash_cnt := cg_crash_cnt - 1
is_cg_crash = cg_crash_cnt > 0
// 伪复苏: 铜金比涨 但 铜价跌
is_fake_recovery = cg_ratio > cg_ratio_prev and copper < copper_prev

// --- 8. 萨姆规则 (就业) ---
// 确认时长: 非农公布日
[sahm_val, sahm_time] = request.security("FRED:SAHMREALTIME", "M", [close, time], gaps = barmerge.gaps_off)
// ICSA 预警: 初请失业金同比 > 15%
[icsa, icsa_yoy, icsa_yoy_prev] = request.security("FRED:ICSA", "W", [close, (close / close[52] - 1) * 100, (close[1] / close[53] - 1) * 100], gaps = barmerge.gaps_off)
// 连续 2 周确认
icsa_warn = icsa_yoy > 15.0 and icsa_yoy_prev > 15.0

// ==========================================
// 3. 评分逻辑 (Scoring Logic)
// ==========================================

// --- 权重系统 ---
// 基础权重
float w1=1.0, float w2=1.0, float w3=1.0, float w4=1.0
float w5=1.0, float w6=1.0, float w7=1.0, float w8=1.0

// 时代判定 (Regime)
bool is_inflation_era = us_cpi_yoy > 3.0
bool is_panic_era     = sahm_val >= 0.3 or is_bull_steep

// 动态权重调整
if is_inflation_era
    w6 := 2.0 // 利润
    w7 := 2.0 // 实体
if is_panic_era
    w3 := 2.0 // 利差
    w4 := 2.0 // 信用
    w8 := 2.0 // 萨姆

// --- 评分计算 ---
float s1=0.0, float s2=0.0, float s3=0.0, float s4=0.0
float s5=0.0, float s6=0.0, float s7=0.0, float s8=0.0

// 1. EFFR
// 状态定义：基于 EMA 的周期判定
bool is_cut_cycle  = effr_live < effr_ema - th_effr_noise
bool is_hike_cycle = effr_live > effr_ema + th_effr_noise

// 救火事件判定 (Panic Event)
bool is_panic_drop = is_cut_cycle and effr_drop >= 0.50

// 计算距离上次救火事件的时间 (Days)
// 使用 bar_index 辅助判断，若从未触发则为 na
int bars_since_panic = ta.barssince(is_panic_drop)
// 将 K 线数粗略转换为天数 (假设日线数据连续，如果有周末跳空则大约是 1.4 倍 bar 数，这里简单用时间差更准)
// Pine Script v6 中，time 是毫秒，一天 = 86400000
// 如果当前时间 - 上次触发时间 < 30天，则维持救火状态
bool in_panic_window = false
if not na(bars_since_panic)
    // 获取上次触发时的时间
    // 注意：ta.valuewhen(condition, source, occurrence)
    int time_of_panic = ta.valuewhen(is_panic_drop, time, 0)
    if time - time_of_panic < 90 * 86400000 // 90天有效期 (一个季度)
        in_panic_window := true

// 评分逻辑
if in_panic_window
    s1 := -1.0 // 救火降息 (衰退) - 有效期 90 天
else if is_hike_cycle
    s1 := -0.5 // 加息周期 (抽水)
else if is_cut_cycle
    s1 := 1.0  // 降息周期 (放水)
else
    s1 := 0.0  // 常态震荡

// 2. TIPS
if tips_live >= rgdp_val
    s2 := -1.0 // 虹吸
else if tips_live >= 0.5 * rgdp_val
    s2 := -0.5 // 杀估值
else if tips_live < 0
    s2 := 1.0  // 负利率
else
    s2 := 1.0  // 健康支撑

// 3. Yield Curve
if is_bull_steep
    w3 := 2.0
    s3 := -1.0 // 基础分设为-1, 配合权重2 => -2
else if yc_val < -th_yc_noise
    s3 := -0.5 // 倒挂
else if math.abs(yc_val) <= th_yc_noise
    s3 := 0.0  // 平坦
else
    // 熊陡: 双涨且长债涨幅 > 短债涨幅
    bool is_bear_steep = y10_chg > 0 and y2_chg > 0 and y10_chg > y2_chg
    s3 := is_bear_steep ? 1.0 : 0.0 // 默认为0，如果是熊陡则+1

// 4. OAS
if is_oas_crash
    s4 := -1.0 // 信用崩盘 (配合权重x2)
    w4 := 2.0
else if oas_val > 6.0
    s4 := -1.0 // 严重恶化
else if oas_val >= 3.5
    // 风险走阔: 趋势向上
    if oas_slope > th_oas_noise
        s4 := -0.5
    else
        s4 := 0.0 // 局部压力
else // < 3.5
    // 底部回升: 趋势向上
    if oas_slope > th_oas_noise
        s4 := 0.0
    else
        s4 := 1.0 // 风险收敛

// 5. Liquidity
if region == "美国"
    if us_m2_yoy < -2.0
        s5 := -1.0 // 枯竭
    else if us_m2_yoy < -th_liq_us_noise
        s5 := -0.5 // 紧缩
    else if us_m2_yoy > th_liq_us_noise
        s5 := 1.0  // 扩张
    else
        s5 := 0.0  // 存量博弈
else // CN
    if cn_gap < -5.0
        s5 := -1.0 // 严重空转
    else if cn_m1_yoy < cn_m2_yoy - th_liq_cn_noise
        s5 := -0.5 // 资金空转
    else if cn_m1_yoy > cn_m2_yoy + th_liq_cn_noise
        s5 := 1.0  // 活化
    else
        s5 := 0.0  // 结构震荡

// 6. Profit
if region == "美国"
    if us_cpi_yoy > 3.0
        s6 := -1.0 // 通胀过热 (配合权重x2)
        w6 := 2.0
    else if us_cpi_yoy < 0 and us_ppi_yoy < 0
        s6 := -1.0 // 通缩幻觉
    else if us_profit_gap < -th_prof_noise
        s6 := -0.5 // 亏损
    else if us_profit_gap > th_prof_noise
        // 走阔
        if us_profit_gap > us_profit_gap[1]
            s6 := 1.0 // 躺赚
        else
            s6 := 0.5 // 修复
    else
        s6 := 0.0 // 震荡
else // CN
    if cn_cpi_yoy > 3.0
        s6 := -1.0 // 通胀过热
        w6 := 2.0
    else if cn_cpi_yoy < 0 and cn_ppi_yoy < 0
        s6 := -1.0 // 深度通缩
    else if cn_profit_gap < -th_prof_noise
        // 亏损
        if cn_profit_gap > cn_profit_gap[1] // 收窄
            s6 := 0.5 
        else
            s6 := -0.5
    else if cn_profit_gap > th_prof_noise
        // 盈利
        if cn_profit_gap > cn_profit_gap[1]
            s6 := 1.0
        else
            s6 := 0.0
    else
        s6 := 0.0

// 7. Real Economy
if is_cg_crash
    s7 := -1.0 // 崩盘
else if cg_ratio < cg_ratio_prev * (1.0 - th_cg_noise/100.0) // 使用斜率阈值作为下跌缓冲? 这里简单处理，如果跌幅超过阈值
    s7 := -0.5 // 衰退
else if is_fake_recovery
    s7 := -0.5 // 伪复苏
else if cg_ratio > cg_ratio_prev * (1.0 + th_cg_noise/100.0) and copper > copper_prev
    s7 := 1.0  // 复苏
else
    s7 := 0.0  // 震荡

// 8. Sahm
if sahm_val >= 0.5
    s8 := -1.0 // 衰退熔断 (配合权重x2)
    w8 := 2.0
else if sahm_val >= 0.3
    s8 := -1.0 // 衰退预警
else if icsa_warn
    s8 := -0.5 // ICSA 预警
else
    s8 := 1.0  // 就业健康

// --- 总分计算 ---
total_score = s1*w1 + s2*w2 + s3*w3 + s4*w4 + s5*w5 + s6*w6 + s7*w7 + s8*w8
max_score   = w1 + w2 + w3 + w4 + w5 + w6 + w7 + w8

// 熔断一票否决
bool is_meltdown = (s3 == -1.0 and w3 > 1.0) or (s4 == -1.0 and w4 > 1.0) or (s8 == -1.0 and w8 > 1.0)

// ==========================================
// 4. UI 渲染 (UI Rendering)
// ==========================================

// --- 状态文本生成器 ---
get_act_txt(score, w, meltdown_label, red_label, orange_label, yellow_label, green_label, assets_sell, assets_buy) =>
    // 熔断处理
    if score == -1.0 and w > 1.0
        "【清仓】 卖出" + assets_sell + "，买入" + assets_buy
    else if score == -1.0
        "【避险】 卖出" + assets_sell + "，买入" + assets_buy
    else if score == -0.5
        "【防御】 卖出" + assets_sell + "，买入" + assets_buy
    else if score == 0.0
        "【观察】 多看少做"
    else if score == 0.5
        "【进攻】 卖出" + assets_sell + "，买入" + assets_buy // 修复/弱进攻
    else
        "【进攻】 卖出" + assets_sell + "，买入" + assets_buy

// 资产定义
a_risk     = "风险资产"
a_tech     = "科技/顺周期"
a_safe     = "黄金/长债"
a_cash     = "美元/短债"
a_def      = "长债/成长" // 加息周期卖出
a_hyg      = "垃圾债/股票"
a_core     = "核心/红利"
a_cycle    = "周期/大宗"

// 状态描述与建议 (Strictly from README)
string t1_s = "", string t1_a = ""
if s1 == -1.0
    t1_s := "救火降息 (衰退)", t1_a := "【避险】 卖出科技/顺周期，买入黄金/长债"
else if s1 == -0.5
    t1_s := "加息周期 (抽水)", t1_a := "【防御】 卖出长债/成长，买入短债/美元"
else if s1 == 1.0
    t1_s := "降息周期 (放水)", t1_a := "【进攻】 卖出美元/短债，买入科技/长债"
else
    t1_s := "常态震荡", t1_a := "【观察】 多看少动"

string t2_s = "", string t2_a = ""
if s2 == -1.0
    t2_s := "虹吸", t2_a := "【避险】 卖出所有资产，买入美元/短债"
else if s2 == -0.5
    t2_s := "杀估值", t2_a := "【防御】 卖出高估值/加密，买入核心/红利"
else if s2 == 1.0
    if tips_live < 0
        t2_s := "负利率", t2_a := "【进攻】 卖出美元，买入黄金/加密"
    else
        t2_s := "健康支撑", t2_a := "【进攻】 卖出美元，买入科技/成长"

string t3_s = "", string t3_a = ""
if s3 == -1.0 and w3 > 1.0
    t3_s := "牛陡 (熔断)", t3_a := "【清仓】 卖出风险资产/大宗，买入美债/黄金"
else if s3 == -0.5
    t3_s := "倒挂 (警报)", t3_a := "【防御】 卖出成长股，买入现金/红利"
else if s3 == 1.0
    t3_s := "熊陡 (复苏)", t3_a := "【进攻】 卖出美债，买入周期/大宗"
else
    t3_s := "平坦 (震荡)", t3_a := "【观察】 多看少做"

string t4_s = "", string t4_a = ""
if s4 == -1.0 and w4 > 1.0
    t4_s := "危机 (熔断)", t4_a := "【清仓】 卖出垃圾债/股票，买入美元/短债"
else if s4 == -1.0
    t4_s := "严重恶化 (信用枯竭)", t4_a := "【避险】 卖出垃圾债/小盘，买入美元/短债"
else if s4 == -0.5
    t4_s := "风险走阔 (信用收缩)", t4_a := "【防御】 卖出垃圾债/小盘，买入核心/红利"
else if s4 == 1.0
    t4_s := "风险收敛 (信用扩张)", t4_a := "【进攻】 卖出美元，买入垃圾债/小盘"
else
    if oas_val < 3.5
        t4_s := "底部回升 (关注)", t4_a := "【观察】 环境依然宽松，保持关注"
    else
        t4_s := "局部压力 (信用摇摆)", t4_a := "【观察】 多看少做"

string t5_s = "", string t5_a = ""
if region == "美国"
    if s5 == -1.0
        t5_s := "枯竭 (休克)", t5_a := "【避险】 卖出所有资产，买入美元现金"
    else if s5 == -0.5
        t5_s := "紧缩 (水位下降)", t5_a := "【防御】 卖出风险资产，买入现金"
    else if s5 == 1.0
        t5_s := "扩张 (水位上涨)", t5_a := "【进攻】 卖出美元，买入科技/成长"
    else
        t5_s := "存量博弈 (水位不定)", t5_a := "【观察】 多看少做"
else
    if cn_gap < -5.0
        t5_s := "严重空转 (活水稀缺)", t5_a := "【避险】 卖出所有资产，买入现金"
    else if s5 == -0.5
        t5_s := "资金空转 (活水变少)", t5_a := "【防御】 卖出重资产，买入高股息"
    else if s5 == 1.0
        t5_s := "活化 (活水变多)", t5_a := "【进攻】 卖出防御资产，买入科技/成长"
    else
        t5_s := "结构震荡", t5_a := "【观察】 多看少做"

string t6_s = "", string t6_a = ""
if region == "美国"
    if s6 == -1.0 and w6 > 1.0
        t6_s := "通胀过热", t6_a := "【避险】 卖出成长股，买入现金/能源"
    else if s6 == -1.0
        t6_s := "通缩幻觉 (双负)", t6_a := "【避险】 卖出所有资产，买入美元现金"
    else if s6 == -0.5
        t6_s := "亏损 (成本倒挂)", t6_a := "【防御】 卖出中下游制造，买入防御资产"
    else if s6 == 0.5
        t6_s := "修复 (利润变薄)", t6_a := "【进攻】 卖出投机股，买入绩优股"
    else if s6 == 1.0
        t6_s := "躺赚 (利润变厚)", t6_a := "【进攻】 卖出低效资产，买入成长股"
    else
        t6_s := "震荡", t6_a := "【观察】 多看少做"
else
    if s6 == -1.0 and w6 > 1.0
        t6_s := "通胀过热", t6_a := "【避险】 卖出成长股，买入现金/能源"
    else if s6 == -1.0
        t6_s := "深度通缩 (双负)", t6_a := "【避险】 卖出周期股，买入必选消费"
    else if s6 == -0.5
        t6_s := "亏损 (成本倒挂)", t6_a := "【防御】 卖出中游制造，买入上游资源"
    else if s6 == 0.0
        t6_s := "内卷 (利润压缩)", t6_a := "【观察】 回避同质化竞争，只看龙头"
    else if s6 == 0.5
        t6_s := "修复 (困境反转)", t6_a := "【进攻】 卖出防御股，买入反转股"
    else if s6 == 1.0
        t6_s := "躺赚 (利润释放)", t6_a := "【进攻】 卖出上游资源，买入消费/中下游"

string t7_s = "", string t7_a = ""
if s7 == -1.0
    t7_s := "崩盘 (信心崩溃)", t7_a := "【避险】 卖出所有资产，买入美元/美债"
else if s7 == -0.5
    if is_fake_recovery
        t7_s := "伪复苏", t7_a := "【防御】 卖出铜/工业品，买入黄金/美债"
    else
        t7_s := "衰退 (弃修鱼池)", t7_a := "【防御】 卖出强周期板块，买入黄金/美债"
else if s7 == 1.0
    t7_s := "复苏 (扩建鱼池)", t7_a := "【进攻】 卖出避险资产，买入周期/大宗"
else
    t7_s := "震荡", t7_a := "【观察】 多看少做"

string t8_s = "", string t8_a = ""
if s8 == -1.0 and w8 > 1.0
    t8_s := "衰退熔断", t8_a := "【清仓】 卖出风险资产，买入美债/黄金"
else if s8 == -1.0
    t8_s := "衰退预警", t8_a := "【避险】 卖出风险资产，买入美债/黄金"
else if s8 == -0.5
    t8_s := "ICSA 提前预警", t8_a := "【防御】 卖出风险资产，买入现金/红利"
else
    t8_s := "就业健康", t8_a := "【进攻】 卖出避险资产，买入科技/消费"

// --- 颜色辅助函数 ---
get_score_col(s) =>
    if s == -1.0
        c_red
    else if s == -0.5
        c_orange
    else if s == 0.0
        c_yellow
    else
        c_lime // +0.5 or +1.0

// 绘制主图曲线
float plot_val = 0.0
if mode == "1. 基准利率"
    plot_val := effr_live
else if mode == "2. 真实利率"
    plot_val := tips_live
else if mode == "3. 利差结构"
    plot_val := yc_val
else if mode == "4. 信用风险"
    plot_val := oas_val
else if mode == "5. 流动性"
    plot_val := region == "美国" ? us_m2_yoy : cn_gap
else if mode == "6. 利润空间"
    plot_val := region == "美国" ? us_profit_gap : cn_profit_gap
else if mode == "7. 实体热度"
    plot_val := cg_ratio
else if mode == "8. 萨姆规则"
    plot_val := sahm_val

color dyn_c = c_white
if mode == "1. 基准利率"
    dyn_c := get_score_col(s1)
else if mode == "2. 真实利率"
    dyn_c := get_score_col(s2)
else if mode == "3. 利差结构"
    dyn_c := get_score_col(s3)
else if mode == "4. 信用风险"
    dyn_c := get_score_col(s4)
else if mode == "5. 流动性"
    dyn_c := get_score_col(s5)
else if mode == "6. 利润空间"
    dyn_c := get_score_col(s6)
else if mode == "7. 实体热度"
    dyn_c := get_score_col(s7)
else if mode == "8. 萨姆规则"
    dyn_c := get_score_col(s8)

// --- 综合绘图 (Plotting) ---
// 1. 基准利率: 阶梯图 + EMA
plot(mode == "1. 基准利率" ? plot_val : na, "EFFR", color = dyn_c, linewidth = 2, style = plot.style_stepline)
plot(mode == "1. 基准利率" ? effr_ema : na, "EFFR EMA", color = color.blue, linewidth = 1)

// 2. 真实利率: TIPS + RGDP + 阈值
plot(mode == "2. 真实利率" ? plot_val : na, "TIPS", color = dyn_c, linewidth = 2)
plot(mode == "2. 真实利率" ? rgdp_val : na, "RGDP", color = color.gray, linewidth = 1)
plot(mode == "2. 真实利率" ? 0.5 * rgdp_val : na, "0.5 RGDP", color = color.new(color.orange, 50), style = plot.style_circles)

// 3. 利差结构: 10Y-2Y
plot(mode == "3. 利差结构" ? plot_val : na, "10Y-2Y", color = dyn_c, linewidth = 2)

// 4. 信用风险: OAS + 阈值
plot(mode == "4. 信用风险" ? plot_val : na, "OAS", color = dyn_c, linewidth = 2)
plot(mode == "4. 信用风险" ? 10.0 : na, "OAS 10", color = c_super_red, style = plot.style_circles)
plot(mode == "4. 信用风险" ? 6.0 : na, "OAS 6", color = c_red)
plot(mode == "4. 信用风险" ? 3.5 : na, "OAS 3.5", color = c_lime)

// 5. 流动性: M2 YoY + 阈值
plot(mode == "5. 流动性" ? plot_val : na, "Liquidity", color = dyn_c, linewidth = 2)
plot(mode == "5. 流动性" and region == "美国" ? -2.0 : na, "M2 -2", color = c_red)

// 6. 利润空间: Gap
plot(mode == "6. 利润空间" ? plot_val : na, "Profit Gap", color = dyn_c, linewidth = 2)

// 7. 实体热度: 铜金比
plot(mode == "7. 实体热度" ? plot_val : na, "Copper/Gold", color = dyn_c, linewidth = 2)

// 8. 萨姆规则: Sahm + 阈值
plot(mode == "8. 萨姆规则" ? plot_val : na, "Sahm", color = dyn_c, linewidth = 2)
plot(mode == "8. 萨姆规则" ? 0.5 : na, "Sahm 0.5", color = c_red, style = plot.style_circles)
plot(mode == "8. 萨姆规则" ? 0.3 : na, "Sahm 0.3", color = c_orange)

// 通用 0 轴 (虚线)
hline(0, "Zero Line", color = color.gray, linestyle = hline.style_dashed)

// --- 看板绘制 ---
var table rpt = table.new(position.middle_left, 7, 11, bgcolor = c_bg, border_width = 1, border_color = color.gray)
var table info = table.new(position.middle_right, 4, 6, bgcolor = c_bg, border_width = 1, border_color = color.gray)

// Helper to fill row
fill_row(r, name, val_str, s, w, meta, status, action) =>
    c_s = get_score_col(s)
    w_str = w > 1.0 ? "x2" : ""
    // 修正分数显示格式：移除多余符号，确保正数带+，负数带-，0不带
    float final_s = s * w
    string s_str = final_s > 0 ? "+" + str.tostring(final_s, "#.#") : (final_s == 0 ? "0" : str.tostring(final_s, "#.#"))
    
    table.cell(rpt, 0, r, name, text_color = c_white)
    table.cell(rpt, 1, r, val_str, text_color = c_s)
    table.cell(rpt, 2, r, s_str, text_color = c_score_col)
    table.cell(rpt, 3, r, w_str, text_color = c_white) // 权重字体改为白色
    table.cell(rpt, 4, r, meta, text_color = c_white)
    table.cell(rpt, 5, r, status, text_color = c_white)
    table.cell(rpt, 6, r, action, text_color = c_s, text_halign = text.align_left)

if barstate.islast and show_report
    // --- 左表: 报告 ---
    // Header
    table.cell(rpt, 0, 0, "维度", text_color = c_white, bgcolor = c_header)
    table.cell(rpt, 1, 0, "数值", text_color = c_white, bgcolor = c_header)
    table.cell(rpt, 2, 0, "得分", text_color = c_white, bgcolor = c_header)
    table.cell(rpt, 3, 0, "权重", text_color = c_white, bgcolor = c_header)
    table.cell(rpt, 4, 0, "比喻", text_color = c_white, bgcolor = c_header)
    table.cell(rpt, 5, 0, "现状含义", text_color = c_white, bgcolor = c_header)
    table.cell(rpt, 6, 0, "建议操作逻辑", text_color = c_white, bgcolor = c_header)

    fill_row(1, "1.基准利率", str.tostring(effr_live, "0.00")+"%", s1, w1, "总水坝闸门", t1_s, t1_a)
    fill_row(2, "2.真实利率", str.tostring(tips_live, "0.00")+"%", s2, w2, "水厂回购价", t2_s, t2_a)
    fill_row(3, "3.利差结构", str.tostring(yc_val, "0.00"), s3, w3, "天气预报", t3_s, t3_a)
    fill_row(4, "4.信用风险", str.tostring(oas_val, "0.2")+"%", s4, w4, "风险保证金", t4_s, t4_a)
    
    string l5_v = region == "美国 (US)" ? str.tostring(us_m2_yoy, "0.00")+"%" : str.tostring(cn_gap, "0.00")+"%"
    fill_row(5, "5.流动性", l5_v, s5, w5, "鱼池活水率", t5_s, t5_a)
    
    string l6_v = region == "美国 (US)" ? str.tostring(us_profit_gap, "0.00")+"%" : str.tostring(cn_profit_gap, "0.00")+"%"
    fill_row(6, "6.利润空间", l6_v, s6, w6, "养鱼账本", t6_s, t6_a)
    
    fill_row(7, "7.实体热度", str.tostring(cg_ratio, "0.00"), s7, w7, "铜金比", t7_s, t7_a)
    fill_row(8, "8.萨姆规则", str.tostring(sahm_val, "0.2")+"%", s8, w8, "死神信号", t8_s, t8_a)

    // Row 9: Macro Hedge Strategy
    // Logic: US (Liquidity + Rate), CN (Liquidity)
    // US: Loose (Cut or Expand), Tight (Hike or Contract), Panic (Meltdown)
    bool us_loose = s1 == 1.0 or s5 == 1.0
    bool us_tight = s1 < 0 or s5 < 0
    bool us_panic = is_panic_era or is_meltdown
    // CN: Loose (Activate), Tight (Idle), Flat
    bool cn_loose = s5 == 1.0
    bool cn_tight = s5 < 0
    
    string strat_t = "", string strat_d = "", string strat_us = "", string strat_cn = ""
    color strat_c = c_white
    
    if us_loose and cn_loose
        strat_t := "🟢 共振复苏", strat_d := "【全仓猛干】 买铜、原油、澳元、新兴市场(港股/A股)", strat_c := c_lime
        strat_us := "🟢 松 (印钱)", strat_cn := "🟢 松 (放水)"
    else if us_tight and cn_tight
        strat_t := "🔴 双重紧缩", strat_d := "【现金为王】 只持有美元现金，或者做空 A 股", strat_c := c_orange
        strat_us := "🟠 紧 (抽水)", strat_cn := "🟠 紧 (空转)"
    else if us_panic and cn_tight
        strat_t := "🔴 衰退共振", strat_d := "【避险】 买美债、黄金、日元避险", strat_c := c_orange
        strat_us := "🔴 恐慌 (救火)", strat_cn := "🟠 紧 (空转)"
    else if us_panic and cn_loose
        strat_t := "🟠 东升西降", strat_d := "【结构性做多】 买 A股龙头，做空美股", strat_c := c_yellow
        strat_us := "🔴 恐慌 (救火)", strat_cn := "🟢 松 (放水)"
    else if us_tight and cn_loose
        strat_t := "🟠 分化博弈", strat_d := "【两头吃】 存美元吃利息，同时买 A股结构性机会", strat_c := c_yellow
        strat_us := "🟠 紧 (加息)", strat_cn := "🟢 松 (放水)"
    else if us_loose and cn_tight
        strat_t := "🟠 单极驱动", strat_d := "【只买美国】 买美股科技/黄金，千万别碰工业品", strat_c := c_yellow
        strat_us := "🟢 松 (降息)", strat_cn := "🟠 紧 (躺平)"
    else
        strat_t := "🟡 垃圾时间", strat_d := "【多看少动】 别瞎折腾，等新趋势出来", strat_c := c_yellow
        strat_us := "🟡 平", strat_cn := "🟡 平"

    table.cell(rpt, 0, 9, "中美宏观对冲", bgcolor = c_navy_60, text_color = c_white), table.merge_cells(rpt, 0, 9, 1, 9)
    table.cell(rpt, 2, 9, strat_t, bgcolor = c_navy_60, text_color = strat_c), table.merge_cells(rpt, 2, 9, 3, 9)
    table.cell(rpt, 4, 9, strat_us + "\n" + strat_cn, bgcolor = c_navy_60, text_color = c_white, text_size = size.small)
    table.cell(rpt, 5, 9, strat_d, bgcolor = c_navy_60, text_color = c_white), table.merge_cells(rpt, 5, 9, 6, 9)

    // Row 10: Final Diagnosis
    string final_res = "", string final_sugg = ""
    color final_bg = c_gray_dark
    color final_txt = c_white
    
    if is_meltdown
        final_res := "【熔断】 " + (s3==-1.0 and w3>1.0 ? "3.牛陡 " : "") + (s4==-1.0 and w4>1.0 ? "4.信用 " : "") + (s8==-1.0 and w8>1.0 ? "8.萨姆" : "")
        final_sugg := "一键清仓"
        final_bg := c_super_red
        final_txt := c_yellow
    else if total_score < -6.0
        final_res := "衰退确认", final_sugg := "撤回现金"
        final_bg := c_red
    else if total_score < -2.0
        final_res := "风险防守", final_sugg := "70% 避险 / 30% 绩优股"
        final_bg := c_orange
    else if total_score < 2.0
        final_res := "震荡博弈", final_sugg := "50% 现金 / 50% 红利"
        final_bg := c_yellow
        final_txt := c_black
    else if total_score <= 6.0
        final_res := "趋势向好", final_sugg := "70% 进攻 / 30% 防守"
        final_bg := c_lime
        final_txt := c_black
    else // > 6.0
        final_res := "全线复苏", final_sugg := "100% 满仓"
        final_bg := c_super_green

    table.cell(rpt, 0, 10, "最终诊断", bgcolor = c_bg, text_color = c_white), table.merge_cells(rpt, 0, 10, 1, 10)
    
    string total_s_str = total_score > 0 ? "+" + str.tostring(total_score, "#.#") : (total_score == 0 ? "0" : str.tostring(total_score, "#.#"))
    table.cell(rpt, 2, 10, total_s_str, bgcolor = final_bg, text_color = final_txt)
    
    table.cell(rpt, 3, 10, str.tostring(max_score, "#.#"), bgcolor = c_bg, text_color = c_white)
    table.cell(rpt, 4, 10, "结论", bgcolor = c_bg, text_color = c_white)
    table.cell(rpt, 5, 10, final_res, bgcolor = final_bg, text_color = final_txt)
    table.cell(rpt, 6, 10, final_sugg, bgcolor = final_bg, text_color = final_txt)

    // --- 右表: 详情 ---
    string d_title="", string d_def="", string d_obs="", string d_logic="", string d_conf="", string d_w="", string d_cur_stat="", string d_cur_val="", string d_turn_val="", string d_cur_mean="", string d_risk="", string d_tactics="", string d_tactics_turn=""
    
    if mode == "1. 基准利率"
        d_title := "基准利率\n[EFFR]", d_def := "美联储基准利率，全球资金成本的总阀门。"
        d_obs := "10月 (EMA)", d_logic := "🔴 救火: ≥50bp\n🟠 加息: >EMA\n🟡 震荡: ≈EMA\n🟢 降息: <EMA", d_conf := "公布日确认"
        d_w := w1 > 1.0 ? "x2" : "x1"
        d_cur_stat := t1_s
        d_cur_val := str.tostring(effr_live, "0.00") + "% | " + fmt_ymd(effr_time)
        d_turn_val := s1 > 0 ? "上穿EMA" : "跌破EMA"
        d_cur_mean := s1 > 0 ? "闸门开启，水位上涨" : (s1 < 0 ? "闸门关闭/泄洪" : "闸门半开")
        d_risk := s1 < 0 ? "流动性枯竭" : "通胀反弹"
        // 修复：使用 s1 == -1.0 来判断救火状态，而不是当天的 effr_drop
        d_tactics := "【战术】\n" + (s1 < 0 ? (s1 == -1.0 ? "衰退确信信号，初期伴随暴跌\n此时降息预期极强，买长债对冲股票下跌" : "资金变贵，现金为王\n买短债吃高息，等跌，规避久期敏感资产") : (s1 > 0 ? "资金变便宜，利好利率敏感资产\n布局科技、加密和生物医药" : "政策方向不明朗，观察期，多看少动"))
        d_tactics_turn := "拐点战术:\n关注EMA10\n >EMA10 即切换攻防"

    else if mode == "2. 真实利率"
        d_title := "真实利率\n[TIPS]", d_def := "10年期通胀保值债券收益率。\n买它=把水卖回给水厂(锁定无风险收益)。"
        d_obs := "日线 (实时)", d_logic := "🔴 虹吸: ≥RGDP\n🟠 杀估值: ≥0.5RGDP\n🟢 健康: <0.5RGDP\n🟢 负利率: <0", d_conf := "连续5日"
        d_w := w2 > 1.0 ? "x2" : "x1"
        d_cur_stat := t2_s
        d_cur_val := str.tostring(tips_live, "0.00") + "% | " + fmt_ymd(tips_time)
        d_turn_val := s2 < 0 ? "跌破 " + str.tostring(0.5*rgdp_val, "0.00") : "突破 " + str.tostring(0.5*rgdp_val, "0.00")
        d_cur_mean := s2 < 0 ? "养鱼不如卖水" : "水留鱼池"
        d_risk := s2 < 0 ? "估值崩塌" : "泡沫化"
        d_tactics := "【战术】\n" + (s2 < 0 ? (tips_live >= rgdp_val ? "无风险收益太高，虹吸一切资产\n只有美元现金最安全" : "估值承压，资金偏好确定性\n买低估值红利股或核心资产") : (tips_live < 0 ? "法币贬值，资产泡沫化\n实物资产和数字黄金是抗贬值首选" : "估值有支撑，安心持有成长股"))
        d_tactics_turn := "拐点战术:\n紧盯 " + str.tostring(0.5*rgdp_val, "0.00") + "% 阈值，穿越即变盘"

    else if mode == "3. 利差结构"
        d_title := "利差结构\n[10Y-2Y]", d_def := "长债减短债收益率。\n预测未来经济状况的最准指标(天气预报)。"
        d_obs := "20日 (趋势)", d_logic := "🛑 牛陡: 熔断\n🟠 倒挂: <0\n🟡 平坦: ≈0\n🟢 熊陡: 复苏", d_conf := "熔断锁5日"
        d_w := w3 > 1.0 ? "x2" : "x1"
        d_cur_stat := t3_s
        d_cur_val := str.tostring(yc_val, "0.00")
        d_turn_val := s3 < 0 ? "重新转正(熊陡)" : "重新倒挂"
        d_cur_mean := s3 < 0 ? (w3>1.0 ? "大家都在赌救命降息" : "不看好长期发展") : (s3>0 ? "看好未来，不存死期" : "看不清")
        d_risk := "衰退交易惯性"
        d_tactics := "【战术】\n" + (s3 < 0 ? (w3>1.0 ? "最危险时刻，立刻清空股票\n避险资金涌入，买美债(TLT)或黄金(GLD)" : "衰退倒计时，收缩战线\n买防御性资产(红利/必选消费)，避激进投资") : (s3 > 0 ? "经济复苏，通胀回升\n卖美债(TLT)，买周期股(XLE/XLI)和大宗商品" : "倒挂/走阔转换期，方向未定，多看少做"))
        d_tactics_turn := "拐点战术:\n警惕‘牛陡’陷阱，确认‘熊陡’(双涨)再进攻"

    else if mode == "4. 信用风险"
        d_title := "信用风险\n[OAS]", d_def := "高收益债期权调整利差。\n银行借钱给烂公司的额外利息(风险保证金)。"
        d_obs := "20日 (趋势)", d_logic := "🛑 危机: >10%或暴涨\n🔴 恶化: >6%\n🟠 走阔: 趋势上\n🟡 压力: 震荡\n🟢 收敛: <3.5%", d_conf := "熔断锁5日"
        d_w := w4 > 1.0 ? "x2" : "x1"
        d_cur_stat := t4_s
        d_cur_val := str.tostring(oas_val, "0.2") + "%"
        d_turn_val := s4 < 0 ? "回落至 6% 下" : "突破 3.5%"
        d_cur_mean := s4 < 0 ? "借不到钱，要破产" : "随便借钱，胆子大"
        d_risk := "违约潮/流动性危机"
        d_tactics := "【战术】\n" + (s4 < 0 ? (w4>1.0 ? "信用市场冻结，融资断裂\n连黄金都可能被抛售，仅美元现金/短债安全" : "风险过高，下降也不碰\n抛售垃圾债和小盘股") : (s4 > 0 ? "风险偏好提升，资金泛滥\n买高弹性资产，如小盘股和垃圾债" : "虽有压力但未失控，或处于观望期"))
        d_tactics_turn := "拐点战术:\n关注斜率变化，趋势形成难逆转"

    else if mode == "5. 流动性"
        if region == "美国"
            d_title := "流动性\n[M2 YoY]", d_def := "广义货币供应量同比(剔除通胀)。\n美国印钱=全球水位上涨。"
            d_obs := "12月 (同比)", d_logic := "🔴 枯竭: <-2%\n🟠 紧缩: <0\n🟡 存量: ≈0\n🟢 扩张: >0", d_conf := "公布日"
            d_w := w5 > 1.0 ? "x2" : "x1"
            d_cur_stat := t5_s
            d_cur_val := str.tostring(us_m2_yoy, "0.00") + "% | " + fmt_ym(us_m2_time)
            d_turn_val := s5 > 0 ? "跌破 0 轴" : "突破 0 轴"
            d_cur_mean := s5 > 0 ? "水漫金山" : "旱灾/蒸发"
            d_risk := "资产重估/去杠杆"
            d_tactics := "【战术】\n" + (s5 < 0 ? (us_m2_yoy < -2.0 ? "历史级货币收缩，资产重估\n极度危险，必须离场" : "实际货币供应收缩，资金枯竭\n空仓或持有现金") : (s5 > 0 ? "资金充裕，美国放水\n全球‘水漫金山’，闭眼买" : "存量博弈，多看少做"))
            d_tactics_turn := "拐点战术:\n紧盯0轴，由负转正时右侧建仓"
        else
            d_title := "流动性\n[M1-M2]", d_def := "M1增速减M2增速(剪刀差)。\n正: 活水注入; 负: 资金空转(定期化)。"
            d_obs := "12月 (同比)", d_logic := "🔴 严重空转: <-5%\n🟠 空转: <0\n🟢 活化: >0", d_conf := "公布日"
            d_w := w5 > 1.0 ? "x2" : "x1"
            d_cur_stat := t5_s
            d_cur_val := str.tostring(cn_gap, "0.00") + "% | " + fmt_ym(cn_time)
            d_turn_val := s5 > 0 ? "跌破 0 轴" : "突破 0 轴"
            d_cur_mean := s5 > 0 ? "存款搬家进股市" : "躺平吃利息"
            d_risk := "流动性陷阱"
            d_tactics := "【战术】\n" + (s5 < 0 ? (cn_gap < -5.0 ? "活期存款断崖下跌，现金流枯竭\n现金为王，回避一切风险资产" : "资金定期化，躺平存钱\n回避重资产，关注高股息") : (s5 > 0 ? "存款活期化，流向消费/投资\n挑真正受益于资金活化的板块" : "资金结构稳定，多看少做"))
            d_tactics_turn := "拐点战术:\n剪刀差收窄是第一步，转正即冲锋"

    else if mode == "6. 利润空间"
        if region == "美国"
            d_title := "利润空间\n[CPI-PPI]", d_def := "售价(CPI) - 成本(PPI)。\n差值走阔=企业赚钱容易。"
            d_obs := "12月 (同比)", d_logic := "🔴 过热: CPI>3%\n🔴 通缩: 双负\n🟠 亏损: <0\n🟡 震荡: ≈0\n🟢 修复: 收窄\n🟢 躺赚: 走阔", d_conf := "公布日"
            d_w := w6 > 1.0 ? "x2" : "x1"
            d_cur_stat := t6_s
            d_cur_val := str.tostring(us_profit_gap, "0.00") + "% | " + fmt_ym(us_prof_time)
            d_turn_val := s6 == 1.0 ? "差值收窄" : "差值走阔"
            d_cur_mean := s6 == 1.0 ? "两头赚" : (s6 < 0 ? "卖一条亏一条" : "薄利多销")
            d_risk := "加息杀估值/通缩"
            d_tactics := "【战术】\n" + (s6 < 0 ? (w6 > 1.0 ? "通胀失控，必须刹车\n回避高估值，现金为王，拥抱抗通胀资产" : (us_cpi_yoy<0 ? "成本降因经济崩，全线通缩\n现金为王" : "成本高于售价，卖多亏多\n规避中下游制造业")) : (s6 == 1.0 ? "售价涨幅 > 成本涨幅，利润暴增\n积极买入成长股" : "虽利润变薄，但还在赚钱\n不激进追高，但可安心拿住"))
            d_tactics_turn := "拐点战术:\n利润走阔重仓成长，收窄切换绩优"
        else
            d_title := "利润空间\n[CPI-PPI]", d_def := "内需(CPI) - 产能(PPI)。\n中国是制造国，重点看PPI(全球需求)。"
            d_obs := "12月 (同比)", d_logic := "🔴 通缩: PPI<0\n🟢 复苏: PPI涨", d_conf := "公布日"
            d_w := w6 > 1.0 ? "x2" : "x1"
            d_cur_stat := t6_s
            d_cur_val := str.tostring(cn_profit_gap, "0.00") + "%"
            d_turn_val := s6 > 0 ? "重新倒挂" : "亏损收窄"
            d_cur_mean := s6 < 0 ? "亏本甩卖" : "供不应求"
            d_risk := "产能过剩/价格战"
            d_tactics := "【战术】\n" + (s6 < 0 ? (w6 > 1.0 ? "内需过热，物价飞涨。回避高估值，现金为王" : (cn_cpi_yoy<0 ? "全产业链通缩，需求疲软\n远离周期股，关注必选消费" : "出厂价低于成本价\n回避中游制造，关注上游资源")) : (s6 == 1.0 ? "上游降价，下游需求旺\n卖上游资源，买消费/中下游制造" : "最惨时刻已过，亏损减少\n博弈困境反转，左侧建仓"))
            d_tactics_turn := "拐点战术:\n关注PPI触底反弹，困境反转信号"

    else if mode == "7. 实体热度"
        d_title := "实体热度\n[铜金比]", d_def := "铜(工业) / 金(避险)。\n比值涨=复苏; 比值跌=衰退。"
        d_obs := "20日 (趋势)", d_logic := "🔴 崩盘: 单日跌>3%\n🟠 衰退: 跌\n🟠 伪复苏: 铜跌\n🟡 震荡: 平\n🟢 复苏: 双涨", d_conf := "崩盘锁3日"
        d_w := w7 > 1.0 ? "x2" : "x1"
        d_cur_stat := t7_s
        d_cur_val := str.tostring(cg_ratio, "0.00")
        d_turn_val := s7 > 0 ? "转跌" : "转涨(双涨)"
        d_cur_mean := s7 > 0 ? "修鱼池" : "藏金子"
        d_risk := "死猫跳/假突破"
        d_tactics := "【战术】\n" + (s7 < 0 ? (is_cg_crash ? "极度恐慌，抛售一切资产\n只有美元和美债最安全" : (is_fake_recovery ? "铜比金强但都在跌，衰退假象\n不要被比值上涨迷惑" : "实体疲软，避险主导\n买黄金/美债，规避强周期")) : (s7 > 0 ? "实体需求旺盛，风险偏好上升\n买周期股、工业大宗商品" : "方向不明，多看少做"))
        d_tactics_turn := "拐点战术:\n确认‘铜价’也在涨，才是真复苏"

    else if mode == "8. 萨姆规则"
        d_title := "衰退预警\n[Sahm]", d_def := "失业率3月均值 - 12月低点。\n死神信号，100%准确率。"
        d_obs := "12月 (低点)", d_logic := "🛑 衰退: ≥0.5%\n🔴 预警: ≥0.3%\n🟠 预警: ICSA>15%\n🟢 健康: <0.3%", d_conf := "公布日"
        d_w := w8 > 1.0 ? "x2" : "x1"
        d_cur_stat := t8_s
        d_cur_val := str.tostring(sahm_val, "0.00") + "% | " + fmt_ym(sahm_time)
        d_turn_val := s8 < 0 ? "回落至 0.3% 下" : "突破 0.3% / 0.5%"
        d_cur_mean := s8 < 0 ? "失业潮来袭" : "就业充分"
        d_risk := "硬着陆"
        d_tactics := "【战术】\n" + (s8 < 0 ? (sahm_val >= 0.5 ? "历史准确率100%的衰退信号，必须离场\n买入美债 (TLT) 和黄金 (GLD) 避险" : "衰退概率激增，不再恋战\n清仓股票，转入防御性资产") : "就业市场健康，经济韧性强\n大胆持有风险资产")
        d_tactics_turn := "拐点战术:\n一旦突破0.5%，立即清仓，没有任何侥幸"

    // Render Right Table
    // Row 0
    table.cell(info, 0, 0, d_title, bgcolor = c_header, text_color = c_white)
    table.cell(info, 1, 0, d_def, bgcolor = c_bg, text_color = c_white, text_halign = text.align_left), table.merge_cells(info, 1, 0, 3, 0)
    // Row 1
    table.cell(info, 0, 1, "观测周期:", bgcolor = c_bg, text_color = c_beige, text_halign = text.align_left)
    table.cell(info, 1, 1, d_obs, bgcolor = c_bg, text_color = c_white, text_halign = text.align_left)
    table.cell(info, 2, 1, d_logic, bgcolor = c_bg, text_color = c_beige, text_halign = text.align_left, text_size = size.small)
    table.cell(info, 3, 1, d_conf, bgcolor = c_bg, text_color = c_score_col, text_halign = text.align_left)
    // Row 2
    table.cell(info, 0, 2, "权重: " + d_w, bgcolor = c_bg, text_color = c_score_col, text_halign = text.align_left)
    table.cell(info, 1, 2, "【当前】", bgcolor = c_header, text_color = c_white), table.merge_cells(info, 1, 2, 2, 2)
    table.cell(info, 3, 2, "【拐点】", bgcolor = c_header, text_color = c_white)
    // Row 3
    table.cell(info, 0, 3, "状态:", bgcolor = c_bg, text_color = c_beige, text_halign = text.align_left)
    
    float cur_score_disp = 0.0
    float turn_score_disp = 0.0 // 新增：拐点得分，用于判断颜色

    if mode == "1. 基准利率"
        cur_score_disp := s1
        // 修正：基准利率 (EFFR) 
        // 加息周期 (s1=-0.5, 橙色) -> 拐点为降息/停止加息 (绿色)
        // 降息周期 (s1=1.0, 绿色) -> 拐点为加息 (橙色)
        // 救火降息 (s1=-1.0, 红色) -> 拐点为企稳 (黄色/绿色)
        if s1 == -0.5 // 加息周期 (橙色)
            turn_score_disp := 1.0 // 绿色 (降息)
        else if s1 == 1.0 // 降息周期 (绿色)
            turn_score_disp := -0.5 // 橙色 (加息)
        else if s1 == -1.0 // 救火 (红色)
            turn_score_disp := 0.0 // 黄色 (震荡)
        else // 震荡
            turn_score_disp := -0.5 // 橙色 (加息风险)
            
    else if mode == "2. 真实利率"
        cur_score_disp := s2
        turn_score_disp := s2 < 0 ? 1.0 : -1.0 // 简单反转
    else if mode == "3. 利差结构"
        cur_score_disp := s3
        turn_score_disp := s3 < 0 ? 1.0 : -1.0
    else if mode == "4. 信用风险"
        cur_score_disp := s4
        turn_score_disp := s4 < 0 ? 1.0 : -1.0
    else if mode == "5. 流动性"
        cur_score_disp := s5
        turn_score_disp := s5 > 0 ? -1.0 : 1.0
    else if mode == "6. 利润空间"
        cur_score_disp := s6
        turn_score_disp := s6 == 1.0 ? -1.0 : 1.0
    else if mode == "7. 实体热度"
        cur_score_disp := s7
        turn_score_disp := s7 > 0 ? -1.0 : 1.0
    else if mode == "8. 萨姆规则"
        cur_score_disp := s8
        turn_score_disp := s8 < 0 ? 1.0 : -1.0

    table.cell(info, 1, 3, d_cur_val, bgcolor = c_bg, text_color = get_score_col(cur_score_disp)), table.merge_cells(info, 1, 3, 2, 3), table.cell_set_text_halign(info, 1, 3, text.align_left)
    // 修改：拐点值颜色根据反转后的状态色显示
    table.cell(info, 3, 3, d_turn_val, bgcolor = c_bg, text_color = get_score_col(turn_score_disp), text_halign = text.align_left)
    // Row 4
    table.cell(info, 0, 4, "含义:", bgcolor = c_bg, text_color = c_beige, text_halign = text.align_left)
    table.cell(info, 1, 4, d_cur_mean, bgcolor = c_bg, text_color = c_white, text_halign = text.align_left), table.merge_cells(info, 1, 4, 2, 4)
    table.cell(info, 3, 4, d_risk, bgcolor = c_bg, text_color = c_white, text_halign = text.align_left)
    // Row 5
    table.cell(info, 0, 5, "战术:", bgcolor = c_bg, text_color = c_beige, text_halign = text.align_left)
    // 修改：移除 "【战术】\n" 前缀，移除 size.small
    string clean_tactics = str.replace(d_tactics, "【战术】\n", "")
    table.cell(info, 1, 5, clean_tactics, bgcolor = c_bg, text_color = c_white, text_halign = text.align_left), table.merge_cells(info, 1, 5, 2, 5)
    // 修改：移除 "拐点战术:\n" 前缀，移除 size.small
    string clean_tactics_turn = str.replace(d_tactics_turn, "拐点战术:\n", "")
    table.cell(info, 3, 5, clean_tactics_turn, bgcolor = c_bg, text_color = c_white, text_halign = text.align_left)
