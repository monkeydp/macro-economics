//@version=6
indicator("[薯仔 QA] 宏观经济测试", overlay = true, precision = 2, max_labels_count = 500)

// ==========================================
// 1. 设置与参数
// ==========================================
region = input.string("美国", "监控地区", options=["美国", "中国"], group="显示设置")
bool is_us = region == "美国"
bool is_cn = region == "中国"

// --- 1. 基准利率 ---
grp_1 = "1. 基准利率 (EFFR)"
sym_effr        = input.symbol("FRED:EFFR", "数据源 (EFFR)", group=grp_1)
effr_ema_len    = input.int(10, "EMA 周期", group=grp_1)
th_effr_noise   = input.float(0.05, "震荡阈值", group=grp_1)
dur_sahm_panic  = input.int(90, "救火降息有效期 (日)", group=grp_1)

// --- 2. 真实利率 ---
grp_2 = "2. 真实利率 (TIPS)"
sym_tips        = input.symbol("FRED:DFII10", "TIPS", group=grp_2)
sym_rgdp        = input.symbol("FRED:A191RL1Q225SBEA", "RGDP", group=grp_2)
dur_tips_conf   = input.int(5, "确认时长 (日)", group=grp_2)

// --- 3. 利差结构 ---
grp_3 = "3. 利差结构 (10Y-2Y)"
sym_us_10y      = input.symbol("FRED:GS10", "10Y", group=grp_3)
sym_us_2y       = input.symbol("FRED:GS2", "2Y", group=grp_3)
dur_yc_bear_conf= input.int(5, "熊陡确认时长 (日)", group=grp_3)
th_yc_noise     = input.float(0.15, "震荡阈值", group=grp_3)
th_yc_bull_steep= input.float(0.15, "牛陡容差", group=grp_3)
th_yc_bear_steep= input.float(0.15, "熊陡容差", group=grp_3)
lock_bull_steep = input.int(10, "牛陡熔断锁定 (日)", group=grp_3)

// --- 4. 信用风险 ---
grp_4 = "4. 信用风险 (OAS)"
sym_oas         = input.symbol("FRED:BAMLH0A0HYM2", "OAS", group=grp_4)
oas_slope_len   = input.int(60, "斜率周期", group=grp_4)
dur_oas_conf    = input.int(3, "确认时长 (日)", group=grp_4)
th_oas_noise    = input.float(0.01, "斜率震荡阈值", group=grp_4)
lock_credit_crash = input.int(10, "熔断锁定 (日)", group=grp_4)

// --- 5. 流动性 ---
grp_5 = "5. 流动性"
sym_us_m2       = input.symbol("FRED:M2REAL", "美国M2", group=grp_5)
sym_cn_m1       = input.symbol("ECONOMICS:CNM1", "中国M1", group=grp_5)
sym_cn_m2       = input.symbol("ECONOMICS:CNM2", "中国M2", group=grp_5)
liq_yoy_len     = input.int(12, "同比周期 (月)", group=grp_5)
th_liq_us_crash = input.float(-2.0, "美国枯竭阈值", group=grp_5)
th_liq_cn_crash = input.float(-5.0, "中国空转阈值", group=grp_5)
lock_liq_crash  = input.int(3, "熔断锁定 (月)", group=grp_5)

// --- 6. 利润空间 ---
grp_6 = "6. 利润空间"
sym_us_cpi      = input.symbol("FRED:CPIAUCSL", "美国CPI", group=grp_6)
sym_us_ppi      = input.symbol("FRED:PPIACO", "美国PPI", group=grp_6)
sym_cn_cpi      = input.symbol("ECONOMICS:CNCPI", "中国CPI", group=grp_6)
sym_cn_ppi      = input.symbol("ECONOMICS:CNPPI", "中国PPI", group=grp_6)
prof_yoy_len    = input.int(12, "同比周期 (月)", group=grp_6)
dur_prof_state  = input.int(2, "状态确认时长 (月)", group=grp_6)

// --- 7. 实体热度 ---
grp_7 = "7. 实体热度"
sym_copper      = input.symbol("COMEX:HG1!", "铜", group=grp_7)
sym_gold        = input.symbol("COMEX:GC1!", "金", group=grp_7)
cg_slope_len    = input.int(60, "斜率周期", group=grp_7)
dur_cg_conf     = input.int(5, "趋势确认时长 (日)", group=grp_7)
th_cg_noise     = input.float(1.0, "涨跌幅容差 (%)", group=grp_7) 
lock_cg_crash   = input.int(5, "崩盘锁定 (日)", group=grp_7)

// --- 8. 萨姆规则 ---
grp_8 = "8. 萨姆规则"
sym_sahm        = input.symbol("FRED:SAHMREALTIME", "Sahm", group=grp_8)
sym_icsa        = input.symbol("FRED:ICSA", "ICSA", group=grp_8)

// 颜色
c_red          = color.red
c_orange       = color.orange
c_yellow       = color.yellow
c_lime         = color.lime
c_super_red    = #800000
c_super_green  = #006400
c_navy_60      = color.new(#000080, 40)
c_score_col    = #78D6FB
c_gray_dark    = #333333
c_bg           = color.new(c_gray_dark, 10)
c_header       = color.new(color.gray, 50)
c_white        = color.white
c_black        = color.black

// ==========================================
// 2. 状态注册与资产常量
// ==========================================
type StateConfig
    float score
    float weight_mult
    string label
    string advice

var state_map = map.new<string, StateConfig>()

method register_state(string id, float s, float w, string l, string a) =>
    state_map.put(id, StateConfig.new(s, w, l, a))

// 资产定义
string A_RISK       = is_cn ? "A股/港股" : "风险资产"
string A_CASH       = is_cn ? "现金/美债" : "美元/短债/现金"
string A_USD        = "美元"
string A_CASH_ONLY  = "现金"
string A_BOND_S     = is_cn ? "短债/理财" : "短债"
string A_BOND_L     = is_cn ? "中国长债" : "长债"
string A_BOND_US    = "美债"
string A_GOLD       = "黄金"
string A_YEN        = "日元"

string A_TECH       = is_cn ? "科创/创业板" : "科技/成长/加密"
string A_CORE       = is_cn ? "A50/沪深300" : "可选消费/核心"
string A_DIV        = is_cn ? "红利低波" : "红利/价值"
string A_STAPLES    = is_cn ? "必选/医药" : "必选消费/医药"
string A_SMALL      = is_cn ? "微盘/中证2000" : "小盘/垃圾债"
string A_JUNK       = "垃圾债"
string A_CYCLE      = is_cn ? "顺周期/资源" : "周期/能源/大宗"
string A_ENERGY     = "能源"
string A_CYCLE_UP   = "上游资源"
string A_CYCLE_MID  = "中游制造"

// 注册状态
if barstate.isfirst
    register_state("S1_PANIC", -1.0, 1.0, "救火降息", "【避险】 ⛔" + A_CYCLE + "/" + A_TECH + " 🛡️" + A_GOLD + "/" + A_BOND_L)
    register_state("S1_HIKE",  -0.5, 1.0, "加息周期", "【防御】 ⛔" + A_BOND_L + "/" + A_TECH + " 🛡️" + A_CASH)
    register_state("S1_NOISE",  0.0, 1.0, "常态震荡", "【观察】 多看少动")
    register_state("S1_CUT",    1.0, 1.0, "降息周期", "【进攻】 ⛔" + A_USD + "/" + A_BOND_S + " ⚔️" + A_TECH + "/" + A_BOND_L)

    register_state("S2_STAG",   -1.0, 1.0, "滞胀/萧条", "【避险】 ⛔" + A_CYCLE + "/" + A_TECH + " 🛡️" + A_USD + "/" + A_GOLD)
    register_state("S2_SIPHON", -1.0, 1.0, "虹吸效应", "【避险】 ⛔" + A_TECH + "/" + A_SMALL + " 🛡️" + A_CASH)
    register_state("S2_KILL",   -0.5, 1.0, "杀估值", "【防御】 ⛔" + A_TECH + " 🛡️" + A_CORE + "/" + A_DIV)
    register_state("S2_RISE",    0.0, 1.0, "资金成本上升", "【观察】 多看少做")
    register_state("S2_NEG",     1.0, 1.0, "负利率", "【进攻】 ⚔️" + A_GOLD + "/" + A_TECH)
    register_state("S2_HEALTH",  1.0, 1.0, "健康支撑", "【进攻】 ⚔️" + A_TECH)

    register_state("S3_CRASH",  -1.0, 2.0, "牛陡", "【清仓】 ⛔" + A_CYCLE + "/" + A_TECH + " 🛡️" + A_BOND_US + "/" + A_GOLD)
    register_state("S3_INVERT", -0.5, 1.0, "倒挂", "【防御】 ⛔" + A_CYCLE + "/" + A_TECH + " 🛡️" + A_CASH_ONLY + "/" + A_DIV)
    register_state("S3_FLAT",    0.0, 1.0, "平坦", "【观察】 多看少做")
    register_state("S3_STEEP",   0.5, 1.0, "陡峭", "【进攻】 ⚔️" + A_TECH + "/" + A_CORE)
    register_state("S3_BEAR",    1.0, 1.0, "熊陡", "【进攻】 ⚔️" + A_CYCLE + "/" + A_ENERGY)

    register_state("S4_CRASH",  -1.0, 2.0, "信用崩盘", "【清仓】 ⛔" + A_JUNK + "/" + A_SMALL + " 🛡️" + A_CASH)
    register_state("S4_BAD",    -1.0, 1.0, "严重恶化", "【避险】 ⛔" + A_JUNK + "/" + A_SMALL + " 🛡️" + A_BOND_S)
    register_state("S4_WIDEN",  -0.5, 1.0, "风险走阔", "【防御】 ⛔" + A_JUNK + " 🛡️" + A_DIV)
    register_state("S4_BOTTOM",  0.0, 1.0, "底部回升", "【观察】 保持关注")
    register_state("S4_LOCAL",   0.0, 1.0, "局部压力", "【观察】 多看少做")
    register_state("S4_GOOD",    1.0, 1.0, "风险收敛", "【进攻】 ⚔️" + A_JUNK + "/" + A_SMALL)

    register_state("S5_US_CRASH", -1.0, 1.0, "流动性枯竭", "【清仓】 ⛔所有资产 🛡️" + A_CASH)
    register_state("S5_US_TIGHT", -0.5, 1.0, "收缩", "【防御】 ⛔" + A_CYCLE + " 🛡️" + A_DIV)
    register_state("S5_US_NOISE",  0.0, 1.0, "存量博弈", "【观察】 多看少做")
    register_state("S5_US_GOOD",   1.0, 1.0, "扩张", "【进攻】 ⚔️" + A_TECH + "/" + A_CORE)
    
    register_state("S5_CN_CRASH", -1.0, 1.0, "严重空转", "【清仓】 ⛔所有资产 🛡️" + A_CASH)
    register_state("S5_CN_TIGHT", -0.5, 1.0, "资金空转", "【防御】 ⛔" + A_CYCLE + " 🛡️" + A_DIV)
    register_state("S5_CN_NOISE",  0.0, 1.0, "存款搬家停滞", "【观察】 多看少做")
    register_state("S5_CN_GOOD",   1.0, 1.0, "资金活化", "【进攻】 ⚔️" + A_TECH + "/" + A_CORE)

    register_state("S6_HEAT",     -1.0, 2.0, "通胀过热", "【避险】 ⛔" + A_TECH + " 🛡️" + A_CASH + "/" + A_ENERGY)
    register_state("S6_DEFL",     -1.0, 1.0, "深度通缩", "【避险】 ⛔" + A_CYCLE + " 🛡️" + A_STAPLES)
    register_state("S6_BAD",      -0.5, 1.0, "亏损恶化", "【防御】 ⛔" + A_CYCLE_MID + " ⚔️" + A_CYCLE_UP)
    register_state("S6_NOISE_US",  0.0, 1.0, "增长停滞", "【观察】 多看少做")
    register_state("S6_NOISE_CN",  0.0, 1.0, "内卷加剧", "【观察】 多看少做")
    register_state("S6_TURN",      0.5, 1.0, "困境反转", "【进攻】 ⚔️" + A_CYCLE_MID)
    register_state("S6_GOOD",      1.0, 1.0, "利润走阔", "【进攻】 ⚔️" + A_TECH + "/" + A_CORE)

    register_state("S7_CRASH",    -1.0, 1.0, "实体崩盘", "【避险】 ⛔" + A_CYCLE + "/" + A_SMALL + " 🛡️" + A_BOND_US + "/" + A_GOLD)
    register_state("S7_RECESS",   -0.5, 1.0, "衰退交易", "【防御】 ⛔" + A_CYCLE + " 🛡️" + A_GOLD)
    register_state("S7_FAKE",     -0.5, 1.0, "伪复苏", "【观察】 ⚠️" + A_CYCLE)
    register_state("S7_NOISE",     0.0, 1.0, "需求不明", "【观察】 多看少做")
    register_state("S7_GOOD",      1.0, 1.0, "复苏", "【进攻】 ⚔️" + A_CYCLE)

    register_state("S8_CRASH",    -1.0, 2.0, "衰退确认", "【清仓】 ⛔" + A_CYCLE + "/" + A_TECH + " 🛡️" + A_BOND_US)
    register_state("S8_RISK",     -0.5, 1.0, "风险关注", "【防御】 ⛔" + A_CYCLE + "/" + A_TECH + " 🛡️" + A_BOND_US)
    register_state("S8_WARN",     -0.5, 1.0, "ICSA预警", "【防御】 ⛔" + A_CORE + " 🛡️" + A_CASH_ONLY)
    register_state("S8_GOOD",      1.0, 1.0, "就业健康", "【进攻】 ⚔️" + A_TECH + "/" + A_CORE)

// ==========================================
// 3. 辅助函数与数据获取
// ==========================================
calc_slope_linreg(src, len) => ta.linreg(src, len, 0) - ta.linreg(src, len, 1)
calc_yoy(src, len) => (src / src[len] - 1) * 100
float sec_per_bar = timeframe.in_seconds(timeframe.period)
float sec_per_day = 86400

// 1. 基准利率
[effr_live, effr_chg] = request.security(sym_effr, "D", [close, close[1]-close], gaps=barmerge.gaps_off)
effr_ema = request.security(sym_effr, "M", ta.ema(close, effr_ema_len), gaps=barmerge.gaps_off)
float effr_drop_scan = 0.0
if timeframe.isdaily
    effr_drop_scan := effr_chg
else if timeframe.isweekly or timeframe.ismonthly
    float[] drops = request.security_lower_tf(sym_effr, "D", close[1]-close)
    if array.size(drops) > 0
        effr_drop_scan := array.max(drops)

// 2. 真实利率
[tips_live, rgdp_val] = request.security(sym_tips, "D", [close, close], gaps=barmerge.gaps_off) // RGDP简化处理
[rgdp_r, rgdp_t] = request.security(sym_rgdp, "D", [close, time], gaps=barmerge.gaps_off)
rgdp_val := rgdp_r // 覆盖

// 3. 利差
[y10, y10_chg] = request.security(sym_us_10y, "D", [close, close-close[1]], gaps=barmerge.gaps_off)
[y2, y2_chg] = request.security(sym_us_2y, "D", [close, close-close[1]], gaps=barmerge.gaps_off)
yc_val = y10 - y2
bool is_bull_steep_daily = y10_chg < 0 and y2_chg < -th_yc_bull_steep and y2_chg < y10_chg
bool is_bull_steep_htf = false
if timeframe.isweekly or timeframe.ismonthly
    [d10_m, t10_m] = request.security_lower_tf(sym_us_10y, "D", [close-close[1], time])
    [d2_m, t2_m] = request.security_lower_tf(sym_us_2y, "D", [close-close[1], time])
    if array.size(d10_m) > 0 and array.size(d2_m) > 0
        int len = math.min(array.size(d10_m), array.size(d2_m))
        for i = 0 to len - 1
            if array.get(d10_m, i) < 0 and array.get(d2_m, i) < -th_yc_bull_steep and array.get(d2_m, i) < array.get(d10_m, i)
                is_bull_steep_htf := true
                break
is_bull_steep_trigger = timeframe.isweekly or timeframe.ismonthly ? is_bull_steep_htf : is_bull_steep_daily
int bars_lock_bull = math.max(1, math.ceil(lock_bull_steep * sec_per_day / sec_per_bar))
var int bull_steep_cnt = 0
if is_bull_steep_trigger
    bull_steep_cnt := bars_lock_bull
else if bull_steep_cnt > 0
    bull_steep_cnt := bull_steep_cnt - 1
is_bull_steep = bull_steep_cnt > 0

// 4. 信用
[oas_val, oas_slope, oas_chg_5d] = request.security(sym_oas, "D", [close, calc_slope_linreg(close, oas_slope_len), (close/close[5]-1)*100], gaps=barmerge.gaps_off)
bool oas_crash_scan = false
if timeframe.isdaily
    oas_crash_scan := oas_val > 10.0 or (oas_val > 6.0 and oas_chg_5d > 20.0)
else if timeframe.isweekly or timeframe.ismonthly
    float[] flags = request.security_lower_tf(sym_oas, "D", (close > 10.0 or (close > 6.0 and (close/close[5]-1)*100 > 20.0)) ? 1.0 : 0.0)
    if array.size(flags) > 0
        if array.max(flags) > 0.5
            oas_crash_scan := true
int bars_lock_cred = math.max(1, math.ceil(lock_credit_crash * sec_per_day / sec_per_bar))
var int oas_crash_cnt = 0
if oas_crash_scan
    oas_crash_cnt := bars_lock_cred
else if oas_crash_cnt > 0
    oas_crash_cnt := oas_crash_cnt - 1
is_oas_crash = oas_crash_cnt > 0

// 5. 流动性
[us_m2, us_m2_yoy] = request.security(sym_us_m2, "M", [close, calc_yoy(close, liq_yoy_len)], gaps=barmerge.gaps_off)
[cn_m1, cn_m1_yoy] = request.security(sym_cn_m1, "M", [close, calc_yoy(close, liq_yoy_len)], gaps=barmerge.gaps_off)
[cn_m2, cn_m2_yoy] = request.security(sym_cn_m2, "M", [close, calc_yoy(close, liq_yoy_len)], gaps=barmerge.gaps_off)
cn_gap = cn_m1_yoy - cn_m2_yoy

// 6. 利润
[us_cpi, us_cpi_yoy] = request.security(sym_us_cpi, "M", [close, calc_yoy(close, prof_yoy_len)], gaps=barmerge.gaps_off)
[us_ppi, us_ppi_yoy] = request.security(sym_us_ppi, "M", [close, calc_yoy(close, prof_yoy_len)], gaps=barmerge.gaps_off)
us_prof_gap = us_cpi_yoy - us_ppi_yoy
[cn_cpi, cn_cpi_yoy] = request.security(sym_cn_cpi, "M", [close, calc_yoy(close, prof_yoy_len)], gaps=barmerge.gaps_off)
[cn_ppi, cn_ppi_yoy] = request.security(sym_cn_ppi, "M", [close, calc_yoy(close, prof_yoy_len)], gaps=barmerge.gaps_off)
cn_prof_gap = cn_cpi_yoy - cn_ppi_yoy

// 7. 热度
[cop_d, cop_trend] = request.security(sym_copper, "D", [close, close[cg_slope_len]], gaps=barmerge.gaps_off)
[gld_d, gld_trend] = request.security(sym_gold, "D", [close, close[cg_slope_len]], gaps=barmerge.gaps_off)
cg_ratio = cop_d / gld_d * 1000
cg_ratio_trend = cop_trend / gld_trend * 1000

bool cg_crash_scan = false
if timeframe.isdaily
    cg_crash_scan := (cg_ratio / cg_ratio[1] - 1) * 100 < -3.0
else if timeframe.isweekly or timeframe.ismonthly
    // 全量扫描日线跌幅
    float[] c_vals = request.security_lower_tf(sym_copper, "D", close)
    float[] g_vals = request.security_lower_tf(sym_gold, "D", close)
    if array.size(c_vals) > 1 and array.size(g_vals) > 1
        int len = math.min(array.size(c_vals), array.size(g_vals))
        // 从第二天开始遍历
        for i = 1 to len - 1
            float r_curr = array.get(c_vals, i) / array.get(g_vals, i)
            float r_prev = array.get(c_vals, i-1) / array.get(g_vals, i-1)
            if (r_curr/r_prev - 1) * 100 < -3.0
                cg_crash_scan := true
                break

int bars_lock_cg = math.max(1, math.ceil(lock_cg_crash * sec_per_day / sec_per_bar))
var int cg_crash_cnt = 0
if cg_crash_scan
    cg_crash_cnt := bars_lock_cg
else if cg_crash_cnt > 0
    cg_crash_cnt := cg_crash_cnt - 1
is_cg_crash = cg_crash_cnt > 0

cg_trend_chg = (cg_ratio/cg_ratio_trend-1)*100
cop_trend_chg = (cop_d/cop_trend-1)*100
// 伪复苏: 铜金比涨(趋势) 但 铜价跌(趋势)
is_cg_fake = cg_trend_chg > th_cg_noise and cop_trend_chg < 0

// 8. 萨姆
[sahm_val, icsa_dummy] = request.security(sym_sahm, "M", [close, close], gaps=barmerge.gaps_off)
[icsa_yoy, icsa_prev] = request.security(sym_icsa, "W", [(close/close[52]-1)*100, (close[1]/close[53]-1)*100], gaps=barmerge.gaps_off)
icsa_warn = icsa_yoy > 15.0 and icsa_prev > 15.0

// ==========================================
// 4. 评分与逻辑
// ==========================================
// 辅助函数
is_sustained(cond, len) => math.sum(cond ? 1 : 0, len) == len

// 转换Bars
bars_tips = math.max(1, math.ceil(dur_tips_conf * sec_per_day / sec_per_bar))
bars_yc = math.max(1, math.ceil(dur_yc_bear_conf * sec_per_day / sec_per_bar))
bars_oas = math.max(1, math.ceil(dur_oas_conf * sec_per_day / sec_per_bar))
bars_prof = math.max(1, math.ceil(dur_prof_state * 30 * sec_per_day / sec_per_bar))
bars_cg = math.max(1, math.ceil(dur_cg_conf * sec_per_day / sec_per_bar))
bars_panic = math.max(1, math.ceil(dur_sahm_panic * sec_per_day / sec_per_bar))

// 状态ID计算
string id1=na, string id2=na, string id3=na, string id4=na
string id5=na, string id6=na, string id7=na, string id8=na

// S1
bool in_panic_win = ta.barssince(effr_drop_scan >= 0.5) < bars_panic
if in_panic_win
    id1 := "S1_PANIC"
else if effr_live > effr_ema + th_effr_noise
    id1 := "S1_HIKE"
else if effr_live < effr_ema - th_effr_noise
    id1 := "S1_CUT"
else
    id1 := "S1_NOISE"

// S2
if is_sustained(rgdp_val < 0, bars_tips)
    id2 := "S2_STAG"
else if is_sustained(tips_live >= rgdp_val, bars_tips)
    id2 := "S2_SIPHON"
else if is_sustained(tips_live >= 0.75*rgdp_val, bars_tips)
    id2 := "S2_KILL"
else if is_sustained(tips_live >= 0.5*rgdp_val, bars_tips)
    id2 := "S2_RISE"
else if is_sustained(tips_live < 0, bars_tips)
    id2 := "S2_NEG"
else
    id2 := "S2_HEALTH"

// S3
if is_bull_steep
    id3 := "S3_CRASH"
else if yc_val < -th_yc_noise
    id3 := "S3_INVERT"
else if math.abs(yc_val) <= th_yc_noise
    id3 := "S3_FLAT"
else
    // 熊陡
    bool is_bear = y10_chg > th_yc_bear_steep and y2_chg > 0 and y10_chg > y2_chg
    id3 := is_sustained(is_bear, bars_yc) ? "S3_BEAR" : "S3_STEEP"

// S4
if is_oas_crash
    id4 := "S4_CRASH"
else if oas_val > 6.0
    id4 := "S4_BAD"
else if oas_val >= 3.5
    id4 := is_sustained(oas_slope > th_oas_noise, bars_oas) ? "S4_WIDEN" : "S4_LOCAL"
else
    id4 := is_sustained(oas_slope > th_oas_noise, bars_oas) ? "S4_BOTTOM" : "S4_GOOD"

// S5
if is_us
    if us_m2_yoy < th_liq_us_crash
        id5 := "S5_US_CRASH"
    else if us_m2_yoy < 0
        id5 := "S5_US_TIGHT"
    else if us_m2_yoy > 0
        id5 := "S5_US_GOOD"
    else
        id5 := "S5_US_NOISE"
else
    if cn_gap < th_liq_cn_crash
        id5 := "S5_CN_CRASH"
    else if cn_gap < 0
        id5 := "S5_CN_TIGHT"
    else if cn_gap > 0
        id5 := "S5_CN_GOOD"
    else
        id5 := "S5_CN_NOISE"

// S6
if is_us
    if us_cpi_yoy > 3.0
        id6 := "S6_HEAT"
    else if us_cpi_yoy < 0 and us_ppi_yoy < 0
        id6 := "S6_DEFL"
    else if is_sustained(us_prof_gap < 0, bars_prof)
        id6 := (us_prof_gap > us_prof_gap[1]) ? "S6_TURN" : "S6_BAD"
    else if is_sustained(us_prof_gap > 0, bars_prof)
        id6 := (us_prof_gap > us_prof_gap[1]) ? "S6_GOOD" : "S6_NOISE_US"
    else
        id6 := "S6_NOISE_US"
else
    if cn_cpi_yoy > 3.0
        id6 := "S6_HEAT" // 少见但保留
    else if cn_cpi_yoy < 0 and cn_ppi_yoy < 0
        id6 := "S6_DEFL"
    else if is_sustained(cn_prof_gap < 0, bars_prof)
        id6 := (cn_prof_gap > cn_prof_gap[1]) ? "S6_TURN" : "S6_BAD"
    else if is_sustained(cn_prof_gap > 0, bars_prof)
        id6 := (cn_prof_gap > cn_prof_gap[1]) ? "S6_GOOD" : "S6_NOISE_CN"
    else
        id6 := "S6_NOISE_CN"

// S7
if is_cg_crash
    id7 := "S7_CRASH"
else if is_sustained(is_cg_fake, bars_cg)
    id7 := "S7_FAKE"
else if is_sustained(cg_trend_chg < -th_cg_noise, bars_cg)
    id7 := "S7_RECESS"
else if is_sustained(cg_trend_chg > th_cg_noise and cop_trend_chg > 0, bars_cg)
    id7 := "S7_GOOD"
else
    id7 := "S7_NOISE"

// S8
if sahm_val >= 0.5
    id8 := "S8_CRASH"
else if sahm_val >= 0.3
    id8 := "S8_RISK"
else if icsa_warn
    id8 := "S8_WARN"
else
    id8 := "S8_GOOD"

// 读取配置
StateConfig c1 = state_map.get(id1), float s1=c1.score, float w1=c1.weight_mult
StateConfig c2 = state_map.get(id2), float s2=c2.score, float w2=c2.weight_mult
StateConfig c3 = state_map.get(id3), float s3=c3.score, float w3=c3.weight_mult
StateConfig c4 = state_map.get(id4), float s4=c4.score, float w4=c4.weight_mult
StateConfig c5 = state_map.get(id5), float s5=c5.score, float w5=c5.weight_mult
StateConfig c6 = state_map.get(id6), float s6=c6.score, float w6=c6.weight_mult
StateConfig c7 = state_map.get(id7), float s7=c7.score, float w7=c7.weight_mult
StateConfig c8 = state_map.get(id8), float s8=c8.score, float w8=c8.weight_mult

// 权重修正
bool is_inf_era = us_cpi_yoy > 3.0
bool is_panic_era = sahm_val >= 0.3 or is_bull_steep

if is_inf_era
    w6 := 2.0, w7 := 2.0
if is_panic_era
    if s3 < 0
        w3 := 2.0
    if s4 < 0
        w4 := 2.0
    if s8 < 0
        w8 := 2.0

float total = s1*w1 + s2*w2 + s3*w3 + s4*w4 + s5*w5 + s6*w6 + s7*w7 + s8*w8
float t_max = w1+w2+w3+w4+w5+w6+w7+w8

// 熔断检测
bool is_melt = (s3==-1.0 and w3>1.0) or (s4==-1.0 and w4>1.0) or (s8==-1.0 and w8>1.0) or (s5==-1.0)

// 绘制表格
var table rpt = table.new(position.middle_right, 6, 15, bgcolor=c_bg, border_width=1, border_color=color.gray)

fill_r(r, n, v, s, w, meta, st) =>
    c_s = s>=0.5?c_lime:(s==0?c_yellow:(s==-0.5?c_orange:c_red))
    // 熔断行高亮
    bool is_m_row = (n=="3.利差结构" and s3==-1 and w3>1) or (n=="4.信用风险" and s4==-1 and w4>1) or (n=="8.萨姆规则" and s8==-1 and w8>1) or (n=="5.流动性" and s5==-1)
    bg_v = is_m_row ? c_super_red : c_bg
    tx_v = is_m_row ? c_yellow : c_s
    
    table.cell(rpt, 0, r, n, text_color=c_white, bgcolor=c_bg, text_size=size.small)
    table.cell(rpt, 1, r, v, text_color=tx_v, bgcolor=bg_v, text_size=size.small)
    table.cell(rpt, 2, r, str.tostring(s*w, "+#.#"), text_color=c_score_col, bgcolor=c_bg, text_size=size.small)
    table.cell(rpt, 3, r, w>1?"x2":"", text_color=c_white, bgcolor=c_bg, text_size=size.small)
    table.cell(rpt, 4, r, meta, text_color=c_white, bgcolor=c_bg, text_size=size.small)
    table.cell(rpt, 5, r, st, text_color=tx_v, bgcolor=bg_v, text_size=size.small)

if barstate.islast
    table.cell(rpt, 0, 0, "维度", bgcolor=c_header, text_color=c_white), table.cell(rpt, 1, 0, "数值", bgcolor=c_header, text_color=c_white)
    table.cell(rpt, 2, 0, "得分", bgcolor=c_header, text_color=c_white), table.cell(rpt, 3, 0, "权", bgcolor=c_header, text_color=c_white)
    table.cell(rpt, 4, 0, "比喻", bgcolor=c_header, text_color=c_white), table.cell(rpt, 5, 0, "状态", bgcolor=c_header, text_color=c_white)
    
    fill_r(1, "1.基准利率", str.tostring(effr_live, "0.00")+"%", s1, w1, "闸门", c1.label)
    fill_r(2, "2.真实利率", str.tostring(tips_live, "0.00")+"%", s2, w2, "回购", c2.label)
    fill_r(3, "3.利差结构", str.tostring(yc_val, "0.00"), s3, w3, "天气", c3.label)
    fill_r(4, "4.信用风险", str.tostring(oas_val, "0.00")+"%", s4, w4, "保证金", c4.label)
    fill_r(5, "5.流动性", is_us ? str.tostring(us_m2_yoy,"0.0")+"%" : str.tostring(cn_gap,"0.0")+"%", s5, w5, "活水", c5.label)
    fill_r(6, "6.利润空间", is_us ? str.tostring(us_prof_gap,"0.0")+"%" : str.tostring(cn_prof_gap,"0.0")+"%", s6, w6, "账本", c6.label)
    fill_r(7, "7.实体热度", str.tostring(cg_ratio, "0.00"), s7, w7, "扩建", c7.label)
    fill_r(8, "8.萨姆规则", str.tostring(sahm_val, "0.00")+"%", s8, w8, "失业", c8.label)
    
    // 宏观对冲
    float us_liq = (us_m2_yoy < -2.0 ? -1.0 : (us_m2_yoy < 0 ? -0.5 : (us_m2_yoy > 0 ? 1.0 : 0.0)))
    float cn_liq = (cn_gap < -5.0 ? -1.0 : (cn_gap < 0 ? -0.5 : (cn_gap > 0 ? 1.0 : 0.0)))
    bool us_l = s1==1 or us_liq==1, us_t = s1<0 or us_liq<0
    bool cn_l = cn_liq==1, cn_t = cn_liq==-1
    string strat = "🟡 垃圾时间"
    color strat_c = c_yellow
    
    if us_l and cn_l
        strat := "🟢 共振复苏", strat_c := c_lime
    else if us_t and cn_t
        strat := "🔴 双重紧缩", strat_c := c_orange
    else if is_panic_era and cn_t
        strat := "🔴 衰退共振", strat_c := c_orange
    else if is_panic_era and cn_l
        strat := "🟠 东升西降", strat_c := c_yellow
    else if us_t and cn_l
        strat := "🟠 分化博弈", strat_c := c_yellow
    else if us_l and cn_t
        strat := "🟠 单极驱动", strat_c := c_yellow
        
    table.cell(rpt, 0, 9, "对冲策略", bgcolor=c_navy_60, text_color=c_white), table.merge_cells(rpt, 0, 9, 1, 9)
    table.cell(rpt, 2, 9, strat, bgcolor=c_navy_60, text_color=strat_c), table.merge_cells(rpt, 2, 9, 5, 9)

    // 最终诊断
    string res = ""
    color bg_res = c_bg
    color tx_res = c_black
    string pos = ""
    
    if is_melt
        res := "🛑 熔断", bg_res := c_super_red, tx_res := c_yellow, pos := "0% (空仓)"
    else if total <= -5.0
        res := "🔴 危机", bg_res := c_red, tx_res := c_white, pos := "0-10%"
    else if total < -1.5
        res := "🟠 衰退", bg_res := c_orange, tx_res := c_black, pos := "10-30%"
    else if total <= 1.5
        res := "🟡 震荡", bg_res := c_yellow, tx_res := c_black, pos := "30-50%"
    else if total < 5.0
        res := "🟢 复苏", bg_res := c_lime, tx_res := c_black, pos := "50-80%"
    else
        res := "🟢 满仓", bg_res := c_super_green, tx_res := c_white, pos := "80-100%"
        
    table.cell(rpt, 0, 10, "最终诊断", bgcolor=c_bg, text_color=c_white), table.merge_cells(rpt, 0, 10, 1, 10)
    table.cell(rpt, 2, 10, str.tostring(total, "0.0"), bgcolor=bg_res, text_color=tx_res)
    table.cell(rpt, 3, 10, "/ " + str.tostring(t_max, "0"), bgcolor=c_bg, text_color=c_white)
    table.cell(rpt, 4, 10, res, bgcolor=bg_res, text_color=tx_res)
    table.cell(rpt, 5, 10, pos, bgcolor=c_bg, text_color=c_white)
    
    // QA透视面板
    string debug_info = "QA透视:\n"
    debug_info += "通胀时代: " + str.tostring(is_inf_era) + " | 恐慌时代: " + str.tostring(is_panic_era) + "\n"
    debug_info += "熔断: " + str.tostring(is_melt) + " (S3=" + str.tostring(s3==-1 and w3>1) + ", S4=" + str.tostring(s4==-1 and w4>1) + ", S5=" + str.tostring(s5==-1) + ", S8=" + str.tostring(s8==-1 and w8>1) + ")"
    
    table.cell(rpt, 0, 11, debug_info, bgcolor=c_bg, text_color=c_white, text_size=size.tiny, text_halign=text.align_left), table.merge_cells(rpt, 0, 11, 5, 11)